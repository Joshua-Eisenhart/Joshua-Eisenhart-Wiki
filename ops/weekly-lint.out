    s=s.replace('## Related pages\\n', '## Related pages\\n- Merged from [[compression-mathematics-and-density-matrix]] on 2026-07-03; unique coverage retained: PCA/kernel PCA, spectral decomposition, quantum computing applications, and classical-vs-quantum compression routing.\\n')
    for link in extra_links:
        if link not in s:
            s=s.rstrip()+f'\\n- {link}\\n'
    surv.write_text(s)
loser.write_text('Redirect: [[compression-math-density-matrix]]\\n')

files=[p for p in root.rglob('*.md') if not any(part in {'.git','_archive','raw'} for part in p.parts)]
links=collections.Counter()
for p in files:
 txt=p.read_text(errors='ignore')
 for m in re.finditer(r'\\[\\[(["'^'"\\]|#]+)(?:#["'^'"\\]|]+)?(?:\\|["'^'"\\]]*)?\\]\\]', txt):
  target=m.group(1).strip().split('#')[0]
  if target:
   links[target]+=1; links[target.split('/')[-1]]+=1
orph=[]
for p in files:
 if any(part.startswith('.') for part in p.parts): continue
 if p.name=='AGENTS.md': continue
 if p.as_posix().startswith('ops/') and p.name in {'orphans.md','contradictions.md','stale-status.md'}: continue
 stem=str(p.with_suffix(''))
 if links[p.stem]==0 and links[stem]==0:
  orph.append(p.as_posix())
orph=sorted(orph)

ops=root/'ops'; ops.mkdir(exist_ok=True)
(ops/'orphans.md').write_text('# Orphans\\n\\nGenerated: 2026-07-03. Excludes "'`_archive/`, `raw/`, hidden dot-directories, and `AGENTS.md`. Inbound link detection uses Obsidian wikilinks by basename or path.'"\\n\\nCount: %d\\n\\n%s\\n' % (len(orph), '\\n'.join(f'- [[{p[:-3]}]]' for p in orph)))

