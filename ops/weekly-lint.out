There are about 2,177 markdown pages in scope, and the three weekly report files don’t exist yet, so this pass will create them. I’m going to compute candidates first, then only merge truly obvious duplicates rather than doing fuzzy cleanup that might erase useful divergence.
exec
/bin/zsh -lc "python3 - <<'PY'
from pathlib import Path
import re, difflib, collections, datetime
root=Path('.')
files=[p for p in root.rglob('*.md') if not any(part in {'.git','_archive','raw'} for part in p.parts)]
# titles and slugs
items=[]
for p in files:
    txt=p.read_text(errors='ignore')
    title=None
    for line in txt.splitlines()[:20]:
        if line.startswith('# '): title=line[2:].strip(); break
    stem=p.stem
    norm=re.sub(r'[-_]+',' ', stem.lower())
    norm=re.sub(r'\\b(reference|formal reference|mathematics|math|current|router|note|full|source digest|translated|companion)\\b','',norm)
    norm=re.sub(r'\\s+',' ',norm).strip()
    items.append((str(p),stem,norm,title or ''))
# exact normalized groups size>1
for norm, group in collections.defaultdict(list,{}).items(): pass
groups=collections.defaultdict(list)
for it in items: groups[it[2]].append(it)
print('EXACT-ish groups')
for norm,g in sorted(groups.items(), key=lambda kv:(-len(kv[1]), kv[0]))[:80]:
    if len(g)>1 and norm:
        print('\\n',norm)
        for p,stem,n,t in g: print(' ',p,'|',t)
print('\\nSIMILAR names high ratio')
seen=set()
for i,a in enumerate(items):
  for b in items[i+1:]:
    if a[0].split('/')[0]"'!=b[0].split('"'/')[0]: continue
    r=difflib.SequenceMatcher(None,a[2],b[2]).ratio()
    if r>0.88 and a[2]"'!=b[2] and len(a[2])>8 and len(b[2])>8:
      print(f'"'{r:.2f}',a[0],' <-> ',b[0])
PY" in /Users/joshuaeisenhart/wiki
