{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lev.dev/schemas/lev.mc-object.v0.schema.json",
  "title": "Lev M(C) Finite Admissibility Object v0",
  "type": "object",
  "required": [
    "objectId",
    "finiteCarrier",
    "constraints",
    "readoutMap",
    "admissibilityPredicate",
    "composition",
    "controls",
    "receiptRefs",
    "promotion"
  ],
  "additionalProperties": false,
  "properties": {
    "objectId": {
      "type": "string",
      "pattern": "^mc://"
    },
    "finiteCarrier": {
      "type": "object",
      "required": [
        "stateSetRef",
        "operatorSetRef",
        "probeSetRef",
        "pathSetRef"
      ],
      "additionalProperties": true
    },
    "constraints": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "readoutMap": {
      "type": "object",
      "required": [
        "quotientRef",
        "readoutRefs"
      ],
      "properties": {
        "quotientRef": {
          "type": "string"
        },
        "readoutRefs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": true
    },
    "admissibilityPredicate": {
      "type": "object",
      "required": [
        "predicateRef",
        "gateProofRequired"
      ],
      "properties": {
        "predicateRef": {
          "type": "string"
        },
        "gateProofRequired": {
          "const": true
        }
      },
      "additionalProperties": true
    },
    "composition": {
      "type": "object",
      "required": [
        "bracketPolicy",
        "noncommuting",
        "nonassociativePolicy"
      ],
      "properties": {
        "bracketPolicy": {
          "enum": [
            "explicit_tree",
            "associative_with_witness"
          ]
        },
        "noncommuting": {
          "type": "boolean"
        },
        "nonassociativePolicy": {
          "enum": [
            "not_installed",
            "fenced_carrier_pressure",
            "installed_with_witnesses"
          ]
        }
      },
      "additionalProperties": true
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "receiptRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "promotion": {
      "type": "object",
      "required": [
        "allowed",
        "status"
      ],
      "properties": {
        "allowed": {
          "type": "boolean"
        },
        "status": {
          "enum": [
            "scratch",
            "preflight",
            "admitted"
          ]
        }
      },
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "promotion": {
            "properties": {
              "status": {
                "const": "admitted"
              }
            }
          }
        }
      },
      "then": {
        "properties": {
          "promotion": {
            "properties": {
              "allowed": {
                "const": true
              }
            }
          },
          "receiptRefs": {
            "minItems": 1
          }
        }
      }
    }
  ]
}