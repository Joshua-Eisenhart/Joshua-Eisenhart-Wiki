{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lev.dev/schemas/lev.geometry-evidence-receipt.v1.schema.json",
  "title": "Lev Geometry Evidence Receipt v1",
  "type": "object",
  "required": [
    "receiptId",
    "stageId",
    "claimCeiling",
    "classification",
    "promotionAllowed",
    "formalAdmissionAllowed",
    "engineEvidence",
    "controls",
    "artifactRefs"
  ],
  "additionalProperties": false,
  "properties": {
    "receiptId": {
      "type": "string"
    },
    "stageId": {
      "type": "string"
    },
    "claimCeiling": {
      "enum": [
        "scratch_diagnostic_only",
        "tool_micro_probe_only",
        "same_carrier_micro_lego_candidate",
        "admitted"
      ]
    },
    "classification": {
      "enum": [
        "scratch_diagnostic",
        "tool_lego_fit_probe",
        "canonical_by_process_candidate",
        "admitted"
      ]
    },
    "promotionAllowed": {
      "type": "boolean"
    },
    "formalAdmissionAllowed": {
      "type": "boolean"
    },
    "engineEvidence": {
      "type": "object",
      "required": [
        "julia",
        "jax",
        "torch"
      ],
      "properties": {
        "julia": {
          "type": "string"
        },
        "jax": {
          "type": "string"
        },
        "torch": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "controls": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "artifactRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "gateProofRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "classification": {
            "const": "admitted"
          }
        }
      },
      "then": {
        "properties": {
          "promotionAllowed": {
            "const": true
          },
          "formalAdmissionAllowed": {
            "const": true
          },
          "claimCeiling": {
            "const": "admitted"
          }
        },
        "required": [
          "gateProofRefs"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "classification": {
            "const": "scratch_diagnostic"
          }
        }
      },
      "then": {
        "properties": {
          "promotionAllowed": {
            "const": false
          },
          "formalAdmissionAllowed": {
            "const": false
          }
        }
      }
    }
  ]
}