{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "lev.contamination-report.v1",
  "type": "object",
  "required": [
    "status",
    "findings"
  ],
  "properties": {
    "status": {
      "enum": [
        "pass",
        "warn",
        "block"
      ]
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "line",
          "pattern",
          "severity",
          "reason"
        ],
        "properties": {
          "path": {
            "type": "string"
          },
          "line": {
            "type": "integer"
          },
          "pattern": {
            "type": "string"
          },
          "severity": {
            "enum": [
              "info",
              "warn",
              "block"
            ]
          },
          "reason": {
            "type": "string"
          },
          "allowedBoundary": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
