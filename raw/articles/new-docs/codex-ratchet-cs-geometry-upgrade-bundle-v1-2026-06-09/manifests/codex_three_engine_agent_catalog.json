{
  "schema": "codex.three_engine_agent_catalog.v1",
  "status": "design_catalog",
  "authority_model": "Codex controller/runner owns queue and result classification; engines emit evidence receipts; fan-in admission is controller-serial.",
  "providers": [
    {
      "providerId": "lev-sim-julia",
      "role": "semantic/proof-side evaluator",
      "strengths": [
        "finite carrier semantics",
        "nonassociative algebra tables",
        "Attractors/basin analysis",
        "interval/reachability/SOS certificates",
        "QIT and tensor network reference kernels"
      ],
      "must_not": [
        "mutate Graph directly",
        "claim admission without GateProof",
        "force Julia objects into Lev core"
      ]
    },
    {
      "providerId": "lev-sim-jax",
      "role": "batched differentiable dynamics worker",
      "strengths": [
        "Diffrax/Dynamiqs/NetKet-style sweeps",
        "counterexample search",
        "policy stability scans",
        "GPU/TPU sharded kernels"
      ],
      "must_not": [
        "own nonassociative semantics",
        "use optimizer success as proof",
        "use host_callback or old pmap-first patterns"
      ]
    },
    {
      "providerId": "lev-sim-torch",
      "role": "graph/geometric/scorer worker",
      "strengths": [
        "PyG message passing",
        "e3nn equivariant layers",
        "torchode/torchdiffeq dynamics",
        "xitorch scientific functions",
        "PyTorch3D geometry"
      ],
      "must_not": [
        "treat learned score as final proof",
        "promote NetworkX/adjacency matrix as canonical graph",
        "cross NumPy into canonical state"
      ]
    },
    {
      "providerId": "lev-proof-solver",
      "role": "formal proof/witness provider",
      "strengths": [
        "cvc5/Z3 SMT",
        "UNSAT cores",
        "finite model checks",
        "counterexample repair hints"
      ],
      "must_not": [
        "run in hot path unless compiled guard",
        "replace Semantic Control policy",
        "claim admission without Semantic Control policy and GateProof refs"
      ]
    }
  ],
  "agent_roles": [
    {
      "agentId": "geometry_stack_auditor",
      "job": "map Codex geometry evidence to Lev-native stage labels",
      "authority": "advisory",
      "emits": [
        "geometry_evidence_receipt"
      ]
    },
    {
      "agentId": "M_C_gap_auditor",
      "job": "fill finite object gap table before geometry promotion",
      "authority": "advisory",
      "emits": [
        "M_C_gap_table"
      ]
    },
    {
      "agentId": "julia_canon_worker",
      "job": "produce algebra/proof/basin artifacts",
      "authority": "provider",
      "emits": [
        "sim_eval_result",
        "GateProofRef"
      ]
    },
    {
      "agentId": "jax_dynamics_worker",
      "job": "run batched dynamics and counterexample search",
      "authority": "provider",
      "emits": [
        "sim_eval_result"
      ]
    },
    {
      "agentId": "torch_graph_worker",
      "job": "run graph/geometric scorer and ablation checks",
      "authority": "provider",
      "emits": [
        "sim_eval_result"
      ]
    },
    {
      "agentId": "contamination_auditor",
      "job": "scan for NumPy/classical contamination in candidate lanes",
      "authority": "gate",
      "emits": [
        "contamination_report"
      ]
    },
    {
      "agentId": "graph_operation_projector",
      "job": "convert accepted evidence into GraphOperation proposals",
      "authority": "proposal_only",
      "emits": [
        "GraphOperation[]"
      ]
    }
  ],
  "fan_in_rule": "No agent or engine self-approves. Fan-in admission requires code-owned scorer facts, GateProof refs, receipt refs, and policy branch."
}