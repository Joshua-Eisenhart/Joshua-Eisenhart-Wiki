+schema: lev.flowmind.flow.v1
+id: cr_cross_engine_parity.measure
+description: Measure cross-engine parity over non-authoritative Codex-Ratchet sim provider evidence.
+inputs:
+  provider_evidence:
+    type: array
+    required: true
+  observable_name:
+    type: string
+    required: true
+  tolerance:
+    type: number
+    required: true
+outputs:
+  observations:
+    type: object
+  measurements:
+    type: object
+nodes:
+  - id: score_measurements
+    kind: companion.score
+    inputs:
+      companion: ../companions/sensor.mjs
+      provider_evidence: ${inputs.provider_evidence}
+      observable_name: ${inputs.observable_name}
+      tolerance: ${inputs.tolerance}
+    outputs:
+      variables:
+        - max_abs_diff
+        - engines_agree
+        - engines_present
+        - negative_control_present
