+type CdoClaimGateCouncilWaveMember = NonNullable<CdoClaimGateCouncilWaveInput['waves'][number]['members']>[number];
+
+function cognitiveBindingForMember(
+  skillRefs: string[],
+  sourceRefs: string[],
+): NonNullable<CdoClaimGateCouncilWaveMember['cognitiveBinding']> {
+  return {
+    mmmRefs: [
+      'dna:graph',
+      'dna:vernacular',
+      'mmm:codex-ratchet-attractor-basin',
+    ],
+    skillRefs,
+    sourceRefs,
+    inputContractRefs: ['contract:ClaimGateCouncilWaveInput'],
+    outputContractRefs: ['contract:ClaimGateCouncilWaveClaim'],
+    gateContractRefs: [
+      'gate:claim-gate-loop',
+      'gate:object_binding',
+      'gate:evidence_manifest',
+      'gate:falsifier',
+    ],
+    requeuePolicyRef: 'repair_failed_claims_only',
+  };
+}
+
+function memberKindForNode(record: CdoArtifactNodeSnapshot): CdoClaimGateCouncilWaveMember['kind'] {
+  if (record.nodeId.includes('research')) return 'autoresearch';
+  if (record.nodeId.includes('skeptic')) return 'premortem';
+  if (record.adapter === 'gate') return 'gate_loop';
+  return 'agent';
+}
+
+function councilMemberForWave(
+  producerPrefix: string,
+  waveId: string,
+): CdoClaimGateCouncilWaveMember {
+  const skillRefs = [
+    'skill:cdo',
+    'skill:three-council-wizard-v4-3',
+  ];
+  return {
+    memberId: `${waveId}.council`,
+    kind: 'council',
+    role: `${waveId} council`,
+    producer: `${producerPrefix}.${waveId}`,
+    skillRefs,
+    cognitiveBinding: cognitiveBindingForMember(skillRefs, [
+      `cdo:${producerPrefix}`,
+      `wave:${waveId}`,
+    ]),
+  };
+}
+
+function memberForNode(
+  producerPrefix: string,
+  waveId: string,
+  record: CdoArtifactNodeSnapshot,
+  parentMemberId: string,
+  executionProfile: string,
+): CdoClaimGateCouncilWaveMember {
+  const kind = memberKindForNode(record);
+  const skillRefs = [
+    `adapter:${record.adapter}`,
+    `model:${record.model}`,
+    ...(kind === 'agent' ? [`profile:${executionProfile}`] : []),
+  ];
+  return {
+    memberId: record.nodeId,
+    kind,
+    role: `${waveId}.${record.adapter}`,
+    producer: `${producerPrefix}.${waveId}`,
+    parentMemberId,
+    skillRefs,
+    cognitiveBinding: cognitiveBindingForMember(skillRefs, [
+      `cdo:${producerPrefix}`,
+      `wave:${waveId}`,
+      `node:${record.nodeId}`,
+    ]),
+  };
+}
+
+function buildCouncilWaveInput({
+  runId,
+  artifactRoot,
+  workstreamId,
+  producerPrefix,
+  executionProfile,
+  waveRecords,
+  nodeRecords,
+}: {
+  runId: string;
+  artifactRoot: string;
+  workstreamId?: string;
+  producerPrefix: string;
+  executionProfile: string;
+  waveRecords: CdoArtifactWaveSnapshot[];
+  nodeRecords: Map<string, CdoArtifactNodeSnapshot>;
+}): CdoClaimGateCouncilWaveInput {
+  const assigned = new Set<string>();
+  const lastWaveByNodeId = new Map<string, number>();
+  const waves = waveRecords.map((waveRecord, index) => {
+    const waveNumber = index + 1;
+    const councilMember = councilMemberForWave(producerPrefix, waveRecord.waveId);
+    const members = [
+      councilMember,
+      ...waveRecord.nodes.map((record) => memberForNode(
+        producerPrefix,
+        waveRecord.waveId,
+        record,
+        councilMember.memberId,
+        executionProfile,
+      )),
+    ];
+    const claims = waveRecord.nodes.map((record) => {
+      const previousWave = lastWaveByNodeId.get(record.nodeId);
+      const ok = isSuccessfulNode(record);
+      const evidenceRefs = nodeEvidenceRefs(artifactRoot, record, waveRecord.waveId);
+      return {
+        claimId: record.nodeId,
+        payload: claimPayloadForNode(record, waveRecord.waveId),
+        producer: `${producerPrefix}.${waveRecord.waveId}`,
+        memberId: record.nodeId,
+        ...(previousWave !== undefined ? {
+          repairOf: {
+            failurePacketId: claimGateFailurePacketId(record.nodeId, previousWave),
+            sourceClaimId: record.nodeId,
+          },
+        } : {}),
+        gateChecks: [
+          {
+            gateId: 'object_binding',
+            status: ok ? 'pass' as const : 'fail' as const,
+            severity: 'blocker' as const,
+            reason: ok ? 'node record is bound to a recorded CDO wave' : nodeStatusReason(record),
+            evidenceRefs,
+          },
+          {
+            gateId: 'evidence_manifest',
+            status: ok && record.outputPath ? 'pass' as const : 'fail' as const,
+            severity: 'blocker' as const,
+            reason: ok && record.outputPath
+              ? 'node output artifact was written'
+              : 'node output artifact missing or node did not complete',
+            evidenceRefs,
+          },
+          {
+            gateId: 'falsifier',
+            status: ok ? 'pass' as const : 'fail' as const,
+            severity: 'blocker' as const,
+            reason: ok
+              ? 'runtime failure falsifier closed by node success status'
+              : `runtime failure falsifier remains open: ${nodeStatusReason(record)}`,
+            evidenceRefs,
+          },
+        ],
+      };
+    });
+
+    for (const record of waveRecord.nodes) {
+      assigned.add(record.nodeId);
+      lastWaveByNodeId.set(record.nodeId, waveNumber);
+    }
+
+    return {
+      wave: waveNumber,
+      contract: councilWaveContract(producerPrefix, waveRecord.waveId),
+      members,
+      claims,
+    };
+  });
+
+  const unassigned = Array.from(nodeRecords.values())
+    .filter((record) => !assigned.has(record.nodeId) && isClaimBearingNode(record));
+  if (unassigned.length > 0) {
+    const waveId = 'unassigned';
+    const councilMember = councilMemberForWave(producerPrefix, waveId);
+    waves.push({
+      wave: Math.max(1, waves.length + 1),
+      contract: councilWaveContract(producerPrefix, waveId),
+      members: [
+        councilMember,
+        ...unassigned.map((record) => memberForNode(
+          producerPrefix,
+          waveId,
+          record,
+          councilMember.memberId,
+          executionProfile,
+        )),
+      ],
+      claims: unassigned.map((record) => {
+        const ok = isSuccessfulNode(record);
+        const evidenceRefs = nodeEvidenceRefs(artifactRoot, record, waveId);
+        return {
+          claimId: record.nodeId,
+          payload: claimPayloadForNode(record, waveId),
+          producer: `${producerPrefix}.unassigned`,
+          memberId: record.nodeId,
+          gateChecks: [
+            {
+              gateId: 'object_binding',
+              status: 'fail' as const,
+              severity: 'blocker' as const,
+              reason: 'node was recorded outside a CDO wave and cannot be wave-bound',
+              evidenceRefs,
+            },
+            {
+              gateId: 'evidence_manifest',
+              status: ok && record.outputPath ? 'pass' as const : 'fail' as const,
+              severity: 'blocker' as const,
+              reason: ok && record.outputPath
+                ? 'node output artifact was written'
+                : 'node output artifact missing or node did not complete',
+              evidenceRefs,
+            },
+            {
+              gateId: 'falsifier',
+              status: ok ? 'pass' as const : 'fail' as const,
+              severity: 'blocker' as const,
+              reason: ok
+                ? 'runtime failure falsifier closed by node success status'
+                : `runtime failure falsifier remains open: ${nodeStatusReason(record)}`,
+              evidenceRefs,
+            },
+          ],
+        };
+      }),
+    });
+  }
+
+  return {
+    kind: 'ClaimGateCouncilWaveInput',
+    sessionId: runId,
+    ...(workstreamId ? { workstreamId } : {}),
+    maxWaves: Math.max(1, waves.length),
+    waves: waves.length ? waves : [{ wave: 1, contract: councilWaveContract(producerPrefix, 'empty'), claims: [] }],
+  };
+}
