+}
+
+function graphPatchExecutionData(result: ClaimGateGraphPatchExecutionInput): ClaimGateGraphPatchExecutionInput {
+  return result && typeof result.data === 'object' && result.data !== null
+    ? result.data
+    : result;
+}
+
+function graphPatchExecutionSuccess(result: ClaimGateGraphPatchExecutionInput): boolean | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.success ?? result.success;
+}
+
+function graphPatchExecutionStatus(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.status ?? result.status;
+}
+
+function graphPatchExecutionApplied(result: ClaimGateGraphPatchExecutionInput): number | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.applied ?? result.applied;
+}
+
+function graphPatchExecutionApplyPlanReceiptId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.apply_plan_receipt_id
+    ?? data.applyPlanReceiptId
+    ?? result.apply_plan_receipt_id
+    ?? result.applyPlanReceiptId;
+}
+
+function graphPatchExecutionGraphEventId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.graph_event_id ?? data.graphEventId ?? result.graph_event_id ?? result.graphEventId;
+}
+
+function graphPatchExecutionErrors(result: ClaimGateGraphPatchExecutionInput): unknown[] {
+  const data = graphPatchExecutionData(result);
+  return [
+    ...(Array.isArray(result.errors) ? result.errors : []),
+    ...(Array.isArray(data.errors) ? data.errors : []),
+  ];
+}
+
+function validateGraphPatchExecutionInputs(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+  graphResult: ClaimGateGraphPatchExecutionInput,
+  trustedRefs: Set<string>,
+): ClaimGateGraphPatchExecutionFinding[] {
+  const findings: ClaimGateGraphPatchExecutionFinding[] = [];
+  const success = graphPatchExecutionSuccess(graphResult);
+  const status = graphPatchExecutionStatus(graphResult);
+  const applied = graphPatchExecutionApplied(graphResult);
+  const applyPlanReceiptId = graphPatchExecutionApplyPlanReceiptId(graphResult);
+  const graphEventId = graphPatchExecutionGraphEventId(graphResult);
+  const errors = graphPatchExecutionErrors(graphResult);
+
+  if (applyPlan.kind !== 'ClaimGateGraphPatchApplyPlan') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.invalid_apply_plan_kind',
+      'Apply plan artifact kind must be ClaimGateGraphPatchApplyPlan.',
+    );
+  }
+
+  if (!applyPlan.ok || applyPlan.status !== 'apply_ready') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_not_ready',
+      'Graph execution can only be recorded for an ok apply_ready plan.',
+    );
+  }
+
+  if (applyPlan.graphMutationApplied !== false) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.source_already_marked_applied',
+      'Apply plans must preserve graphMutationApplied:false; the host graph result is the mutation evidence.',
+    );
+  }
+
+  if (applyPlan.claimCeiling !== 'apply_plan_only_requires_graph_patch_execution') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.unexpected_apply_plan_ceiling',
+      'Apply plan claim ceiling must preserve the separate graph execution boundary.',
+    );
+  }
+
+  if (!applyPlan.receipt.evalResults.every((evalResult) => evalResult.passed)) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_receipt_failed_eval',
+      'Apply plan receipt must have all eval results passing before graph execution can be admitted.',
+    );
+  }
+
+  if (!receiptContentHashMatches(applyPlan.receipt, graphPatchApplyPlanReceiptPayload(applyPlan))) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_receipt_hash_mismatch',
+      'The apply plan receipt contentHash must match the current apply plan artifact before graph execution can be admitted.',
+    );
+  }
+
+  if (success !== true) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.result_not_successful',
+      'Graph patch execution result must report success:true.',
+    );
+  }
+
+  if (status !== 'applied') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.result_not_applied',
+      'Graph patch execution result status must be applied.',
+    );
+  }
+
+  if (!Number.isFinite(applied) || applied !== applyPlan.operationCount) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.operation_count_mismatch',
+      'Graph patch applied count must match the apply plan operationCount.',
+    );
+  }
+
+  if (applyPlanReceiptId !== applyPlan.receipt.id) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_receipt_id_mismatch',
+      'Graph patch execution result must echo the apply plan receipt id it executed.',
+    );
+  }
+
+  if (typeof graphEventId !== 'string' || !graphEventId.startsWith('ge-')) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.graph_event_id_missing',
+      'Graph patch execution must return a graph_event_id beginning with ge-.',
+    );
+  } else if (!trustedRefs.has(graphEventId)) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.graph_event_untrusted',
+      'Graph patch execution graph_event_id must be supplied by a host-trusted graph event ref.',
+    );
+  }
+
+  if (errors.length > 0) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.result_errors_present',
+      'Graph patch execution result must not carry errors.',
+    );
+  }
+
+  return findings;
+}
+
+function createGraphPatchExecutionReceipt({
+  sessionId,
+  workstreamId,
+  applyPlan,
+  graphResult,
+  ok,
+  findings,
+  graphEventId,
