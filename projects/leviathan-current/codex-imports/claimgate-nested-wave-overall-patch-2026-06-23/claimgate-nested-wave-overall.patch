+    applyPlanReceiptId: applyPlan.receipt.id,
+    operationCount: applyPlan.operationCount,
+    graphEventId,
+    graphResult,
+    findings,
+    claimCeiling: 'graph_patch_executed_by_explicit_host_action',
+    graphMutationApplied: ok,
+  };
+
+  return createReceipt({
+    scope: 'session',
+    sessionId,
+    workUnitId: 'claim-gate-graph-patch-execution',
+    workstreamId,
+    contentHash: sha256(receiptPayload),
+    evalResults: [
+      {
+        id: 'eval-claim-gate-graph-patch-execution',
+        strategy: 'gate-based',
+        timestamp: new Date().toISOString(),
+        passed: ok,
+        reasoning: ok
+          ? 'Explicit host graph-patch execution matched the ClaimGate apply plan and returned a graph event id.'
+          : 'Explicit host graph-patch execution was not admitted for this ClaimGate apply plan.',
+        metadata: {
+          sourceReceiptId: applyPlan.sourceReceiptId,
+          admissionReceiptId: applyPlan.admissionReceiptId,
+          applyPlanReceiptId: applyPlan.receipt.id,
+          operationCount: applyPlan.operationCount,
+          graphEventId,
+          findingCodes: findings.map((finding) => finding.code),
+          claimCeiling: 'graph_patch_executed_by_explicit_host_action',
+          graphMutationApplied: ok,
+        },
+      },
+    ],
+    effectResults: [
+      {
+        declaration: {
+          kind: 'state_mutation',
+          target: 'claim-gate.graph-patch-execution',
+          description: 'Record an explicit graph-patch execution result for a ClaimGate apply plan.',
+          reversible: false,
+        },
+        status: ok ? 'applied' : 'skipped',
+        timestamp: new Date().toISOString(),
+      },
+    ],
+    provenance: {
+      surface: 'proof',
+      host: 'lev',
+      profile: 'claim-gate-graph-patch-execution',
+    },
+  });
+}
+
+export function runClaimGateLoopFixture(
+  options: RunClaimGateLoopFixtureOptions = {},
+): ClaimGateLoopResult {
+  const claims = options.claims ?? DEFAULT_CLAIMS;
+  const maxWaves = Math.max(1, Math.floor(options.maxWaves ?? 2));
+  const sessionId = options.sessionId ?? 'claim-gate-loop-fixture';
+
+  const accepted = new Set<string>();
+  const terminal = new Set<string>();
+  const waves: ClaimGateLoopWave[] = [];
+  const failurePackets: ClaimGateFailurePacket[] = [];
+  const requeueEvents: ClaimGateRequeueEvent[] = [];
+  const repairBindings: ClaimGateLoopRepairBinding[] = [];
+
+  let queue = claims.slice();
+  for (let wave = 1; wave <= maxWaves && queue.length > 0; wave++) {
+    const current = queue;
+    queue = [];
+    const verdicts: ClaimGateLoopVerdict[] = [];
+
+    for (const claim of current) {
+      if (accepted.has(claim.claimId) || terminal.has(claim.claimId)) continue;
+      if (passesFixtureGate(claim, wave)) {
+        accepted.add(claim.claimId);
+        verdicts.push({ claimId: claim.claimId, wave, verdict: 'pass' });
+        continue;
+      }
+
+      const isTerminal = wave >= maxWaves;
+      const packet = makeFailurePacket(claim, wave, maxWaves, isTerminal);
+      failurePackets.push(packet);
+      verdicts.push({
+        claimId: claim.claimId,
+        wave,
+        verdict: 'fail',
+        failurePacketId: packet.packetId,
+      });
+
+      if (isTerminal) {
+        terminal.add(claim.claimId);
+      } else {
+        queue.push(claim);
+        requeueEvents.push({
+          fromWave: wave,
+          toWave: wave + 1,
+          claimId: claim.claimId,
+          failurePacketId: packet.packetId,
+        });
+      }
+    }
+
+    waves.push({
+      wave,
+      dispatchedClaimIds: current.map((claim) => claim.claimId),
+      verdicts,
+    });
+  }
+
+  const graphPatchProposal = buildGraphPatchProposal(claims, accepted, terminal);
+  const receipt = createLoopReceipt({
+    profile: 'claim-gate-loop-fixture',
+    sessionId,
+    workstreamId: options.workstreamId,
+    maxWaves,
+    waves,
+    failurePackets,
+    requeueEvents,
+    repairBindings,
+    graphPatchProposal,
+    terminal,
+  });
+
+  return {
+    kind: 'ClaimGateLoopFixtureResult',
+    maxWaves,
+    waves,
+    failurePackets,
+    requeueEvents,
+    repairBindings,
+    graphPatchProposal,
+    receipt,
+  };
+}
+
+function requiredGateFindings(
+  claim: ClaimGateCouncilWaveClaim,
+  requiredGateIds: string[],
+  trustedRefs: Set<string>,
+): ClaimGateCouncilGateFinding[] {
+  const findings: ClaimGateCouncilGateFinding[] = [];
+
+  for (const gateId of requiredGateIds) {
+    const checks = claim.gateChecks.filter((check) => check.gateId === gateId);
+    if (checks.length === 0) {
+      findings.push({
+        gateId,
+        status: 'missing',
+        reason: `Required gate ${gateId} was not supplied by the council wave output.`,
+        evidenceRefs: [`claim:${claim.claimId}`, `gate:${gateId}`],
+      });
+      continue;
+    }
+    if (checks.length > 1) {
+      findings.push({
+        gateId,
+        status: 'failed',
+        reason: `Required gate ${gateId} appeared ${checks.length} times; duplicate gate decisions are ambiguous.`,
+        evidenceRefs: checks.flatMap((check) => check.evidenceRefs ?? []).length
+          ? checks.flatMap((check) => check.evidenceRefs ?? [])
+          : [`claim:${claim.claimId}`, `gate:${gateId}`],
+      });
+      continue;
+    }
+
+    const [check] = checks;
+    if (check.status !== 'pass') {
+      findings.push({
+        gateId,
+        status: 'failed',
+        reason: check.reason ?? `Required gate ${gateId} failed.`,
+        evidenceRefs: check.evidenceRefs?.length
+          ? check.evidenceRefs
+          : [`claim:${claim.claimId}`, `gate:${gateId}`],
+      });
+      continue;
+    }
+
+    if (!check.evidenceRefs?.length) {
+      findings.push({
+        gateId,
+        status: 'failed',
+        reason: `Required gate ${gateId} passed without evidence refs.`,
+        evidenceRefs: [`claim:${claim.claimId}`, `gate:${gateId}`],
+      });
+      continue;
+    }
+
+    findings.push(...sourceBoundEvidenceFindings(gateId, check.evidenceRefs, trustedRefs));
+    findings.push(...fileEvidenceFindings(gateId, check.evidenceRefs));
+  }
+
+  return findings;
+}
+
+function repairLineageFinding(reason: string, evidenceRefs: string[]): ClaimGateCouncilGateFinding {
+  return {
+    gateId: 'repair_lineage',
+    status: 'failed',
+    reason,
+    evidenceRefs,
+  };
+}
+
+function externalRepairLineageForClaim(
+  claim: ClaimGateCouncilWaveClaim,
+  wave: number,
+  parentResult: ClaimGateLoopResult | undefined,
+): { findings: ClaimGateCouncilGateFinding[]; binding?: ClaimGateLoopRepairBinding } {
+  const repairOf = claim.repairOf;
+  if (!repairOf) return { findings: [] };
+
+  const findings: ClaimGateCouncilGateFinding[] = [];
+  const evidenceRefs = [
+    `claim:${claim.claimId}`,
+    `wave:${wave}`,
+    `failure-packet:${repairOf.failurePacketId}`,
+    ...(repairOf.parentReceiptId ? [`receipt:${repairOf.parentReceiptId}`] : []),
+  ];
+
+  if (repairOf.sourceClaimId !== undefined && repairOf.sourceClaimId !== claim.claimId) {
+    findings.push(repairLineageFinding(
+      `External repair sourceClaimId ${repairOf.sourceClaimId} must match claimId ${claim.claimId}.`,
+      evidenceRefs,
+    ));
+  }
+
+  if (!repairOf.parentReceiptId) {
+    findings.push(repairLineageFinding(
+      'External repair lineage must include repairOf.parentReceiptId.',
+      evidenceRefs,
+    ));
+  }
+
+  if (!parentResult) {
+    findings.push(repairLineageFinding(
+      'External repair lineage requires a parent ClaimGate loop result supplied by the host.',
+      evidenceRefs,
+    ));
+    return { findings };
+  }
+
+  if (repairOf.parentReceiptId !== parentResult.receipt.id) {
+    findings.push(repairLineageFinding(
+      `External repair parentReceiptId ${repairOf.parentReceiptId ?? '(missing)'} must match parent result receipt ${parentResult.receipt.id}.`,
+      evidenceRefs,
+    ));
+  }
+
+  if (!receiptContentHashMatches(parentResult.receipt, loopReceiptPayload(parentResult))) {
+    findings.push(repairLineageFinding(
+      'External repair parent result receipt contentHash does not match the current parent result payload.',
+      [`receipt:${parentResult.receipt.id}`, ...evidenceRefs],
+    ));
+  }
+
+  const parentPacket = parentResult.failurePackets.find((packet) => (
+    packet.packetId === repairOf.failurePacketId
+    && packet.claimId === claim.claimId
+  ));
+  if (!parentPacket) {
+    findings.push(repairLineageFinding(
+      `External repair failurePacketId ${repairOf.failurePacketId} was not found on the parent result for claim ${claim.claimId}.`,
+      evidenceRefs,
+    ));
+  }
+
+  if (!parentResult.graphPatchProposal.withheldClaimIds.includes(claim.claimId)) {
+    findings.push(repairLineageFinding(
+      `External repair claim ${claim.claimId} must be withheld by the parent result before it can be repaired in a later run.`,
+      [`receipt:${parentResult.receipt.id}`, `claim:${claim.claimId}`],
+    ));
+  }
+
+  if (parentResult.graphPatchProposal.acceptedClaimIds.includes(claim.claimId)) {
+    findings.push(repairLineageFinding(
+      `External repair claim ${claim.claimId} is already accepted by the parent result and cannot be repaired as withheld work.`,
+      [`receipt:${parentResult.receipt.id}`, `claim:${claim.claimId}`],
+    ));
+  }
+
+  if (findings.length > 0 || !parentPacket) return { findings };
+
+  return {
+    findings,
+    binding: {
+      claimId: claim.claimId,
+      wave,
+      failurePacketId: repairOf.failurePacketId,
+      source: 'parent_result',
+      parentReceiptId: parentResult.receipt.id,
+      parentSessionId: parentResult.receipt.sessionId,
+      parentWave: parentPacket.wave,
+      parentReceiptContentHash: parentResult.receipt.contentHash,
+    },
+  };
+}
+
+function classifyRepairKinds(findings: ClaimGateCouncilGateFinding[]): ClaimGateRepairKind[] {
+  const kinds = new Set<ClaimGateRepairKind>();
+  const text = findings
+    .map((finding) => `${finding.gateId} ${finding.reason}`)
+    .join('\n')
+    .toLowerCase();
+
+  if (
+    /\b(unavailable|preflight|provider|adapter|timeout|timed out|missing api key|api_key|spawn|enoent|model degraded|degraded|network|rate limit|quota)\b/.test(text)
+  ) {
+    kinds.add('transport_or_availability_repair');
+  }
+
+  if (findings.some((finding) => finding.gateId === 'object_binding')) {
+    kinds.add('object_binding_repair');
+  }
+  if (findings.some((finding) => finding.gateId === 'evidence_manifest')) {
+    kinds.add('evidence_manifest_repair');
+  }
+  if (findings.some((finding) => finding.gateId === 'falsifier')) {
+    kinds.add('falsifier_repair');
+  }
+
+  if (kinds.size === 0) {
+    kinds.add('claim_delta_repair');
+  }
+
+  const order: ClaimGateRepairKind[] = [
+    'transport_or_availability_repair',
+    'object_binding_repair',
+    'evidence_manifest_repair',
+    'falsifier_repair',
+    'claim_delta_repair',
+  ];
+  return order.filter((kind) => kinds.has(kind));
+}
+
+function makeCouncilFailurePacket({
+  claim,
+  wave,
+  maxWaves,
+  findings,
+  nextWave,
+  waveContract,
+}: {
+  claim: ClaimGateCouncilWaveClaim;
+  wave: number;
+  maxWaves: number;
+  findings: ClaimGateCouncilGateFinding[];
+  nextWave: number | null;
+  waveContract?: ClaimGateCouncilWaveContract;
+}): ClaimGateFailurePacket {
+  const packetId = councilFailurePacketId(claim.claimId, wave);
+  const terminal = nextWave === null;
+  const violatedGates = findings.map((finding) => finding.gateId);
+  const repairKinds = classifyRepairKinds(findings);
+  const evidenceRefs = [
+    `claim:${claim.claimId}`,
+    `wave:${wave}`,
+    ...findings.flatMap((finding) => finding.evidenceRefs),
+  ];
+  return {
+    packetId,
+    claimId: claim.claimId,
+    wave,
+    violatedGate: violatedGates[0] ?? 'unknown_gate',
+    violatedGates,
+    gateFindings: findings,
+    repairKinds,
+    ...(waveContract ? { waveContract } : {}),
+    evidenceRefs: Array.from(new Set(evidenceRefs)),
+    falsifier: findings.map((finding) => finding.reason).join(' '),
+    retryPatch: terminal
+      ? null
+      : {
+          nextWave,
+          instruction: `Requeue ${claim.claimId} with failure packet ${packetId}.`,
+        },
+    owner: 'claim-gate-council-wave',
+    budget: { remainingWaves: Math.max(0, maxWaves - wave) },
+    ...(terminal ? { graveyardReason: 'max_passes_exceeded' as const } : {}),
+  };
+}
+
+function nextWaveForClaim(
+  input: ClaimGateCouncilWaveInput,
+  claimId: string,
+  wave: number,
+  failurePacketId: string,
+): number | null {
+  const future = input.waves
+    .filter((candidateWave) => candidateWave.wave > wave)
+    .sort((a, b) => a.wave - b.wave)
+    .find((candidateWave) => candidateWave.claims.some((claim) => (
+      claim.claimId === claimId
+      && claim.repairOf?.failurePacketId === failurePacketId
+      && (claim.repairOf.sourceClaimId === undefined || claim.repairOf.sourceClaimId === claimId)
+    )));
+  return future?.wave ?? null;
+}
+
+export function runClaimGateCouncilWaveLoop(
+  input: ClaimGateCouncilWaveInput,
+  options: RunClaimGateCouncilWaveLoopOptions = {},
+): ClaimGateLoopResult {
+  const validatedInput = validateClaimGateCouncilWaveInput(input, {
+    allowExternalRepairLineage: Boolean(options.parentResult),
+  });
+  const requiredGateIds = resolveRequiredGateIds(options);
+  const trustedRefs = trustedEvidenceRefSet(options.trustedEvidenceRefs);
+  const sortedInputWaves = validatedInput.waves.slice().sort((a, b) => a.wave - b.wave);
+  const maxInputWave = sortedInputWaves.reduce((max, wave) => Math.max(max, wave.wave), 0);
+  const maxWaves = Math.max(1, Math.floor(options.maxWaves ?? validatedInput.maxWaves ?? (maxInputWave || 1)));
+  const sessionId = options.sessionId ?? validatedInput.sessionId ?? 'claim-gate-council-wave';
+
+  const accepted = new Set<string>();
+  const terminal = new Set<string>();
+  const payloads = new Map<string, string>();
+  const waves: ClaimGateLoopWave[] = [];
+  const failurePackets: ClaimGateFailurePacket[] = [];
+  const requeueEvents: ClaimGateRequeueEvent[] = [];
+  const repairBindings: ClaimGateLoopRepairBinding[] = [];
+  const seenClaimIds = new Set<string>();
+
+  for (const inputWave of sortedInputWaves.filter((wave) => wave.wave <= maxWaves)) {
+    const verdicts: ClaimGateLoopVerdict[] = [];
+    const dispatchedClaimIds: string[] = [];
+
+    for (const claim of inputWave.claims) {
+      if (accepted.has(claim.claimId) || terminal.has(claim.claimId)) continue;
+      dispatchedClaimIds.push(claim.claimId);
+      payloads.set(claim.claimId, claim.payload);
+      const hasPriorClaimInCurrentInput = seenClaimIds.has(claim.claimId);
+      const externalRepair = claim.repairOf !== undefined && !hasPriorClaimInCurrentInput;
+      const externalLineage = externalRepair
+        ? externalRepairLineageForClaim(claim, inputWave.wave, options.parentResult)
+        : { findings: [] };
+      const findings = [
+        ...externalLineage.findings,
+        ...requiredGateFindings(claim, requiredGateIds, trustedRefs),
+      ];
+      if (findings.length === 0) {
+        if (externalLineage.binding) {
+          repairBindings.push(externalLineage.binding);
+        } else if (claim.repairOf) {
+          repairBindings.push({
+            claimId: claim.claimId,
+            wave: inputWave.wave,
+            failurePacketId: claim.repairOf.failurePacketId,
+            source: 'current_input',
+            ...(claim.repairOf.parentReceiptId ? { parentReceiptId: claim.repairOf.parentReceiptId } : {}),
+          });
+        }
+        accepted.add(claim.claimId);
+        verdicts.push({ claimId: claim.claimId, wave: inputWave.wave, verdict: 'pass' });
+        seenClaimIds.add(claim.claimId);
+        continue;
+      }
+
+      const failurePacketId = councilFailurePacketId(claim.claimId, inputWave.wave);
+      const futureWave = nextWaveForClaim(validatedInput, claim.claimId, inputWave.wave, failurePacketId);
+      const nextWave = futureWave !== null && futureWave <= maxWaves ? futureWave : null;
+      const packet = makeCouncilFailurePacket({
+        claim,
+        wave: inputWave.wave,
+        maxWaves,
+        findings,
+        nextWave,
+        waveContract: inputWave.contract,
+      });
+      failurePackets.push(packet);
+      verdicts.push({
+        claimId: claim.claimId,
+        wave: inputWave.wave,
+        verdict: 'fail',
+        failurePacketId: packet.packetId,
+      });
+
+      if (nextWave === null) {
+        terminal.add(claim.claimId);
+      } else {
+        requeueEvents.push({
+          fromWave: inputWave.wave,
+          toWave: nextWave,
+          claimId: claim.claimId,
+          failurePacketId: packet.packetId,
+        });
+      }
+      seenClaimIds.add(claim.claimId);
+    }
+
+    waves.push({
+      wave: inputWave.wave,
+      dispatchedClaimIds,
+      verdicts,
+    });
+  }
+
+  const allClaims = Array.from(payloads.entries()).map(([claimId, payload]) => ({ claimId, payload }));
+  const graphPatchProposal = buildGraphPatchProposal(allClaims, accepted, terminal);
+  const receipt = createLoopReceipt({
+    profile: 'claim-gate-council-wave',
+    sessionId,
+    workstreamId: options.workstreamId ?? validatedInput.workstreamId,
+    maxWaves,
+    waves,
+    failurePackets,
+    requeueEvents,
+    repairBindings,
+    graphPatchProposal,
+    terminal,
+  });
+
+  return {
+    kind: 'ClaimGateLoopCouncilWaveResult',
+    maxWaves,
+    waves,
+    failurePackets,
+    requeueEvents,
+    repairBindings,
+    graphPatchProposal,
+    receipt,
+  };
+}
+
+export function buildClaimGateRepairWavePlan(
+  input: ClaimGateCouncilWaveInput,
+  result: ClaimGateLoopResult,
+  options: BuildClaimGateRepairWavePlanOptions = {},
+): ClaimGateRepairWavePlan {
+  const validatedInput = validateClaimGateCouncilWaveInput(input);
+  const sortedInputWaves = validatedInput.waves.slice().sort((a, b) => a.wave - b.wave);
+  const maxInputWave = sortedInputWaves.reduce((max, wave) => Math.max(max, wave.wave), 0);
+  const maxResultWave = result.waves.reduce((max, wave) => Math.max(max, wave.wave), 0);
+  const nextWave = Math.max(1, Math.floor(options.nextWave ?? Math.max(maxInputWave, maxResultWave) + 1));
+  const sourceSessionId = validatedInput.sessionId ?? result.receipt.sessionId ?? 'claim-gate-council-wave';
+  const sessionId = options.sessionId ?? `${sourceSessionId}-repair-wave-${nextWave}`;
+  const workstreamId = options.workstreamId ?? validatedInput.workstreamId ?? result.receipt.workstreamId;
+  const parentReceiptId = result.receipt.id;
+
+  const sourceClaims = new Map<string, {
+    claim: ClaimGateCouncilWaveClaim;
+    wave: number;
+    member?: ClaimGateCouncilWaveMember;
+  }>();
+  for (const wave of sortedInputWaves) {
+    const membersById = new Map((wave.members ?? []).map((member) => [member.memberId, member]));
+    for (const claim of wave.claims) {
+      sourceClaims.set(claim.claimId, {
+        claim,
+        wave: wave.wave,
+        ...(claim.memberId ? { member: membersById.get(claim.memberId) } : {}),
+      });
+    }
+  }
+
+  const terminalPackets = new Map<string, ClaimGateFailurePacket>();
+  for (const packet of result.failurePackets.slice().sort((a, b) => a.wave - b.wave)) {
+    terminalPackets.set(packet.claimId, packet);
+  }
+
+  const withheldClaimIds = result.graphPatchProposal.withheldClaimIds;
+  const missingClaimIds: string[] = [];
+  const repairClaims: ClaimGateRepairWavePlanClaim[] = [];
+
+  for (const claimId of withheldClaimIds) {
+    const source = sourceClaims.get(claimId);
+    const packet = terminalPackets.get(claimId);
+    if (!source || !packet) {
+      missingClaimIds.push(claimId);
+      continue;
+    }
+
+    const violatedGates = packet.violatedGates?.length ? packet.violatedGates : [packet.violatedGate];
+    const repairKinds = packet.repairKinds?.length ? packet.repairKinds : classifyRepairKinds(packet.gateFindings ?? []);
+    const instruction = [
+      `Repair ${claimId} in council wave ${nextWave}.`,
+      `Set repairOf.failurePacketId=${packet.packetId} and repairOf.parentReceiptId=${parentReceiptId}.`,
+      `Satisfy required gates: ${violatedGates.join(', ')}.`,
+      `Repair taxonomy: ${repairKinds.join(', ')}.`,
+      'Do not promote by council agreement; return new gateChecks with evidence refs for deterministic ClaimGate consumption.',
+    ].join(' ');
+
+    repairClaims.push({
+      claimId,
+      sourceWave: packet.wave,
+      targetWave: nextWave,
+      failurePacketId: packet.packetId,
+      repairOf: {
+        failurePacketId: packet.packetId,
+        sourceClaimId: claimId,
+        parentReceiptId,
+      },
+      violatedGates,
+      repairKinds,
+      gateFindings: packet.gateFindings ?? [],
+      ...(packet.waveContract ? { sourceWaveContract: packet.waveContract } : {}),
+      evidenceRefs: packet.evidenceRefs,
+      falsifier: packet.falsifier,
+      payload: source.claim.payload,
+      ...(source.claim.producer ? { producer: source.claim.producer } : {}),
+      ...(source.claim.memberId ? { sourceMemberId: source.claim.memberId } : {}),
+      ...(source.member ? { sourceMember: source.member } : {}),
+      instruction,
+    });
+  }
+
+  const receipt = createRepairWavePlanReceipt({
+    sessionId,
+    sourceSessionId,
+    workstreamId,
+    parentReceiptId,
+    nextWave,
+    repairClaims,
+    missingClaimIds,
+  });
+
+  return {
+    kind: 'ClaimGateRepairWavePlan',
+    sessionId,
+    sourceSessionId,
+    ...(workstreamId ? { workstreamId } : {}),
+    parentReceiptId,
+    nextWave,
+    claimCeiling: 'repair_wave_plan_proposal_only',
+    repairClaims,
+    missingClaimIds,
+    receipt,
+  };
+}
+
+function repairPlanReceiptPayload(plan: ClaimGateRepairWavePlan) {
+  return repairWavePlanReceiptPayload({
+    sourceSessionId: plan.sourceSessionId,
+    parentReceiptId: plan.parentReceiptId,
+    nextWave: plan.nextWave,
+    repairClaims: plan.repairClaims,
+    missingClaimIds: plan.missingClaimIds,
+  });
+}
+
+function explicitTargetRefFromSkillRefs(
+  skillRefs: string[] | undefined,
+  prefixes: string[],
+): string | undefined {
+  return (skillRefs ?? []).find((ref) => prefixes.some((prefix) => ref.startsWith(prefix)));
+}
+
+function repairDispatchTargetForClaim(
+  claim: ClaimGateRepairWavePlanClaim,
+  findings: ClaimGateRepairDispatchPlanFinding[],
+): ClaimGateRepairDispatchTarget | null {
+  const member = claim.sourceMember;
+  if (!member || !claim.sourceMemberId) {
+    addRepairDispatchFinding(
+      findings,
+      'repair_dispatch.source_member_missing',
+      'Repair dispatch requires the full sourceMember and sourceMemberId so execution can route by kind and skills.',
+      claim.claimId,
+    );
+    return null;
+  }
+
+  if (member.kind === 'autoresearch') {
+    return {
+      kind: 'skill',
+      ref: 'skill:codex-autoresearch',
+      commandPreview: ['lev', 'exec', '<repair-wave-producer>', '--profile=codex-autoresearch'],
+    };
+  }
+
+  if (member.kind === 'premortem') {
+    return {
+      kind: 'skill',
+      ref: 'skill:premortem',
+      commandPreview: ['lev', 'exec', '<repair-wave-producer>', '--profile=premortem'],
+    };
+  }
+
+  if (member.kind === 'gate_loop') {
+    return {
+      kind: 'gate_loop',
+      ref: 'lev orchestration claim-gate-loop',
+      commandPreview: ['lev', 'orchestration', 'claim-gate-loop', 'consume', '<repair-wave.json>', '--parent-result', '<parent-result.json>'],
+    };
+  }
+
+  if (member.kind === 'council') {
+    const ref = explicitTargetRefFromSkillRefs(member.skillRefs, ['skill:cdo', 'skill:three-council-wizard']);
+    if (ref) {
+      return {
+        kind: 'council',
+        ref,
+        commandPreview: ['lev', 'exec', '<repair-council-wave>', '--profile=cdo'],
+      };
+    }
+  }
+
+  if (member.kind === 'skill') {
+    const ref = explicitTargetRefFromSkillRefs(member.skillRefs, ['skill:']);
+    if (ref) {
+      return {
+        kind: 'skill',
+        ref,
+        commandPreview: ['lev', 'exec', '<repair-skill-wave>', `--skill=${ref}`],
+      };
+    }
+  }
+
+  if (member.kind === 'workflow') {
+    const ref = explicitTargetRefFromSkillRefs(member.skillRefs, ['workflow:', 'flow:']);
+    if (ref) {
+      return {
+        kind: 'workflow',
+        ref,
+        commandPreview: ['lev', 'exec', '<repair-workflow-wave>', `--flow=${ref}`],
+      };
+    }
+  }
+
+  if (member.kind === 'agent') {
+    const ref = explicitTargetRefFromSkillRefs(member.skillRefs, ['profile:', 'workflow:', 'flow:', 'skill:']);
+    if (ref) {
+      return {
+        kind: ref.startsWith('skill:') ? 'skill' : 'lev_exec',
+        ref,
+        commandPreview: ['lev', 'exec', '<repair-agent-wave>', `--target=${ref}`],
+      };
+    }
+  }
+
+  addRepairDispatchFinding(
+    findings,
+    'repair_dispatch.no_executable_route',
+    `No explicit executable route is known for source member ${member.memberId} (${member.kind}).`,
+    claim.claimId,
+  );
+  return null;
+}
+
+export function buildClaimGateRepairDispatchPlan(
+  repairPlan: ClaimGateRepairWavePlan,
+  options: BuildClaimGateRepairDispatchPlanOptions = {},
+): ClaimGateRepairDispatchPlan {
+  const sessionId = options.sessionId ?? `${repairPlan.sessionId}-dispatch-plan`;
+  const workstreamId = options.workstreamId ?? repairPlan.receipt.workstreamId;
+  const findings: ClaimGateRepairDispatchPlanFinding[] = [];
+  const dispatchRequests: ClaimGateRepairDispatchRequest[] = [];
+
+  if (!receiptContentHashMatches(repairPlan.receipt, repairPlanReceiptPayload(repairPlan))) {
+    addRepairDispatchFinding(
+      findings,
+      'repair_dispatch.source_repair_plan_receipt_hash_mismatch',
+      'Repair dispatch plan source receipt contentHash no longer matches the repair plan payload.',
+    );
+  }
+
+  for (const claim of repairPlan.repairClaims) {
+    const target = repairDispatchTargetForClaim(claim, findings);
+    if (!target || !claim.sourceMember || !claim.sourceMemberId) continue;
+    dispatchRequests.push({
+      requestId: `dispatch-${safeGraphIdComponent(claim.claimId)}-${safeGraphIdComponent(claim.sourceMemberId)}`,
+      claimId: claim.claimId,
+      failurePacketId: claim.failurePacketId,
+      repairKinds: claim.repairKinds,
+      sourceMemberId: claim.sourceMemberId,
+      sourceMember: claim.sourceMember,
+      target,
+      requiredInputs: {
+        repairOf: claim.repairOf,
+        parentReceiptId: repairPlan.parentReceiptId,
+        violatedGates: claim.violatedGates,
+      },
+      instruction: claim.instruction,
+    });
+  }
+
+  const ok = findings.every((finding) => finding.severity !== 'error');
+  const receipt = createRepairDispatchPlanReceipt({
+    sessionId,
+    workstreamId,
+    sourceRepairPlanReceiptId: repairPlan.receipt.id,
+    dispatchRequests,
+    findings,
+    ok,
+  });
+
+  return {
+    kind: 'ClaimGateRepairDispatchPlan',
+    sessionId,
+    sourceRepairPlanReceiptId: repairPlan.receipt.id,
+    status: ok ? 'dispatch_ready' : 'dispatch_blocked',
+    ok,
+    claimCeiling: 'repair_dispatch_plan_only_requires_lev_exec_execution',
+    dispatchRequests,
+    findings,
+    receipt,
+  };
+}
+
+function repairDispatchPlanPayload(plan: ClaimGateRepairDispatchPlan) {
+  return repairDispatchPlanReceiptPayload({
+    sourceRepairPlanReceiptId: plan.sourceRepairPlanReceiptId,
+    dispatchRequests: plan.dispatchRequests,
+    findings: plan.findings,
+  });
+}
+
+function claimsById(input: ClaimGateCouncilWaveInput): Map<string, ClaimGateCouncilWaveClaim> {
+  const out = new Map<string, ClaimGateCouncilWaveClaim>();
+  for (const wave of input.waves) {
+    for (const claim of wave.claims) {
+      out.set(claim.claimId, claim);
+    }
+  }
+  return out;
+}
+
+export function recordClaimGateRepairDispatchExecution(
+  dispatchPlan: ClaimGateRepairDispatchPlan,
+  repairWaveInput: ClaimGateCouncilWaveInput,
+  options: RecordClaimGateRepairDispatchExecutionOptions = {},
+): ClaimGateRepairDispatchExecutionReceipt {
+  const sessionId = options.sessionId ?? `${dispatchPlan.sessionId}-execution`;
+  const workstreamId = options.workstreamId ?? dispatchPlan.receipt.workstreamId;
+  const validatedRepairWaveInput = validateClaimGateCouncilWaveInput(repairWaveInput, {
+    allowExternalRepairLineage: true,
+  });
+  const findings: ClaimGateRepairDispatchExecutionFinding[] = [];
+
+  if (!receiptContentHashMatches(dispatchPlan.receipt, repairDispatchPlanPayload(dispatchPlan))) {
+    addRepairDispatchExecutionFinding(
+      findings,
+      'repair_dispatch_execution.dispatch_plan_receipt_hash_mismatch',
+      'Repair dispatch execution source receipt contentHash no longer matches the dispatch plan payload.',
+    );
+  }
+
+  if (!dispatchPlan.ok) {
+    addRepairDispatchExecutionFinding(
+      findings,
+      'repair_dispatch_execution.dispatch_plan_blocked',
+      'Cannot record repair dispatch execution from a blocked dispatch plan.',
+    );
+  }
+
+  const emittedClaims = claimsById(validatedRepairWaveInput);
+  const emittedClaimIds: string[] = [];
+  const missingDispatchClaimIds: string[] = [];
+
+  for (const request of dispatchPlan.dispatchRequests) {
+    const claim = emittedClaims.get(request.claimId);
+    if (!claim) {
+      missingDispatchClaimIds.push(request.claimId);
+      addRepairDispatchExecutionFinding(
+        findings,
+        'repair_dispatch_execution.missing_repair_claim',
+        'Repair council-wave artifact did not emit a claim for this dispatch request.',
+        request.claimId,
+      );
+      continue;
+    }
+
+    emittedClaimIds.push(request.claimId);
+    if (!claim.repairOf) {
+      addRepairDispatchExecutionFinding(
+        findings,
+        'repair_dispatch_execution.missing_repair_lineage',
+        'Repair council-wave claim must bind repairOf lineage to the dispatch request.',
+        request.claimId,
+      );
+      continue;
+    }
+    if (claim.repairOf.failurePacketId !== request.failurePacketId) {
+      addRepairDispatchExecutionFinding(
+        findings,
+        'repair_dispatch_execution.failure_packet_mismatch',
+        `Repair council-wave claim must bind repairOf.failurePacketId=${request.failurePacketId}.`,
+        request.claimId,
+      );
+    }
+    if (claim.repairOf.parentReceiptId !== request.requiredInputs.parentReceiptId) {
+      addRepairDispatchExecutionFinding(
+        findings,
+        'repair_dispatch_execution.parent_receipt_mismatch',
+        `Repair council-wave claim must bind repairOf.parentReceiptId=${request.requiredInputs.parentReceiptId}.`,
+        request.claimId,
+      );
+    }
+    if (claim.repairOf.sourceClaimId !== undefined && claim.repairOf.sourceClaimId !== request.claimId) {
+      addRepairDispatchExecutionFinding(
+        findings,
+        'repair_dispatch_execution.source_claim_mismatch',
+        `Repair council-wave claim repairOf.sourceClaimId must equal ${request.claimId}.`,
+        request.claimId,
+      );
+    }
+  }
+
+  const ok = findings.every((finding) => finding.severity !== 'error');
+  const receipt = createRepairDispatchExecutionReceipt({
+    sessionId,
+    workstreamId,
+    dispatchPlan,
+    repairWaveInput: validatedRepairWaveInput,
+    emittedClaimIds,
+    missingDispatchClaimIds,
+    findings,
+    ok,
+  });
+
+  return {
+    kind: 'ClaimGateRepairDispatchExecutionReceipt',
+    sessionId,
+    repairDispatchPlanReceiptId: dispatchPlan.receipt.id,
+    status: ok ? 'repair_dispatch_executed' : 'repair_dispatch_blocked',
+    ok,
+    claimCeiling: 'repair_dispatch_executed_by_explicit_runtime_artifact',
+    emittedClaimIds,
+    missingDispatchClaimIds,
+    findings,
+    receipt,
+  };
+}
+
+export function consumeClaimGateGraphPatchProposal(
+  result: ClaimGateLoopResult,
+  options: ConsumeClaimGateGraphPatchProposalOptions = {},
+): ClaimGateGraphPatchAdmission {
+  const sourceReceiptId = result.receipt.id;
+  const sessionId = options.sessionId ?? `${result.receipt.sessionId}-graph-patch-admission`;
+  const workstreamId = options.workstreamId ?? result.receipt.workstreamId;
+  const findings = validateGraphPatchProposalForHostAdmission(result);
+  const ok = findings.every((finding) => finding.severity !== 'error');
+  const receipt = createGraphPatchAdmissionReceipt({
+    sessionId,
+    workstreamId,
+    sourceReceiptId,
+    ok,
+    graphPatchProposal: result.graphPatchProposal,
+    findings,
+  });
+
+  return {
+    kind: 'ClaimGateGraphPatchAdmission',
+    sessionId,
+    sourceReceiptId,
+    status: ok ? 'host_reviewed' : 'host_blocked',
+    ok,
+    claimCeiling: 'graph_patch_proposal_only_requires_separate_apply_gate',
+    graphMutationApplied: false,
+    acceptedClaimIds: result.graphPatchProposal.acceptedClaimIds,
+    withheldClaimIds: result.graphPatchProposal.withheldClaimIds,
+    admittedOperationCount: ok ? result.graphPatchProposal.operations.length : 0,
+    findings,
+    receipt,
+  };
+}
+
+export function buildClaimGateGraphPatchApplyPlan(
+  result: ClaimGateLoopResult,
+  admission: ClaimGateGraphPatchAdmission,
+  options: BuildClaimGateGraphPatchApplyPlanOptions = {},
+): ClaimGateGraphPatchApplyPlan {
+  const sessionId = options.sessionId ?? `${admission.sessionId}-apply-plan`;
+  const workstreamId = options.workstreamId ?? result.receipt.workstreamId;
+  const findings = validateGraphPatchApplyPlanInputs(result, admission);
+  const ok = findings.every((finding) => finding.severity !== 'error');
+  const graphOperations = ok
+    ? compileGraphPatchOperations({ result, admission })
+    : [];
+  const receipt = createGraphPatchApplyPlanReceipt({
+    sessionId,
+    workstreamId,
+    sourceReceiptId: result.receipt.id,
+    admissionReceiptId: admission.receipt.id,
+    ok,
+    findings,
+    graphOperations,
+    acceptedClaimIds: result.graphPatchProposal.acceptedClaimIds,
+    withheldClaimIds: result.graphPatchProposal.withheldClaimIds,
+  });
+
+  return {
+    kind: 'ClaimGateGraphPatchApplyPlan',
+    sessionId,
+    sourceReceiptId: result.receipt.id,
+    admissionReceiptId: admission.receipt.id,
+    status: ok ? 'apply_ready' : 'apply_blocked',
+    ok,
+    claimCeiling: 'apply_plan_only_requires_graph_patch_execution',
+    graphMutationApplied: false,
+    acceptedClaimIds: result.graphPatchProposal.acceptedClaimIds,
+    withheldClaimIds: result.graphPatchProposal.withheldClaimIds,
+    graphOperations,
+    operationCount: graphOperations.length,
+    findings,
+    receipt,
+  };
+}
+
+export function recordClaimGateGraphPatchExecution(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+  graphResult: ClaimGateGraphPatchExecutionInput,
+  options: RecordClaimGateGraphPatchExecutionOptions = {},
+): ClaimGateGraphPatchExecutionReceipt {
+  const sessionId = options.sessionId ?? `${applyPlan.sessionId}-graph-execution`;
+  const workstreamId = options.workstreamId ?? applyPlan.receipt.workstreamId;
+  const findings = validateGraphPatchExecutionInputs(
+    applyPlan,
+    graphResult,
+    trustedEvidenceRefSet(options.trustedEvidenceRefs),
+  );
+  const ok = findings.every((finding) => finding.severity !== 'error');
+  const graphEventId = graphPatchExecutionGraphEventId(graphResult) ?? null;
+  const receipt = createGraphPatchExecutionReceipt({
+    sessionId,
+    workstreamId,
+    applyPlan,
+    graphResult,
+    ok,
+    findings,
+    graphEventId,
+  });
+
+  return {
+    kind: 'ClaimGateGraphPatchExecutionReceipt',
+    sessionId,
+    sourceReceiptId: applyPlan.sourceReceiptId,
+    admissionReceiptId: applyPlan.admissionReceiptId,
+    applyPlanReceiptId: applyPlan.receipt.id,
+    status: ok ? 'graph_patch_executed' : 'graph_patch_blocked',
+    ok,
+    claimCeiling: 'graph_patch_executed_by_explicit_host_action',
+    graphMutationApplied: ok,
+    operationCount: applyPlan.operationCount,
+    graphEventId,
+    findings,
+    receipt,
+  };
+}
