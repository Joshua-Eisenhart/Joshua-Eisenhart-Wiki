+function isSuccessfulNode(record: CdoArtifactNodeSnapshot): boolean {
+  return record.status === 'success';
+}
+
+function isClaimBearingNode(record: CdoArtifactNodeSnapshot): boolean {
+  return record.adapter !== 'parallel' && record.adapter !== 'gate' && record.adapter !== 'notify';
+}
+
+function summarizeClaimBearingNodes(records: Iterable<CdoArtifactNodeSnapshot>): {
+  total: number;
+  success: number;
+  degraded: number;
+  failed: number;
+} {
+  const summary = {
+    total: 0,
+    success: 0,
+    degraded: 0,
+    failed: 0,
+  };
+
+  for (const record of records) {
+    if (!isClaimBearingNode(record)) continue;
+    summary.total++;
+    if (record.status === 'success') {
+      summary.success++;
+    } else if (record.status === 'degraded') {
+      summary.degraded++;
+    } else {
+      summary.failed++;
+    }
+  }
+
+  return summary;
+}
+
+function artifactStatusFor(payloadStatus: string, summary: ReturnType<typeof summarizeClaimBearingNodes>): string {
+  if (payloadStatus !== 'success') return payloadStatus;
+  if (summary.total === 0) return payloadStatus;
+  if (summary.success === summary.total) return payloadStatus;
+  if (summary.success === 0 && summary.degraded > 0 && summary.failed === 0) return 'degraded';
+  return 'partial';
+}
