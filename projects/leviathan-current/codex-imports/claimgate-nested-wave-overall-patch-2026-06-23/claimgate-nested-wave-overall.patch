+          target: 'claim-gate.graph-patch-apply-plan',
+          description: 'Compile host-reviewed ClaimGate graph patch proposals into concrete graph operations without applying them.',
+          reversible: true,
+        },
+        status: ok ? 'applied' : 'skipped',
+        timestamp: new Date().toISOString(),
