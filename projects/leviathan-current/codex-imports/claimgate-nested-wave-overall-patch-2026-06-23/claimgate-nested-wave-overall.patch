+    evalResults: [
+      {
+        id: 'eval-claim-gate-graph-patch-apply-plan',
+        strategy: 'gate-based',
+        timestamp: new Date().toISOString(),
+        passed: ok,
+        reasoning: ok
+          ? 'Host-reviewed ClaimGate graph patch compiled to concrete GraphOperation[] for the graph:patch compositor surface.'
+          : 'ClaimGate graph patch apply plan blocked before graph compositor handoff.',
+        metadata: {
+          sourceReceiptId,
