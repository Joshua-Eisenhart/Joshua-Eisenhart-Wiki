+import { mkdirSync, rmSync } from 'node:fs';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+
+import { describe, expect, it } from 'vitest';
+
+import { handler } from './claimgate-steering.js';
+
+function makeTempDir(name: string): string {
+  const dir = join(tmpdir(), `lev-cg-handler-${name}-${Date.now()}-${Math.random().toString(16).slice(2)}`);
+  mkdirSync(dir, { recursive: true });
+  return dir;
+}
+
+describe('claimgate-steering handler — batch fail-closed', () => {
+  it('fails closed when batch discovers zero runs (no fail-open host_consumed)', async () => {
+    const empty = makeTempDir('empty');
+    try {
+      const result = await handler(['batch', empty, '--no-write', '--json']);
+
+      expect(result.success).toBe(false);
+      expect(result.error_code).toBe('CLAIMGATE_STEERING_BATCH_EMPTY');
+      expect(result.formatted_response).toContain('no_runs_found');
+    } finally {
+      rmSync(empty, { recursive: true, force: true });
+    }
+  });
+
+  it('still reports success for a non-empty, all-consumed batch root', async () => {
+    // The good fixture dir is itself a single discoverable run; --no-write keeps
+    // the committed fixture clean (no per-run receipts, no requeue ledger).
+    const result = await handler([
+      'batch',
+      'test-fixtures/claimgate-steering/good',
+      '--no-write',
+      '--json',
+    ]);
+
+    expect(result.success).toBe(true);
+    expect(result.error_code).toBeUndefined();
+  });
+});
