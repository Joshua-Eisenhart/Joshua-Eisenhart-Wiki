+name: cdo-openrouter-sparse
+entry: research_wave
+
+knobs:
+  task:
+    type: string
+    default: "Assess the target problem and produce a gate-bound final decision."
+
+nodes:
+  research_wave:
+    targets: [research_glm, research_deepseek, research_kimi]
+    concurrency: 3
+    failure_mode: majority
+    sync_mode: majority_complete
+    diversity_lens: source_and_runtime_scan
+    output: research_wave_result
+    next: constraint_wave
+
+  constraint_wave:
+    targets: [constraint_qwen, gate_minimax]
+    concurrency: 2
+    failure_mode: all
+    sync_mode: wait_for_all
+    diversity_lens: axiom_constraint_gate
+    output: constraint_wave_result
+    next: skeptic_wave
+
+  skeptic_wave:
+    targets: [skeptic_glm, skeptic_deepseek]
+    concurrency: 2
+    failure_mode: majority
+    sync_mode: majority_complete
+    diversity_lens: premortem_and_loophole
+    output: skeptic_wave_result
+    next: synth_wave
+
+  synth_wave:
+    targets: [synth_qwen]
+    concurrency: 1
+    failure_mode: all
+    sync_mode: wait_for_all
+    diversity_lens: synthesis
+    output: synth_wave_result
+    next: integrate_wave
+
+  integrate_wave:
+    targets: [integrator_status, integrator_report]
+    concurrency: 2
+    failure_mode: all
+    sync_mode: wait_for_all
+    diversity_lens: integration
+    output: integrate_wave_result
+    next: replay_gate
+
+  replay_gate:
+    eval: integrate_wave_result.integrator_status === 'INCONCLUSIVE'
+    branches:
+      yes: replay_wave
+      no: done
+
+  replay_wave:
+    targets: [constraint_qwen, skeptic_deepseek, synth_qwen]
+    concurrency: 3
+    failure_mode: all
+    sync_mode: wait_for_all
+    diversity_lens: contested_cluster_replay
+    output: replay_wave_result
+    next: post_replay_wave
+
+  post_replay_wave:
+    targets: [integrator_status, integrator_report]
+    concurrency: 2
+    failure_mode: all
+    sync_mode: wait_for_all
+    diversity_lens: replay_resolution
+    output: post_replay_wave_result
+    next: done
+
+  done:
+    terminal: true
+    description: Sparse OpenRouter CDO council finished.
+
+  research_glm:
+    prompt: "Role: source/runtime researcher. Task: {{knobs.task}}. Return four bullets only: repo facts, useful branch, risk, next gate."
+    output: research_glm_output
+    inputs:
+      adapter: ai-sdk
+      model: z-ai/glm-5.2
+
+  research_deepseek:
+    prompt: "Role: implementation researcher. Task: {{knobs.task}}. Return four bullets only: likely code seam, useful branch, risk, next gate."
+    output: research_deepseek_output
+    inputs:
+      adapter: ai-sdk
+      model: deepseek/deepseek-v4-pro
+
+  research_kimi:
+    prompt: "Role: code-path scout. Task: {{knobs.task}}. Return four bullets only: likely files, useful branch, risk, next gate."
+    output: research_kimi_output
+    inputs:
+      adapter: ai-sdk
+      model: moonshotai/kimi-k2.7-code
+
+  constraint_qwen:
+    prompt: "Role: axiom/constraint digger. Task: {{knobs.task}}. Extract two candidate constraints and one deterministic gate that could reject bad work."
+    output: constraint_qwen_output
+    inputs:
+      adapter: ai-sdk
+      model: qwen/qwen3.7-max
+
+  gate_minimax:
+    prompt: "Role: gate designer. Task: {{knobs.task}}. Propose one hard gate with evidence refs required, one falsifier, and one stop condition."
+    output: gate_minimax_output
+    inputs:
+      adapter: ai-sdk
+      model: minimax/minimax-m3
+
+  skeptic_glm:
+    prompt: "Role: premortem skeptic. Task: {{knobs.task}}. Assume the plan failed. Give exactly three concrete failure modes and their early warning signals."
+    output: skeptic_glm_output
+    inputs:
+      adapter: ai-sdk
+      model: z-ai/glm-5.2
+
+  skeptic_deepseek:
+    prompt: "Role: loophole auditor. Task: {{knobs.task}}. Find exactly three ways the council could fake progress without passing deterministic gates."
+    output: skeptic_deepseek_output
+    inputs:
+      adapter: ai-sdk
+      model: deepseek/deepseek-v4-pro
+
+  synth_qwen:
+    prompt: "Role: synthesis. Task: {{knobs.task}}. Produce headings only: Decision/Answer, Confidence, Key Tensions, Minority Reports, Action Items."
+    output: synth_qwen_output
+    inputs:
+      adapter: ai-sdk
+      model: qwen/qwen3.7-max
+
+  integrator_status:
+    prompt: "Role: integrator status. Task: {{knobs.task}}. Decide if the council is COMPLETE or INCONCLUSIVE. Reply with exactly one token: COMPLETE or INCONCLUSIVE."
+    output: integration_status
+    inputs:
+      adapter: ai-sdk
+      model: z-ai/glm-5.2
+
+  integrator_report:
+    prompt: "Role: integrator report. Task: {{knobs.task}}. Produce the final artifact with headings only: Decision/Answer, Confidence, Key Tensions, Minority Reports, Action Items."
+    output: integration_report
+    inputs:
+      adapter: ai-sdk
+      model: deepseek/deepseek-v4-pro
