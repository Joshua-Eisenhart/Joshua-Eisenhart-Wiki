+
+function validateGraphPatchApplyPlanInputs(
+  result: ClaimGateLoopResult,
+  admission: ClaimGateGraphPatchAdmission,
+): ClaimGateGraphPatchApplyFinding[] {
+  const findings: ClaimGateGraphPatchApplyFinding[] = [];
+  const proposal = result.graphPatchProposal;
+
+  if (admission.kind !== 'ClaimGateGraphPatchAdmission') {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.invalid_admission_kind',
+      'Admission artifact kind must be ClaimGateGraphPatchAdmission.',
+    );
+  }
+
+  if (admission.sourceReceiptId !== result.receipt.id) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.source_receipt_mismatch',
+      'Admission sourceReceiptId must match the ClaimGate loop result receipt.',
+    );
+  }
+
+  if (!admission.ok || admission.status !== 'host_reviewed') {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.admission_not_host_reviewed',
+      'Graph patch admission must be ok and host_reviewed before an apply plan can be emitted.',
+    );
+  }
+
+  if (admission.graphMutationApplied !== false) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.source_already_marked_applied',
+      'ClaimGate apply planning requires admission.graphMutationApplied:false; graph mutations are performed by the graph compositor surface.',
+    );
+  }
+
+  if (admission.claimCeiling !== 'graph_patch_proposal_only_requires_separate_apply_gate') {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.unexpected_admission_ceiling',
+      'Admission claim ceiling must preserve the separate apply-gate boundary.',
+    );
+  }
+
+  if (!result.receipt.evalResults.every((evalResult) => evalResult.passed)) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.source_receipt_failed_eval',
+      'The ClaimGate loop result receipt must have all eval results passing before apply planning.',
+    );
+  }
+
+  if (!receiptContentHashMatches(result.receipt, loopReceiptPayload(result))) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.source_receipt_hash_mismatch',
+      'The ClaimGate loop receipt contentHash must match the current source result before apply planning.',
+    );
+  }
+
+  if (!admission.receipt.evalResults.every((evalResult) => evalResult.passed)) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.admission_receipt_failed_eval',
+      'The graph patch admission receipt must have all eval results passing before apply planning.',
+    );
+  }
+
+  if (!receiptContentHashMatches(admission.receipt, graphPatchAdmissionReceiptPayload(result, admission))) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.admission_receipt_hash_mismatch',
+      'The graph patch admission receipt contentHash must match the current admission artifact and source proposal before apply planning.',
+    );
+  }
+
+  const accepted = proposal.acceptedClaimIds;
+  const withheld = proposal.withheldClaimIds;
+  const operations = proposal.operations;
+  const operationClaimIds = operations.map((operation) => operation.claimId);
+
+  if (stableStringify(admission.acceptedClaimIds) !== stableStringify(accepted)) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.accepted_claims_mismatch',
+      'Admission acceptedClaimIds must match the source graph patch proposal.',
+    );
+  }
+
+  if (stableStringify(admission.withheldClaimIds) !== stableStringify(withheld)) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.withheld_claims_mismatch',
+      'Admission withheldClaimIds must match the source graph patch proposal.',
+    );
+  }
+
+  if (admission.admittedOperationCount !== operations.length) {
+    addGraphApplyFinding(
+      findings,
+      'graph_apply.operation_count_mismatch',
+      'Admission admittedOperationCount must match source proposal operation count.',
+    );
+  }
+
+  const acceptedSet = new Set(accepted);
+  const withheldSet = new Set(withheld);
+  for (const claimId of operationClaimIds) {
+    if (!acceptedSet.has(claimId)) {
+      addGraphApplyFinding(
+        findings,
+        'graph_apply.operation_without_accepted_claim',
+        'Only accepted claims may compile into graph operations.',
+        claimId,
+      );
+    }
+    if (withheldSet.has(claimId)) {
+      addGraphApplyFinding(
+        findings,
+        'graph_apply.withheld_claim_operation_leak',
+        'Withheld claims must not compile into graph operations.',
+        claimId,
+      );
+    }
+  }
+
+  return findings;
+}
+
+function compileGraphPatchOperations({
+  result,
+  admission,
+}: {
+  result: ClaimGateLoopResult;
+  admission: ClaimGateGraphPatchAdmission;
+}): ClaimGateCompiledGraphOperation[] {
+  const timestamp = new Date().toISOString();
+  const sessionId = safeGraphIdComponent(result.receipt.sessionId);
+  return result.graphPatchProposal.operations.flatMap((operation) => {
+    const claimId = safeGraphIdComponent(operation.claimId);
+    const entityId = `claim-gate:${sessionId}:${claimId}`;
+    const evidenceRefs = [
+      `receipt:${result.receipt.id}`,
+      `receipt:${admission.receipt.id}`,
+      `claim:${operation.claimId}`,
+    ];
+    return [
+      {
+        type: 'upsert_entity' as const,
+        timestamp,
+        source: 'claim-gate-loop' as const,
+        entity_id: entityId,
+        payload: {
+          id: entityId,
+          type: 'proposal',
+          source: 'claim-gate-loop',
+          via: 'claim-gate.graph-patch-apply-plan',
+          depth: 'L1',
+          lifecycle_state: 'crystallizing',
+          last_classified: timestamp,
+          decay_rate: 0,
+          claims: [],
+          links: [],
+        },
+      },
+      {
+        type: 'add_claim' as const,
+        timestamp,
+        source: 'claim-gate-loop' as const,
+        entity_id: entityId,
+        payload: {
+          id: `claim:${entityId}:payload`,
+          kind: 'assertion',
+          subject: entityId,
+          predicate: 'has_claim_payload',
+          object: operation.payload,
+          truth_state: 'accepted',
+          evidence_refs: evidenceRefs,
+          created_at: timestamp,
+        },
+      },
+    ];
+  });
+}
