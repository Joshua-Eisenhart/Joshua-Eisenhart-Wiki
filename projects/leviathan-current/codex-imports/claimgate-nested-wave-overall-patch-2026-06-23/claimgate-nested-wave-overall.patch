+
+    expect(admission.ok).toBe(false);
+    expect(applyPlan.ok).toBe(false);
+    expect(applyPlan.status).toBe('apply_blocked');
+    expect(applyPlan.operationCount).toBe(0);
+    expect(applyPlan.findings.map((finding) => finding.code)).toContain('graph_apply.admission_not_host_reviewed');
+    expect(applyPlan.findings.map((finding) => finding.code)).toContain('graph_apply.admission_receipt_failed_eval');
+  });
+
+  it('blocks apply plans when admission operation counts drift from the source proposal', () => {
+    const result = runClaimGateLoopFixture({ sessionId: 'claim-gate-apply-count-drift' });
