+  'council',
+  'workflow',
+  'gate_loop',
+  'autoresearch',
+  'premortem',
+]);
+
+function addViolation(
+  violations: ClaimGateCouncilWaveInputViolation[],
+  path: string,
+  code: string,
+  message: string,
+): void {
+  violations.push({ path, code, message });
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function byteLength(value: string): number {
+  return Buffer.byteLength(value, 'utf8');
+}
+
+function validateOptionalBoundedString(
+  value: unknown,
+  path: string,
+  maxBytes: number,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (value === undefined) return;
+  if (typeof value !== 'string') {
+    addViolation(violations, path, 'expected_string', `${path} must be a string when supplied.`);
+    return;
+  }
+  if (byteLength(value) > maxBytes) {
+    addViolation(violations, path, 'string_too_large', `${path} exceeds ${maxBytes} bytes.`);
+  }
+}
+
+function validateRequiredBoundedString(
+  value: unknown,
+  path: string,
+  maxBytes: number,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (typeof value !== 'string' || value.trim().length === 0) {
+    addViolation(violations, path, 'expected_nonempty_string', `${path} must be a non-empty string.`);
+    return;
+  }
+  if (byteLength(value) > maxBytes) {
+    addViolation(violations, path, 'string_too_large', `${path} exceeds ${maxBytes} bytes.`);
+  }
+}
+
+function validateRequiredBoundedStringWithCode(
+  value: unknown,
+  path: string,
+  maxBytes: number,
+  missingCode: string,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (typeof value !== 'string' || value.trim().length === 0) {
+    addViolation(violations, path, missingCode, `${path} must be a non-empty string.`);
+    return;
+  }
+  if (byteLength(value) > maxBytes) {
+    addViolation(violations, path, 'string_too_large', `${path} exceeds ${maxBytes} bytes.`);
+  }
+}
+
+function validateOptionalStringArray(
+  value: unknown,
+  path: string,
+  maxItems: number,
+  maxBytes: number,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (value === undefined) return;
+  if (!Array.isArray(value)) {
+    addViolation(violations, path, 'expected_string_array', `${path} must be a string array when supplied.`);
+    return;
+  }
+  if (value.length > maxItems) {
+    addViolation(violations, path, 'array_too_large', `${path} may contain at most ${maxItems} items.`);
+  }
+  value.forEach((item, index) => {
+    validateRequiredBoundedString(item, `${path}[${index}]`, maxBytes, violations);
+  });
+}
+
+function validateRequiredStringArray(
+  value: unknown,
+  path: string,
+  maxItems: number,
+  maxBytes: number,
+  missingCode: string,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (!Array.isArray(value) || value.length === 0) {
+    addViolation(violations, path, missingCode, `${path} must be a non-empty string array.`);
+    return;
+  }
+  if (value.length > maxItems) {
+    addViolation(violations, path, 'array_too_large', `${path} may contain at most ${maxItems} items.`);
+  }
+  value.forEach((item, index) => {
+    validateRequiredBoundedString(item, `${path}[${index}]`, maxBytes, violations);
+  });
+}
+
+function validatePositiveInteger(
+  value: unknown,
+  path: string,
+  maxValue: number,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (!Number.isInteger(value) || Number(value) <= 0) {
+    addViolation(violations, path, 'expected_positive_integer', `${path} must be a positive integer.`);
+    return;
+  }
+  if (Number(value) > maxValue) {
+    addViolation(violations, path, 'integer_too_large', `${path} must be <= ${maxValue}.`);
+  }
+}
+
+function validateRequiredWaveContract(
+  value: unknown,
+  path: string,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (value === undefined) {
+    addViolation(violations, path, 'missing_wave_contract', `${path} is required.`);
+    return;
+  }
+  if (!isRecord(value)) {
+    addViolation(violations, path, 'expected_wave_contract_object', `${path} must be an object.`);
+    return;
+  }
+
+  for (const field of [
+    'owner',
+    'producerKind',
+    'expectedVerifier',
+    'requeueRule',
+    'nextAdmissibleState',
+    'claimCeiling',
+  ]) {
+    validateRequiredBoundedString(
+      value[field],
+      `${path}.${field}`,
+      MAX_COUNCIL_CONTRACT_FIELD_BYTES,
+      violations,
+    );
+  }
+}
+
+function validateRequiredCognitiveBinding(
+  value: unknown,
+  path: string,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (value === undefined) {
+    addViolation(violations, path, 'missing_cognitive_binding', `${path} is required for every declared council-wave member.`);
+    return;
+  }
+  if (!isRecord(value)) {
+    addViolation(violations, path, 'expected_cognitive_binding_object', `${path} must be an object.`);
+    return;
+  }
+
+  validateRequiredStringArray(
+    value.mmmRefs,
+    `${path}.mmmRefs`,
+    MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+    MAX_COUNCIL_ID_BYTES,
+    'missing_mmm_refs',
+    violations,
+  );
+  validateRequiredStringArray(
+    value.skillRefs,
+    `${path}.skillRefs`,
+    MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+    MAX_COUNCIL_ID_BYTES,
+    'missing_skill_refs',
+    violations,
+  );
+  validateRequiredStringArray(
+    value.sourceRefs,
+    `${path}.sourceRefs`,
+    MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+    MAX_COUNCIL_ID_BYTES,
+    'missing_source_refs',
+    violations,
+  );
+  validateRequiredStringArray(
+    value.inputContractRefs,
+    `${path}.inputContractRefs`,
+    MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+    MAX_COUNCIL_CONTRACT_FIELD_BYTES,
+    'missing_input_contract_refs',
+    violations,
+  );
+  validateRequiredStringArray(
+    value.outputContractRefs,
+    `${path}.outputContractRefs`,
+    MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+    MAX_COUNCIL_CONTRACT_FIELD_BYTES,
+    'missing_output_contract_refs',
+    violations,
+  );
+  validateRequiredStringArray(
+    value.gateContractRefs,
+    `${path}.gateContractRefs`,
+    MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+    MAX_COUNCIL_CONTRACT_FIELD_BYTES,
+    'missing_gate_contract_refs',
+    violations,
+  );
+  validateRequiredBoundedStringWithCode(
+    value.requeuePolicyRef,
+    `${path}.requeuePolicyRef`,
+    MAX_COUNCIL_CONTRACT_FIELD_BYTES,
+    'missing_requeue_policy_ref',
+    violations,
+  );
+}
+
+function validateOptionalWaveMembers(
+  value: unknown,
+  path: string,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): Set<string> {
+  const memberIds = new Set<string>();
+  const parentRefs: Array<{ path: string; parentMemberId: string }> = [];
+
+  if (value === undefined) return memberIds;
+  if (!Array.isArray(value)) {
+    addViolation(violations, path, 'expected_member_array', `${path} must be an array when supplied.`);
+    return memberIds;
+  }
+  if (value.length > MAX_COUNCIL_MEMBERS_PER_WAVE) {
+    addViolation(violations, path, 'array_too_large', `${path} may contain at most ${MAX_COUNCIL_MEMBERS_PER_WAVE} items.`);
+  }
+
+  value.forEach((member, index) => {
+    const memberPath = `${path}[${index}]`;
+    if (!isRecord(member)) {
+      addViolation(violations, memberPath, 'expected_member_object', `${memberPath} must be an object.`);
+      return;
+    }
+    validateRequiredBoundedString(member.memberId, `${memberPath}.memberId`, MAX_COUNCIL_ID_BYTES, violations);
+    if (typeof member.memberId === 'string' && member.memberId.trim().length > 0) {
+      if (memberIds.has(member.memberId)) {
+        addViolation(violations, `${memberPath}.memberId`, 'duplicate_member_id', `${memberPath}.memberId must be unique within the wave.`);
+      }
+      memberIds.add(member.memberId);
+    }
+    if (typeof member.kind !== 'string' || !VALID_COUNCIL_MEMBER_KINDS.has(member.kind as ClaimGateCouncilWaveMemberKind)) {
+      addViolation(
+        violations,
+        `${memberPath}.kind`,
+        'invalid_member_kind',
+        `${memberPath}.kind must be one of ${Array.from(VALID_COUNCIL_MEMBER_KINDS).join(', ')}.`,
+      );
+    }
+    validateRequiredBoundedString(member.role, `${memberPath}.role`, MAX_COUNCIL_ROLE_BYTES, violations);
+    validateOptionalBoundedString(member.producer, `${memberPath}.producer`, MAX_COUNCIL_PRODUCER_BYTES, violations);
+    validateOptionalBoundedString(member.parentMemberId, `${memberPath}.parentMemberId`, MAX_COUNCIL_ID_BYTES, violations);
+    if (typeof member.parentMemberId === 'string' && member.parentMemberId.trim().length > 0) {
+      parentRefs.push({ path: `${memberPath}.parentMemberId`, parentMemberId: member.parentMemberId });
+    }
+    validateOptionalStringArray(
+      member.skillRefs,
+      `${memberPath}.skillRefs`,
+      MAX_COUNCIL_SKILL_REFS_PER_MEMBER,
+      MAX_COUNCIL_ID_BYTES,
+      violations,
+    );
+    validateRequiredCognitiveBinding(member.cognitiveBinding, `${memberPath}.cognitiveBinding`, violations);
+  });
+
+  for (const ref of parentRefs) {
+    if (!memberIds.has(ref.parentMemberId)) {
+      addViolation(
+        violations,
+        ref.path,
+        'unknown_parent_member',
+        `${ref.path} must reference another memberId in the same wave.`,
+      );
+    }
+  }
+
+  return memberIds;
+}
+
+function validateOptionalRepairBinding(
+  value: unknown,
+  path: string,
+  violations: ClaimGateCouncilWaveInputViolation[],
+): void {
+  if (value === undefined) return;
+  if (!isRecord(value)) {
+    addViolation(violations, path, 'expected_repair_binding_object', `${path} must be an object when supplied.`);
+    return;
+  }
+  validateRequiredBoundedString(
+    value.failurePacketId,
+    `${path}.failurePacketId`,
+    MAX_COUNCIL_ID_BYTES,
+    violations,
+  );
+  validateOptionalBoundedString(value.sourceClaimId, `${path}.sourceClaimId`, MAX_COUNCIL_ID_BYTES, violations);
+  validateOptionalBoundedString(value.parentReceiptId, `${path}.parentReceiptId`, MAX_COUNCIL_ID_BYTES, violations);
+}
+
+function councilFailurePacketId(claimId: string, wave: number): string {
+  return `fp-${claimId}-w${wave}`;
+}
+
+export function validateClaimGateCouncilWaveInput(
+  value: unknown,
+  options: ValidateClaimGateCouncilWaveInputOptions = {},
+): ClaimGateCouncilWaveInput {
+  const violations: ClaimGateCouncilWaveInputViolation[] = [];
+
+  if (!isRecord(value)) {
+    throw new ClaimGateCouncilWaveInputError([
+      {
+        path: '$',
+        code: 'expected_object',
+        message: 'ClaimGate council-wave input must be a JSON object.',
+      },
+    ]);
+  }
+
+  if (value.kind !== undefined && value.kind !== 'ClaimGateCouncilWaveInput') {
+    addViolation(violations, 'kind', 'invalid_kind', 'kind must be ClaimGateCouncilWaveInput when supplied.');
+  }
+  validateOptionalBoundedString(value.sessionId, 'sessionId', MAX_COUNCIL_ID_BYTES, violations);
+  validateOptionalBoundedString(value.workstreamId, 'workstreamId', MAX_COUNCIL_ID_BYTES, violations);
+  if (value.maxWaves !== undefined) {
+    validatePositiveInteger(value.maxWaves, 'maxWaves', MAX_COUNCIL_WAVES, violations);
+  }
+  validateOptionalStringArray(
+    value.requiredGateIds,
+    'requiredGateIds',
+    MAX_COUNCIL_GATE_CHECKS_PER_CLAIM,
+    MAX_COUNCIL_ID_BYTES,
+    violations,
+  );
+
+  if (!Array.isArray(value.waves)) {
+    addViolation(violations, 'waves', 'expected_wave_array', 'waves must be an array.');
+  } else {
+    if (value.waves.length === 0) {
+      addViolation(violations, 'waves', 'empty_wave_array', 'waves must contain at least one wave.');
+    }
+    if (value.waves.length > MAX_COUNCIL_WAVES) {
+      addViolation(violations, 'waves', 'array_too_large', `waves may contain at most ${MAX_COUNCIL_WAVES} items.`);
+    }
+
+    let previousWaveNumber = 0;
+    const lastWaveByClaimId = new Map<string, number>();
+    value.waves.forEach((wave, waveIndex) => {
+      const wavePath = `waves[${waveIndex}]`;
+      if (!isRecord(wave)) {
+        addViolation(violations, wavePath, 'expected_wave_object', `${wavePath} must be an object.`);
+        return;
+      }
+      validatePositiveInteger(wave.wave, `${wavePath}.wave`, MAX_COUNCIL_WAVES, violations);
+      if (Number.isInteger(wave.wave) && Number(wave.wave) > 0) {
+        const waveNumber = Number(wave.wave);
+        if (waveNumber <= previousWaveNumber) {
+          addViolation(
+            violations,
+            `${wavePath}.wave`,
+            'wave_order_not_strictly_increasing',
+            'waves must be supplied in strictly increasing wave order.',
+          );
+        }
+        previousWaveNumber = waveNumber;
+      }
+      validateRequiredWaveContract(wave.contract, `${wavePath}.contract`, violations);
+      const memberIds = validateOptionalWaveMembers(wave.members, `${wavePath}.members`, violations);
+      if (!Array.isArray(wave.claims)) {
+        addViolation(violations, `${wavePath}.claims`, 'expected_claim_array', `${wavePath}.claims must be an array.`);
+        return;
+      }
+      if (wave.claims.length > MAX_COUNCIL_CLAIMS_PER_WAVE) {
+        addViolation(
+          violations,
+          `${wavePath}.claims`,
+          'array_too_large',
+          `${wavePath}.claims may contain at most ${MAX_COUNCIL_CLAIMS_PER_WAVE} items.`,
+        );
+      }
+
+      wave.claims.forEach((claim, claimIndex) => {
+        const claimPath = `${wavePath}.claims[${claimIndex}]`;
+        if (!isRecord(claim)) {
+          addViolation(violations, claimPath, 'expected_claim_object', `${claimPath} must be an object.`);
+          return;
+        }
+        validateRequiredBoundedString(claim.claimId, `${claimPath}.claimId`, MAX_COUNCIL_ID_BYTES, violations);
+        validateRequiredBoundedString(claim.payload, `${claimPath}.payload`, MAX_COUNCIL_PAYLOAD_BYTES, violations);
+        validateOptionalBoundedString(claim.producer, `${claimPath}.producer`, MAX_COUNCIL_PRODUCER_BYTES, violations);
+        validateOptionalBoundedString(claim.memberId, `${claimPath}.memberId`, MAX_COUNCIL_ID_BYTES, violations);
+        if (memberIds.size > 0) {
+          if (typeof claim.memberId !== 'string' || claim.memberId.trim().length === 0) {
+            addViolation(
+              violations,
+              `${claimPath}.memberId`,
+              'missing_claim_member_id',
+              `${claimPath}.memberId is required when the wave declares members.`,
+            );
+          } else if (!memberIds.has(claim.memberId)) {
+            addViolation(
+              violations,
+              `${claimPath}.memberId`,
+              'unknown_claim_member_id',
+              `${claimPath}.memberId must reference a memberId in the same wave.`,
+            );
+          }
+        }
+        validateOptionalRepairBinding(claim.repairOf, `${claimPath}.repairOf`, violations);
+
+        if (typeof claim.claimId === 'string' && claim.claimId.trim().length > 0 && Number.isInteger(wave.wave)) {
+          const claimId = claim.claimId;
+          const previousWave = lastWaveByClaimId.get(claimId);
+          const repairOf = isRecord(claim.repairOf) ? claim.repairOf : undefined;
+          if (previousWave === undefined && repairOf !== undefined) {
+            if (options.allowExternalRepairLineage) {
+              if (typeof repairOf.parentReceiptId !== 'string' || repairOf.parentReceiptId.trim().length === 0) {
+                addViolation(
+                  violations,
+                  `${claimPath}.repairOf.parentReceiptId`,
+                  'missing_external_parent_receipt',
+                  'External repair lineage must include repairOf.parentReceiptId.',
+                );
+              }
+            } else {
+              addViolation(
+                violations,
+                `${claimPath}.repairOf`,
+                'unmatched_repair_lineage',
+                'repairOf may only be supplied after an earlier wave emitted the same claimId.',
+              );
+            }
+          }
+          if (previousWave !== undefined && repairOf === undefined) {
+            addViolation(
+              violations,
+              `${claimPath}.repairOf`,
+              'missing_repair_lineage',
+              'Repeated claimIds are repair attempts and must bind repairOf.failurePacketId to the prior failure packet.',
+            );
+          }
+          if (previousWave !== undefined && repairOf !== undefined) {
+            const expectedPacketId = councilFailurePacketId(claimId, previousWave);
+            if (repairOf.failurePacketId !== expectedPacketId) {
+              addViolation(
+                violations,
+                `${claimPath}.repairOf.failurePacketId`,
+                'repair_lineage_packet_mismatch',
+                `${claimPath}.repairOf.failurePacketId must equal ${expectedPacketId}.`,
+              );
+            }
+            if (repairOf.sourceClaimId !== undefined && repairOf.sourceClaimId !== claimId) {
+              addViolation(
+                violations,
+                `${claimPath}.repairOf.sourceClaimId`,
+                'repair_lineage_claim_mismatch',
+                `${claimPath}.repairOf.sourceClaimId must equal ${claimId}.`,
+              );
+            }
+          }
+          lastWaveByClaimId.set(claimId, Number(wave.wave));
+        }
+
+        if (!Array.isArray(claim.gateChecks)) {
+          addViolation(
+            violations,
+            `${claimPath}.gateChecks`,
+            'expected_gate_check_array',
+            `${claimPath}.gateChecks must be an array.`,
+          );
+          return;
+        }
+        if (claim.gateChecks.length > MAX_COUNCIL_GATE_CHECKS_PER_CLAIM) {
+          addViolation(
+            violations,
+            `${claimPath}.gateChecks`,
+            'array_too_large',
+            `${claimPath}.gateChecks may contain at most ${MAX_COUNCIL_GATE_CHECKS_PER_CLAIM} items.`,
+          );
+        }
+
+        claim.gateChecks.forEach((check, checkIndex) => {
+          const checkPath = `${claimPath}.gateChecks[${checkIndex}]`;
+          if (!isRecord(check)) {
+            addViolation(violations, checkPath, 'expected_gate_check_object', `${checkPath} must be an object.`);
+            return;
+          }
+          validateRequiredBoundedString(check.gateId, `${checkPath}.gateId`, MAX_COUNCIL_ID_BYTES, violations);
+          if (check.status !== 'pass' && check.status !== 'fail') {
+            addViolation(violations, `${checkPath}.status`, 'invalid_gate_status', `${checkPath}.status must be pass or fail.`);
+          }
+          if (check.severity !== undefined && check.severity !== 'blocker' && check.severity !== 'warning') {
+            addViolation(
+              violations,
+              `${checkPath}.severity`,
+              'invalid_gate_severity',
+              `${checkPath}.severity must be blocker or warning when supplied.`,
+            );
+          }
+          validateOptionalBoundedString(check.reason, `${checkPath}.reason`, MAX_COUNCIL_REASON_BYTES, violations);
+          validateOptionalStringArray(
+            check.evidenceRefs,
+            `${checkPath}.evidenceRefs`,
+            MAX_COUNCIL_EVIDENCE_REFS_PER_GATE,
+            MAX_COUNCIL_EVIDENCE_REF_BYTES,
+            violations,
+          );
+        });
+      });
+    });
+  }
+
+  if (violations.length > 0) {
+    throw new ClaimGateCouncilWaveInputError(violations);
+  }
+
+  return value as unknown as ClaimGateCouncilWaveInput;
+}
+
+function resolveRequiredGateIds(options: RunClaimGateCouncilWaveLoopOptions): string[] {
+  if (!options.requiredGateIds?.length) return DEFAULT_REQUIRED_COUNCIL_GATES;
+
+  const requiredGateIds = Array.from(new Set(options.requiredGateIds));
+  const missingDefaults = DEFAULT_REQUIRED_COUNCIL_GATES.filter((gateId) => !requiredGateIds.includes(gateId));
+  if (missingDefaults.length > 0) {
+    throw new ClaimGateCouncilWaveInputError([
+      {
+        path: 'options.requiredGateIds',
+        code: 'reduced_required_gate_set',
+        message: `requiredGateIds may add gates but must include the default hard gates: ${missingDefaults.join(', ')}.`,
+      },
+    ]);
+  }
+
+  return requiredGateIds;
+}
+
+function stableStringify(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? 'null';
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`).join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(stableStringify(value)).digest('hex')}`;
+}
+
+function sha256Buffer(value: Buffer): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function filePathFromEvidenceRef(ref: string): string | null {
+  if (!ref.startsWith('file:')) return null;
+  const path = ref.slice('file:'.length);
+  return path.length > 0 ? path : null;
+}
+
+function fileEvidenceFindings(
+  gateId: string,
+  evidenceRefs: string[],
+): ClaimGateCouncilGateFinding[] {
+  const findings: ClaimGateCouncilGateFinding[] = [];
+  const expectedHashes = new Set(evidenceRefs.filter((ref) => ref.startsWith('sha256:')));
+  const fileRefs = evidenceRefs.filter((ref) => ref.startsWith('file:'));
+
+  for (const ref of fileRefs) {
+    const filePath = filePathFromEvidenceRef(ref);
+    if (!filePath) {
+      findings.push({
+        gateId,
+        status: 'failed',
+        reason: `File evidence ref ${ref} does not contain a file path.`,
+        evidenceRefs: [ref],
+      });
+      continue;
+    }
+
+    let hash: string;
+    try {
+      if (!statSync(filePath).isFile()) {
+        findings.push({
+          gateId,
+          status: 'failed',
+          reason: `File evidence ref ${ref} is not a regular file.`,
+          evidenceRefs: [ref],
+        });
+        continue;
+      }
+      hash = sha256Buffer(readFileSync(filePath));
+    } catch (error) {
+      findings.push({
+        gateId,
+        status: 'failed',
+        reason: `File evidence ref ${ref} could not be read or hashed: ${error instanceof Error ? error.message : String(error)}`,
+        evidenceRefs: [ref],
+      });
+      continue;
+    }
+
+    if (!expectedHashes.has(hash)) {
+      findings.push({
+        gateId,
+        status: 'failed',
+        reason: `File evidence ref ${ref} hash ${hash} was not bound by a matching sha256 evidence ref.`,
+        evidenceRefs: [ref, hash],
+      });
+    }
+  }
+
+  return findings;
+}
+
+function trustedEvidenceRefSet(refs: string[] | undefined): Set<string> {
+  return new Set((refs ?? []).filter((ref) => typeof ref === 'string' && ref.length > 0));
+}
+
+function isTrustedReceiptEvidenceRef(ref: string, trustedRefs: Set<string>): boolean {
+  return /^receipt:rcpt-[a-zA-Z0-9._:-]+$/.test(ref) && trustedRefs.has(ref);
+}
+
+function isTrustedGraphEventEvidenceRef(ref: string, trustedRefs: Set<string>): boolean {
+  return (
+    ref.startsWith('ge-')
+    || ref.startsWith('graph-event:ge-')
+    || ref.startsWith('graph_event:ge-')
+  ) && trustedRefs.has(ref);
+}
+
+function hasSourceBoundEvidenceRef(evidenceRefs: string[], trustedRefs: Set<string>): boolean {
+  return evidenceRefs.some((ref) => (
+    ref.startsWith('file:')
+    || isTrustedReceiptEvidenceRef(ref, trustedRefs)
+    || isTrustedGraphEventEvidenceRef(ref, trustedRefs)
+  ));
+}
+
+function sourceBoundEvidenceFindings(
+  gateId: string,
+  evidenceRefs: string[],
+  trustedRefs: Set<string>,
+): ClaimGateCouncilGateFinding[] {
+  if (!SOURCE_BOUND_REQUIRED_GATE_IDS.has(gateId)) return [];
+  if (hasSourceBoundEvidenceRef(evidenceRefs, trustedRefs)) return [];
+  return [
+    {
+      gateId,
+      status: 'failed',
+      reason: `Required gate ${gateId} passed without a source-bound evidence ref. Use a hash-bound file: ref or a host-trusted receipt/event ref supplied by trustedEvidenceRefs.`,
+      evidenceRefs: evidenceRefs.length ? evidenceRefs : [`gate:${gateId}`],
+    },
+  ];
+}
+
+function passesFixtureGate(claim: ClaimGateLoopClaim, wave: number): boolean {
+  return claim.passOnWave !== null && wave >= claim.passOnWave;
+}
+
+function makeFailurePacket(
+  claim: ClaimGateLoopClaim,
+  wave: number,
+  maxWaves: number,
+  terminal: boolean,
+): ClaimGateFailurePacket {
+  const packetId = councilFailurePacketId(claim.claimId, wave);
+  const remainingWaves = Math.max(0, maxWaves - wave);
+  return {
+    packetId,
+    claimId: claim.claimId,
+    wave,
+    violatedGate: 'fixture_truth_gate',
+    violatedGates: ['fixture_truth_gate'],
+    evidenceRefs: [`claim:${claim.claimId}`, `wave:${wave}`, `gate:fixture_truth_gate`],
+    falsifier: `Claim ${claim.claimId} must satisfy fixture_truth_gate on wave ${wave}.`,
+    repairKinds: ['claim_delta_repair'],
+    retryPatch: terminal
+      ? null
+      : {
+          nextWave: wave + 1,
+          instruction: `Requeue ${claim.claimId} with failure packet ${packetId}.`,
+        },
+    owner: 'claim-gate-loop-fixture',
+    budget: { remainingWaves },
+    ...(terminal ? { graveyardReason: 'max_passes_exceeded' as const } : {}),
+  };
+}
+
+function buildGraphPatchProposal(
+  claims: Array<{ claimId: string; payload: string }>,
+  accepted: Set<string>,
+  terminal: Set<string>,
+): ClaimGateGraphPatchProposal {
+  const byId = new Map(claims.map((claim) => [claim.claimId, claim]));
+  const acceptedClaimIds = claims.map((claim) => claim.claimId).filter((claimId) => accepted.has(claimId));
+  const withheldClaimIds = claims.map((claim) => claim.claimId).filter((claimId) => terminal.has(claimId));
+  return {
+    kind: 'ClaimGateGraphPatchProposal',
+    acceptedClaimIds,
+    withheldClaimIds,
+    operations: acceptedClaimIds.map((claimId) => ({
+      op: 'add_claim',
+      claimId,
+      payload: byId.get(claimId)?.payload ?? '',
+    })),
+  };
+}
