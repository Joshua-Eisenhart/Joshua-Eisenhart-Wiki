index 000000000..ed775d2d2
--- /dev/null
+++ b/core/orchestration/src/proof/claim-gate-model-lane-runners.ts
@@ -0,0 +1,266 @@
+import { createHash } from 'node:crypto';
+
+import type {
+  ClaimGateModelLaneManifest,
+  ClaimGateModelLaneRunner,
+  ClaimGateModelLaneRunnerMap,
+  ClaimGateModelLaneRunnerOutput,
+} from './claim-gate-wavegraph-slice.js';
+
+export interface ClaimGateProcessRunnerRequest {
+  lane: ClaimGateModelLaneManifest;
+  model: string;
+  prompt: string;
+  timeoutMs: number;
+  signal: AbortSignal;
+}
+
+export interface ClaimGateProcessRunnerResult {
+  stdout?: string;
+  stderr?: string;
+  exitCode?: number;
+  elapsedMs?: number;
+  costUsd?: number;
+}
+
+export interface ClaimGateHttpModelMessage {
+  role: 'user';
+  content: string;
+}
+
+export interface ClaimGateHttpModelRequestBody {
+  model: string;
+  messages: ClaimGateHttpModelMessage[];
+  temperature: number;
+  max_tokens: number;
+  response_format?: { type: 'json_object' };
+}
+
+export interface ClaimGateHttpJsonRequest {
+  lane: ClaimGateModelLaneManifest;
+  model: string;
+  prompt: string;
+  timeoutMs: number;
+  signal: AbortSignal;
+  body: ClaimGateHttpModelRequestBody;
+}
+
+export interface ClaimGateHttpJsonResult {
+  json: unknown;
+  elapsedMs?: number;
+}
+
+export interface ClaimGateClaudeBridgeRunnerOptions {
+  run: (request: ClaimGateProcessRunnerRequest) => Promise<ClaimGateProcessRunnerResult>;
+}
+
+export interface ClaimGateGoogleGeminiTuiRunnerOptions {
+  run: (request: ClaimGateProcessRunnerRequest) => Promise<ClaimGateProcessRunnerResult>;
+}
+
+export interface ClaimGateHttpModelRunnerOptions {
+  postJson: (request: ClaimGateHttpJsonRequest) => Promise<ClaimGateHttpJsonResult>;
+  maxTokens?: number;
+  temperature?: number;
+}
+
+export interface ClaimGateCodexLocalRunnerOptions {
+  run: (request: ClaimGateProcessRunnerRequest) => Promise<ClaimGateModelLaneRunnerOutput>;
+}
+
+export interface ClaimGateModelLaneRunnerMapOptions {
+  claudeBridge?: ClaimGateClaudeBridgeRunnerOptions;
+  openRouter?: ClaimGateHttpModelRunnerOptions;
+  xai?: ClaimGateHttpModelRunnerOptions;
+  googleGeminiTui?: ClaimGateGoogleGeminiTuiRunnerOptions;
+  codexLocal?: ClaimGateCodexLocalRunnerOptions;
+}
+
+function sha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(value)).digest('hex')}`;
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function stringField(record: Record<string, unknown> | undefined, key: string): string | undefined {
+  const value = record?.[key];
+  return typeof value === 'string' && value.trim().length > 0 ? value : undefined;
+}
+
+function numberField(record: Record<string, unknown> | undefined, key: string): number | undefined {
+  const value = record?.[key];
+  return typeof value === 'number' && Number.isFinite(value) ? value : undefined;
+}
+
+function parseJsonObject(text: string | undefined): Record<string, unknown> | undefined {
+  if (!text?.trim()) return undefined;
+  try {
+    const parsed = JSON.parse(text);
+    return isRecord(parsed) ? parsed : undefined;
+  } catch {
+    return undefined;
+  }
+}
+
+function normalizeProcessResult(result: ClaimGateProcessRunnerResult): ClaimGateModelLaneRunnerOutput {
+  const parsed = parseJsonObject(result.stdout);
+  const outputText = stringField(parsed, 'outputText')
+    ?? stringField(parsed, 'content')
+    ?? result.stdout?.trim()
+    ?? '';
+  const receiptRef = stringField(parsed, 'receiptRef');
+  const costUsd = numberField(parsed, 'costUsd') ?? result.costUsd;
+  const failed = result.exitCode !== undefined && result.exitCode !== 0;
+
+  return {
+    ...(outputText ? { outputText } : {}),
+    ...(receiptRef ? { receiptRef } : {}),
+    ...(result.elapsedMs !== undefined ? { elapsedMs: result.elapsedMs } : {}),
+    ...(costUsd !== undefined ? { costUsd } : {}),
+    ...(failed ? { schemaValid: false } : {}),
+    ...(failed ? { reason: result.stderr?.trim() || `Process exited with code ${result.exitCode}.` } : {}),
+  };
+}
+
+function buildHttpBody(
+  lane: ClaimGateModelLaneManifest,
+  prompt: string,
+  options: ClaimGateHttpModelRunnerOptions,
+): ClaimGateHttpModelRequestBody {
+  const wantsJson = lane.outputSchema.toLowerCase().includes('json');
+  return {
+    model: lane.model,
+    messages: [{ role: 'user', content: prompt }],
+    temperature: options.temperature ?? 0.1,
+    max_tokens: options.maxTokens ?? 1200,
+    ...(wantsJson ? { response_format: { type: 'json_object' as const } } : {}),
+  };
+}
+
+function extractChatCompletionContent(json: unknown): string {
+  if (!isRecord(json)) return '';
+  const choices = json.choices;
+  if (!Array.isArray(choices)) return '';
+  const first = choices[0];
+  if (!isRecord(first)) return '';
+  const message = first.message;
+  if (!isRecord(message)) return '';
+  const content = message.content;
+  return typeof content === 'string' ? content : '';
+}
+
+function extractCostUsd(json: unknown): number | undefined {
+  if (!isRecord(json)) return undefined;
+  const usage = json.usage;
+  if (!isRecord(usage)) return undefined;
+  const cost = usage.cost;
+  return typeof cost === 'number' && Number.isFinite(cost) ? cost : undefined;
+}
+
+function strictJsonSchemaValid(lane: ClaimGateModelLaneManifest, outputText: string): boolean | undefined {
+  if (!lane.outputSchema.toLowerCase().includes('strict_json')) return undefined;
+  try {
+    JSON.parse(outputText);
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+function receiptHashFragment(lane: ClaimGateModelLaneManifest, outputText: string): string {
+  return sha256({
+    laneId: lane.laneId,
+    provider: lane.provider,
+    model: lane.model,
+    outputText,
+  }).slice('sha256:'.length, 'sha256:'.length + 16);
+}
+
+export function createClaimGateClaudeBridgeRunner(options: ClaimGateClaudeBridgeRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => normalizeProcessResult(await options.run({
+    lane,
+    model: lane.model,
+    prompt,
+    timeoutMs,
+    signal,
+  }));
+}
+
+export function createClaimGateGoogleGeminiTuiRunner(options: ClaimGateGoogleGeminiTuiRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => normalizeProcessResult(await options.run({
+    lane,
+    model: lane.model,
+    prompt,
+    timeoutMs,
+    signal,
+  }));
+}
+
+export function createClaimGateOpenRouterRunner(options: ClaimGateHttpModelRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => {
+    const result = await options.postJson({
+      lane,
+      model: lane.model,
+      prompt,
+      timeoutMs,
+      signal,
+      body: buildHttpBody(lane, prompt, options),
+    });
+    const outputText = extractChatCompletionContent(result.json);
+    const schemaValid = strictJsonSchemaValid(lane, outputText);
+    return {
+      outputText,
+      outputHash: sha256({ laneId: lane.laneId, provider: lane.provider, model: lane.model, outputText }),
+      receiptRef: `receipt:rcpt-runtime-${lane.laneId}-${receiptHashFragment(lane, outputText)}`,
+      ...(schemaValid === false ? { schemaValid, reason: `Provider output did not satisfy ${lane.outputSchema} schema.` } : {}),
+      ...(result.elapsedMs !== undefined ? { elapsedMs: result.elapsedMs } : {}),
+      ...(extractCostUsd(result.json) !== undefined ? { costUsd: extractCostUsd(result.json) } : {}),
+    };
+  };
+}
+
+export function createClaimGateXaiRunner(options: ClaimGateHttpModelRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => {
+    const result = await options.postJson({
+      lane,
+      model: lane.model,
+      prompt,
+      timeoutMs,
+      signal,
+      body: buildHttpBody(lane, prompt, options),
+    });
+    const outputText = extractChatCompletionContent(result.json);
+    return {
+      outputText,
+      outputHash: sha256({ laneId: lane.laneId, provider: lane.provider, model: lane.model, outputText }),
+      receiptRef: `receipt:rcpt-runtime-${lane.laneId}-${receiptHashFragment(lane, outputText)}`,
+      ...(result.elapsedMs !== undefined ? { elapsedMs: result.elapsedMs } : {}),
+      ...(extractCostUsd(result.json) !== undefined ? { costUsd: extractCostUsd(result.json) } : {}),
+    };
+  };
+}
+
+export function createClaimGateCodexLocalRunner(options: ClaimGateCodexLocalRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => options.run({
+    lane,
+    model: lane.model,
+    prompt,
+    timeoutMs,
+    signal,
+  });
+}
+
+export function createClaimGateModelLaneRunnerMap(options: ClaimGateModelLaneRunnerMapOptions): ClaimGateModelLaneRunnerMap {
+  return {
+    ...(options.claudeBridge ? { claude: createClaimGateClaudeBridgeRunner(options.claudeBridge) } : {}),
+    ...(options.openRouter ? { openrouter: createClaimGateOpenRouterRunner(options.openRouter) } : {}),
+    ...(options.xai ? { xai: createClaimGateXaiRunner(options.xai) } : {}),
+    ...(options.googleGeminiTui ? { google: createClaimGateGoogleGeminiTuiRunner(options.googleGeminiTui) } : {}),
+    ...(options.codexLocal ? {
+      codex: createClaimGateCodexLocalRunner(options.codexLocal),
+      local: createClaimGateCodexLocalRunner(options.codexLocal),
+    } : {}),
+  };
+}
