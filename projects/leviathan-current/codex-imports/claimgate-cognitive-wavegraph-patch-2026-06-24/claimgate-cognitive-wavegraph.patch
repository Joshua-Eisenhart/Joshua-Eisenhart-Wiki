+      addViolation(
+        violations,
+        `${path}.authority`,
+        'management_authority_overclaim',
+        `${path}.authority must be route_or_quarantine_only; management sidecars cannot promote, rewrite, or suppress work-plane receipts.`,
+      );
+    }
+    if (action.claimCeiling !== 'management_sidecar_not_promotion') {
+      addViolation(
+        violations,
+        `${path}.claimCeiling`,
+        'management_claim_ceiling_overclaim',
+        `${path}.claimCeiling must be management_sidecar_not_promotion.`,
+      );
+    }
+
+    const sidecarsForWave = sidecarsByWave.get(action.wave);
+    if (typeof action.sidecarMemberId === 'string') {
+      if (!sidecarsForWave?.has(action.sidecarMemberId)) {
+        addViolation(
+          violations,
+          `${path}.sidecarMemberId`,
+          'unknown_management_sidecar',
+          `${path}.sidecarMemberId must reference a management sidecar in the same wave.`,
+        );
+      }
+      actionSidecars.add(`${action.wave}:${action.sidecarMemberId}`);
+    }
+  });
+
+  for (const [wave, sidecarIds] of sidecarsByWave) {
+    for (const sidecarId of sidecarIds) {
+      if (!actionSidecars.has(`${wave}:${sidecarId}`)) {
+        addViolation(
+          violations,
+          'managementActions',
+          'missing_management_action_for_sidecar',
+          `Management sidecar ${sidecarId} in wave ${wave} has no receipt-bearing management action.`,
+        );
+      }
+    }
+  }
+}
