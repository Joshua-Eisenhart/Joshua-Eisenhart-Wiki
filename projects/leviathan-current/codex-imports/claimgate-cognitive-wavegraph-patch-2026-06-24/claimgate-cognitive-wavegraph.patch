+    gates: state.gates.map((gate) => ({
+      ...gate,
+      dependsOnReceiptIds: [...gate.dependsOnReceiptIds],
+    })),
+  };
+}
+
+function findGateRecordByGateAndReceipt(
+  state: ClaimGateLoopState,
+  gateId: string,
+  receiptId: string,
+): ClaimGateLoopStateGateRecord | undefined {
+  return state.gates.find((gate) => gate.gateId === gateId && gate.receiptId === receiptId);
+}
+
+function findGateRecordByGateId(
+  state: ClaimGateLoopState,
+  gateId: string,
+): ClaimGateLoopStateGateRecord | undefined {
+  return state.gates.find((gate) => gate.gateId === gateId);
+}
+
+function transitiveDependentReceiptIds(
+  state: ClaimGateLoopState,
+  targetReceiptId: string,
+  excludedReceiptIds: Set<string>,
+): string[] {
+  const orderedGates = state.gates
+    .map((gate, index) => ({ gate, index }))
+    .sort((a, b) => (a.gate.gateOrder - b.gate.gateOrder) || (a.index - b.index));
+  const discovered = new Set<string>();
+  const queue = [targetReceiptId];
+
+  while (queue.length > 0) {
+    const currentReceiptId = queue.shift();
+    if (!currentReceiptId) continue;
+    for (const { gate } of orderedGates) {
+      if (!gate.dependsOnReceiptIds.includes(currentReceiptId)) continue;
+      if (gate.receiptId === targetReceiptId) continue;
+      if (excludedReceiptIds.has(gate.receiptId)) continue;
+      if (discovered.has(gate.receiptId)) continue;
+      discovered.add(gate.receiptId);
+      queue.push(gate.receiptId);
+    }
+  }
+
+  return orderedGates
+    .map(({ gate }) => gate.receiptId)
+    .filter((receiptId) => discovered.has(receiptId));
+}
