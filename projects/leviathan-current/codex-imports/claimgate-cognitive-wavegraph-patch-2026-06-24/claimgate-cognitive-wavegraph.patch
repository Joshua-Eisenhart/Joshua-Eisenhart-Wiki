+
+function receiptContentHashMatches(receipt: Receipt, payload: unknown): boolean {
+  return receipt.contentHash === sha256(payload);
+}
+
+function validateGraphPatchProposalForHostAdmission(
+  result: ClaimGateLoopResult,
+): ClaimGateGraphPatchAdmissionFinding[] {
+  const findings: ClaimGateGraphPatchAdmissionFinding[] = [];
+  const proposal = result.graphPatchProposal;
+
+  if (proposal.kind !== 'ClaimGateGraphPatchProposal') {
+    addGraphAdmissionFinding(
+      findings,
+      'graph_patch.invalid_kind',
+      'graphPatchProposal.kind must be ClaimGateGraphPatchProposal.',
+    );
+  }
+
+  if (!result.receipt.evalResults.every((evalResult) => evalResult.passed)) {
+    addGraphAdmissionFinding(
+      findings,
+      'source_receipt.failed_eval',
+      'The source ClaimGate loop receipt must have all eval results passing before host graph-patch review.',
+    );
+  }
+
+  if (!receiptContentHashMatches(result.receipt, loopReceiptPayload(result))) {
+    addGraphAdmissionFinding(
+      findings,
+      'source_receipt.content_hash_mismatch',
+      'The source ClaimGate loop receipt contentHash must match the current loop result payload before host graph-patch review.',
+    );
+  }
+
+  const acceptedClaimIds = proposal.acceptedClaimIds ?? [];
+  const withheldClaimIds = proposal.withheldClaimIds ?? [];
+  const operations = proposal.operations ?? [];
+  const accepted = new Set(acceptedClaimIds);
+  const withheld = new Set(withheldClaimIds);
+  const operationClaimIds = operations.map((operation) => operation.claimId);
+  const operationIds = new Set(operationClaimIds);
+
+  for (const claimId of duplicateIds(acceptedClaimIds)) {
+    addGraphAdmissionFinding(findings, 'graph_patch.duplicate_accepted_claim', 'Accepted claim IDs must be unique.', claimId);
+  }
+  for (const claimId of duplicateIds(withheldClaimIds)) {
+    addGraphAdmissionFinding(findings, 'graph_patch.duplicate_withheld_claim', 'Withheld claim IDs must be unique.', claimId);
+  }
+  for (const claimId of duplicateIds(operationClaimIds)) {
+    addGraphAdmissionFinding(findings, 'graph_patch.duplicate_operation_claim', 'Graph patch operation claim IDs must be unique.', claimId);
+  }
+
+  for (const claimId of acceptedClaimIds) {
+    if (withheld.has(claimId)) {
+      addGraphAdmissionFinding(
+        findings,
+        'graph_patch.accepted_withheld_overlap',
+        'A claim cannot be both accepted and withheld.',
+        claimId,
+      );
+    }
+    if (!operationIds.has(claimId)) {
+      addGraphAdmissionFinding(
+        findings,
+        'graph_patch.accepted_claim_missing_operation',
+        'Every accepted claim must have a matching proposal operation.',
+        claimId,
+      );
+    }
+  }
+
+  for (const operation of operations) {
+    if (operation.op !== 'add_claim') {
+      addGraphAdmissionFinding(
+        findings,
+        'graph_patch.invalid_operation',
+        'ClaimGate graph patch proposals may only contain add_claim operations.',
+        operation.claimId,
+      );
+    }
+    if (!accepted.has(operation.claimId)) {
+      addGraphAdmissionFinding(
+        findings,
+        'graph_patch.operation_without_accepted_claim',
+        'Graph patch operations must correspond to accepted claims.',
+        operation.claimId,
+      );
+    }
+    if (withheld.has(operation.claimId)) {
+      addGraphAdmissionFinding(
+        findings,
+        'graph_patch.withheld_claim_operation_leak',
+        'Withheld claims must not appear in graph patch operations.',
+        operation.claimId,
+      );
+    }
+    if (typeof operation.payload !== 'string' || operation.payload.trim().length === 0) {
+      addGraphAdmissionFinding(
+        findings,
+        'graph_patch.empty_operation_payload',
+        'Graph patch operations must carry a non-empty payload.',
+        operation.claimId,
+      );
+    }
+  }
+
+  return findings;
+}
+
+function createGraphPatchAdmissionReceipt({
+  sessionId,
+  workstreamId,
+  sourceReceiptId,
+  ok,
+  graphPatchProposal,
+  findings,
+}: {
+  sessionId: string;
