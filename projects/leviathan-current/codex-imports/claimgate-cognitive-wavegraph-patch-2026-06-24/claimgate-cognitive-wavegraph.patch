+function makePassConditionContract(
+  requiredGateIds: string[],
+  evidencePolicy: ClaimGateDeterministicEvidencePolicy,
+): ClaimGateDeterministicPassConditionContract {
+  return {
+    kind: 'ClaimGateDeterministicPassConditionContract',
+    requiredGateIds,
+    sourceBoundRequiredGateIds: requiredGateIds.filter((gateId) => SOURCE_BOUND_REQUIRED_GATE_IDS.has(gateId)),
+    evidencePolicy,
+    requeuePolicy: 'failed_claims_only',
+    terminalWithholdPolicy: 'withhold_failed_claims_after_max_waves',
+    graphPatchPolicy: 'accepted_claims_only_proposal_operations',
+    claimCeiling: 'deterministic_pass_conditions_fixture_level',
+  };
+}
