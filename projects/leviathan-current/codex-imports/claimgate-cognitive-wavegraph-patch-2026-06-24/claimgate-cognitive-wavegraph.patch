+
+function receiptEvalPassed(receipt: Receipt): boolean {
+  return receipt.evalResults.length > 0 && receipt.evalResults.every((evalResult) => evalResult.passed);
+}
+
+function proofResultForPassed(passed: boolean): ProofResult {
+  return {
+    status: passed ? 'passed' : 'failed',
+    elapsedMs: 0,
+    verifierVersion: 'claim-gate-wavegraph-steering-projection/0.1.0',
+  };
+}
+
+function makeWavegraphSteeringObligation(
+  runId: string,
+  index: number,
+  constraintId: string,
+  passed: boolean,
+): ProofObligation {
+  return {
+    obligationId: `obl-${index}-${runId}`,
+    constraintId,
+    shellCheck: `projection-derived:${constraintId}`,
+    expectedResult: 'exit_zero',
+    actualResult: proofResultForPassed(passed),
+  };
+}
+
+function verdictFromProofResults(results: ProofResult[]): EvalVerdict {
+  if (results.some((result) => result.status === 'failed' || result.status === 'timeout')) return 'fail';
+  if (results.every((result) => result.status === 'passed')) return 'pass';
+  return 'conditional';
+}
