+    addViolation(
+      violations,
+      'slice',
+      'ambiguous_workflow_slice_source',
+      'Workflow specs must compile model lanes, loaded context, and waves from workflow fields instead of accepting a prebuilt opaque slice.',
+    );
+  }
+  if (spec.loadedContextReceipts !== undefined) {
+    addViolation(
+      violations,
+      'loadedContextReceipts',
+      'ambiguous_workflow_loaded_context_receipts',
+      'Workflow specs must compile loaded context receipts from contextLoadPlan instead of accepting pre-minted loaded context receipts.',
+    );
+  }
+  if (spec.gateLoopReopenDecisions !== undefined) {
+    addViolation(
+      violations,
+      'gateLoopReopenDecisions',
+      'ambiguous_workflow_gate_loop_reopen_decisions',
+      'Workflow specs must evaluate Gate 3 reopen requests instead of accepting pre-minted reopen decisions.',
+    );
+  }
+  if (spec.gateLoopStateReceipt !== undefined) {
+    addViolation(
+      violations,
+      'gateLoopStateReceipt',
+      'ambiguous_workflow_gate_loop_state_receipt',
+      'Workflow specs must compile Gate 3 reopen state from explicit gate records instead of accepting a pre-minted reopen state receipt.',
+    );
+  }
