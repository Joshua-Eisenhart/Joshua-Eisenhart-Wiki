+
+function validateTopology(
+  input: ClaimGateWavegraphSliceInput,
+  loadedRefs: Set<string>,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): void {
+  if (!Array.isArray(input.waves) || input.waves.length === 0) {
+    addViolation(violations, 'waves', 'missing_waves', 'A wavegraph slice requires waves.');
+    return;
+  }
+  if (input.waves.length < 2) {
+    addViolation(violations, 'waves', 'missing_two_wave_fixture', 'The first executable slice must contain at least two waves.');
+  }
+
+  input.waves.forEach((wave, waveIndex) => {
+    const wavePath = `waves[${waveIndex}]`;
+    if (!isRecord(wave)) {
+      addViolation(violations, wavePath, 'expected_wave_object', `${wavePath} must be an object.`);
+      return;
+    }
+    validateString(wave.phase, `${wavePath}.phase`, violations, MAX_TEXT_BYTES);
+    if (!Number.isInteger(wave.wave) || wave.wave <= 0) {
+      addViolation(violations, `${wavePath}.wave`, 'invalid_wave_number', `${wavePath}.wave must be a positive integer.`);
+    }
+
+    const waveMemberIds = new Set<string>();
+    if (!Array.isArray(wave.councils) || wave.councils.length === 0) {
+      addViolation(violations, `${wavePath}.councils`, 'missing_wave_councils', 'A wave must contain councils; raw claim fanout is not a wave.');
+    } else {
+      wave.councils.forEach((council, councilIndex) => {
+        const councilPath = `${wavePath}.councils[${councilIndex}]`;
+        if (!isRecord(council)) {
+          addViolation(violations, councilPath, 'expected_council_object', `${councilPath} must be an object.`);
+          return;
+        }
+        validateString(council.councilId, `${councilPath}.councilId`, violations, MAX_ID_BYTES);
+        validateString(council.role, `${councilPath}.role`, violations, MAX_TEXT_BYTES);
+        if (!Array.isArray(council.members) || council.members.length === 0) {
+          addViolation(violations, `${councilPath}.members`, 'missing_council_members', `${councilPath}.members must be non-empty.`);
+          return;
+        }
+        council.members.forEach((member, memberIndex) => {
+          const memberPath = `${councilPath}.members[${memberIndex}]`;
+          if (validateMember(member, memberPath, loadedRefs, violations)) {
+            waveMemberIds.add(member.memberId);
+          }
+        });
+      });
+    }
+
+    if (!Array.isArray(wave.managementSidecars) || wave.managementSidecars.length === 0) {
+      addViolation(violations, `${wavePath}.managementSidecars`, 'missing_management_sidecar', 'Each wave in the first slice needs at least one management sidecar.');
+    } else {
+      wave.managementSidecars.forEach((member, memberIndex) => {
+        validateMember(member, `${wavePath}.managementSidecars[${memberIndex}]`, loadedRefs, violations);
+      });
+    }
+
+    if (!Array.isArray(wave.claims) || wave.claims.length === 0) {
+      addViolation(violations, `${wavePath}.claims`, 'missing_wave_claims', `${wavePath}.claims must be non-empty.`);
+    } else {
+      wave.claims.forEach((claim, claimIndex) => {
+        const claimPath = `${wavePath}.claims[${claimIndex}]`;
+        if (!isRecord(claim)) {
+          addViolation(violations, claimPath, 'expected_claim_object', `${claimPath} must be an object.`);
+          return;
+        }
+        if (typeof claim.memberId === 'string' && !waveMemberIds.has(claim.memberId)) {
+          addViolation(
+            violations,
+            `${claimPath}.memberId`,
+            'unknown_claim_member',
+            `${claimPath}.memberId must reference a member in one of the wave councils.`,
+          );
+        }
+      });
+    }
+  });
+}
