+export function writeClaimGateWavegraphSteeringProjection(
+  options: ClaimGateWavegraphSteeringProjectionWriteOptions,
+): ClaimGateWavegraphSteeringProjection {
+  const { workflowResult, runDir } = options;
+  const runId = options.runId ?? basename(runDir);
+  const suiteId = options.suiteId ?? 'claim-gate-wavegraph-gate9-steering';
+  const files = steeringRunFileSet(runDir);
+  const { sliceResult } = workflowResult;
+  const targetRef = `claim-gate-wavegraph:${workflowResult.workflowId}:${sliceResult.sessionId}`;
+  const proofSpecId = `ps-${runId}-wavegraph-steering`;
+  const evalJobId = `ej-${runId}-wavegraph-steering`;
+  const graphPatchProposal = sliceResult.loopResult.graphPatchProposal;
+  const graphPatchProposalOnly = graphPatchProposal.kind === 'ClaimGateGraphPatchProposal'
+    && sliceResult.sliceReceipt.effectResults.every((effect) => effect.declaration.target !== 'lev.graph.canon');
+  const obligations: ProofObligation[] = [
+    makeWavegraphSteeringObligation(runId, 0, 'claim-gate.wavegraph.workflow_receipt_passed', receiptEvalPassed(workflowResult.workflowReceipt)),
+    makeWavegraphSteeringObligation(runId, 1, 'claim-gate.wavegraph.model_lane_receipt_passed', receiptEvalPassed(sliceResult.modelLaneReceipt)),
+    makeWavegraphSteeringObligation(runId, 2, 'claim-gate.wavegraph.context_load_receipt_passed', receiptEvalPassed(sliceResult.contextLoadReceipt)),
+    makeWavegraphSteeringObligation(runId, 3, 'claim-gate.wavegraph.management_plane_receipt_passed', receiptEvalPassed(sliceResult.managementPlaneReceipt)),
+    makeWavegraphSteeringObligation(runId, 4, 'claim-gate.wavegraph.claim_gate_loop_receipt_passed', receiptEvalPassed(sliceResult.loopResult.receipt)),
+    makeWavegraphSteeringObligation(runId, 5, 'claim-gate.wavegraph.slice_receipt_passed', receiptEvalPassed(sliceResult.sliceReceipt)),
+    makeWavegraphSteeringObligation(runId, 6, 'claim-gate.wavegraph.graph_patch_proposal_only', graphPatchProposalOnly),
+  ];
+  const evidence = obligations.map((obligation) => obligation.actualResult!);
+  const verdict = verdictFromProofResults(evidence);
+  const proofSpec: ProofSpec = {
+    specId: proofSpecId,
+    targetRef,
+    constraintPackId: suiteId,
+    proofObligations: obligations,
+    proofStrategy: 'compiled_guard',
+    generatedAt: new Date().toISOString(),
+  };
+  const output: EvalJobOutput = {
+    verdict,
+    evidence,
+    receiptId: sliceResult.sliceReceipt.id,
+  };
+  const evalJob: EvalJob = {
+    jobId: evalJobId,
+    jobClass: 'eval',
+    targetRef,
+    proofSpecId,
+    constraintPackId: suiteId,
+    inputReceiptIds: [
+      workflowResult.workflowReceipt.id,
+      sliceResult.modelLaneReceipt.id,
+      sliceResult.contextLoadReceipt.id,
+      sliceResult.managementPlaneReceipt.id,
+      sliceResult.loopResult.receipt.id,
+      ...sliceResult.gateLoopReopenDecisions.map((decision) => decision.receipt.id),
+      sliceResult.sliceReceipt.id,
+    ],
+    output,
+  };
+
+  writeJson(files.runJson, {
+    run_id: runId,
+    suite_id: suiteId,
+    target_ref: targetRef,
+    live_lev_consumed: false,
+    claim_ceiling: 'source_projection_only_requires_host_steering_consumption',
+    graphMutationApplied: false,
+  });
+  writeJson(files.proofSpec, proofSpec);
+  writeJson(files.evalJob, evalJob);
+  writeJson(files.evalJobOutput, output);
+  writeJson(files.boundary, {
+    live_lev_consumed: false,
+    compatibility_only: true,
+    source_projection_only: 'true',
+    graphMutationApplied: false,
+    graph_patch_proposal_kind: graphPatchProposal.kind,
+    source_receipt_id: sliceResult.sliceReceipt.id,
+  });
+
+  return {
+    kind: 'ClaimGateWavegraphSteeringProjection',
+    runDir,
+    runId,
+    files,
+    proofSpecId,
+    evalJobId,
+    targetRef,
+    verdict,
+    claimCeiling: 'source_projection_only_requires_host_steering_consumption',
+    graphMutationApplied: false,
+  };
+}
