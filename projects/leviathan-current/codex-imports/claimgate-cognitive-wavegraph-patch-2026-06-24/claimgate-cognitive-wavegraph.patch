     });
+    // Fail-closed: discovering zero runs is NOT "host_consumed". Pointing batch
+    // at a wrong/empty path must not report success with no verifications behind
+    // it — a verification gate that decides on an empty set decides nothing.
+    const empty = result.runCount === 0;
+    const ok = !empty && result.blockedCount === 0;
+    const errorCode = empty
+      ? 'CLAIMGATE_STEERING_BATCH_EMPTY'
+      : result.blockedCount === 0
+        ? undefined
+        : 'CLAIMGATE_STEERING_BATCH_BLOCKED';
     return {
-      success: result.blockedCount === 0,
-      formatted_response: formatBatch(result),
+      success: ok,
+      formatted_response: empty
+        ? [
+            'ClaimGate steering batch: no_runs_found',
+            `Root: ${result.rootDir}`,
+            'Runs: 0',
+            'Refusing to report host_consumed: no steering runs discovered under root.',
+          ].join('\n')
+        : formatBatch(result),
       data: result,
-      error_code: result.blockedCount === 0 ? undefined : 'CLAIMGATE_STEERING_BATCH_BLOCKED',
+      error_code: errorCode,
     };
   }
 
