+
+export function evaluateClaimGateLoopReopenRequest(
+  state: ClaimGateLoopState,
+  request: ClaimGateLoopStateReopenRequest,
+): ClaimGateLoopStateReopenDecision {
+  const findings: ClaimGateLoopStateReopenFinding[] = [];
+  const targetGate = findGateRecordByGateAndReceipt(state, request.targetGateId, request.targetReceiptId);
+  const authorityGate = findGateRecordByGateId(state, request.reopenAuthorityGateId);
+
+  if (!request.requestId?.trim()) {
+    addLoopStateReopenFinding(findings, 'reopen.missing_request_id', 'Reopen request must have a requestId.');
+  }
+  if (!targetGate) {
+    addLoopStateReopenFinding(
+      findings,
+      'reopen.target_gate_not_found',
+      `Target gate ${request.targetGateId} with receipt ${request.targetReceiptId} was not found.`,
+    );
+  }
+  if (!authorityGate) {
+    addLoopStateReopenFinding(
+      findings,
+      'reopen.authority_gate_not_found',
+      `Reopen authority gate ${request.reopenAuthorityGateId} was not found.`,
+    );
+  }
+  if (!request.contradictionArtifactRef?.trim() && !request.strongerContractRef?.trim()) {
+    addLoopStateReopenFinding(
+      findings,
+      'reopen.missing_artifact_or_contract',
+      'Reopening a gate requires a contradictionArtifactRef or strongerContractRef; model/council prose is not authority.',
+    );
+  }
+  if (!Number.isInteger(request.tickBudget) || request.tickBudget <= 0) {
+    addLoopStateReopenFinding(
+      findings,
+      'reopen.invalid_tick_budget',
+      'Reopen request tickBudget must be a positive integer.',
+    );
+  }
+
+  if (targetGate) {
+    if (targetGate.status !== 'passed') {
+      addLoopStateReopenFinding(
+        findings,
+        'reopen.target_gate_not_passed',
+        `Target gate ${targetGate.gateId} must be passed before it can be reopened.`,
+      );
+    }
+    if (targetGate.reopenCount >= targetGate.maxReopenCount) {
+      addLoopStateReopenFinding(
+        findings,
+        'reopen.reopen_count_exhausted',
+        `Target gate ${targetGate.gateId} has exhausted its reopen count.`,
+      );
+    }
+    if (Number.isInteger(request.tickBudget) && request.tickBudget > targetGate.tickBudgetRemaining) {
+      addLoopStateReopenFinding(
+        findings,
+        'reopen.tick_budget_exhausted',
+        `Target gate ${targetGate.gateId} does not have enough tick budget remaining for this reopen.`,
+      );
+    }
+  }
+
+  if (targetGate && authorityGate) {
+    if (authorityGate.status !== 'passed') {
+      addLoopStateReopenFinding(
+        findings,
+        'reopen.authority_gate_not_passed',
+        `Reopen authority gate ${authorityGate.gateId} must be passed before it can reopen earlier gates.`,
+      );
+    }
+    if (authorityGate.gateOrder <= targetGate.gateOrder) {
+      addLoopStateReopenFinding(
+        findings,
+        'reopen.authority_gate_not_later',
+        `Reopen authority gate ${authorityGate.gateId} must be later than target gate ${targetGate.gateId}.`,
+      );
+    }
+  }
+
+  const accepted = findings.every((finding) => finding.severity !== 'error');
+  const invalidatedReceiptIds = accepted && targetGate
+    ? transitiveDependentReceiptIds(
+        state,
+        targetGate.receiptId,
+        new Set(authorityGate ? [authorityGate.receiptId] : []),
+      )
+    : [];
+  const nextState = accepted && targetGate
+    ? cloneClaimGateLoopState(state)
+    : state;
+
+  if (accepted && targetGate) {
+    const target = findGateRecordByGateAndReceipt(nextState, targetGate.gateId, targetGate.receiptId);
+    if (target) {
+      target.status = 'reopened';
+      target.reopenCount += 1;
+      target.tickBudgetRemaining = Math.max(0, target.tickBudgetRemaining - request.tickBudget);
+      target.reopenedByRequestId = request.requestId;
+      target.reopenedByGateId = request.reopenAuthorityGateId;
+      target.ceilingAction = request.ceilingAction;
+      if (request.contradictionArtifactRef) target.contradictionArtifactRef = request.contradictionArtifactRef;
+      if (request.strongerContractRef) target.strongerContractRef = request.strongerContractRef;
+    }
+    for (const invalidatedReceiptId of invalidatedReceiptIds) {
+      const invalidatedGate = nextState.gates.find((gate) => gate.receiptId === invalidatedReceiptId);
+      if (!invalidatedGate) continue;
+      invalidatedGate.status = 'invalidated';
+      invalidatedGate.invalidatedByRequestId = request.requestId;
+      invalidatedGate.invalidatedByReceiptId = targetGate.receiptId;
+    }
+  }
+
+  const receipt = createLoopStateReopenDecisionReceipt({
+    state,
+    request,
+    accepted,
+    invalidatedReceiptIds,
+    findings,
+  });
+
+  return {
+    kind: 'ClaimGateLoopStateReopenDecision',
+    requestId: request.requestId,
+    accepted,
+    status: accepted ? 'reopened' : 'blocked',
+    targetGateId: request.targetGateId,
+    targetReceiptId: request.targetReceiptId,
+    authorityGateId: request.reopenAuthorityGateId,
+    claimCeiling: 'reopen_decision_proposal_only',
+    graphMutationApplied: false,
+    invalidatedReceiptIds,
+    findings,
+    nextState,
+    receipt,
+  };
+}
+
+function duplicateIds(ids: string[]): string[] {
+  const seen = new Set<string>();
+  const duplicates = new Set<string>();
+  for (const id of ids) {
+    if (seen.has(id)) duplicates.add(id);
+    seen.add(id);
+  }
+  return Array.from(duplicates).sort();
+}
+
