+
+      const execution = recordClaimGateRepairDispatchExecution(dispatchPlan, repairWaveInput);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), execution);
+      }
+      return {
+        success: execution.ok,
+        formatted_response: parsed.json ? JSON.stringify(execution, null, 2) : formatRepairDispatchExecution(execution, parsed.out),
+        data: execution,
+        error_code: execution.ok ? undefined : 'CLAIMGATE_REPAIR_DISPATCH_EXECUTION_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'admit-graph-patch') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let result: ClaimGateLoopResult;
+      try {
+        result = readJson<ClaimGateLoopResult>(parsed.input);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const admission = consumeClaimGateGraphPatchProposal(result);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), admission);
+      }
+      return {
+        success: admission.ok,
+        formatted_response: parsed.json ? JSON.stringify(admission, null, 2) : formatGraphPatchAdmission(admission, parsed.out),
+        data: admission,
+        error_code: admission.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'apply-plan') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let result: ClaimGateLoopResult;
+      let admission: ClaimGateGraphPatchAdmission;
+      try {
+        result = readJson<ClaimGateLoopResult>(parsed.input);
+        admission = readJson<ClaimGateGraphPatchAdmission>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const applyPlan = buildClaimGateGraphPatchApplyPlan(result, admission);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), applyPlan);
+      }
+      return {
+        success: applyPlan.ok,
+        formatted_response: parsed.json ? JSON.stringify(applyPlan, null, 2) : formatGraphPatchApplyPlan(applyPlan, parsed.out),
+        data: applyPlan,
+        error_code: applyPlan.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_APPLY_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'apply-graph-patch') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let result: ClaimGateLoopResult;
+      let admission: ClaimGateGraphPatchAdmission;
+      try {
+        result = readJson<ClaimGateLoopResult>(parsed.input);
+        admission = readJson<ClaimGateGraphPatchAdmission>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const applyPlan = buildClaimGateGraphPatchApplyPlan(result, admission);
+      const bridge = await applyGraphPatchThroughHost(applyPlan);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), bridge);
+      }
+      return {
+        success: bridge.ok,
+        formatted_response: parsed.json ? JSON.stringify(bridge, null, 2) : formatGraphPatchBridge(bridge, parsed.out),
+        data: bridge,
+        error_code: bridge.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_EXECUTION_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'record-graph-execution') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let applyPlan: ClaimGateGraphPatchApplyPlan;
+      let graphResult: ClaimGateGraphPatchExecutionInput;
+      try {
+        applyPlan = readJson<ClaimGateGraphPatchApplyPlan>(parsed.input);
+        graphResult = readJson<ClaimGateGraphPatchExecutionInput>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const execution = recordClaimGateGraphPatchExecution(applyPlan, graphResult, {
+        trustedEvidenceRefs: parsed.trustedEvidenceRefs,
+      });
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), execution);
+      }
+      return {
+        success: execution.ok,
+        formatted_response: parsed.json ? JSON.stringify(execution, null, 2) : formatGraphPatchExecution(execution, parsed.out),
+        data: execution,
+        error_code: execution.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_EXECUTION_BLOCKED',
+      };
+    }
+
+    return {
+      success: false,
+      formatted_response: usage(),
+      error_code: 'UNKNOWN_SUBCOMMAND',
+    };
+  }
+
+  const result = runClaimGateLoopFixture({
+    sessionId: 'claim-gate-loop-demo',
+    workstreamId: 'ws-claim-gate-loop-demo',
+    maxWaves: parsed.maxWaves,
+  });
