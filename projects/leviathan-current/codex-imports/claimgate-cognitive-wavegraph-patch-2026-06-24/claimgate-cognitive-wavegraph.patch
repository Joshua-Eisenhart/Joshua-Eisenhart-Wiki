+/**
+ * lev orchestration claim-gate-loop
+ *
+ * Deterministic ClaimGate verify/reject/requeue fixture.
+ */
+
+import { mkdirSync, readFileSync, writeFileSync } from 'node:fs';
+import { dirname, resolve } from 'node:path';
+
+import {
+  buildClaimGateRepairDispatchPlan,
+  buildClaimGateGraphPatchApplyPlan,
+  buildClaimGateRepairWavePlan,
+  ClaimGateCouncilWaveInputError,
+  consumeClaimGateGraphPatchProposal,
+  type ClaimGateGraphPatchAdmission,
+  type ClaimGateGraphPatchApplyPlan,
+  type ClaimGateGraphPatchExecutionInput,
+  type ClaimGateCouncilWaveInput,
+  type ClaimGateLoopResult,
+  type ClaimGateRepairDispatchPlan,
+  type ClaimGateRepairWavePlan,
+  recordClaimGateGraphPatchExecution,
+  recordClaimGateRepairDispatchExecution,
+  runClaimGateCouncilWaveLoop,
+  runClaimGateLoopFixture,
+  validateClaimGateCouncilWaveInput,
+} from '../proof/claim-gate-loop.js';
+
+interface ClaimGateGraphPatchBridgeResult {
+  kind: 'ClaimGateGraphPatchBridgeResult';
+  status: 'graph_patch_executed' | 'graph_patch_blocked';
+  ok: boolean;
+  applyPlan: ClaimGateGraphPatchApplyPlan;
+  graphResult: ClaimGateGraphPatchExecutionInput;
+  execution: ReturnType<typeof recordClaimGateGraphPatchExecution>;
+}
+
+interface GraphPatchHandlerModule {
+  patch(args: string[] | { operations: string; applyPlanReceiptId?: string } | undefined): Promise<ClaimGateGraphPatchExecutionInput>;
+}
+
+interface ParsedArgs {
+  subcommand: string;
+  json: boolean;
+  input?: string;
+  result?: string;
+  out?: string;
+  parentResult?: string;
+  maxWaves?: number;
+  trustedEvidenceRefs: string[];
+  rawTrustedEvidenceRefs: string[];
+}
+
+function parseArgs(args: string[]): ParsedArgs {
+  const [subcommand = 'help'] = args;
+  const json = args.includes('--json');
+  const outFlag = args.find((arg) => arg.startsWith('--out='));
+  const outIndex = args.indexOf('--out');
+  const out = outFlag
+    ? outFlag.slice('--out='.length)
+    : outIndex >= 0
+      ? args[outIndex + 1]
+      : undefined;
+  const parentResultFlag = args.find((arg) => arg.startsWith('--parent-result='));
+  const parentResultIndex = args.indexOf('--parent-result');
+  const parentResult = parentResultFlag
+    ? parentResultFlag.slice('--parent-result='.length)
+    : parentResultIndex >= 0
+      ? args[parentResultIndex + 1]
+      : undefined;
+  const maxWavesFlag = args.find((arg) => arg.startsWith('--max-waves='));
+  const parsedMaxWaves = maxWavesFlag ? Number(maxWavesFlag.slice('--max-waves='.length)) : undefined;
+  const trustedEvidenceRefs: string[] = [];
+  const rawTrustedEvidenceRefs: string[] = [];
+  args.forEach((arg, index) => {
+    if (arg.startsWith('--host-trusted-evidence-ref=')) {
+      const value = arg.slice('--host-trusted-evidence-ref='.length);
+      if (value.length > 0) trustedEvidenceRefs.push(value);
+    } else if (arg === '--host-trusted-evidence-ref') {
+      const value = args[index + 1];
+      if (value && !value.startsWith('--')) trustedEvidenceRefs.push(value);
+    } else if (arg.startsWith('--trusted-evidence-ref=')) {
+      const value = arg.slice('--trusted-evidence-ref='.length);
+      if (value.length > 0) rawTrustedEvidenceRefs.push(value);
+    } else if (arg === '--trusted-evidence-ref') {
+      const value = args[index + 1];
+      if (value && !value.startsWith('--')) rawTrustedEvidenceRefs.push(value);
+    }
+  });
+  const positional = args.slice(1).filter((arg, index, rest) => {
+    if (arg.startsWith('--')) return false;
+    const previous = rest[index - 1];
+    return previous !== '--out'
+      && previous !== '--parent-result'
+      && previous !== '--trusted-evidence-ref'
+      && previous !== '--host-trusted-evidence-ref';
+  });
+  return {
+    subcommand,
+    json,
+    input: positional[0],
+    result: positional[1],
+    out: out && !out.startsWith('--') ? out : undefined,
+    parentResult: parentResult && !parentResult.startsWith('--') ? parentResult : undefined,
+    maxWaves: Number.isFinite(parsedMaxWaves) && parsedMaxWaves! > 0 ? Math.floor(parsedMaxWaves!) : undefined,
+    trustedEvidenceRefs,
+    rawTrustedEvidenceRefs,
+  };
+}
+
+function usage(): string {
+  return [
+    'Usage:',
+    '  lev orchestration claim-gate-loop demo [--json] [--out <file>] [--max-waves=N]',
+    '  lev orchestration claim-gate-loop consume <council-wave.json> [--json] [--out <file>] [--parent-result <claim-gate-result.json>] [--host-trusted-evidence-ref <ref>...]',
+    '  lev orchestration claim-gate-loop repair-plan <council-wave.json> <claim-gate-result.json> [--json] [--out <file>]',
+    '  lev orchestration claim-gate-loop repair-dispatch-plan <repair-plan.json> [--json] [--out <file>]',
+    '  lev orchestration claim-gate-loop record-repair-dispatch-execution <dispatch-plan.json> <repair-council-wave.json> [--json] [--out <file>]',
+    '  lev orchestration claim-gate-loop admit-graph-patch <claim-gate-result.json> [--json] [--out <file>]',
+    '  lev orchestration claim-gate-loop apply-plan <claim-gate-result.json> <graph-admission.json> [--json] [--out <file>]',
+    '  lev orchestration claim-gate-loop apply-graph-patch <claim-gate-result.json> <graph-admission.json> [--json] [--out <file>]',
+    '  lev orchestration claim-gate-loop record-graph-execution <graph-apply-plan.json> <graph-patch-result.json> [--json] [--out <file>] [--host-trusted-evidence-ref <ref>...]',
+    '',
+    'Runs deterministic ClaimGate verify/reject/requeue over fixture or council-wave artifacts and emits receipt-backed graph patch or repair-wave proposals.',
+  ].join('\n');
+}
+
+function rawTrustedEvidenceRefResponse(refs: string[], json: boolean) {
+  const payload = {
+    error_code: 'RAW_TRUSTED_EVIDENCE_REF_DISABLED',
+    message: 'Use --host-trusted-evidence-ref after the host has resolved the receipt or graph-event authority. Raw trusted evidence refs are not accepted at the CLI boundary.',
+    refs,
+  };
+  return {
+    success: false,
+    formatted_response: json
+      ? JSON.stringify(payload, null, 2)
+      : [
+          'ClaimGate gate loop: raw trusted evidence refs disabled',
+          payload.message,
+          ...refs.map((ref) => `  - ${ref}`),
+        ].join('\n'),
+    data: payload,
+    error_code: payload.error_code,
+  };
+}
+
+function writeJson(file: string, value: unknown): void {
+  mkdirSync(dirname(file), { recursive: true });
+  writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+function invalidInputResponse(error: unknown, json: boolean) {
+  const message = error instanceof Error ? error.message : String(error);
+  const violations = error instanceof ClaimGateCouncilWaveInputError ? error.violations : [];
+  const payload = {
+    error_code: 'CLAIMGATE_LOOP_INVALID_INPUT',
+    message,
+    violations,
+  };
+  return {
+    success: false,
+    formatted_response: json
+      ? JSON.stringify(payload, null, 2)
+      : [
+          'ClaimGate gate loop: invalid council-wave artifact',
+          message,
+          ...violations.map((violation) => `  - ${violation.path}: ${violation.code} - ${violation.message}`),
+        ].join('\n'),
+    data: payload,
+    error_code: 'CLAIMGATE_LOOP_INVALID_INPUT',
+  };
+}
+
+function readJson<T>(file: string): T {
+  return JSON.parse(readFileSync(resolve(file), 'utf8')) as T;
+}
+
+function formatDemo(result: ReturnType<typeof runClaimGateLoopFixture>, out?: string): string {
+  return [
+    'ClaimGate gate loop: completed',
+    `Waves: ${result.waves.length}/${result.maxWaves}`,
+    `Accepted: ${result.graphPatchProposal.acceptedClaimIds.join(', ') || 'none'}`,
+    `Withheld: ${result.graphPatchProposal.withheldClaimIds.join(', ') || 'none'}`,
+    `Failure packets: ${result.failurePackets.length}`,
+    `Requeue events: ${result.requeueEvents.length}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function formatRepairPlan(result: ReturnType<typeof buildClaimGateRepairWavePlan>, out?: string): string {
+  return [
+    'ClaimGate repair wave plan: completed',
+    `Source session: ${result.sourceSessionId}`,
+    `Next wave: ${result.nextWave}`,
+    `Repair claims: ${result.repairClaims.length}`,
+    `Missing claims: ${result.missingClaimIds.join(', ') || 'none'}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function formatRepairDispatchPlan(result: ReturnType<typeof buildClaimGateRepairDispatchPlan>, out?: string): string {
+  return [
+    `ClaimGate repair dispatch plan: ${result.status}`,
+    `Source repair-plan receipt: ${result.sourceRepairPlanReceiptId}`,
+    `Dispatch requests: ${result.dispatchRequests.length}`,
+    `Findings: ${result.findings.length}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function formatRepairDispatchExecution(result: ReturnType<typeof recordClaimGateRepairDispatchExecution>, out?: string): string {
+  return [
+    `ClaimGate repair dispatch execution: ${result.status}`,
+    `Dispatch plan receipt: ${result.repairDispatchPlanReceiptId}`,
+    `Emitted claims: ${result.emittedClaimIds.join(', ') || 'none'}`,
+    `Missing claims: ${result.missingDispatchClaimIds.join(', ') || 'none'}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Findings: ${result.findings.length}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function formatGraphPatchAdmission(result: ReturnType<typeof consumeClaimGateGraphPatchProposal>, out?: string): string {
+  return [
+    `ClaimGate graph patch admission: ${result.status}`,
+    `Source receipt: ${result.sourceReceiptId}`,
+    `Accepted claims: ${result.acceptedClaimIds.join(', ') || 'none'}`,
+    `Withheld claims: ${result.withheldClaimIds.join(', ') || 'none'}`,
+    `Admitted operations: ${result.admittedOperationCount}`,
+    `Graph mutation applied: ${result.graphMutationApplied}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Findings: ${result.findings.length}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function formatGraphPatchApplyPlan(result: ReturnType<typeof buildClaimGateGraphPatchApplyPlan>, out?: string): string {
+  return [
+    `ClaimGate graph patch apply plan: ${result.status}`,
+    `Source receipt: ${result.sourceReceiptId}`,
+    `Admission receipt: ${result.admissionReceiptId}`,
+    `Accepted claims: ${result.acceptedClaimIds.join(', ') || 'none'}`,
+    `Withheld claims: ${result.withheldClaimIds.join(', ') || 'none'}`,
+    `Compiled graph operations: ${result.operationCount}`,
+    `Graph mutation applied: ${result.graphMutationApplied}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Findings: ${result.findings.length}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function formatGraphPatchExecution(result: ReturnType<typeof recordClaimGateGraphPatchExecution>, out?: string): string {
+  return [
+    `ClaimGate graph patch execution: ${result.status}`,
+    `Source receipt: ${result.sourceReceiptId}`,
+    `Admission receipt: ${result.admissionReceiptId}`,
+    `Apply plan receipt: ${result.applyPlanReceiptId}`,
+    `Graph event id: ${result.graphEventId ?? '(missing)'}`,
+    `Compiled graph operations: ${result.operationCount}`,
+    `Graph mutation applied: ${result.graphMutationApplied}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Findings: ${result.findings.length}`,
+    `Receipt: ${result.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function graphResultEventId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const data = result.data && typeof result.data === 'object' ? result.data : undefined;
+  return data?.graph_event_id ?? data?.graphEventId ?? result.graph_event_id ?? result.graphEventId;
+}
+
+async function applyGraphPatchThroughHost(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+): Promise<ClaimGateGraphPatchBridgeResult> {
+  const graphHandlers = await import('@lev-os/graph/handlers') as GraphPatchHandlerModule;
+  const graphResult = applyPlan.ok
+    ? await graphHandlers.patch([
+        '--operations',
+        JSON.stringify(applyPlan.graphOperations),
+        '--apply-plan-receipt-id',
+        applyPlan.receipt.id,
+      ]) as ClaimGateGraphPatchExecutionInput
+    : {
+        success: false,
+        status: 'skipped',
+        applied: 0,
+        apply_plan_receipt_id: applyPlan.receipt.id,
+        errors: ['apply_plan_blocked_before_graph_handler'],
+      };
+
+  const graphEventId = graphResultEventId(graphResult);
+  const execution = recordClaimGateGraphPatchExecution(applyPlan, graphResult, {
+    trustedEvidenceRefs: graphEventId ? [graphEventId] : [],
+  });
+
+  return {
+    kind: 'ClaimGateGraphPatchBridgeResult',
+    status: execution.status,
+    ok: execution.ok,
+    applyPlan,
+    graphResult,
+    execution,
+  };
+}
+
+function formatGraphPatchBridge(result: ClaimGateGraphPatchBridgeResult, out?: string): string {
