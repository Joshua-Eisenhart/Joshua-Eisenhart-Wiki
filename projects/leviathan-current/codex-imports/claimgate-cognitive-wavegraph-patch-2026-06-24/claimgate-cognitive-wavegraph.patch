+import { describe, expect, it } from 'vitest';
+import { createHash } from 'node:crypto';
+import { mkdtempSync, rmSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+import {
+  buildClaimGateGraphPatchApplyPlan,
+  buildClaimGateRepairDispatchPlan,
+  buildClaimGateRepairWavePlan,
+  ClaimGateCouncilWaveInputError,
+  consumeClaimGateGraphPatchProposal,
+  evaluateClaimGateLoopReopenRequest,
+  recordClaimGateRepairDispatchExecution,
+  recordClaimGateGraphPatchExecution,
+  type ClaimGateCouncilMemberCognitiveBinding,
+  type ClaimGateLoopState,
+  type ClaimGateCouncilWaveContract,
+  type ClaimGateCouncilWaveInput,
+  runClaimGateCouncilWaveLoop as runClaimGateCouncilWaveLoopImpl,
+  runClaimGateLoopFixture,
+  validateClaimGateCouncilWaveInput,
+} from './claim-gate-loop.js';
+
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function testWaveContract(overrides: Partial<ClaimGateCouncilWaveContract> = {}): ClaimGateCouncilWaveContract {
+  return {
+    owner: 'claim-gate-loop-test',
+    producerKind: 'test_council_wave',
+    expectedVerifier: 'claim-gate-loop',
+    requeueRule: 'repair_failed_claims_only',
+    nextAdmissibleState: 'repair_wave_plan',
+    claimCeiling: 'proposal_only_test_candidate',
+    ...overrides,
+  };
+}
+
+function testCognitiveBinding(
+  overrides: Partial<ClaimGateCouncilMemberCognitiveBinding> = {},
+): ClaimGateCouncilMemberCognitiveBinding {
+  return {
+    mmmRefs: ['dna:graph', 'dna:vernacular'],
+    skillRefs: ['skill:claim-gate-test'],
+    sourceRefs: ['source:claim-gate-loop-test'],
+    inputContractRefs: ['contract:ClaimGateCouncilWaveInput'],
+    outputContractRefs: ['contract:ClaimGateCouncilWaveClaim'],
+    gateContractRefs: ['gate:claim-gate-loop'],
+    requeuePolicyRef: 'repair_failed_claims_only',
+    ...overrides,
+  };
+}
+
+const TRUSTED_TEST_EVIDENCE_REFS = [
+  'receipt:rcpt-object-bound',
+  'receipt:rcpt-manifest-clean',
+  'receipt:rcpt-manifest-repairable',
+  'receipt:rcpt-manifest-extra',
+  'receipt:rcpt-manifest-duplicate',
+  'receipt:rcpt-manifest-bound',
+  'receipt:rcpt-manifest-contract',
+  'receipt:rcpt-manifest-accepted',
+  'receipt:rcpt-falsifier-bound',
+];
+
+function runTrustedClaimGateCouncilWaveLoop(
+  input: ClaimGateCouncilWaveInput,
+  options: Parameters<typeof runClaimGateCouncilWaveLoopImpl>[1] = {},
+) {
+  return runClaimGateCouncilWaveLoopImpl(input, {
+    ...options,
+    trustedEvidenceRefs: [
+      ...TRUSTED_TEST_EVIDENCE_REFS,
+      ...(options.trustedEvidenceRefs ?? []),
+    ],
+  });
+}
+
+const runClaimGateCouncilWaveLoop = runTrustedClaimGateCouncilWaveLoop;
+
+describe('ClaimGate deterministic gate loop fixture', () => {
+  it('passes clean claims, requeues repairable failures, and withholds terminal failures from graph patch proposals', () => {
+    const result = runClaimGateLoopFixture({
+      sessionId: 'claim-gate-loop-test',
+      workstreamId: 'ws-claim-gate-loop',
+    });
+
+    expect(result.waves.map((wave) => wave.dispatchedClaimIds)).toEqual([
+      ['C1', 'C2', 'C3'],
+      ['C2', 'C3'],
+    ]);
+    expect(result.graphPatchProposal.acceptedClaimIds).toEqual(['C1', 'C2']);
+    expect(result.graphPatchProposal.withheldClaimIds).toEqual(['C3']);
+    expect(result.graphPatchProposal.operations.map((operation) => operation.claimId)).toEqual(['C1', 'C2']);
+  });
+
+  it('emits actionable failure packets and only requeues failed items', () => {
+    const result = runClaimGateLoopFixture();
+
+    expect(result.failurePackets.map((packet) => packet.packetId)).toEqual([
+      'fp-C2-w1',
+      'fp-C3-w1',
+      'fp-C3-w2',
+    ]);
+    expect(result.requeueEvents).toEqual([
+      { fromWave: 1, toWave: 2, claimId: 'C2', failurePacketId: 'fp-C2-w1' },
+      { fromWave: 1, toWave: 2, claimId: 'C3', failurePacketId: 'fp-C3-w1' },
+    ]);
+    expect(result.requeueEvents.some((event) => event.claimId === 'C1')).toBe(false);
+
+    const terminalPacket = result.failurePackets.find((packet) => packet.packetId === 'fp-C3-w2');
+    expect(terminalPacket?.retryPatch).toBeNull();
+    expect(terminalPacket?.graveyardReason).toBe('max_passes_exceeded');
+    expect(terminalPacket?.evidenceRefs.length).toBeGreaterThan(0);
+  });
+
+  it('seals a Lev receipt covering the bounded loop result', () => {
+    const result = runClaimGateLoopFixture({
+      sessionId: 'claim-gate-loop-receipt-test',
+      workstreamId: 'ws-loop-receipt',
+    });
+
+    expect(result.receipt.scope).toBe('session');
+    expect(result.receipt.sessionId).toBe('claim-gate-loop-receipt-test');
+    expect(result.receipt.workstreamId).toBe('ws-loop-receipt');
+    expect(result.receipt.workUnitId).toBe('claim-gate-loop-fixture');
+    expect(result.receipt.contentHash).toMatch(/^sha256:/);
+    expect(result.receipt.evalResults[0].passed).toBe(true);
+    expect(result.receipt.evalResults[0].metadata).toMatchObject({
+      acceptedClaimIds: ['C1', 'C2'],
+      withheldClaimIds: ['C3'],
+      failurePacketCount: 3,
+      requeueCount: 2,
+      leakedTerminalClaims: [],
+    });
+  });
+
+  it('seals explicit deterministic pass conditions instead of prose-only gate clean', () => {
+    const result = runClaimGateCouncilWaveLoop({
+      sessionId: 'claim-gate-explicit-pass-conditions',
+      waves: [
+        {
+          wave: 1,
+          contract: testWaveContract(),
+          claims: [
+            {
+              claimId: 'EXPLICIT_CONTRACT_CLEAN',
+              payload: 'all hard gates pass with host-trusted evidence',
+              gateChecks: [
+                { gateId: 'object_binding', status: 'pass', evidenceRefs: ['receipt:rcpt-object-bound'] },
+                { gateId: 'evidence_manifest', status: 'pass', evidenceRefs: ['receipt:rcpt-manifest-clean'] },
+                { gateId: 'falsifier', status: 'pass', evidenceRefs: ['receipt:rcpt-falsifier-bound'] },
+              ],
+            },
+          ],
+        },
+      ],
+    });
+
+    expect(result.passConditionContract).toEqual({
+      kind: 'ClaimGateDeterministicPassConditionContract',
+      requiredGateIds: ['object_binding', 'evidence_manifest', 'falsifier'],
+      sourceBoundRequiredGateIds: ['object_binding', 'evidence_manifest', 'falsifier'],
+      evidencePolicy: 'host_trusted_receipt_or_hash_bound_file',
+      requeuePolicy: 'failed_claims_only',
+      terminalWithholdPolicy: 'withhold_failed_claims_after_max_waves',
+      graphPatchPolicy: 'accepted_claims_only_proposal_operations',
+      claimCeiling: 'deterministic_pass_conditions_fixture_level',
+    });
+    expect(result.receipt.evalResults[0].metadata).toMatchObject({
+      passConditionContract: result.passConditionContract,
+      deterministicClean: true,
+      terminalWithheldClaimIds: [],
+    });
+  });
+
+  it('consumes council-wave gate outputs without letting council consensus promote failed gates', () => {
+    const input: ClaimGateCouncilWaveInput = {
+      sessionId: 'claim-gate-council-wave-test',
+      workstreamId: 'ws-council-wave',
+      waves: [
+        {
+          wave: 1,
+          contract: testWaveContract(),
+          claims: [
+            {
+              claimId: 'CLEAN',
+              payload: 'accepted council branch',
+              producer: 'decision.source_bound_checklist',
+              gateChecks: [
