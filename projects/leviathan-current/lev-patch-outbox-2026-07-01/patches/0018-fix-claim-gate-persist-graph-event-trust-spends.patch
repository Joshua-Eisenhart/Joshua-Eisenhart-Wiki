+  it('blocks replay of a spent host-trusted graph event across process boundaries', () => {
+    const root = mkdtempSync(join(tmpdir(), 'claim-gate-graph-event-spend-'));
+    const previousSecretPath = process.env.LEV_HOST_TRUST_SECRET_PATH;
+    try {
+      process.env.LEV_HOST_TRUST_SECRET_PATH = join(root, 'host-trust-root-secret');
+      resetHostTrustRootSecretCacheForTests();
+      const ledgerPath = join(root, 'graph-event-trust.jsonl');
+      const result = runClaimGateLoopFixture({ sessionId: 'claim-gate-graph-execution-replay' });
+      const admission = consumeClaimGateGraphPatchProposal(result);
+      const applyPlan = buildClaimGateGraphPatchApplyPlan(result, admission);
+      const graphResult = {
+        success: true,
+        data: {
+          status: 'applied',
+          applied: applyPlan.operationCount,
+          apply_plan_receipt_id: applyPlan.receipt.id,
+          graph_event_id: 'ge-claim-gate-replay-spend',
+        },
+      };
+
+      const first = recordHostClaimGateGraphPatchExecution(applyPlan, graphResult, {
+        hostGraphEventTrustLedgerPath: ledgerPath,
+      });
+      resetHostTrustRootSecretCacheForTests();
+      const replayGraphResultPath = join(root, 'graph-result-replay.json');
+      writeFileSync(replayGraphResultPath, `${JSON.stringify(graphResult, null, 2)}\n`);
+      const replayGraphResult = JSON.parse(readFileSync(replayGraphResultPath, 'utf8')) as typeof graphResult;
+      const replay = recordClaimGateGraphPatchExecution(applyPlan, replayGraphResult, {
+        hostGraphEventTrustLedgerPath: ledgerPath,
+      });
+
+      expect(first.ok).toBe(true);
+      expect(first.status).toBe('graph_patch_executed');
+      expect(replay.ok).toBe(false);
+      expect(replay.status).toBe('graph_patch_blocked');
+      expect(replay.graphMutationApplied).toBe(false);
+      expect(replay.findings.map((finding) => finding.code)).toEqual([
+        'graph_execution.graph_event_trust_spent',
+        'graph_execution.graph_event_untrusted',
+      ]);
+      expect(replay.receipt.evalResults[0].passed).toBe(false);
+    } finally {
+      if (previousSecretPath === undefined) delete process.env.LEV_HOST_TRUST_SECRET_PATH;
+      else process.env.LEV_HOST_TRUST_SECRET_PATH = previousSecretPath;
+      resetHostTrustRootSecretCacheForTests();
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
