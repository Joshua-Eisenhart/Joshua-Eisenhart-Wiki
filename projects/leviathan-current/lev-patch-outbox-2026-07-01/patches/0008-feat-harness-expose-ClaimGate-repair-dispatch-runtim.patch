@@ -0,0 +1,343 @@
+import { describe, expect, it } from 'vitest';
+
+import {
+  buildClaimGateRepairDispatchPlan,
+  buildClaimGateRepairWavePlan,
+  runClaimGateCouncilWaveLoop,
+  type ClaimGateCouncilMemberCognitiveBinding,
+  type ClaimGateCouncilWaveContract,
+  type ClaimGateCouncilWaveInput,
+} from '@lev-os/orchestration';
+import type { ExecutionRunRequest, ExecutionRunResponse } from '@lev-os/domain';
+
+import {
+  buildClaimGateRepairRuntimeExecutionRequests,
+  executeClaimGateRepairDispatchPlan,
+} from './claim-gate-repair-dispatch.js';
+
+function testWaveContract(overrides: Partial<ClaimGateCouncilWaveContract> = {}): ClaimGateCouncilWaveContract {
+  return {
+    owner: 'harness.claim-gate-repair-dispatch-test',
+    producerKind: 'test_council_wave',
+    expectedVerifier: 'claim-gate-loop',
+    requeueRule: 'repair_failed_claims_only',
+    nextAdmissibleState: 'repair_wave_plan',
+    claimCeiling: 'proposal_only_council_candidate_not_admission',
+    ...overrides,
+  };
+}
+
+function testCognitiveBinding(
+  skillRefs: string[],
+  sourceRefs: string[] = ['source:harness-claim-gate-repair-dispatch-test'],
+): ClaimGateCouncilMemberCognitiveBinding {
+  return {
+    mmmRefs: ['dna:graph', 'dna:vernacular'],
+    skillRefs,
+    sourceRefs,
+    inputContractRefs: ['contract:ClaimGateCouncilWaveInput'],
+    outputContractRefs: ['contract:ClaimGateCouncilWaveClaim'],
+    gateContractRefs: ['gate:claim-gate-loop', 'gate:claim-gate-repair-dispatch'],
+    requeuePolicyRef: 'repair_failed_claims_only',
+  };
+}
+
+function makeDispatchPlan(claimIds: string[] = ['REPAIR_ME']) {
+  const memberIds = claimIds.map((claimId, index) => (
+    claimIds.length === 1 ? 'failure.premortem' : `failure.premortem.${index + 1}`
+  ));
+  const input: ClaimGateCouncilWaveInput = {
+    kind: 'ClaimGateCouncilWaveInput',
+    sessionId: 'harness-claim-gate-repair-dispatch-source',
+    waves: [
+      {
+        wave: 1,
+        contract: testWaveContract(),
+        members: [
+          ...memberIds.map((memberId) => ({
+            memberId,
+            kind: 'premortem',
+            role: 'failure premortem lane',
+            skillRefs: ['skill:premortem'],
+            cognitiveBinding: testCognitiveBinding(['skill:premortem'], [
+              'source:harness-claim-gate-repair-dispatch-test',
+              `member:${memberId}`,
+            ]),
+          } as const)),
+        ],
+        claims: claimIds.map((claimId, index) => ({
+            claimId,
+            payload: 'candidate missing source-bound evidence manifest',
+            memberId: memberIds[index],
+            gateChecks: [
+              { gateId: 'object_binding', status: 'pass', evidenceRefs: ['receipt:object-bound'] },
+              { gateId: 'evidence_manifest', status: 'fail', reason: 'manifest missing', evidenceRefs: ['artifact:missing'] },
+              { gateId: 'falsifier', status: 'pass', evidenceRefs: ['receipt:falsifier-bound'] },
+            ],
+          })),
+      },
+    ],
+  };
+  const result = runClaimGateCouncilWaveLoop(input);
+  const repairPlan = buildClaimGateRepairWavePlan(input, result);
+  return buildClaimGateRepairDispatchPlan(repairPlan);
+}
+
+function repairWaveFor(dispatchPlan: ReturnType<typeof makeDispatchPlan>): ClaimGateCouncilWaveInput {
+  const request = dispatchPlan.dispatchRequests[0]!;
+  return repairWaveForRequest(request);
+}
+
+function repairWaveForRequest(request: ReturnType<typeof makeDispatchPlan>['dispatchRequests'][number]): ClaimGateCouncilWaveInput {
+  return {
+    kind: 'ClaimGateCouncilWaveInput',
+    sessionId: 'harness-claim-gate-repair-dispatch-runtime-output',
+    waves: [
+      {
+        wave: 2,
+        contract: testWaveContract({
+          owner: 'harness.claim-gate-repair-dispatch-runtime',
+          producerKind: 'repair_dispatch_runtime',
+          nextAdmissibleState: 'claim_gate_loop_consume_parent_result',
+        }),
+        members: [request.sourceMember],
+        claims: [
+          {
+            claimId: request.claimId,
+            payload: 'repair emitted source-bound evidence manifest',
+            memberId: request.sourceMemberId,
+            repairOf: request.requiredInputs.repairOf,
+            gateChecks: [
+              { gateId: 'object_binding', status: 'pass', evidenceRefs: ['receipt:object-bound'] },
+              { gateId: 'evidence_manifest', status: 'pass', evidenceRefs: ['receipt:manifest-bound'] },
+              { gateId: 'falsifier', status: 'pass', evidenceRefs: ['receipt:falsifier-bound'] },
+            ],
+          },
+        ],
+      },
+    ],
+  };
+}
+
+describe('ClaimGate repair dispatch runtime bridge', () => {
+  it('materializes Lev exec requests without pretending dry-run is execution', async () => {
+    const dispatchPlan = makeDispatchPlan();
+    const requests = buildClaimGateRepairRuntimeExecutionRequests(dispatchPlan, {
+      rootPath: '/tmp/lev-claim-gate-test',
+    });
+
+    expect(requests).toHaveLength(1);
+    expect(requests[0]).toMatchObject({
+      claimId: 'REPAIR_ME',
+      sourceMemberId: 'failure.premortem',
+      targetRef: 'skill:premortem',
+      outputContract: {
+        kind: 'ClaimGateCouncilWaveInput',
+        requiredClaimId: 'REPAIR_ME',
+      },
+    });
+    expect(requests[0]!.executionRequest.operation).toBe('claim_gate_repair_dispatch');
+    expect(requests[0]!.executionRequest.input).toMatchObject({
+      rootPath: '/tmp/lev-claim-gate-test',
+      adapter: 'sdk',
+      harness: 'sdk',
+      profile: 'premortem',
+      externalDispatchBoundary: 'claim_gate_repair_dispatch_candidate_only',
+    });
+
+    const run = await executeClaimGateRepairDispatchPlan(dispatchPlan, {
+      execute: false,
+      rootPath: '/tmp/lev-claim-gate-test',
+    });
+
+    expect(run.status).toBe('dispatch_planned');
+    expect(run.ok).toBe(true);
+    expect(run.claimCeiling).toBe('repair_dispatch_runtime_requests_only');
+    expect(run.results).toEqual([
+      expect.objectContaining({
+        claimId: 'REPAIR_ME',
+        status: 'planned',
+      }),
+    ]);
+    expect(run.repairDispatchExecution).toBeUndefined();
+    expect(run.receipt.evalResults[0]!.passed).toBe(true);
+  });
+
+  it('materializes explicit model and adapter steering for sparse provider repair lanes', () => {
+    const dispatchPlan = makeDispatchPlan();
+    const requests = buildClaimGateRepairRuntimeExecutionRequests(dispatchPlan, {
+      rootPath: '/tmp/lev-claim-gate-test',
+      adapter: 'ai-sdk',
+      harness: 'sdk',
+      model: 'z-ai/glm-5.2',
+      workstreamId: 'claim-gate-runtime-shakedown',
+    });
+
+    expect(requests).toHaveLength(1);
+    expect(requests[0]!.executionRequest.input).toMatchObject({
+      adapter: 'ai-sdk',
+      harness: 'sdk',
+      model: 'z-ai/glm-5.2',
+      workstream: 'claim-gate-runtime-shakedown',
+      profile: 'premortem',
+      externalDispatchBoundary: 'claim_gate_repair_dispatch_candidate_only',
+    });
+  });
+
+  it('executes via injected Lev exec transport and seals dispatch execution when a repair wave is emitted', async () => {
+    const dispatchPlan = makeDispatchPlan();
+    const repairWave = repairWaveFor(dispatchPlan);
+    const seenRequests: ExecutionRunRequest[] = [];
+    const runner = async (request: ExecutionRunRequest): Promise<ExecutionRunResponse> => {
+      seenRequests.push(request);
+      return {
+        status: 'EXECUTION_STATUS_SUCCEEDED',
+        output: {
+          output: JSON.stringify(repairWave),
+        },
+        usage: {
+          total_tokens: 123,
+        },
+      };
+    };
+
+    const run = await executeClaimGateRepairDispatchPlan(dispatchPlan, {
+      execute: true,
+      rootPath: '/tmp/lev-claim-gate-test',
+      runExecutionRequest: runner,
+    });
+
+    expect(seenRequests).toHaveLength(1);
+    expect(seenRequests[0]!.input).toMatchObject({
+      profile: 'premortem',
+      externalContextMode: 'minimal',
+      externalDispatchBoundary: 'claim_gate_repair_dispatch_candidate_only',
+    });
+    expect(run.status).toBe('dispatch_executed');
+    expect(run.ok).toBe(true);
+    expect(run.claimCeiling).toBe('repair_dispatch_runtime_invoked_requires_claim_gate_consumption');
+    expect(run.results[0]).toMatchObject({
+      claimId: 'REPAIR_ME',
+      status: 'succeeded',
+      executionStatus: 'EXECUTION_STATUS_SUCCEEDED',
+    });
+    expect(run.repairWaveInput?.waves[0]?.claims.map((claim) => claim.claimId)).toEqual(['REPAIR_ME']);
+    expect(run.repairDispatchExecution?.status).toBe('repair_dispatch_executed');
+    expect(run.repairDispatchExecution?.emittedClaimIds).toEqual(['REPAIR_ME']);
+    expect(run.repairDispatchExecution?.receipt.evalResults[0]!.passed).toBe(true);
+    expect(run.receipt.evalResults[0]!.passed).toBe(true);
+  });
+
+  it('executes injected repair requests with bounded concurrency', async () => {
+    const dispatchPlan = makeDispatchPlan(['REPAIR_1', 'REPAIR_2', 'REPAIR_3', 'REPAIR_4']);
+    let active = 0;
+    let maxActive = 0;
+    const seenClaims: string[] = [];
+    const runner = async (request: ExecutionRunRequest): Promise<ExecutionRunResponse> => {
+      const claimId = (request.input.variables as { claimId?: string } | undefined)?.claimId;
+      const dispatchRequest = dispatchPlan.dispatchRequests.find((candidate) => candidate.claimId === claimId);
+      if (!dispatchRequest) throw new Error(`missing dispatch request for ${claimId}`);
+      seenClaims.push(dispatchRequest.claimId);
+      active++;
+      maxActive = Math.max(maxActive, active);
+      await new Promise((resolve) => setTimeout(resolve, 20));
+      active--;
+      return {
+        status: 'EXECUTION_STATUS_SUCCEEDED',
+        output: {
+          output: JSON.stringify(repairWaveForRequest(dispatchRequest)),
+        },
+      };
+    };
+
+    const run = await executeClaimGateRepairDispatchPlan(dispatchPlan, {
+      execute: true,
+      concurrency: 3,
+      runExecutionRequest: runner,
+    });
+
+    expect(run.concurrency).toBe(3);
+    expect(maxActive).toBeGreaterThan(1);
+    expect(seenClaims.sort()).toEqual(['REPAIR_1', 'REPAIR_2', 'REPAIR_3', 'REPAIR_4']);
+    expect(run.status).toBe('dispatch_executed');
+    expect(run.ok).toBe(true);
+    expect(run.results).toHaveLength(4);
+    expect(run.repairDispatchExecution?.emittedClaimIds.sort()).toEqual([
+      'REPAIR_1',
+      'REPAIR_2',
+      'REPAIR_3',
+      'REPAIR_4',
+    ]);
+    expect(run.receipt.evalResults[0]!.metadata).toMatchObject({
+      concurrency: 3,
+      requestCount: 4,
+      resultCount: 4,
+    });
+  });
+
+  it('fails closed when runtime output is not a ClaimGate council-wave JSON object', async () => {
+    const dispatchPlan = makeDispatchPlan();
+
+    const run = await executeClaimGateRepairDispatchPlan(dispatchPlan, {
+      execute: true,
+      runExecutionRequest: async () => ({
+        status: 'EXECUTION_STATUS_SUCCEEDED',
+        output: {
+          output: 'not json',
+        },
+      }),
+    });
+
+    expect(run.status).toBe('dispatch_blocked');
+    expect(run.ok).toBe(false);
+    expect(run.results[0]).toMatchObject({
+      claimId: 'REPAIR_ME',
+      status: 'parse_failed',
+    });
+    expect(run.findings).toEqual([
+      expect.objectContaining({
+        code: 'repair_dispatch_runtime.output_parse_failed',
+        claimId: 'REPAIR_ME',
+      }),
+    ]);
+    expect(run.repairDispatchExecution).toBeUndefined();
+    expect(run.receipt.evalResults[0]!.passed).toBe(false);
+  });
+
+  it('fails closed and preserves worker failure reasons for requeue signal', async () => {
+    const dispatchPlan = makeDispatchPlan();
+
+    const run = await executeClaimGateRepairDispatchPlan(dispatchPlan, {
+      execute: true,
+      runExecutionRequest: async () => ({
+        status: 'EXECUTION_STATUS_FAILED',
+        error: {
+          code: 'EXECUTION_FAILED',
+          message: 'Claude Code returned an error result: Not logged in',
+        },
+        output: {
+          output: 'Error: Claude Code returned an error result: Not logged in',
+        },
+      }),
+    });
+
+    expect(run.status).toBe('dispatch_blocked');
+    expect(run.ok).toBe(false);
+    expect(run.results[0]).toMatchObject({
+      claimId: 'REPAIR_ME',
+      status: 'failed',
+      executionStatus: 'EXECUTION_STATUS_FAILED',
+      error: 'Claude Code returned an error result: Not logged in',
+      output: 'Error: Claude Code returned an error result: Not logged in',
+    });
+    expect(run.findings).toEqual([
+      expect.objectContaining({
+        code: 'repair_dispatch_runtime.execution_failed',
+        message: 'Claude Code returned an error result: Not logged in',
+        claimId: 'REPAIR_ME',
+      }),
+    ]);
+    expect(run.repairDispatchExecution).toBeUndefined();
+    expect(run.receipt.evalResults[0]!.passed).toBe(false);
+  });
+});
