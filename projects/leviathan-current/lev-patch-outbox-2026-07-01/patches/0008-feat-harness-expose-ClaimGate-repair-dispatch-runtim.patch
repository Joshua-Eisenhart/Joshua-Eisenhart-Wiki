+import { createHash } from 'node:crypto';
+
+import {
+  getExecTransport,
+  type ExecutionRunRequest,
+  type ExecutionRunResponse,
+} from '@lev-os/domain';
+import {
+  createReceipt,
+  type EvalResult,
+  type Receipt,
+} from '@lev-os/orchestration';
+import {
+  recordClaimGateRepairDispatchExecution,
+  type ClaimGateCouncilWave,
+  type ClaimGateCouncilWaveClaim,
+  type ClaimGateCouncilWaveInput,
+  type ClaimGateCouncilWaveMember,
+  type ClaimGateRepairDispatchExecutionReceipt,
+  type ClaimGateRepairDispatchPlan,
+  type ClaimGateRepairDispatchRequest,
+} from '@lev-os/orchestration/proof/claim-gate-loop';
+
+export type ClaimGateRepairDispatchRuntimeStatus =
+  | 'dispatch_planned'
+  | 'dispatch_executed'
+  | 'dispatch_blocked';
+
+export interface ClaimGateRepairRuntimeExecutionRequest {
+  requestId: string;
+  claimId: string;
+  sourceMemberId: string;
+  targetRef: string;
+  executionRequest: ExecutionRunRequest;
+  outputContract: {
+    kind: 'ClaimGateCouncilWaveInput';
+    requiredClaimId: string;
+    requiredRepairOf: ClaimGateRepairDispatchRequest['requiredInputs']['repairOf'];
+  };
+}
+
+export interface ClaimGateRepairRuntimeExecutionResult {
+  requestId: string;
+  claimId: string;
+  status: 'planned' | 'succeeded' | 'failed' | 'timeout' | 'parse_failed';
+  executionStatus?: ExecutionRunResponse['status'];
+  output?: string;
+  error?: string;
+}
+
+export interface ClaimGateRepairDispatchRuntimeFinding {
+  severity: 'error' | 'warning';
+  code: string;
+  message: string;
+  requestId?: string;
+  claimId?: string;
+}
+
+export interface ExecuteClaimGateRepairDispatchPlanOptions {
+  execute?: boolean;
+  rootPath?: string;
+  model?: string;
+  adapter?: string;
+  harness?: string;
+  workstreamId?: string;
+  timeoutMs?: number;
+  concurrency?: number;
+  sessionId?: string;
+  runExecutionRequest?: (request: ExecutionRunRequest) => Promise<ExecutionRunResponse>;
+}
+
+export interface ClaimGateRepairDispatchRuntimeRun {
+  kind: 'ClaimGateRepairDispatchRuntimeRun';
+  sessionId: string;
+  sourceRepairDispatchPlanReceiptId: string;
+  status: ClaimGateRepairDispatchRuntimeStatus;
+  ok: boolean;
+  execute: boolean;
+  concurrency: number;
+  claimCeiling:
+    | 'repair_dispatch_runtime_requests_only'
+    | 'repair_dispatch_runtime_invoked_requires_claim_gate_consumption';
+  requests: ClaimGateRepairRuntimeExecutionRequest[];
+  results: ClaimGateRepairRuntimeExecutionResult[];
+  findings: ClaimGateRepairDispatchRuntimeFinding[];
+  repairWaveInput?: ClaimGateCouncilWaveInput;
+  repairDispatchExecution?: ClaimGateRepairDispatchExecutionReceipt;
+  receipt: Receipt;
+}
+
+function stableStringify(value: unknown): string {
+  if (value === undefined) return '"__undefined__"';
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? 'null';
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record)
+    .sort()
+    .map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`)
+    .join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return createHash('sha256').update(stableStringify(value)).digest('hex');
+}
+
+function addFinding(
+  findings: ClaimGateRepairDispatchRuntimeFinding[],
+  severity: ClaimGateRepairDispatchRuntimeFinding['severity'],
+  code: string,
+  message: string,
+  request?: Pick<ClaimGateRepairDispatchRequest, 'requestId' | 'claimId'>,
+): void {
+  findings.push({
+    severity,
+    code,
+    message,
+    ...(request ? { requestId: request.requestId, claimId: request.claimId } : {}),
+  });
+}
+
+function profileForTarget(request: ClaimGateRepairDispatchRequest): string | undefined {
+  if (request.target.ref === 'skill:codex-autoresearch') return 'codex-autoresearch';
+  if (request.target.ref === 'skill:premortem') return 'premortem';
+  if (request.target.ref.startsWith('skill:cdo')) return 'cdo';
+  if (request.target.ref.startsWith('skill:three-council-wizard')) return 'three-council-wizard-v4-3';
+  if (request.target.ref.startsWith('profile:')) return request.target.ref.slice('profile:'.length);
+  return undefined;
+}
+
+function taskPromptForRequest(request: ClaimGateRepairDispatchRequest): string {
+  return [
+    'You are executing one bounded ClaimGate repair dispatch request.',
+    '',
+    'Your output must be exactly one JSON object of kind ClaimGateCouncilWaveInput.',
+    'Do not output prose outside the JSON object.',
+    '',
+    'Required output contract:',
+    JSON.stringify({
+      kind: 'ClaimGateCouncilWaveInput',
+      wave: '<next repair wave>',
+      requiredClaimId: request.claimId,
+      requiredMemberId: request.sourceMemberId,
+      requiredRepairOf: request.requiredInputs.repairOf,
+      requiredGateChecks: request.requiredInputs.violatedGates,
+      ceiling: 'repair_candidate_only_must_return_to_claim_gate_loop_consume',
+    }, null, 2),
+    '',
+    'Dispatch request:',
+    JSON.stringify(request, null, 2),
+  ].join('\n');
+}
+
+export function buildClaimGateRepairRuntimeExecutionRequests(
+  dispatchPlan: ClaimGateRepairDispatchPlan,
+  options: ExecuteClaimGateRepairDispatchPlanOptions = {},
+): ClaimGateRepairRuntimeExecutionRequest[] {
+  return dispatchPlan.dispatchRequests.map((request) => {
+    const profile = profileForTarget(request);
+    const input: Record<string, unknown> = {
+      task: taskPromptForRequest(request),
+      rootPath: options.rootPath ?? process.cwd(),
+      adapter: options.adapter ?? 'sdk',
+      harness: options.harness ?? 'sdk',
+      externalContextMode: 'minimal',
+      externalDispatchBoundary: 'claim_gate_repair_dispatch_candidate_only',
+      variables: {
+        claimId: request.claimId,
+        failurePacketId: request.failurePacketId,
+        sourceMemberId: request.sourceMemberId,
+        targetRef: request.target.ref,
+      },
+    };
+    if (options.model) input.model = options.model;
+    if (options.workstreamId) input.workstream = options.workstreamId;
+    if (profile) input.profile = profile;
+
+    return {
+      requestId: request.requestId,
+      claimId: request.claimId,
+      sourceMemberId: request.sourceMemberId,
+      targetRef: request.target.ref,
+      executionRequest: {
+        operation: 'claim_gate_repair_dispatch',
+        input,
+        target: {
+          surface: 'harness',
+          capability: 'exec',
+          options: {
+            requestId: request.requestId,
+            targetRef: request.target.ref,
+          },
+        },
+        timeoutMs: options.timeoutMs,
+      },
+      outputContract: {
+        kind: 'ClaimGateCouncilWaveInput',
+        requiredClaimId: request.claimId,
+        requiredRepairOf: request.requiredInputs.repairOf,
+      },
+    };
+  });
+}
+
+function extractOutput(response: ExecutionRunResponse): string {
+  const output = response.output?.output;
+  return typeof output === 'string' ? output : '';
+}
+
+function parseJsonObject(text: string): unknown {
+  const trimmed = text.trim();
+  if (trimmed.startsWith('{') && trimmed.endsWith('}')) {
+    return JSON.parse(trimmed);
+  }
+  const start = trimmed.indexOf('{');
+  const end = trimmed.lastIndexOf('}');
+  if (start >= 0 && end > start) {
+    return JSON.parse(trimmed.slice(start, end + 1));
+  }
+  throw new Error('output did not contain a JSON object');
+}
+
+function normalizedConcurrency(value: number | undefined, requestCount: number): number {
+  if (requestCount <= 0) return 0;
+  const n = Math.floor(Number.isFinite(value) ? Number(value) : requestCount);
+  return Math.max(1, Math.min(requestCount, n));
+}
+
+let defaultExecTransportBooted = false;
+async function ensureDefaultExecTransport(): Promise<void> {
+  if (defaultExecTransportBooted) return;
+  const polyModuleName = '@lev-os/poly';
+  await import(polyModuleName);
+  defaultExecTransportBooted = true;
+}
+
+async function executeRuntimeRequest(
+  runtimeRequest: ClaimGateRepairRuntimeExecutionRequest,
+  runner: (request: ExecutionRunRequest) => Promise<ExecutionRunResponse>,
+): Promise<{
+  result: ClaimGateRepairRuntimeExecutionResult;
+  repairWaveInput?: ClaimGateCouncilWaveInput;
+  findings: ClaimGateRepairDispatchRuntimeFinding[];
+}> {
+  const findings: ClaimGateRepairDispatchRuntimeFinding[] = [];
+
+  try {
+    const response = await runner(runtimeRequest.executionRequest);
+    const output = extractOutput(response);
+    if (response.status !== 'EXECUTION_STATUS_SUCCEEDED') {
+      addFinding(
+        findings,
+        'error',
+        'repair_dispatch_runtime.execution_failed',
+        response.error?.message ?? `Execution failed with ${response.status}.`,
+        runtimeRequest,
+      );
+      return {
+        findings,
+        result: {
+          requestId: runtimeRequest.requestId,
+          claimId: runtimeRequest.claimId,
+          status: response.status === 'EXECUTION_STATUS_TIMEOUT' ? 'timeout' : 'failed',
+          executionStatus: response.status,
+          output,
+          error: response.error?.message,
+        },
+      };
+    }
+
+    try {
+      const parsed = parseJsonObject(output) as ClaimGateCouncilWaveInput;
+      return {
+        findings,
+        repairWaveInput: parsed,
+        result: {
+          requestId: runtimeRequest.requestId,
+          claimId: runtimeRequest.claimId,
+          status: 'succeeded',
+          executionStatus: response.status,
+          output,
+        },
+      };
+    } catch (error) {
+      addFinding(
+        findings,
+        'error',
+        'repair_dispatch_runtime.output_parse_failed',
+        error instanceof Error ? error.message : String(error),
+        runtimeRequest,
+      );
+      return {
+        findings,
+        result: {
+          requestId: runtimeRequest.requestId,
+          claimId: runtimeRequest.claimId,
+          status: 'parse_failed',
+          executionStatus: response.status,
+          output,
+          error: error instanceof Error ? error.message : String(error),
+        },
+      };
+    }
+  } catch (error) {
+    addFinding(
+      findings,
+      'error',
+      'repair_dispatch_runtime.runner_threw',
+      error instanceof Error ? error.message : String(error),
+      runtimeRequest,
+    );
+    return {
+      findings,
+      result: {
+        requestId: runtimeRequest.requestId,
+        claimId: runtimeRequest.claimId,
+        status: 'failed',
+        error: error instanceof Error ? error.message : String(error),
+      },
+    };
+  }
+}
+
+function mergeRepairWaveInputs(inputs: ClaimGateCouncilWaveInput[], sessionId: string): ClaimGateCouncilWaveInput {
+  const memberMap = new Map<string, ClaimGateCouncilWaveMember>();
+  const claimMap = new Map<string, ClaimGateCouncilWaveClaim>();
+  let waveNumber = 1;
+  let contract: ClaimGateCouncilWave['contract'] | undefined;
+
+  for (const input of inputs) {
+    for (const wave of input.waves) {
+      waveNumber = Math.max(waveNumber, wave.wave);
+      contract ??= wave.contract;
+      for (const member of wave.members ?? []) memberMap.set(member.memberId, member);
+      for (const claim of wave.claims) claimMap.set(claim.claimId, claim);
+    }
+  }
+
+  if (!contract) {
+    contract = {
+      owner: 'harness.claim-gate-repair-dispatch',
+      producerKind: 'repair_dispatch_runtime',
+      expectedVerifier: 'claim-gate-loop',
+      requeueRule: 'repair_failed_claims_only',
+      nextAdmissibleState: 'claim_gate_loop_consume_parent_result',
+      claimCeiling: 'repair_candidate_only_must_return_to_claim_gate_loop_consume',
+    };
+  }
+
+  return {
+    kind: 'ClaimGateCouncilWaveInput',
+    sessionId,
+    waves: [
+      {
+        wave: waveNumber,
+        contract,
+        members: Array.from(memberMap.values()),
+        claims: Array.from(claimMap.values()),
+      },
+    ],
+  };
+}
+
+function createRuntimeReceipt(params: {
+  run: Omit<ClaimGateRepairDispatchRuntimeRun, 'receipt'>;
+  workstreamId?: string;
+}): Receipt {
+  const passed = params.run.ok;
+  const evalResult: EvalResult = {
+    id: `eval-${params.run.sessionId}`,
+    strategy: 'gate-based',
+    timestamp: new Date().toISOString(),
+    passed,
+    reasoning: passed
+      ? `${params.run.status}: ClaimGate repair dispatch runtime boundary satisfied.`
+      : `${params.run.status}: ${params.run.findings
+        .filter((finding) => finding.severity === 'error')
+        .map((finding) => finding.code)
+        .join(', ') || 'blocked'}`,
+    metadata: {
+      execute: params.run.execute,
+      concurrency: params.run.concurrency,
+      requestCount: params.run.requests.length,
+      resultCount: params.run.results.length,
+      claimCeiling: params.run.claimCeiling,
+    },
+  };
+
+  return createReceipt({
+    scope: 'invocation',
+    sessionId: params.run.sessionId,
+    workUnitId: 'claim-gate-repair-dispatch-runtime',
+    workstreamId: params.workstreamId,
+    contentHash: sha256({
+      sourceRepairDispatchPlanReceiptId: params.run.sourceRepairDispatchPlanReceiptId,
+      execute: params.run.execute,
+      concurrency: params.run.concurrency,
+      requests: params.run.requests,
+      results: params.run.results,
+      findings: params.run.findings,
+      repairDispatchExecutionReceiptId: params.run.repairDispatchExecution?.receipt.id ?? null,
+    }),
+    evalResults: [evalResult],
+    provenance: {
+      surface: 'sdk',
+      host: 'lev',
+      profile: 'claim-gate-repair-dispatch-runtime',
+    },
+  });
+}
+
+export async function executeClaimGateRepairDispatchPlan(
+  dispatchPlan: ClaimGateRepairDispatchPlan,
+  options: ExecuteClaimGateRepairDispatchPlanOptions = {},
+): Promise<ClaimGateRepairDispatchRuntimeRun> {
+  const execute = options.execute === true;
+  const sessionId = options.sessionId ?? `${dispatchPlan.sessionId}-runtime`;
+  const workstreamId = options.workstreamId ?? dispatchPlan.receipt.workstreamId;
+  const requests = buildClaimGateRepairRuntimeExecutionRequests(dispatchPlan, options);
+  const concurrency = options.execute === true
+    ? normalizedConcurrency(options.concurrency, requests.length)
+    : 0;
+  const findings: ClaimGateRepairDispatchRuntimeFinding[] = [];
+  const results: ClaimGateRepairRuntimeExecutionResult[] = [];
+
+  if (!dispatchPlan.ok) {
+    addFinding(
+      findings,
+      'error',
+      'repair_dispatch_runtime.dispatch_plan_blocked',
+      'Cannot execute a blocked ClaimGate repair dispatch plan.',
+    );
+  }
+  if (requests.length === 0) {
+    addFinding(
+      findings,
+      'error',
+      'repair_dispatch_runtime.no_dispatch_requests',
+      'ClaimGate repair dispatch plan has no executable requests.',
+    );
+  }
+
+  let repairWaveInput: ClaimGateCouncilWaveInput | undefined;
+  let repairDispatchExecution: ClaimGateRepairDispatchExecutionReceipt | undefined;
+
+  if (!execute) {
+    for (const request of requests) {
+      results.push({
+        requestId: request.requestId,
+        claimId: request.claimId,
+        status: 'planned',
+      });
+    }
+  } else if (findings.every((finding) => finding.severity !== 'error')) {
+    const runner = options.runExecutionRequest
+      ?? (async (request: ExecutionRunRequest): Promise<ExecutionRunResponse> => {
+        await ensureDefaultExecTransport();
+        return getExecTransport().runExecutionRequest(request);
+      });
+    const parsedRepairWaves: ClaimGateCouncilWaveInput[] = [];
+
+    const outcomes: Array<Awaited<ReturnType<typeof executeRuntimeRequest>> | undefined> = [];
+    let next = 0;
+    async function worker(): Promise<void> {
+      while (next < requests.length) {
+        const index = next++;
+        outcomes[index] = await executeRuntimeRequest(requests[index]!, runner);
+      }
+    }
+
+    await Promise.all(Array.from({ length: concurrency }, () => worker()));
+
+    for (const outcome of outcomes) {
+      if (!outcome) continue;
+      results.push(outcome.result);
+      findings.push(...outcome.findings);
+      if (outcome.repairWaveInput) parsedRepairWaves.push(outcome.repairWaveInput);
+    }
+
+    if (parsedRepairWaves.length === requests.length) {
+      repairWaveInput = mergeRepairWaveInputs(parsedRepairWaves, `${sessionId}-repair-wave`);
+      repairDispatchExecution = recordClaimGateRepairDispatchExecution(dispatchPlan, repairWaveInput, {
+        sessionId: `${sessionId}-claim-gate-repair-dispatch-execution`,
+        workstreamId,
+      });
+      if (!repairDispatchExecution.ok) {
+        for (const finding of repairDispatchExecution.findings) {
+          addFinding(
+            findings,
+            finding.severity,
+            finding.code,
+            finding.message,
+            finding.claimId ? { requestId: finding.claimId, claimId: finding.claimId } : undefined,
+          );
+        }
+      }
+    }
+  }
+
+  const ok = findings.every((finding) => finding.severity !== 'error')
+    && (!execute || repairDispatchExecution?.ok === true);
+  const status: ClaimGateRepairDispatchRuntimeStatus = !dispatchPlan.ok || !ok
+    ? 'dispatch_blocked'
+    : execute
+      ? 'dispatch_executed'
+      : 'dispatch_planned';
+  const runWithoutReceipt: Omit<ClaimGateRepairDispatchRuntimeRun, 'receipt'> = {
+    kind: 'ClaimGateRepairDispatchRuntimeRun',
+    sessionId,
+    sourceRepairDispatchPlanReceiptId: dispatchPlan.receipt.id,
+    status,
+    ok,
+    execute,
+    concurrency,
+    claimCeiling: execute
+      ? 'repair_dispatch_runtime_invoked_requires_claim_gate_consumption'
+      : 'repair_dispatch_runtime_requests_only',
+    requests,
+    results,
+    findings,
+    ...(repairWaveInput ? { repairWaveInput } : {}),
+    ...(repairDispatchExecution ? { repairDispatchExecution } : {}),
+  };
+  const receipt = createRuntimeReceipt({ run: runWithoutReceipt, workstreamId });
+  return { ...runWithoutReceipt, receipt };
+}
