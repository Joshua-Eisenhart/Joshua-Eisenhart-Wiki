+#!/usr/bin/env bun
+/**
+ * lev harness claim-gate-repair-dispatch
+ *
+ * Harness-owned runtime bridge for ClaimGate repair dispatch plans. Orchestration
+ * builds deterministic repair/dispatch plans; harness owns optional worker
+ * execution through Lev exec transport. Worker output is still proposal-only and
+ * must return to ClaimGate consumption before it can advance.
+ */
+
+import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';
+import { dirname, resolve } from 'node:path';
+
+import type { ExecutionRunRequest, ExecutionRunResponse } from '@lev-os/domain';
+import type { ClaimGateRepairDispatchPlan } from '@lev-os/orchestration/proof/claim-gate-loop';
+
+import { executeClaimGateRepairDispatchPlan } from '../execution/claim-gate-repair-dispatch.js';
+
+interface ParsedArgs {
+  input?: string;
+  out?: string;
+  json: boolean;
+  execute: boolean;
+  rootPath?: string;
+  model?: string;
+  adapter?: string;
+  harness?: string;
+  workstreamId?: string;
+  timeoutMs?: number;
+  concurrency?: number;
+  sessionId?: string;
+  replayOutput?: string;
+  help: boolean;
+}
+
+interface CommandRunResult {
+  success: boolean;
+  formatted_response?: string;
+  data?: unknown;
+  error_code?: string;
+}
+
+function usage(): string {
+  return [
+    'Usage:',
+    '  lev harness claim-gate-repair-dispatch <dispatch-plan.json> [--json] [--out <file>]',
+    '    [--execute] [--root-path <path>] [--model <model>] [--adapter <adapter>]',
+    '    [--harness <harness>] [--workstream <id>] [--timeout-ms <ms>]',
+    '    [--concurrency <n>] [--session-id <id>]',
+    '',
+    'Safe default: without --execute this only materializes bounded Lev exec requests.',
+    'Execution ceiling: worker output remains repair-candidate JSON and must return to ClaimGate.',
+    '',
+    'Test/replay helper:',
+    '  --replay-output <repair-wave.json>  Execute against a pre-captured repair wave JSON instead of live model dispatch.',
+  ].join('\n');
+}
+
+function requireValue(args: string[], index: number, key: string, inline?: string): { value: string; nextIndex: number } {
+  if (inline !== undefined && inline.length > 0) return { value: inline, nextIndex: index };
+  const next = args[index + 1];
+  if (!next || next.startsWith('--')) throw new Error(`--${key} requires a value`);
+  return { value: next, nextIndex: index + 1 };
+}
+
+function parseArgs(args: string[]): ParsedArgs {
+  const parsed: ParsedArgs = {
+    json: false,
+    execute: false,
+    help: false,
+  };
+
+  for (let i = 0; i < args.length; i += 1) {
+    const arg = args[i]!;
+    if (arg === '--help' || arg === '-h' || arg === 'help') {
+      parsed.help = true;
+      continue;
+    }
+    if (arg.startsWith('--')) {
+      const [key, inline] = arg.slice(2).split(/=(.*)/s, 2);
+      const value = () => {
+        const result = requireValue(args, i, key, inline);
+        i = result.nextIndex;
+        return result.value;
+      };
+      switch (key) {
+        case 'json':
+          parsed.json = true;
+          break;
+        case 'execute':
+          parsed.execute = true;
+          break;
+        case 'out':
+          parsed.out = value();
+          break;
+        case 'root-path':
+          parsed.rootPath = value();
+          break;
+        case 'model':
+          parsed.model = value();
+          break;
+        case 'adapter':
+          parsed.adapter = value();
+          break;
+        case 'harness':
+          parsed.harness = value();
+          break;
+        case 'workstream':
+        case 'workstream-id':
+          parsed.workstreamId = value();
+          break;
+        case 'timeout-ms': {
+          const n = Number(value());
+          if (!Number.isFinite(n) || n < 1) throw new Error('--timeout-ms must be a positive number');
+          parsed.timeoutMs = Math.floor(n);
+          break;
+        }
+        case 'concurrency': {
+          const n = Number(value());
+          if (!Number.isInteger(n) || n < 1) throw new Error('--concurrency must be a positive integer');
+          parsed.concurrency = n;
+          break;
+        }
+        case 'session-id':
+          parsed.sessionId = value();
+          break;
+        case 'replay-output':
+          parsed.replayOutput = value();
+          parsed.execute = true;
+          break;
+        default:
+          throw new Error(`Unknown flag: --${key}`);
+      }
+      continue;
+    }
+    if (!parsed.input) {
+      parsed.input = arg;
+      continue;
+    }
+    throw new Error(`Unexpected argument: ${arg}`);
+  }
+
+  return parsed;
+}
+
+function readJson<T>(file: string): T {
+  return JSON.parse(readFileSync(file, 'utf8')) as T;
+}
+
+function writeJson(file: string, value: unknown): void {
+  mkdirSync(dirname(file), { recursive: true });
+  writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+function replayRunner(file: string): (request: ExecutionRunRequest) => Promise<ExecutionRunResponse> {
+  const output = readFileSync(file, 'utf8');
+  return async () => ({
+    status: 'EXECUTION_STATUS_SUCCEEDED',
+    output: { output },
+  });
+}
+
+function formatRun(run: Awaited<ReturnType<typeof executeClaimGateRepairDispatchPlan>>, out?: string): string {
+  const lines = [
+    `ClaimGate repair dispatch runtime: ${run.status}`,
+    `ok: ${run.ok}`,
+    `execute: ${run.execute}`,
+    `requests: ${run.requests.length}`,
+    `results: ${run.results.length}`,
+    `findings: ${run.findings.length}`,
+    `claimCeiling: ${run.claimCeiling}`,
+  ];
+  if (run.repairWaveInput) lines.push(`repairWaveClaims: ${run.repairWaveInput.waves.flatMap((wave) => wave.claims).length}`);
+  if (run.repairDispatchExecution) lines.push(`repairDispatchExecution: ${run.repairDispatchExecution.status}`);
+  if (out) lines.push(`wrote: ${out}`);
+  return lines.join('\n');
+}
+
+export async function handler(args: string[]): Promise<CommandRunResult> {
+  let parsed: ParsedArgs;
+  try {
+    parsed = parseArgs(args);
+  } catch (error) {
+    const message = error instanceof Error ? error.message : String(error);
+    return {
+      success: false,
+      formatted_response: `${message}\n\n${usage()}`,
+      error_code: 'INVALID_ARGUMENTS',
+    };
+  }
+
+  if (parsed.help || !parsed.input) {
+    return {
+      success: true,
+      formatted_response: usage(),
+      data: { ok: true, kind: 'claim_gate_repair_dispatch_help' },
+    };
+  }
+
+  const inputPath = resolve(parsed.input);
+  if (!existsSync(inputPath)) {
+    return {
+      success: false,
+      formatted_response: `Dispatch plan not found: ${inputPath}`,
+      error_code: 'MISSING_INPUT',
+    };
+  }
+  if (parsed.replayOutput && !existsSync(resolve(parsed.replayOutput))) {
+    return {
+      success: false,
+      formatted_response: `Replay repair-wave output not found: ${resolve(parsed.replayOutput)}`,
+      error_code: 'MISSING_REPLAY_OUTPUT',
+    };
+  }
+
+  try {
+    const dispatchPlan = readJson<ClaimGateRepairDispatchPlan>(inputPath);
+    const run = await executeClaimGateRepairDispatchPlan(dispatchPlan, {
+      execute: parsed.execute,
+      ...(parsed.rootPath ? { rootPath: parsed.rootPath } : {}),
+      ...(parsed.model ? { model: parsed.model } : {}),
+      ...(parsed.adapter ? { adapter: parsed.adapter } : {}),
+      ...(parsed.harness ? { harness: parsed.harness } : {}),
+      ...(parsed.workstreamId ? { workstreamId: parsed.workstreamId } : {}),
+      ...(parsed.timeoutMs ? { timeoutMs: parsed.timeoutMs } : {}),
+      ...(parsed.concurrency ? { concurrency: parsed.concurrency } : {}),
+      ...(parsed.sessionId ? { sessionId: parsed.sessionId } : {}),
+      ...(parsed.replayOutput ? { runExecutionRequest: replayRunner(resolve(parsed.replayOutput)) } : {}),
+    });
+
+    if (parsed.out) writeJson(resolve(parsed.out), run);
+
+    return {
+      success: run.ok,
+      formatted_response: parsed.json ? JSON.stringify(run, null, 2) : formatRun(run, parsed.out),
+      data: run,
+      error_code: run.ok ? undefined : 'CLAIMGATE_REPAIR_DISPATCH_RUNTIME_BLOCKED',
+    };
+  } catch (error) {
+    const message = error instanceof Error ? error.message : String(error);
+    return {
+      success: false,
+      formatted_response: parsed.json
+        ? JSON.stringify({ ok: false, error: message }, null, 2)
+        : `ClaimGate repair dispatch failed: ${message}`,
+      error_code: 'CLAIMGATE_REPAIR_DISPATCH_RUNTIME_ERROR',
+    };
+  }
+}
+
+export const metadata = {
+  name: 'claim-gate-repair-dispatch',
+  description: 'Execute or dry-run ClaimGate repair dispatch plans through the harness runtime.',
+};
