+import { mkdtempSync, readFileSync, rmSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+import { describe, expect, it } from 'vitest';
+
+import {
+  buildClaimGateRepairDispatchPlan,
+  buildClaimGateRepairWavePlan,
+  runClaimGateCouncilWaveLoop,
+  type ClaimGateCouncilMemberCognitiveBinding,
+  type ClaimGateCouncilWaveContract,
+  type ClaimGateCouncilWaveInput,
+  type ClaimGateRepairDispatchRequest,
+} from '@lev-os/orchestration';
+
+import { handler } from './claim-gate-repair-dispatch.js';
+
+function testWaveContract(overrides: Partial<ClaimGateCouncilWaveContract> = {}): ClaimGateCouncilWaveContract {
+  return {
+    owner: 'harness.claim-gate-repair-dispatch-handler-test',
+    producerKind: 'test_council_wave',
+    expectedVerifier: 'claim-gate-loop',
+    requeueRule: 'repair_failed_claims_only',
+    nextAdmissibleState: 'repair_wave_plan',
+    claimCeiling: 'proposal_only_council_candidate_not_admission',
+    ...overrides,
+  };
+}
+
+function testCognitiveBinding(): ClaimGateCouncilMemberCognitiveBinding {
+  return {
+    mmmRefs: ['dna:graph'],
+    skillRefs: ['skill:premortem'],
+    sourceRefs: ['source:harness-claim-gate-repair-dispatch-handler-test'],
+    inputContractRefs: ['contract:ClaimGateCouncilWaveInput'],
+    outputContractRefs: ['contract:ClaimGateCouncilWaveClaim'],
+    gateContractRefs: ['gate:claim-gate-loop', 'gate:claim-gate-repair-dispatch'],
+    requeuePolicyRef: 'repair_failed_claims_only',
+  };
+}
+
+function makeDispatchPlan(): ReturnType<typeof buildClaimGateRepairDispatchPlan> {
+  const input: ClaimGateCouncilWaveInput = {
+    kind: 'ClaimGateCouncilWaveInput',
+    sessionId: 'harness-claim-gate-repair-dispatch-handler-source',
+    waves: [
+      {
+        wave: 1,
+        contract: testWaveContract(),
+        members: [
+          {
+            memberId: 'failure.premortem',
+            kind: 'premortem',
+            role: 'failure premortem lane',
+            skillRefs: ['skill:premortem'],
+            cognitiveBinding: testCognitiveBinding(),
+          },
+        ],
+        claims: [
+          {
+            claimId: 'REPAIR_ME',
+            payload: 'candidate missing source-bound evidence manifest',
+            memberId: 'failure.premortem',
+            gateChecks: [
+              { gateId: 'object_binding', status: 'pass', evidenceRefs: ['receipt:object-bound'] },
+              { gateId: 'evidence_manifest', status: 'fail', reason: 'manifest missing', evidenceRefs: ['artifact:missing'] },
+              { gateId: 'falsifier', status: 'pass', evidenceRefs: ['receipt:falsifier-bound'] },
+            ],
+          },
+        ],
+      },
+    ],
+  };
+  const result = runClaimGateCouncilWaveLoop(input);
+  const repairPlan = buildClaimGateRepairWavePlan(input, result);
+  return buildClaimGateRepairDispatchPlan(repairPlan);
+}
+
+function repairWaveForRequest(request: ClaimGateRepairDispatchRequest): ClaimGateCouncilWaveInput {
+  return {
+    kind: 'ClaimGateCouncilWaveInput',
+    sessionId: 'harness-claim-gate-repair-dispatch-handler-output',
+    waves: [
+      {
+        wave: 2,
+        contract: testWaveContract({
+          owner: 'harness.claim-gate-repair-dispatch-handler-runtime',
+          producerKind: 'repair_dispatch_runtime',
+          nextAdmissibleState: 'claim_gate_loop_consume_parent_result',
+        }),
+        members: [request.sourceMember],
+        claims: [
+          {
+            claimId: request.claimId,
+            payload: 'repair emitted source-bound evidence manifest',
+            memberId: request.sourceMemberId,
+            repairOf: request.requiredInputs.repairOf,
+            gateChecks: [
+              { gateId: 'object_binding', status: 'pass', evidenceRefs: ['receipt:object-bound'] },
+              { gateId: 'evidence_manifest', status: 'pass', evidenceRefs: ['receipt:manifest-bound'] },
+              { gateId: 'falsifier', status: 'pass', evidenceRefs: ['receipt:falsifier-bound'] },
+            ],
+          },
+        ],
+      },
+    ],
+  };
+}
+
+function writeJson(file: string, value: unknown): void {
+  writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+describe('claim-gate-repair-dispatch handler', () => {
+  it('shows help without requiring a dispatch plan', async () => {
+    const result = await handler(['--help']);
+    expect(result.success).toBe(true);
+    expect(result.formatted_response).toContain('lev harness claim-gate-repair-dispatch');
+  });
+
+  it('materializes bounded repair execution requests without live model execution by default', async () => {
+    const root = mkdtempSync(join(tmpdir(), 'claim-gate-repair-dispatch-handler-'));
+    try {
+      const dispatchPlan = makeDispatchPlan();
+      const dispatchPlanPath = join(root, 'dispatch-plan.json');
+      const out = join(root, 'runtime-run.json');
+      writeJson(dispatchPlanPath, dispatchPlan);
+
+      const result = await handler([dispatchPlanPath, '--json', '--out', out, '--root-path', root]);
+
+      expect(result.success).toBe(true);
+      const run = JSON.parse(readFileSync(out, 'utf8')) as Record<string, unknown>;
+      expect(run).toMatchObject({
+        kind: 'ClaimGateRepairDispatchRuntimeRun',
+        status: 'dispatch_planned',
+        ok: true,
+        execute: false,
+        claimCeiling: 'repair_dispatch_runtime_requests_only',
+      });
+      expect((run.requests as unknown[])).toHaveLength(1);
+      expect((run.results as Array<Record<string, unknown>>)[0]).toMatchObject({
+        claimId: 'REPAIR_ME',
+        status: 'planned',
+      });
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('executes against a replayed worker repair-wave output and seals dispatch execution', async () => {
+    const root = mkdtempSync(join(tmpdir(), 'claim-gate-repair-dispatch-handler-'));
+    try {
+      const dispatchPlan = makeDispatchPlan();
+      const dispatchPlanPath = join(root, 'dispatch-plan.json');
+      const repairWavePath = join(root, 'repair-wave.json');
+      const out = join(root, 'runtime-run.json');
+      writeJson(dispatchPlanPath, dispatchPlan);
+      writeJson(repairWavePath, repairWaveForRequest(dispatchPlan.dispatchRequests[0]!));
+
+      const result = await handler([
+        dispatchPlanPath,
+        '--execute',
+        '--replay-output',
+        repairWavePath,
+        '--out',
+        out,
+        '--json',
+      ]);
+
+      expect(result.success).toBe(true);
+      const run = JSON.parse(readFileSync(out, 'utf8')) as Record<string, unknown>;
+      expect(run).toMatchObject({
+        kind: 'ClaimGateRepairDispatchRuntimeRun',
+        status: 'dispatch_executed',
+        ok: true,
+        execute: true,
+        claimCeiling: 'repair_dispatch_runtime_invoked_requires_claim_gate_consumption',
+      });
+      expect(run).toHaveProperty('repairWaveInput');
+      expect(run).toHaveProperty('repairDispatchExecution');
+      expect((run.repairDispatchExecution as Record<string, unknown>).status).toBe('repair_dispatch_executed');
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('fails closed when replayed worker output is not a repair-wave JSON object', async () => {
+    const root = mkdtempSync(join(tmpdir(), 'claim-gate-repair-dispatch-handler-'));
+    try {
+      const dispatchPlan = makeDispatchPlan();
+      const dispatchPlanPath = join(root, 'dispatch-plan.json');
+      const badOutput = join(root, 'not-json.txt');
+      writeJson(dispatchPlanPath, dispatchPlan);
+      writeFileSync(badOutput, 'not json');
+
+      const result = await handler([
+        dispatchPlanPath,
+        '--execute',
+        '--replay-output',
+        badOutput,
+        '--json',
+      ]);
+
+      expect(result.success).toBe(false);
+      const run = result.data as Record<string, unknown>;
+      expect(run).toMatchObject({
+        status: 'dispatch_blocked',
+        ok: false,
+      });
+      expect((run.findings as Array<Record<string, unknown>>)).toEqual([
+        expect.objectContaining({
+          code: 'repair_dispatch_runtime.output_parse_failed',
+          claimId: 'REPAIR_ME',
+        }),
+      ]);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+});
