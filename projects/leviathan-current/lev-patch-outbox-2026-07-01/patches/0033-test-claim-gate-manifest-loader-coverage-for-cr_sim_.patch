Subject: [PATCH 33/35] test(claim-gate): manifest loader coverage for
 cr_sim_packet_v0

Belongs with 5b7c485fe (missed in the add): loader tests for simId
traversal rejection, hash-pin mismatch, schema fail-closed cases.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 .../proof/real-three-engine-envelope.test.ts  | 54 ++++++++++++++++++-
 1 file changed, 53 insertions(+), 1 deletion(-)

diff --git a/core/orchestration/src/proof/real-three-engine-envelope.test.ts b/core/orchestration/src/proof/real-three-engine-envelope.test.ts
index f8cd2b3ce..c0d7aa054 100644
--- a/core/orchestration/src/proof/real-three-engine-envelope.test.ts
+++ b/core/orchestration/src/proof/real-three-engine-envelope.test.ts
@@ -1,4 +1,5 @@
-import { existsSync, mkdirSync, mkdtempSync, symlinkSync } from 'node:fs';
+import { createHash } from 'node:crypto';
+import { existsSync, mkdirSync, mkdtempSync, rmSync, symlinkSync, writeFileSync } from 'node:fs';
 import { tmpdir } from 'node:os';
 import { dirname, join } from 'node:path';
 import { fileURLToPath } from 'node:url';
@@ -6,12 +7,17 @@ import { fileURLToPath } from 'node:url';
 import { describe, expect, it } from 'vitest';
 
 import {
+  loadCrSimPacketManifest,
   resolveEngineCarrierForRuntime,
   resolveLevOwnedSimEngineCarrierFromModuleDir,
 } from './real-three-engine-envelope.js';
 
 const repoRoot = join(dirname(fileURLToPath(import.meta.url)), '..', '..', '..', '..');
 
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
 describe('real three-engine carrier provenance', () => {
   it('resolves built dist runtime back to the Lev-owned source carrier scripts', () => {
     const distProofDir = join(repoRoot, 'core', 'orchestration', 'dist', 'proof');
@@ -41,6 +47,7 @@ describe('real three-engine carrier provenance', () => {
       } else {
         process.env.LEV_SIM_ENGINE_CARRIER = previous;
       }
+      rmSync(root, { recursive: true, force: true });
     }
   });
 
@@ -60,6 +67,7 @@ describe('real three-engine carrier provenance', () => {
       } else {
         process.env.LEV_SIM_ENGINE_CARRIER = previous;
       }
+      rmSync(root, { recursive: true, force: true });
     }
   });
 
@@ -81,6 +89,7 @@ describe('real three-engine carrier provenance', () => {
       } else {
         process.env.LEV_SIM_ENGINE_CARRIER = previous;
       }
+      rmSync(root, { recursive: true, force: true });
     }
   });
 
@@ -100,6 +109,49 @@ describe('real three-engine carrier provenance', () => {
       } else {
         process.env.LEV_SIM_ENGINE_CARRIER = previous;
       }
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+});
+
+describe('CR sim packet manifest loader', () => {
+  it('throws when expectedSourceSha256 does not match the on-disk script bytes at load time', () => {
+    const root = mkdtempSync(join(tmpdir(), 'cr-sim-packet-manifest-'));
+    try {
+      const moduleDir = join(root, 'proof');
+      const carrier = join(root, 'probes', 'lev-sim-engine-carrier', 'tmp-sim-packet');
+      mkdirSync(carrier, { recursive: true });
+      mkdirSync(moduleDir, { recursive: true });
+      writeFileSync(join(carrier, 'lane.py'), 'print("primary")\n');
+      writeFileSync(join(carrier, 'packet.json'), `${JSON.stringify({
+        schemaVersion: 'cr-sim-packet-v0',
+        simId: 'tmp-sim-packet',
+        claimCeiling: 'fixture ceiling',
+        transformClaim: 'fixture transform',
+        lanes: [
+          {
+            engine: 'jax',
+            role: 'fixture_lane',
+            script: 'lane.py',
+            expectedSourceSha256: sha256Text('different script text'),
+            timeoutMs: 1000,
+            alignedPackagesLoadBearing: ['python-stdlib'],
+            negativeControl: {
+              id: 'fixture_negative',
+              env: { LEV_CR_FIXTURE_NEGATIVE_CONTROL: 'fixture_negative' },
+              expectedOutputIncludes: ['NEGATIVE_CONTROL_DONE'],
+              expectedOutputExcludes: ['PRIMARY_DONE'],
+            },
+            resultArtifact: 'results/lane-results.json',
+          },
+        ],
+      }, null, 2)}\n`);
+
+      expect(() => loadCrSimPacketManifest('tmp-sim-packet', moduleDir)).toThrow(
+        'cr_sim_packet_v0 tmp-sim-packet lane jax expectedSourceSha256 does not match script lane.py',
+      );
+    } finally {
+      rmSync(root, { recursive: true, force: true });
     }
   });
 });
