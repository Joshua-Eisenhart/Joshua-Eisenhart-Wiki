+/**
+ * lev orchestration claimgate-steering
+ *
+ * Host-Lev consumer for ClaimGate `.lev/steering/runs/<id>` projections.
+ */
+
+import { resolve } from 'node:path';
+
+import {
+  consumeClaimGateSteeringRun,
+  consumeClaimGateSteeringRuns,
+} from '../proof/claim-gate-steering-run.js';
+
+interface ParsedArgs {
+  subcommand: string;
+  path?: string;
+  json: boolean;
+  concurrency: number;
+  noWrite: boolean;
+}
+
+function parseArgs(args: string[]): ParsedArgs {
+  const [subcommand = 'help', maybePath] = args;
+  const json = args.includes('--json');
+  const noWrite = args.includes('--no-write') || args.includes('--dry-run');
+  const concurrencyFlag = args.find((arg) => arg.startsWith('--concurrency='));
+  const concurrency = concurrencyFlag ? Number(concurrencyFlag.split('=')[1]) : 4;
+  return {
+    subcommand,
+    path: maybePath && !maybePath.startsWith('--') ? maybePath : undefined,
+    json,
+    concurrency: Number.isFinite(concurrency) && concurrency > 0 ? Math.floor(concurrency) : 4,
+    noWrite,
+  };
+}
+
+function usage(): string {
+  return [
+    'Usage:',
+    '  lev orchestration claimgate-steering consume <run-dir> [--json] [--no-write]',
+    '  lev orchestration claimgate-steering batch <root-dir> [--concurrency=N] [--json] [--no-write]',
+    '',
+    'Consumes ClaimGate EvalJobOutput/ProofSpec steering projections and writes host Lev consumption receipts.',
+  ].join('\n');
+}
+
+function formatSingle(result: ReturnType<typeof consumeClaimGateSteeringRun>): string {
+  const lines = [
+    `ClaimGate steering run: ${result.status}`,
+    `Run: ${result.runDir}`,
+    `Projected verdict: ${result.projectedVerdict ?? 'unknown'}`,
+    `Recomputed verdict: ${result.recomputedVerdict ?? 'unknown'}`,
+    `Receipt: ${result.receipt.id}`,
+    `Live Lev consumed: ${result.liveLevConsumed ? 'true' : 'false'}`,
+  ];
+  if (result.findings.length > 0) {
+    lines.push('Findings:');
+    for (const finding of result.findings) {
+      lines.push(`  - [${finding.severity}] ${finding.code}: ${finding.message}`);
+    }
+  }
+  return lines.join('\n');
+}
+
+function formatBatch(result: Awaited<ReturnType<typeof consumeClaimGateSteeringRuns>>): string {
+  return [
+    `ClaimGate steering batch: ${result.blockedCount === 0 ? 'host_consumed' : 'host_blocked'}`,
+    `Root: ${result.rootDir}`,
+    `Runs: ${result.runCount}`,
+    `Consumed: ${result.okCount}`,
+    `Blocked: ${result.blockedCount}`,
+    `Verdicts: pass=${result.verdictCounts.pass} fail=${result.verdictCounts.fail} conditional=${result.verdictCounts.conditional} deferred=${result.verdictCounts.deferred}`,
+    `Concurrency: ${result.concurrency}`,
+    `Duration: ${result.durationMs}ms`,
+  ].join('\n');
+}
+
+export async function handler(args: string[]) {
+  const parsed = parseArgs(args);
+
+  if (parsed.subcommand === 'help' || parsed.subcommand === '--help' || parsed.subcommand === '-h') {
+    return {
+      success: true,
+      formatted_response: usage(),
+    };
+  }
+
+  if (!parsed.path) {
+    return {
+      success: false,
+      formatted_response: usage(),
+      error_code: 'MISSING_PATH',
+    };
+  }
+
+  if (parsed.subcommand === 'consume') {
+    const result = consumeClaimGateSteeringRun({
+      runDir: resolve(parsed.path),
+      writeReceipt: !parsed.noWrite,
+    });
+    return {
+      success: result.ok,
+      formatted_response: formatSingle(result),
+      data: result,
+      error_code: result.ok ? undefined : 'CLAIMGATE_STEERING_BLOCKED',
+    };
+  }
+
+  if (parsed.subcommand === 'batch') {
+    const result = await consumeClaimGateSteeringRuns({
+      rootDir: resolve(parsed.path),
+      concurrency: parsed.concurrency,
+      writeReceipt: !parsed.noWrite,
+    });
+    return {
+      success: result.blockedCount === 0,
+      formatted_response: formatBatch(result),
+      data: result,
+      error_code: result.blockedCount === 0 ? undefined : 'CLAIMGATE_STEERING_BATCH_BLOCKED',
+    };
+  }
+
+  return {
+    success: false,
+    formatted_response: usage(),
+    error_code: 'UNKNOWN_SUBCOMMAND',
+  };
+}
+
+export const metadata = {
+  name: 'claimgate-steering',
+  description: 'Consume ClaimGate .lev/steering/runs EvalJobOutput projections through host Lev proof checks.',
+};
