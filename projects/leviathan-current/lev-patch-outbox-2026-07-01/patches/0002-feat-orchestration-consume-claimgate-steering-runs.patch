diff --git a/scripts/pressure-claimgate-steering.mjs b/scripts/pressure-claimgate-steering.mjs
new file mode 100755
index 000000000..421c366c2
--- /dev/null
+++ b/scripts/pressure-claimgate-steering.mjs
@@ -0,0 +1,309 @@
+#!/usr/bin/env node
+/**
+ * Generate real ClaimGate steering projections and pressure-test the host Lev
+ * consumer against them.
+ *
+ * This is intentionally cross-repo and opt-in: it does not make ClaimGate a Lev
+ * runtime dependency. Pass --claimgate-root to point at a checked-out product
+ * tree, and the script writes all generated evidence under --out.
+ */
+
+import { spawnSync } from 'node:child_process';
+import { existsSync, mkdirSync, readFileSync, rmSync, writeFileSync } from 'node:fs';
+import { dirname, join, resolve } from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+const levRoot = resolve(dirname(fileURLToPath(import.meta.url)), '..');
+
+function usage() {
+  return [
+    'Usage:',
+    '  node scripts/pressure-claimgate-steering.mjs --claimgate-root <dir> [--out <dir>] [--runs N] [--concurrency N] [--inject-mismatch-every N] [--lev-bin <path>]',
+    '',
+    'Example:',
+    '  node scripts/pressure-claimgate-steering.mjs --claimgate-root ~/claimgate-suite --runs 64 --concurrency 8 --out /tmp/lev-claimgate-pressure',
+  ].join('\n');
+}
+
+function parseArgs(argv) {
+  const options = {
+    claimgateRoot: undefined,
+    out: `/tmp/lev-claimgate-pressure-${Date.now()}`,
+    runs: 32,
+    concurrency: 4,
+    injectMismatchEvery: 0,
+    levBin: join(levRoot, 'core/poly/bin/lev'),
+  };
+
+  for (let i = 0; i < argv.length; i++) {
+    const arg = argv[i];
+    const next = argv[i + 1];
+    if (arg === '--help' || arg === '-h') {
+      console.log(usage());
+      process.exit(0);
+    }
+    if (arg === '--claimgate-root') {
+      options.claimgateRoot = resolve(next);
+      i++;
+    } else if (arg === '--out') {
+      options.out = resolve(next);
+      i++;
+    } else if (arg === '--runs') {
+      options.runs = Number(next);
+      i++;
+    } else if (arg === '--concurrency') {
+      options.concurrency = Number(next);
+      i++;
+    } else if (arg === '--inject-mismatch-every') {
+      options.injectMismatchEvery = Number(next);
+      i++;
+    } else if (arg === '--lev-bin') {
+      options.levBin = resolve(next);
+      i++;
+    } else {
+      throw new Error(`Unknown argument: ${arg}\n${usage()}`);
+    }
+  }
+
+  if (!options.claimgateRoot) throw new Error(`Missing --claimgate-root\n${usage()}`);
+  if (!Number.isInteger(options.runs) || options.runs < 1) throw new Error('--runs must be a positive integer.');
+  if (!Number.isInteger(options.concurrency) || options.concurrency < 1) {
+    throw new Error('--concurrency must be a positive integer.');
+  }
+  if (!Number.isInteger(options.injectMismatchEvery) || options.injectMismatchEvery < 0) {
+    throw new Error('--inject-mismatch-every must be zero or a positive integer.');
+  }
+
+  return options;
+}
+
+function runCommand(command, args, options = {}) {
+  const result = spawnSync(command, args, {
+    cwd: options.cwd,
+    encoding: 'utf8',
+    maxBuffer: 1024 * 1024 * 64,
+  });
+  return {
+    command,
+    args,
+    cwd: options.cwd,
+    status: result.status ?? 1,
+    stdout: result.stdout ?? '',
+    stderr: result.stderr ?? '',
+    signal: result.signal ?? null,
+  };
+}
+
+function assertFile(file, label) {
+  if (!existsSync(file)) throw new Error(`${label} not found: ${file}`);
+}
+
+function parseJsonLoose(text) {
+  const start = text.indexOf('{');
+  const end = text.lastIndexOf('}');
+  if (start === -1 || end === -1 || end < start) return undefined;
+  return JSON.parse(text.slice(start, end + 1));
+}
+
+function readJson(file) {
+  return JSON.parse(readFileSync(file, 'utf8'));
+}
+
+function writeJson(file, value) {
+  mkdirSync(dirname(file), { recursive: true });
+  writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+function tamperProjectedVerdict(steeringDir) {
+  const outputPath = join(steeringDir, 'eval-job-output.json');
+  const evalJobPath = join(steeringDir, 'eval-job.json');
+  const output = readJson(outputPath);
+  const evalJob = readJson(evalJobPath);
+  output.verdict = output.verdict === 'pass' ? 'fail' : 'pass';
+  evalJob.output = output;
+  writeJson(outputPath, output);
+  writeJson(evalJobPath, evalJob);
+  return output.verdict;
+}
+
+const cases = [
+  {
+    name: 'demo_pass',
+    expectedVerifyStatuses: new Set([0]),
+    claimCard: 'examples/demo_pass/claim-card.json',
+    effectEnvelope: 'examples/demo_pass/effect-envelope.json',
+    prBody: 'examples/demo_pass/PR_BODY.md',
+    changedFiles: 'examples/demo_pass/changed-files.txt',
+    repoRoot: 'examples/demo_pass',
+  },
+  {
+    name: 'demo_block',
+    expectedVerifyStatuses: new Set([1]),
+    claimCard: 'examples/demo_block/claim-card.json',
+    effectEnvelope: 'examples/demo_block/effect-envelope.json',
+    prBody: 'examples/demo_block/PR_BODY.md',
+    changedFiles: 'examples/demo_block/changed-files.txt',
+    repoRoot: 'examples/demo_block',
+  },
+  {
+    name: 'demo_scope_fail',
+    expectedVerifyStatuses: new Set([1]),
+    claimCard: 'examples/demo_scope_fail/claim-card.json',
+    effectEnvelope: 'examples/demo_scope_fail/effect-envelope.json',
+    prBody: 'examples/demo_scope_fail/PR_BODY.md',
+    changedFiles: 'examples/demo_scope_fail/changed-files.txt',
+    repoRoot: 'examples/demo_scope_fail',
+  },
+  {
+    name: 'marketing_scientist',
+    expectedVerifyStatuses: new Set([0]),
+    claimCard: 'examples/marketing_scientist/claim-card.json',
+    effectEnvelope: 'examples/marketing_scientist/effect-envelope.json',
+    prBody: 'examples/marketing_scientist/PR_BODY.md',
+    changedFiles: 'examples/marketing_scientist/changed-files.txt',
+    repoRoot: 'examples/marketing_scientist',
+  },
+];
+
+async function main() {
+  const options = parseArgs(process.argv.slice(2));
+  const claimgateCli = join(options.claimgateRoot, 'packages/claimgate-cli/bin/claimgate.js');
+  assertFile(claimgateCli, 'ClaimGate CLI');
+  assertFile(options.levBin, 'Lev CLI');
+
+  rmSync(options.out, { recursive: true, force: true });
+  const runsRoot = join(options.out, 'claim-runs');
+  const evalRoot = join(options.out, 'eval-compatible');
+  const steeringRoot = join(options.out, '.lev/steering/runs');
+  mkdirSync(steeringRoot, { recursive: true });
+
+  const records = [];
+
+  for (let index = 0; index < options.runs; index++) {
+    const testCase = cases[index % cases.length];
+    const ordinal = String(index).padStart(4, '0');
+    const runId = `${ordinal}-${testCase.name}`;
+    const runDir = join(runsRoot, runId);
+    const evalDir = join(evalRoot, runId);
+    const steeringDir = join(steeringRoot, runId);
+
+    const verify = runCommand('node', [
+      claimgateCli,
+      'verify',
+      '--claim-card',
+      join(options.claimgateRoot, testCase.claimCard),
+      '--effect-envelope',
+      join(options.claimgateRoot, testCase.effectEnvelope),
+      '--pr-body',
+      join(options.claimgateRoot, testCase.prBody),
+      '--changed-files',
+      join(options.claimgateRoot, testCase.changedFiles),
+      '--repo-root',
+      join(options.claimgateRoot, testCase.repoRoot),
+      '--out',
+      runDir,
+    ], { cwd: options.claimgateRoot });
+
+    const receiptPath = join(runDir, 'receipt.json');
+    if (!existsSync(receiptPath) || !testCase.expectedVerifyStatuses.has(verify.status)) {
+      records.push({ runId, case: testCase.name, stage: 'verify', ok: false, verify });
+      continue;
+    }
+
+    const project = runCommand('node', [
+      claimgateCli,
+      'lev-adapter',
+      'project-run',
+      '--run',
+      runDir,
+      '--out',
+      evalDir,
+      '--steering-out',
+      steeringDir,
+      '--target-ref',
+      `${testCase.name}:${runId}`,
+    ], { cwd: options.claimgateRoot });
+
+    const outputPath = join(steeringDir, 'eval-job-output.json');
+    if (project.status !== 0 || !existsSync(outputPath)) {
+      records.push({ runId, case: testCase.name, stage: 'project', ok: false, verify, project });
+      continue;
+    }
+
+    const tampered = options.injectMismatchEvery > 0 && (index + 1) % options.injectMismatchEvery === 0;
+    const tamperedVerdict = tampered ? tamperProjectedVerdict(steeringDir) : undefined;
+    const projected = readJson(outputPath);
+    records.push({
+      runId,
+      case: testCase.name,
+      stage: 'projected',
+      ok: true,
+      verifyStatus: verify.status,
+      projectStatus: project.status,
+      steeringDir,
+      projectedVerdict: projected.verdict,
+      tampered,
+      tamperedVerdict,
+    });
+  }
+
+  const levBatch = runCommand(options.levBin, [
+    'orchestration',
+    'claimgate-steering',
+    'batch',
+    steeringRoot,
+    `--concurrency=${options.concurrency}`,
+    '--json',
+  ], { cwd: levRoot });
+  const parsedLevBatch = parseJsonLoose(levBatch.stdout);
+  const failedGeneration = records.filter((record) => !record.ok);
+  const tamperedCount = records.filter((record) => record.tampered).length;
+  const summary = {
+    generatedAt: new Date().toISOString(),
+    options,
+    paths: {
+      levRoot,
+      claimgateCli,
+      runsRoot,
+      evalRoot,
+      steeringRoot,
+    },
+    generatedRuns: records.length,
+    generationFailures: failedGeneration.length,
+    tamperedCount,
+    caseCounts: records.reduce((acc, record) => {
+      acc[record.case] = (acc[record.case] ?? 0) + 1;
+      return acc;
+    }, {}),
+    projectedVerdictCounts: records.reduce((acc, record) => {
+      if (record.projectedVerdict) acc[record.projectedVerdict] = (acc[record.projectedVerdict] ?? 0) + 1;
+      return acc;
+    }, {}),
+    levBatch: {
+      status: levBatch.status,
+      signal: levBatch.signal,
+      stdout: levBatch.stdout,
+      stderr: levBatch.stderr,
+      parsed: parsedLevBatch,
+    },
+    records,
+  };
+
+  const summaryPath = join(options.out, 'pressure-summary.json');
+  writeJson(summaryPath, summary);
+
+  const batch = parsedLevBatch;
+  const line = batch
+    ? `runs=${batch.runCount} ok=${batch.okCount} blocked=${batch.blockedCount} pass=${batch.verdictCounts.pass} fail=${batch.verdictCounts.fail} conditional=${batch.verdictCounts.conditional} durationMs=${batch.durationMs}`
+    : `lev-batch-status=${levBatch.status} parse=failed`;
+  console.log(`ClaimGate steering pressure complete: ${line}`);
+  console.log(`Summary: ${summaryPath}`);
+
+  if (failedGeneration.length > 0) process.exitCode = 1;
+  if (!batch) process.exitCode = 1;
+}
+
+main().catch((error) => {
+  console.error(error.stack || String(error));
+  process.exit(1);
+});
