+import { mkdirSync, readFileSync, rmSync, writeFileSync } from 'node:fs';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+
+import { describe, expect, it } from 'vitest';
+
+import {
+  consumeClaimGateSteeringRun,
+  consumeClaimGateSteeringRuns,
+  findClaimGateSteeringRunDirs,
+} from './claim-gate-steering-run.js';
+import type { EvalJob, EvalJobOutput, EvalVerdict } from './eval-job-types.js';
+import type { ProofObligation, ProofResult, ProofSpec } from './proof-spec-generator.js';
+
+function makeTempRoot(name: string): string {
+  const root = join(tmpdir(), `lev-claimgate-${name}-${Date.now()}-${Math.random().toString(16).slice(2)}`);
+  mkdirSync(root, { recursive: true });
+  return root;
+}
+
+function proofResult(status: ProofResult['status']): ProofResult {
+  return {
+    status,
+    elapsedMs: 1,
+    verifierVersion: 'test/1.0',
+  };
+}
+
+function expectedVerdict(statuses: ProofResult['status'][]): EvalVerdict {
+  if (statuses.length === 0) return 'conditional';
+  if (statuses.some((status) => status === 'failed' || status === 'timeout')) return 'fail';
+  if (statuses.some((status) => status === 'skipped')) return 'conditional';
+  return 'pass';
+}
+
+function writeRun(root: string, id: string, statuses: ProofResult['status'][], forcedVerdict?: EvalVerdict): string {
+  const runDir = join(root, id);
+  mkdirSync(runDir, { recursive: true });
+  const obligations: ProofObligation[] = statuses.map((status, index) => ({
+    obligationId: `obl-${index}`,
+    constraintId: `constraint-${index}`,
+    shellCheck: `echo ${index}`,
+    expectedResult: 'exit_zero',
+    actualResult: proofResult(status),
+  }));
+  const proofSpec: ProofSpec = {
+    specId: `ps-${id}`,
+    targetRef: `target-${id}`,
+    proofObligations: obligations,
+    proofStrategy: 'compiled_guard',
+    generatedAt: new Date().toISOString(),
+  };
+  const output: EvalJobOutput = {
+    verdict: forcedVerdict ?? expectedVerdict(statuses),
+    evidence: obligations.map((obligation) => obligation.actualResult!),
+    receiptId: `claim-receipt-${id}`,
+  };
+  const evalJob: EvalJob = {
+    jobId: `ej-${id}`,
+    jobClass: 'eval',
+    targetRef: proofSpec.targetRef,
+    proofSpecId: proofSpec.specId,
+    output,
+  };
+
+  writeFileSync(join(runDir, 'run.json'), `${JSON.stringify({ run_id: id }, null, 2)}\n`);
+  writeFileSync(join(runDir, 'proof-spec.json'), `${JSON.stringify(proofSpec, null, 2)}\n`);
+  writeFileSync(join(runDir, 'eval-job.json'), `${JSON.stringify(evalJob, null, 2)}\n`);
+  writeFileSync(join(runDir, 'eval-job-output.json'), `${JSON.stringify(output, null, 2)}\n`);
+  writeFileSync(join(runDir, 'boundary.json'), `${JSON.stringify({ live_lev_consumed: false }, null, 2)}\n`);
+  return runDir;
+}
+
+describe('ClaimGate steering-run consumer', () => {
+  it('consumes a valid failed ClaimGate verdict without treating failure as malformed input', () => {
+    const root = makeTempRoot('single-fail');
+    try {
+      const runDir = writeRun(root, 'failed-run', ['passed', 'failed']);
+      const result = consumeClaimGateSteeringRun({ runDir });
+
+      expect(result.ok).toBe(true);
+      expect(result.status).toBe('host_consumed');
+      expect(result.projectedVerdict).toBe('fail');
+      expect(result.recomputedVerdict).toBe('fail');
+      expect(result.liveLevConsumed).toBe(true);
+      expect(result.receipt.proofSpecId).toBe('ps-failed-run');
+
+      const hostBoundary = JSON.parse(readFileSync(join(runDir, 'lev-consumption-boundary.json'), 'utf8'));
+      expect(hostBoundary.live_lev_consumed).toBe(true);
+      expect(hostBoundary.source_boundary_mutated).toBe(false);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('blocks a verdict that does not match proof evidence', () => {
+    const root = makeTempRoot('mismatch');
+    try {
+      const runDir = writeRun(root, 'mismatch-run', ['failed'], 'pass');
+      const result = consumeClaimGateSteeringRun({ runDir });
+
+      expect(result.ok).toBe(false);
+      expect(result.status).toBe('host_blocked');
+      expect(result.projectedVerdict).toBe('pass');
+      expect(result.recomputedVerdict).toBe('fail');
+      expect(result.findings.some((finding) => finding.code === 'eval_output.verdict_mismatch')).toBe(true);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('blocks malformed proof specs without throwing', () => {
+    const root = makeTempRoot('malformed');
+    try {
+      const runDir = writeRun(root, 'malformed-run', ['passed']);
+      writeFileSync(
+        join(runDir, 'proof-spec.json'),
+        `${JSON.stringify({
+          specId: 'ps-malformed-run',
+          targetRef: 'target-malformed-run',
+          proofStrategy: 'compiled_guard',
+          generatedAt: new Date().toISOString(),
+        }, null, 2)}\n`,
+      );
+
+      const result = consumeClaimGateSteeringRun({ runDir });
+
+      expect(result.ok).toBe(false);
+      expect(result.status).toBe('host_blocked');
+      expect(result.findings.some((finding) => finding.code === 'proof_spec.missing_obligations')).toBe(true);
+      expect(result.findings.some((finding) => finding.code === 'proof_spec.evidence_count_mismatch')).toBe(true);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('finds and consumes many steering runs with bounded concurrency', async () => {
+    const root = makeTempRoot('batch');
+    try {
+      const steeringRoot = join(root, '.lev', 'steering', 'runs');
+      for (let i = 0; i < 24; i++) {
+        const statuses: ProofResult['status'][] =
+          i % 3 === 0 ? ['passed'] : i % 3 === 1 ? ['failed'] : ['passed', 'skipped'];
+        writeRun(steeringRoot, `run-${String(i).padStart(2, '0')}`, statuses);
+      }
+
+      expect(findClaimGateSteeringRunDirs(steeringRoot)).toHaveLength(24);
+      const result = await consumeClaimGateSteeringRuns({
+        rootDir: steeringRoot,
+        concurrency: 6,
+      });
+
+      expect(result.runCount).toBe(24);
+      expect(result.okCount).toBe(24);
+      expect(result.blockedCount).toBe(0);
+      expect(result.verdictCounts.pass).toBe(8);
+      expect(result.verdictCounts.fail).toBe(8);
+      expect(result.verdictCounts.conditional).toBe(8);
+      expect(result.concurrency).toBe(6);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+});
