@@ -0,0 +1,454 @@
+/**
+ * ClaimGate steering-run consumer.
+ *
+ * This is the host-Lev side of the ClaimGate adapter seam. ClaimGate may write
+ * EvalJobOutput/ProofSpec-shaped projections under `.lev/steering/runs/<id>`.
+ * This module consumes that projection, checks it against the current Lev proof
+ * vocabulary, recomputes the verdict from proof evidence, and writes a host
+ * consumption receipt without mutating the source projection.
+ */
+
+import { createHash } from 'node:crypto';
+import {
+  appendFileSync,
+  existsSync,
+  mkdirSync,
+  readdirSync,
+  readFileSync,
+  statSync,
+  writeFileSync,
+} from 'node:fs';
+import { basename, dirname, join } from 'node:path';
+
+import type { EvalResult } from '../eval/types.js';
+import { createReceipt } from '../receipt/factory.js';
+import type { Receipt } from '../receipt/types.js';
+import type { EvalJob, EvalJobOutput, EvalVerdict } from './eval-job-types.js';
+import type { ProofResult, ProofSpec } from './proof-spec-generator.js';
+
+const CONSUMER_VERSION = '0.1.0-claimgate-steering-consumer';
+const VALID_VERDICTS = new Set<EvalVerdict>(['pass', 'fail', 'conditional', 'deferred']);
+const VALID_PROOF_STATUSES = new Set<ProofResult['status']>(['passed', 'failed', 'timeout', 'skipped']);
+
+export interface ClaimGateSteeringRunFileSet {
+  runJson: string;
+  proofSpec: string;
+  evalJob: string;
+  evalJobOutput: string;
+  boundary: string;
+}
+
+export interface ClaimGateConsumptionFinding {
+  severity: 'error' | 'warning';
+  code: string;
+  message: string;
+}
+
+export interface ClaimGateConsumptionResult {
+  version: string;
+  runDir: string;
+  runId: string;
+  ok: boolean;
+  status: 'host_consumed' | 'host_blocked';
+  projectedVerdict?: EvalVerdict;
+  recomputedVerdict?: EvalVerdict;
+  liveLevConsumed: boolean;
+  receipt: Receipt;
+  findings: ClaimGateConsumptionFinding[];
+  files: {
+    source: ClaimGateSteeringRunFileSet;
+    hostConsumption: string;
+    hostBoundary: string;
+    hostEvents: string;
+  };
+}
+
+export interface ClaimGateBatchConsumptionResult {
+  version: string;
+  rootDir: string;
+  runCount: number;
+  okCount: number;
+  blockedCount: number;
+  verdictCounts: Record<EvalVerdict, number>;
+  concurrency: number;
+  durationMs: number;
+  results: ClaimGateConsumptionResult[];
+}
+
+export interface ConsumeClaimGateRunOptions {
+  runDir: string;
+  writeReceipt?: boolean;
+}
+
+export interface ConsumeClaimGateRunsOptions {
+  rootDir: string;
+  concurrency?: number;
+  writeReceipt?: boolean;
+}
+
+function readJson<T>(file: string): T {
+  return JSON.parse(readFileSync(file, 'utf8')) as T;
+}
+
+function writeJson(file: string, value: unknown): void {
+  mkdirSync(dirname(file), { recursive: true });
+  writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+function stableStringify(value: unknown): string {
+  if (value === undefined) return '"__undefined__"';
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? '"__undefined__"';
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  const keys = Object.keys(record).sort();
+  return `{${keys.map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`).join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return createHash('sha256').update(stableStringify(value)).digest('hex');
+}
+
+function fileSetFor(runDir: string): ClaimGateSteeringRunFileSet {
+  return {
+    runJson: join(runDir, 'run.json'),
+    proofSpec: join(runDir, 'proof-spec.json'),
+    evalJob: join(runDir, 'eval-job.json'),
+    evalJobOutput: join(runDir, 'eval-job-output.json'),
+    boundary: join(runDir, 'boundary.json'),
+  };
+}
+
+function addFinding(
+  findings: ClaimGateConsumptionFinding[],
+  severity: ClaimGateConsumptionFinding['severity'],
+  code: string,
+  message: string,
+): void {
+  findings.push({ severity, code, message });
+}
+
+function deriveVerdict(results: ProofResult[]): EvalVerdict {
+  if (results.length === 0) return 'conditional';
+  if (results.some((result) => result.status === 'failed' || result.status === 'timeout')) return 'fail';
+  if (results.some((result) => result.status === 'skipped')) return 'conditional';
+  return 'pass';
+}
+
+function proofResultsFromSpec(spec: ProofSpec): ProofResult[] {
+  if (!Array.isArray(spec.proofObligations)) return [];
+  return spec.proofObligations
+    .map((obligation) => obligation.actualResult)
+    .filter((result): result is ProofResult => result !== undefined);
+}
+
+function validateProofResults(
+  output: EvalJobOutput,
+  spec: ProofSpec,
+  findings: ClaimGateConsumptionFinding[],
+): EvalVerdict {
+  const specResults = proofResultsFromSpec(spec);
+  const outputResults = output.evidence;
+
+  if (!Array.isArray(outputResults)) {
+    addFinding(findings, 'error', 'eval_output.evidence_missing', 'EvalJobOutput.evidence must be an array.');
+    return 'conditional';
+  }
+
+  for (const [index, result] of outputResults.entries()) {
+    if (!VALID_PROOF_STATUSES.has(result.status)) {
+      addFinding(
+        findings,
+        'error',
+        'eval_output.invalid_proof_status',
+        `EvalJobOutput.evidence[${index}].status is not a valid ProofResult status.`,
+      );
+    }
+  }
+
+  if (specResults.length !== outputResults.length) {
+    addFinding(
+      findings,
+      'error',
+      'proof_spec.evidence_count_mismatch',
+      `ProofSpec has ${specResults.length} actual results but EvalJobOutput has ${outputResults.length}.`,
+    );
+  }
+
+  const comparable = Math.min(specResults.length, outputResults.length);
+  for (let i = 0; i < comparable; i++) {
+    if (specResults[i].status !== outputResults[i].status) {
+      addFinding(
+        findings,
+        'error',
+        'proof_spec.evidence_status_mismatch',
+        `ProofSpec result ${i} is ${specResults[i].status} but EvalJobOutput evidence ${i} is ${outputResults[i].status}.`,
+      );
+    }
+  }
+
+  return deriveVerdict(outputResults);
+}
+
+function validateProjection(
+  runDir: string,
+): {
+  proofSpec?: ProofSpec;
+  evalJob?: EvalJob;
+  output?: EvalJobOutput;
+  projectedVerdict?: EvalVerdict;
+  recomputedVerdict?: EvalVerdict;
+  findings: ClaimGateConsumptionFinding[];
+  files: ClaimGateSteeringRunFileSet;
+} {
+  const files = fileSetFor(runDir);
+  const findings: ClaimGateConsumptionFinding[] = [];
+
+  for (const [label, file] of Object.entries(files)) {
+    if (!existsSync(file)) {
+      addFinding(findings, 'error', `file.missing_${label}`, `Required steering-run file missing: ${file}`);
+    }
+  }
+
+  if (findings.some((finding) => finding.severity === 'error')) {
+    return { findings, files };
+  }
+
+  const proofSpec = readJson<ProofSpec>(files.proofSpec);
+  const evalJob = readJson<EvalJob>(files.evalJob);
+  const output = readJson<EvalJobOutput>(files.evalJobOutput);
+  const boundary = readJson<Record<string, unknown>>(files.boundary);
+
+  if (!proofSpec.specId) {
+    addFinding(findings, 'error', 'proof_spec.missing_spec_id', 'proof-spec.json must include specId.');
+  }
+  if (!Array.isArray(proofSpec.proofObligations)) {
+    addFinding(findings, 'error', 'proof_spec.missing_obligations', 'proof-spec.json must include proofObligations.');
+  }
+  if (!evalJob.jobId) {
+    addFinding(findings, 'error', 'eval_job.missing_job_id', 'eval-job.json must include jobId.');
+  }
+  if (evalJob.jobClass !== 'eval') {
+    addFinding(findings, 'error', 'eval_job.invalid_job_class', 'eval-job.json jobClass must be eval.');
+  }
+  if (!VALID_VERDICTS.has(output.verdict)) {
+    addFinding(findings, 'error', 'eval_output.invalid_verdict', 'EvalJobOutput.verdict must be pass, fail, conditional, or deferred.');
+  }
+  if (boundary.live_lev_consumed === true) {
+    addFinding(findings, 'warning', 'boundary.already_marked_consumed', 'Source boundary already says live_lev_consumed:true; host will still write a fresh consumption receipt.');
+  }
+
+  const recomputedVerdict = validateProofResults(output, proofSpec, findings);
+  if (VALID_VERDICTS.has(output.verdict) && recomputedVerdict !== output.verdict) {
+    addFinding(
+      findings,
+      'error',
+      'eval_output.verdict_mismatch',
+      `EvalJobOutput verdict is ${output.verdict} but recomputed evidence verdict is ${recomputedVerdict}.`,
+    );
+  }
+
+  if (evalJob.output && stableStringify(evalJob.output) !== stableStringify(output)) {
+    addFinding(
+      findings,
+      'error',
+      'eval_job.output_mismatch',
+      'eval-job.json output must match eval-job-output.json exactly.',
+    );
+  }
+
+  return {
+    proofSpec,
+    evalJob,
+    output,
+    projectedVerdict: output.verdict,
+    recomputedVerdict,
+    findings,
+    files,
+  };
+}
+
+function resultToEvalResult(
+  runId: string,
+  ok: boolean,
+  projectedVerdict: EvalVerdict | undefined,
+  recomputedVerdict: EvalVerdict | undefined,
+  findings: ClaimGateConsumptionFinding[],
+): EvalResult {
+  return {
+    id: `eval-claimgate-steering-${runId}`,
+    strategy: 'gate-based',
+    timestamp: new Date().toISOString(),
+    passed: ok,
+    reasoning: ok
+      ? `ClaimGate steering projection consumed; projected verdict ${projectedVerdict}.`
+      : `ClaimGate steering projection blocked: ${findings.filter((finding) => finding.severity === 'error').map((finding) => finding.code).join(', ')}`,
+    metadata: {
+      projectedVerdict,
+      recomputedVerdict,
+      findingCount: findings.length,
+      errorCount: findings.filter((finding) => finding.severity === 'error').length,
+    },
+  };
+}
+
+export function consumeClaimGateSteeringRun(
+  options: ConsumeClaimGateRunOptions,
+): ClaimGateConsumptionResult {
+  const runDir = options.runDir;
+  const runId = basename(runDir);
+  const validated = validateProjection(runDir);
+  const ok = !validated.findings.some((finding) => finding.severity === 'error');
+  const receipt = createReceipt({
+    scope: 'invocation',
+    sessionId: `claimgate-steering-${runId}`,
+    workUnitId: runId,
+    contentHash: sha256({
+      proofSpec: validated.proofSpec ?? null,
+      evalJobOutput: validated.output ?? null,
+      findings: validated.findings,
+    }),
+    evalResults: [
+      resultToEvalResult(
+        runId,
+        ok,
+        validated.projectedVerdict,
+        validated.recomputedVerdict,
+        validated.findings,
+      ),
+    ],
+    effectResults: [],
+    provenance: {
+      surface: 'cli',
+      host: 'lev',
+      profile: 'claim-gate-steering-consumer',
+      consultedPaths: Object.values(validated.files),
+    },
+    proofSpecId: validated.proofSpec?.specId,
+  });
+
+  const hostConsumption = join(runDir, 'lev-consumption-receipt.json');
+  const hostBoundary = join(runDir, 'lev-consumption-boundary.json');
+  const hostEvents = join(runDir, 'lev-consumption-events.jsonl');
+  const status = ok ? 'host_consumed' : 'host_blocked';
+
+  const result: ClaimGateConsumptionResult = {
+    version: CONSUMER_VERSION,
+    runDir,
+    runId,
+    ok,
+    status,
+    projectedVerdict: validated.projectedVerdict,
+    recomputedVerdict: validated.recomputedVerdict,
+    liveLevConsumed: ok,
+    receipt,
+    findings: validated.findings,
+    files: {
+      source: validated.files,
+      hostConsumption,
+      hostBoundary,
+      hostEvents,
+    },
+  };
+
+  if (options.writeReceipt !== false) {
+    writeJson(hostConsumption, result);
+    writeJson(hostBoundary, {
+      version: CONSUMER_VERSION,
+      status,
+      live_lev_consumed: ok,
+      source_boundary_mutated: false,
+      receipt_id: receipt.id,
+      proof_spec_id: receipt.proofSpecId ?? null,
+      projected_verdict: validated.projectedVerdict ?? null,
+      recomputed_verdict: validated.recomputedVerdict ?? null,
+      consumed_at: receipt.sealedAt,
+    });
+    appendFileSync(hostEvents, `${JSON.stringify({
+      ts: receipt.sealedAt,
+      type: 'claimgate.steering.consumed',
+      data: {
+        runId,
+        status,
+        receiptId: receipt.id,
+        proofSpecId: receipt.proofSpecId ?? null,
+        projectedVerdict: validated.projectedVerdict ?? null,
+        recomputedVerdict: validated.recomputedVerdict ?? null,
+        liveLevConsumed: ok,
+      },
+    })}\n`);
+  }
+
+  return result;
+}
+
+function shouldSkipDir(name: string): boolean {
+  return name === '.git' || name === 'node_modules' || name === 'dist' || name === '.venv';
+}
+
+export function findClaimGateSteeringRunDirs(rootDir: string): string[] {
+  const found: string[] = [];
+  const stack = [rootDir];
+
+  while (stack.length > 0) {
+    const dir = stack.pop();
+    if (!dir) continue;
+    if (!existsSync(dir) || !statSync(dir).isDirectory()) continue;
+
+    if (existsSync(join(dir, 'eval-job-output.json')) && existsSync(join(dir, 'proof-spec.json'))) {
+      found.push(dir);
+      continue;
+    }
+
+    for (const entry of readdirSync(dir)) {
+      if (shouldSkipDir(entry)) continue;
+      const child = join(dir, entry);
+      if (existsSync(child) && statSync(child).isDirectory()) stack.push(child);
+    }
+  }
+
+  return found.sort();
+}
+
+export async function consumeClaimGateSteeringRuns(
+  options: ConsumeClaimGateRunsOptions,
+): Promise<ClaimGateBatchConsumptionResult> {
+  const started = performance.now();
+  const runDirs = findClaimGateSteeringRunDirs(options.rootDir);
+  const concurrency = Math.max(1, Math.floor(options.concurrency ?? 4));
+  const results: ClaimGateConsumptionResult[] = [];
+  let next = 0;
+
+  async function worker(): Promise<void> {
+    while (next < runDirs.length) {
+      const index = next++;
+      results[index] = consumeClaimGateSteeringRun({
+        runDir: runDirs[index],
+        writeReceipt: options.writeReceipt,
+      });
+    }
+  }
+
+  await Promise.all(Array.from({ length: Math.min(concurrency, Math.max(1, runDirs.length)) }, () => worker()));
+
+  const verdictCounts: Record<EvalVerdict, number> = {
+    pass: 0,
+    fail: 0,
+    conditional: 0,
+    deferred: 0,
+  };
+  for (const result of results) {
+    if (result.projectedVerdict) verdictCounts[result.projectedVerdict]++;
+  }
+
+  return {
+    version: CONSUMER_VERSION,
+    rootDir: options.rootDir,
+    runCount: results.length,
+    okCount: results.filter((result) => result.ok).length,
+    blockedCount: results.filter((result) => !result.ok).length,
+    verdictCounts,
+    concurrency,
+    durationMs: Math.round(performance.now() - started),
+    results,
+  };
+}
