---
 .../src/proof/lev-wizard-ratchet.test.ts      | 32 +++++++++++++++++++
 .../src/proof/lev-wizard-ratchet.ts           |  3 +-
 2 files changed, 34 insertions(+), 1 deletion(-)

diff --git a/core/orchestration/src/proof/lev-wizard-ratchet.test.ts b/core/orchestration/src/proof/lev-wizard-ratchet.test.ts
index dee908030..b5e10abf1 100644
--- a/core/orchestration/src/proof/lev-wizard-ratchet.test.ts
+++ b/core/orchestration/src/proof/lev-wizard-ratchet.test.ts
@@ -921,6 +921,38 @@ describe('Lev Wizard Ratchet council run', () => {
     expect(firstRun.nextRunSeed?.inputPatch.sessionId).toBe(firstRun.nextRunSeed?.seedSessionId);
   });
 
+  it('validates recursive nextRunSeed context against the latest accepted-survivor receipt', () => {
+    const firstInput = createExternallyReceiptedInput({
+      trustedEvidenceRefs: [...WIZARD_FIXTURE_TRUSTED_EVIDENCE_REFS],
+    });
+    const firstRun = runLevWizardRatchetCouncil(firstInput, {
+      trustedEvidenceRefs: [...WIZARD_FIXTURE_TRUSTED_EVIDENCE_REFS],
+    });
+    const secondBaseInput = createExternallyReceiptedInput({
+      trustedEvidenceRefs: [...WIZARD_FIXTURE_TRUSTED_EVIDENCE_REFS],
+    });
+    secondBaseInput.sessionId = firstRun.sessionId;
+    const secondInput = createSeededLevWizardRatchetInput(firstRun, secondBaseInput);
+    const secondRun = runLevWizardRatchetCouncil(secondInput, {
+      trustedEvidenceRefs: [...WIZARD_FIXTURE_TRUSTED_EVIDENCE_REFS],
+    });
+    const acceptedSeedReceipts = secondRun.nextRunSeed?.inputPatch.contextReceipts.filter((receipt) => (
+      receipt.ref === 'source:lev-wizard-ratchet:accepted-survivor-seed'
+    ));
+
+    expect(secondRun.steeringAdmission.status).toBe('host_consumed');
+    expect(acceptedSeedReceipts?.length).toBeGreaterThan(1);
+    expect(acceptedSeedReceipts?.[acceptedSeedReceipts.length - 1]).toEqual(expect.objectContaining({
+      receiptRef: secondRun.receipt.id,
+    }));
+
+    const thirdBaseInput = createExternallyReceiptedInput({
+      trustedEvidenceRefs: [...WIZARD_FIXTURE_TRUSTED_EVIDENCE_REFS],
+    });
+    thirdBaseInput.sessionId = secondRun.sessionId;
+    expect(() => createSeededLevWizardRatchetInput(secondRun, thirdBaseInput)).not.toThrow();
+  });
+
   it('fails closed when Wizard gate refs are not supplied by an external trust boundary', () => {
     const input = createDefaultLevWizardRatchetInput();
     const result = runLevWizardRatchetCouncil(input);
diff --git a/core/orchestration/src/proof/lev-wizard-ratchet.ts b/core/orchestration/src/proof/lev-wizard-ratchet.ts
index 8d1808864..cf2b75b7e 100644
--- a/core/orchestration/src/proof/lev-wizard-ratchet.ts
+++ b/core/orchestration/src/proof/lev-wizard-ratchet.ts
@@ -1934,9 +1934,10 @@ export function createSeededLevWizardRatchetInput(
       spinorCellHash: previousResult.spinorCell.cellHash,
     };
     const expectedSeedHash = sha256(expectedSeedFacts);
-    const seedContextReceipt = seed.inputPatch.contextReceipts.find((receipt) => (
+    const acceptedSurvivorSeedReceipts = seed.inputPatch.contextReceipts.filter((receipt) => (
       receipt.ref === 'source:lev-wizard-ratchet:accepted-survivor-seed'
     ));
+    const seedContextReceipt = acceptedSurvivorSeedReceipts[acceptedSurvivorSeedReceipts.length - 1];
     if (!seedContextReceipt) {
       addFinding(findings, 'wizard_next_run_seed_context_receipt_missing', 'seed input patch must carry an accepted-survivor source receipt.', 'nextRunSeed.inputPatch.contextReceipts');
     } else {
