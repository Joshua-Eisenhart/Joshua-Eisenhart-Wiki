diff --git a/core/graph/src/__tests__/mechanical-probe-runner.test.ts b/core/graph/src/__tests__/mechanical-probe-runner.test.ts
index 845e150f1..5fbc896d4 100644
--- a/core/graph/src/__tests__/mechanical-probe-runner.test.ts
+++ b/core/graph/src/__tests__/mechanical-probe-runner.test.ts
@@ -236,6 +236,54 @@ describe('mechanical probe runner', () => {
     });
   });
 
+  it('does not inherit host environment unless explicitly requested', () => {
+    const dir = mkdtempSync(join(tmpdir(), 'lev-probe-env-isolation-'));
+    const scriptPath = join(dir, 'env_probe.js');
+    const sourceText = 'console.log(process.env.LEV_MECHANICAL_PROBE_SECRET_LEAK ?? "absent")';
+    writeFileSync(scriptPath, sourceText);
+    process.env.LEV_MECHANICAL_PROBE_SECRET_LEAK = 'host-secret';
+    try {
+      const isolated = runMechanicalProbeLane({
+        engine: 'jax',
+        role: 'batched_geometry_workhorse',
+        command: process.execPath,
+        args: [scriptPath],
+        sourceRef: `file:${scriptPath}`,
+        sourceText,
+        expectedSourceHash: sha256Text(sourceText),
+        input: { fixture: 'env-isolation' },
+        timeoutMs: 10_000,
+        alignedPackagesLoadBearing: ['node'],
+        negativeControl: 'host_env_must_not_leak',
+        gateEffect: 'can_resolve_uncertain',
+      });
+
+      const inherited = runMechanicalProbeLane({
+        engine: 'jax',
+        role: 'batched_geometry_workhorse',
+        command: process.execPath,
+        args: [scriptPath],
+        inheritEnv: true,
+        sourceRef: `file:${scriptPath}`,
+        sourceText,
+        expectedSourceHash: sha256Text(sourceText),
+        input: { fixture: 'env-inheritance' },
+        timeoutMs: 10_000,
+        alignedPackagesLoadBearing: ['node'],
+        negativeControl: 'host_env_inheritance_is_explicit',
+        gateEffect: 'can_resolve_uncertain',
+      });
+
+      expect(isolated.inheritEnv).toBe(false);
+      expect(isolated.stdout.trim()).toBe('absent');
+      expect(inherited.inheritEnv).toBe(true);
+      expect(inherited.stdout.trim()).toBe('host-secret');
+      expect(validateMechanicalProbeRunReceipt(inherited).findings).toContain('process must not inherit host environment');
+    } finally {
+      delete process.env.LEV_MECHANICAL_PROBE_SECRET_LEAK;
+    }
+  });
+
   juliaIt('captures hash-bound output artifacts written by the probe', () => {
     const dir = mkdtempSync(join(tmpdir(), 'lev-julia-probe-artifact-'));
     const artifactPath = join(dir, 'probe_result.json');
