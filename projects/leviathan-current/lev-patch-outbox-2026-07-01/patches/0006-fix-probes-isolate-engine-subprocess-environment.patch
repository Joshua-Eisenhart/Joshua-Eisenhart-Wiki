@@ -29,6 +29,12 @@ import type { ProofResult, ProofSpec } from './proof-spec-generator.js';
 const CONSUMER_VERSION = '0.1.0-claimgate-steering-consumer';
 const VALID_VERDICTS = new Set<EvalVerdict>(['pass', 'fail', 'conditional', 'deferred']);
 const VALID_PROOF_STATUSES = new Set<ProofResult['status']>(['passed', 'failed', 'timeout', 'skipped']);
+// Host-witness stays a per-process ephemeral secret BY DESIGN: the witness attests
+// in-process proof execution, and a witness minted by another process is treated as a
+// replay attack (see claim-gate-steering-run.test.ts "blocks replaying a host-issued
+// witness ledger from another process"). Unlike host-consume / graph-event-trust — the
+// chain-crossing tokens the recursive loop needs to survive a process boundary — the
+// witness must NOT cross processes without a dedicated single-use/freshness guard.
 const HOST_WITNESS_PROCESS_SECRET = randomBytes(32);
 const HOST_WITNESS_ISSUER_TOKEN = Symbol('claim-gate-host-witness-issuer');
 const HOST_PROOF_EXECUTOR_VERSION = 'lev-host-proof-obligation-runner/1.1:claimgate-internal-gates';
