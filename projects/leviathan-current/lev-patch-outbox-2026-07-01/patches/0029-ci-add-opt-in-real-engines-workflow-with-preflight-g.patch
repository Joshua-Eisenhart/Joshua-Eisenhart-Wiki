@@ -0,0 +1,58 @@
+#!/usr/bin/env bash
+# Preflight for the opt-in real-engine CI backstop (.github/workflows/real-engines.yml).
+#
+# Checks that the toolchain the real-evidence loop tests need is actually present
+# and importable: julia + the pinned sim-stack python + jax/torch/quimb/geomstats.
+# This job is opt-in coverage (workflow_dispatch + weekly cron), so a missing
+# toolchain must SKIP the run cleanly, not fail it red.
+#
+# Emits `real_engines_ready=true|false` to $GITHUB_OUTPUT when GITHUB_OUTPUT is
+# set (CI); otherwise just prints findings and exits non-zero on failure so it
+# is still usable standalone.
+set -uo pipefail
+
+JULIA_BIN="${LEV_JULIA_BIN:-/opt/homebrew/bin/julia}"
+if ! command -v julia >/dev/null 2>&1 && [ ! -x "$JULIA_BIN" ]; then
+  # Fall back to whatever `julia` resolves to on PATH (e.g. CI's apt/asdf install).
+  JULIA_BIN="$(command -v julia || true)"
+fi
+
+PY_BIN="${LEV_PY:-/Users/joshuaeisenhart/.local/share/lev/sim-stack/bin/python3}"
+
+missing=()
+
+if [ -z "$JULIA_BIN" ] || [ ! -x "$JULIA_BIN" ]; then
+  missing+=("julia (checked LEV_JULIA_BIN / PATH)")
+else
+  echo "found julia: $("$JULIA_BIN" --version 2>&1)"
+fi
+
+if [ ! -x "$PY_BIN" ]; then
+  missing+=("sim-stack python3 at $PY_BIN (set LEV_PY to override)")
+else
+  echo "found sim-stack python: $("$PY_BIN" --version 2>&1)"
+  if ! "$PY_BIN" -c "import jax, torch, quimb, geomstats" >/dev/null 2>&1; then
+    missing+=("jax/torch/quimb/geomstats import failed under $PY_BIN")
+  else
+    "$PY_BIN" -c "
+import jax, torch, quimb, geomstats
+print(f'jax {jax.__version__}, torch {torch.__version__}, quimb {quimb.__version__}, geomstats {geomstats.__version__}')
+"
+  fi
+fi
+
+if [ "${#missing[@]}" -gt 0 ]; then
+  echo "REAL ENGINE PREFLIGHT: toolchain not available, this run will SKIP:"
+  for item in "${missing[@]}"; do
+    echo "  - $item"
+  done
+  if [ -n "${GITHUB_OUTPUT:-}" ]; then
+    echo "real_engines_ready=false" >> "$GITHUB_OUTPUT"
+  fi
+  exit 0
+fi
+
+echo "REAL ENGINE PREFLIGHT: julia + sim-stack python + jax/torch/quimb/geomstats all present."
+if [ -n "${GITHUB_OUTPUT:-}" ]; then
+  echo "real_engines_ready=true" >> "$GITHUB_OUTPUT"
+fi
