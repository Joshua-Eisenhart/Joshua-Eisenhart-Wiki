+        "chain_observables" => chain,
+        "T5_order_AB_vs_BA_state_dependence" => t5,
+        "co_ratchet_lock" => Dict(
+            "locked" => lock,
+            "criterion" => "geometry chain changes and T5 state-dependent AB/BA discriminator remains present",
+            "negative_control" => negative_control,
