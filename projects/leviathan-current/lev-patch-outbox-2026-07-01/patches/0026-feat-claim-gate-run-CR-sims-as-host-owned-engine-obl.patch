+        "packages_used" => ["JSON"],
+        "aligned_packages_load_bearing" => ["julia"],
+    )
+end
+
+function main()
+    if get(ENV, "LEV_CR_CORATCHET_NEGATIVE_CONTROL", "") == "erase_state_dependent_order_readout"
+        println(JSON.json(build_result(true)))
