+            "jax.numpy": {"tried": True, "used": True, "reason": "load-bearing count and mask readouts"},
+        },
+        "TOOL_INTEGRATION_DEPTH": {"jax": "load_bearing", "jax.numpy": "load_bearing"},
+        "packages_used": ["jax", "jax.numpy"],
+        "aligned_packages_load_bearing": ["jax", "jax.numpy"],
+    }
+
