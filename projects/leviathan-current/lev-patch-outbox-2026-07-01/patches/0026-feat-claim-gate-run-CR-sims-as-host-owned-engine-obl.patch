+
+def sha256_of(path: Path) -> str:
+    return hashlib.sha256(path.read_bytes()).hexdigest()
+
+
+def log2(n: int | float) -> float:
+    return math.log2(n) if n > 0 else float("-inf")
+
+
+def capacity_entropy(x: list[tuple[int, ...]]) -> float:
+    return log2(len(x))
+
+
+def block_entropy(x: list[tuple[int, ...]]) -> float:
+    blocks = {(tuple(row[i] for i in SUBLATTICE_A), tuple(row[i] for i in SUBLATTICE_B)) for row in x}
+    return log2(len(blocks))
+
+
+def induced_geometry(x: list[tuple[int, ...]]) -> dict[str, int]:
+    xset = set(x)
+    edges = 0
+    for row in x:
+        for i in range(N):
+            y = list(row)
+            y[i] ^= 1
+            y_tuple = tuple(y)
+            if y_tuple in xset and y_tuple > row:
+                edges += 1
+    seen: set[tuple[int, ...]] = set()
+    components = 0
+    for row in x:
+        if row in seen:
+            continue
+        components += 1
+        stack = [row]
+        while stack:
+            current = stack.pop()
+            if current in seen:
+                continue
+            seen.add(current)
+            for i in range(N):
+                neighbor = list(current)
+                neighbor[i] ^= 1
+                neighbor_tuple = tuple(neighbor)
+                if neighbor_tuple in xset and neighbor_tuple not in seen:
+                    stack.append(neighbor_tuple)
+    return {"n": len(x), "edges": edges, "components": components}
+
+
+def constraint_equal(k: int, x: list[tuple[int, ...]]) -> list[tuple[int, ...]]:
+    j = (k + 1) % N
+    arr = jnp.asarray(x, dtype=jnp.int32)
+    mask = jnp.equal(arr[:, k], arr[:, j])
+    keep = set(map(tuple, jax.device_get(arr[mask]).tolist()))
+    return [row for row in x if row in keep]
+
+
+def window_constraint(window: tuple[int, ...], x: list[tuple[int, ...]]) -> list[tuple[int, ...]]:
+    if not x:
+        return x
+    arr = jnp.asarray(x, dtype=jnp.int32)
+    counts = jnp.sum(arr[:, jnp.asarray(window)], axis=1)
+    mean = jnp.mean(counts)
+    keep = set(map(tuple, jax.device_get(arr[counts >= mean]).tolist()))
+    return [row for row in x if row in keep]
+
+
+def chain_observables() -> list[dict[str, Any]]:
+    out: list[dict[str, Any]] = []
+    x = S
+    for k in [0, 2, 4]:
+        x = constraint_equal(k, x)
+        out.append(
+            {
+                "carve": f"x{k}==x{(k + 1) % N}",
+                "capacity": round(capacity_entropy(x), 10),
+                "block": round(block_entropy(x), 10),
+                "geometry": induced_geometry(x),
+            }
+        )
+    return out
+
+
+def t5_order_discriminator() -> dict[str, Any]:
+    windows = [(0, 1), (0, 1, 2), (1, 2), (0, 2, 4), (1, 3, 5), (2, 3)]
