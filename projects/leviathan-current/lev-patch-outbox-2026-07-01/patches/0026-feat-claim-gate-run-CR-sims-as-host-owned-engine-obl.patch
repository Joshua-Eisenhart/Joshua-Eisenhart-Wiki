+#!/usr/bin/env julia
+# Julia lane for entropy_geometry_coratchet_floor_v0.
+
+using Dates
+using JSON
+using SHA
+
+const SIM_ID = "entropy_geometry_coratchet_floor_v0"
+const HERE = @__DIR__
+const RESULTS = joinpath(HERE, "results")
+const N = 6
+const SUBLATTICE_A = [1, 3, 5]
+const SUBLATTICE_B = [2, 4, 6]
+const S = [Tuple(Int(d) for d in digits(i, base = 2, pad = N)) for i in 0:(2^N - 1)]
+
+sha256_of(path::AbstractString) = bytes2hex(open(sha256, path))
+log2_safe(n) = n > 0 ? log2(n) : -Inf
+capacity_entropy(x) = log2_safe(length(x))
+
+function block_entropy(x)
+    blocks = Set((Tuple(row[i] for i in SUBLATTICE_A), Tuple(row[i] for i in SUBLATTICE_B)) for row in x)
+    return log2_safe(length(blocks))
+end
+
+function induced_geometry(x)
+    xset = Set(x)
+    edges = 0
+    for row in x
+        for i in 1:N
+            y = collect(row)
+            y[i] = 1 - y[i]
+            yt = Tuple(y)
+            if yt in xset && yt > row
+                edges += 1
+            end
+        end
+    end
+    seen = Set{typeof(first(S))}()
+    components = 0
+    for row in x
+        if row in seen
+            continue
+        end
+        components += 1
+        stack = [row]
+        while !isempty(stack)
+            current = pop!(stack)
+            if current in seen
+                continue
+            end
+            push!(seen, current)
+            for i in 1:N
+                neighbor = collect(current)
+                neighbor[i] = 1 - neighbor[i]
+                nt = Tuple(neighbor)
+                if nt in xset && !(nt in seen)
+                    push!(stack, nt)
+                end
+            end
+        end
+    end
+    return Dict("n" => length(x), "edges" => edges, "components" => components)
+end
+
+function constraint_equal(k0, x)
+    k = k0 + 1
+    j = (k0 + 1) % N + 1
+    return [row for row in x if row[k] == row[j]]
+end
+
+function window_constraint(window0, x)
+    isempty(x) && return x
+    window = [i + 1 for i in window0]
+    counts = [sum(row[i] for i in window) for row in x]
+    mean_count = sum(counts) / length(counts)
+    return [row for (index, row) in enumerate(x) if counts[index] >= mean_count]
+end
+
+function chain_observables()
+    out = []
+    x = S
+    for k in [0, 2, 4]
+        x = constraint_equal(k, x)
+        push!(out, Dict(
+            "carve" => "x$(k)==x$((k + 1) % N)",
+            "capacity" => round(capacity_entropy(x), digits = 10),
+            "block" => round(block_entropy(x), digits = 10),
+            "geometry" => induced_geometry(x),
+        ))
+    end
+    return out
+end
+
+function t5_order_discriminator()
+    windows = [(0, 1), (0, 1, 2), (1, 2), (0, 2, 4), (1, 3, 5), (2, 3)]
+    pairs = []
+    for i in eachindex(windows)
+        for j in (i + 1):length(windows)
+            push!(pairs, (windows[i], windows[j]))
+        end
+    end
+    count = 0
+    example = nothing
+    for (a, b) in pairs
+        ab = window_constraint(b, window_constraint(a, S))
+        ba = window_constraint(a, window_constraint(b, S))
+        if Set(ab) != Set(ba)
+            count += 1
+            if example === nothing
+                example = Dict(
+                    "win_a" => collect(a),
+                    "win_b" => collect(b),
+                    "symdiff" => length(symdiff(Set(ab), Set(ba))),
+                    "AB_capacity" => round(capacity_entropy(ab), digits = 4),
+                    "BA_capacity" => round(capacity_entropy(ba), digits = 4),
+                )
+            end
+        end
+    end
+    return Dict(
+        "statedep_window_pairs_scanned" => length(pairs),
+        "statedep_window_pairs_noncommuting" => count,
+        "noncommuting_example" => example,
+        "order_changes_readout" => count > 0,
+    )
+end
+
+function build_result(negative_control::Bool)
+    chain = chain_observables()
+    t5 = t5_order_discriminator()
+    lock = length(Set(JSON.json(row["geometry"]) for row in chain)) > 1 &&
+        t5["order_changes_readout"] &&
+        t5["noncommuting_example"]["AB_capacity"] != t5["noncommuting_example"]["BA_capacity"]
+    if negative_control
+        t5 = merge(t5, Dict(
+            "statedep_window_pairs_noncommuting" => 0,
+            "noncommuting_example" => nothing,
+            "order_changes_readout" => false,
+            "negative_control_mutation" => "erase_state_dependent_order_readout",
+        ))
+        lock = false
+    end
+    return Dict(
+        "schema" => "codex_ratchet.engine_leg_result.v1",
+        "sim_id" => SIM_ID,
+        "engine" => "julia",
+        "computation_style" => "julia_exact_finite_sets",
+        "classification" => "scratch_diagnostic",
+        "promotion_allowed" => false,
+        "formal_admission_allowed" => false,
+        "reads_peer_result" => false,
+        "generated_at" => Dates.format(now(UTC), dateformat"yyyy-mm-ddTHH:MM:SSZ"),
+        "source_sha256" => sha256_of(@__FILE__),
