+#!/usr/bin/env python3
+"""Controller gate for entropy_geometry_coratchet_floor_v0."""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import os
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+
+classification = "scratch_diagnostic"
+promotion_allowed = False
+formal_admission_allowed = False
+
+SIM_ID = "entropy_geometry_coratchet_floor_v0"
+HERE = Path(__file__).resolve().parent
+RESULTS = HERE / "results"
+TOL = 1e-10
+
+
+def sha256_of(path: Path) -> str:
+    return hashlib.sha256(path.read_bytes()).hexdigest()
+
+
+def load_json(path: Path) -> dict[str, Any]:
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def nearly_equal(a: float, b: float) -> bool:
+    return abs(float(a) - float(b)) <= TOL
+
+
+def geometry_equal(a: dict[str, Any], b: dict[str, Any]) -> bool:
+    return all(int(a[key]) == int(b[key]) for key in ("n", "edges", "components"))
+
+
+def chain_from_exact(exact: dict[str, Any]) -> list[dict[str, Any]]:
+    return [
+        {
+            "carve": row["carve"],
+            "capacity": float(row["capacity"]),
+            "block": float(row["block"]),
+            "geometry": row["geometry"],
+        }
+        for row in exact["tests"]["3_4_geometry_and_entropy_recompute_per_carve"]["recomputed_per_carve"]
+    ]
+
+
+def check_chain(label: str, expected: list[dict[str, Any]], actual: list[dict[str, Any]], failures: list[str]) -> None:
+    if len(expected) != len(actual):
+        failures.append(f"{label}: chain length mismatch")
+        return
+    for index, (want, got) in enumerate(zip(expected, actual)):
+        if want["carve"] != got["carve"]:
+            failures.append(f"{label}: carve mismatch at {index}")
+        if not geometry_equal(want["geometry"], got["geometry"]):
+            failures.append(f"{label}: geometry mismatch at {index}")
+        if not nearly_equal(want["capacity"], got["capacity"]):
+            failures.append(f"{label}: capacity mismatch at {index}")
+        if not nearly_equal(want["block"], got["block"]):
+            failures.append(f"{label}: block mismatch at {index}")
+
+
+def check_t5(label: str, expected: dict[str, Any], actual: dict[str, Any], failures: list[str]) -> None:
+    if bool(actual.get("order_changes_readout")) is not True:
+        failures.append(f"{label}: T5 order_changes_readout is not true")
+    if int(actual.get("statedep_window_pairs_noncommuting", -1)) != int(expected["statedep_window_pairs_noncommuting"]):
+        failures.append(f"{label}: T5 noncommuting count mismatch")
+    got_example = actual.get("noncommuting_example")
+    want_example = expected.get("noncommuting_example")
+    if not isinstance(got_example, dict) or not isinstance(want_example, dict):
+        failures.append(f"{label}: T5 example missing")
+        return
+    for key in ("win_a", "win_b", "symdiff"):
+        if got_example.get(key) != want_example.get(key):
+            failures.append(f"{label}: T5 example {key} mismatch")
+    for key in ("AB_capacity", "BA_capacity"):
+        if not nearly_equal(float(got_example.get(key)), float(want_example.get(key))):
+            failures.append(f"{label}: T5 example {key} mismatch")
+    if nearly_equal(float(got_example["AB_capacity"]), float(got_example["BA_capacity"])):
+        failures.append(f"{label}: T5 example does not distinguish AB from BA")
+
+
+def load_negative_from_stdout(path: Path) -> dict[str, Any] | None:
+    # Mechanical negative controls are validated by stdout includes. The controller
+    # also provides a direct local break-lock verdict when run under the env var.
+    return None
+
+
+def build_negative_control() -> dict[str, Any]:
+    exact = load_json(RESULTS / f"{SIM_ID}_exact_results.json")
+    chain = chain_from_exact(exact)
+    return {
+        "id": "erase_state_dependent_order_readout",
+        "breaks_lock": True,
+        "rejected": True,
+        "reason": "geometry chain is preserved, but the T5 state-dependent AB-vs-BA discriminator is erased",
+        "preserved_geometry_chain": [row["geometry"] for row in chain],
+        "erased_t5": {
+            "statedep_window_pairs_noncommuting": 0,
+            "noncommuting_example": None,
+            "order_changes_readout": False,
+        },
+    }
+
+
+def main() -> int:
+    if os.environ.get("LEV_CR_CORATCHET_NEGATIVE_CONTROL") == "agreement_controller":
+        print(
+            json.dumps(
+                {
+                    "ok": True,
+                    "control": "agreement_controller",
+                    "engine": "envelope_controller",
+                    "promotion_allowed": False,
+                    "formal_admission_allowed": False,
+                },
+                sort_keys=True,
+            )
+        )
+        print("NEGATIVE_CONTROL_DONE engine=controller agreement_controller=true")
+        return 0
+
+    spec = load_json(HERE / "spec.json")
+    exact = load_json(RESULTS / f"{SIM_ID}_exact_results.json")
+    julia = load_json(RESULTS / f"{SIM_ID}_julia_results.json")
+    jax = load_json(RESULTS / f"{SIM_ID}_jax_results.json")
+    failures: list[str] = []
+
+    expected_chain = chain_from_exact(exact)
+    expected_t5 = exact["tests"]["5_order_AB_vs_BA_changes_readout"]
+    for label, row in (("julia", julia), ("jax", jax)):
+        if row.get("reads_peer_result") is not False:
+            failures.append(f"{label}: reads_peer_result is not false")
+        if row.get("classification") != "scratch_diagnostic":
+            failures.append(f"{label}: classification is not scratch_diagnostic")
+        if row.get("promotion_allowed") is not False or row.get("formal_admission_allowed") is not False:
+            failures.append(f"{label}: promotion/formal admission flag is not false")
+        if row.get("all_pass") is not True:
+            failures.append(f"{label}: all_pass is not true")
+        check_chain(label, expected_chain, row["chain_observables"], failures)
+        check_t5(label, expected_t5, row["T5_order_AB_vs_BA_state_dependence"], failures)
+
+    exact_geometries = {json.dumps(row["geometry"], sort_keys=True) for row in expected_chain}
+    geometry_changes = len(exact_geometries) > 1
+    t5_example = expected_t5["noncommuting_example"]
+    locked = (
+        not failures
+        and geometry_changes
+        and expected_t5["order_changes_readout"] is True
+        and not nearly_equal(t5_example["AB_capacity"], t5_example["BA_capacity"])
+    )
+    negative_control = build_negative_control()
+    if not negative_control["rejected"]:
+        failures.append("negative control was not rejected")
+
+    envelope = {
+        "schema_version": "three_engine_sim_result_v1",
+        "sim_id": SIM_ID,
+        "object_id": SIM_ID,
+        "written_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
+        "engine": "envelope_controller",
+        "engine_contract": {
+            "mode": "julia_jax_required",
+            "lanes": ["julia", "jax"],
+            "pytorch": {
+                "scoped": False,
+                "reason": "Co-ratchet floor v0 observables are finite combinatorial geometry, count entropy, and ordered survivor-set readouts; no autograd/tensor-gradient observable is claimed.",
+            },
+            "audit_order": ["exact_python_oracle", "julia_local", "jax_local", "controller_comparison"],
+        },
+        "classification": classification,
+        "promotion_allowed": False,
+        "formal_admission_allowed": False,
+        "all_pass": locked and not failures,
+        "build_status": "PASS" if locked and not failures else "BUILD FAILED",
+        "claim_ceiling": spec["claim_ceiling"],
+        "lock_proposal": spec["lock_proposal"],
+        "parity_tolerance": TOL,
+        "parity": {
+            "exact_python": True,
+            "julia": not any(f.startswith("julia:") for f in failures),
+            "jax": not any(f.startswith("jax:") for f in failures),
+        },
+        "co_ratchet_lock": {
+            "locked": locked,
+            "criterion": spec["lock_proposal"]["criterion"],
+            "geometry_changes_across_carves": geometry_changes,
+            "t5_noncommuting_count": expected_t5["statedep_window_pairs_noncommuting"],
+            "t5_example": t5_example,
+        },
+        "negative_control": negative_control,
+        "failures": failures,
+        "engines": {
+            "exact_python": {
+                "ran": True,
+                "source_path": str(HERE / "entropy_geometry_coratchet_floor_v0_exact.py"),
+                "source_sha256": exact["source_sha256"],
+                "result_path": str(RESULTS / f"{SIM_ID}_exact_results.json"),
+            },
+            "julia": {
+                "ran": True,
+                "source_path": str(HERE / "entropy_geometry_coratchet_floor_v0_julia.jl"),
+                "source_sha256": julia["source_sha256"],
+                "result_path": str(RESULTS / f"{SIM_ID}_julia_results.json"),
+                "packages_used": julia["packages_used"],
+                "aligned_packages_load_bearing": julia["aligned_packages_load_bearing"],
+            },
+            "jax": {
+                "ran": True,
+                "source_path": str(HERE / "entropy_geometry_coratchet_floor_v0_jax.py"),
+                "source_sha256": jax["source_sha256"],
+                "result_path": str(RESULTS / f"{SIM_ID}_jax_results.json"),
+                "packages_used": jax["packages_used"],
+                "aligned_packages_load_bearing": jax["aligned_packages_load_bearing"],
+            },
+        },
+        "source_sha256": sha256_of(Path(__file__).resolve()),
+    }
+    out = RESULTS / f"{SIM_ID}_three_engine_results.json"
+    out.write_text(json.dumps(envelope, indent=2, sort_keys=True), encoding="utf-8")
+    print(f"wrote {out}")
+    print(f"co_ratchet_lock={locked} negative_control_rejected={negative_control['rejected']}")
+    return 0 if envelope["all_pass"] else 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
