+function claimGateLoopResultFromArtifact(value: unknown): ClaimGateLoopResult | null {
+  if (!isRecord(value)) return null;
+  if (isRecord(value.graphPatchProposal) && isRecord(value.receipt)) {
+    return value as unknown as ClaimGateLoopResult;
+  }
+  if (
+    value.kind === 'ClaimGateWaveRunContinuationResult'
+    && isRecord(value.waveResult)
+  ) {
+    return value.waveResult as unknown as ClaimGateLoopResult;
+  }
+  if (
+    value.kind === 'ClaimGateWaveRunResult'
+    && Array.isArray(value.waveResults)
+    && isRecord(value.waveResults[value.waveResults.length - 1])
+  ) {
+    return value.waveResults[value.waveResults.length - 1] as unknown as ClaimGateLoopResult;
+  }
+  return null;
+}
+
+function readClaimGateLoopResultArtifact(file: string): ClaimGateLoopResult {
+  const parsed = readJson<unknown>(file);
+  const result = claimGateLoopResultFromArtifact(parsed);
+  if (!result) {
+    throw new Error('Expected a ClaimGate loop result, WaveRun result, or WaveRun continuation result with a nested waveResult.');
+  }
+  return result;
+}
