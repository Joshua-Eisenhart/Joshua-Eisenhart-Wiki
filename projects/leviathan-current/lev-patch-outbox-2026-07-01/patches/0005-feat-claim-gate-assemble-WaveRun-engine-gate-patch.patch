+
+function summarizeSkillSourcePack(receipt: FormalExecutionSkillSetRunReceipt): LevWizardSkillSourcePackSummary {
+  const admittedRecordCount = receipt.sourcePackReceipt.admittedRecordIds.length;
+  const formalReceiptFindings = formalSkillSetReceiptFindings(receipt);
+  const formalReceiptConsistent = formalReceiptFindings.length === 0;
+  const admittedFormalSkillCount = formalReceiptConsistent ? receipt.formalSkillSetReceipt?.admittedSkillIds.length ?? 0 : 0;
+  return {
+    rootDir: receipt.rootDir,
+    packId: receipt.packId,
+    totalSkillFilesFound: receipt.totalSkillFilesFound,
+    recordsBuilt: receipt.recordsBuilt,
+    admittedRecordCount,
+    referenceOrBlockedRecordCount: Math.max(0, receipt.totalSkillFilesFound - admittedRecordCount),
+    findingCount: receipt.sourcePackReceipt.findings.length,
+    findingCodes: countByCode(receipt.sourcePackReceipt.findings),
+    purgatoryRecordCount: receipt.sourcePackReceipt.purgatory.length,
+    formalSkillCandidateCount: receipt.formalSkillSet?.skills.length ?? 0,
+    admittedFormalSkillCount,
+    formalSkillBundleCount: formalReceiptConsistent ? receipt.formalSkillSetReceipt?.admittedBundleIds.length ?? 0 : 0,
+    formalSkillFindingCount: (receipt.formalSkillSetReceipt?.findings.length ?? 0) + formalReceiptFindings.length,
+  };
+}
+
+function recordIdMatchesAlias(recordId: string, alias: string): boolean {
+  return recordId === alias || recordId.endsWith(`/${alias}`);
+}
+
+function declaredSkillRefCovered(ref: string, admittedRecordIds: Set<string>): boolean {
+  const aliases = DECLARED_SKILL_ALIASES[ref] ?? [ref.replace(/^skill:/, '')];
+  return aliases.some((alias) => [...admittedRecordIds].some((recordId) => recordIdMatchesAlias(recordId, alias)));
+}
+
+function buildSkillIntakeSummary(
+  input: LevWizardRatchetRunInput,
+  declaredSkillRefs: string[],
+  receipts: FormalExecutionSkillSetRunReceipt[] | undefined,
+): LevWizardSkillIntakeSummary {
+  const sourcePacks = (receipts ?? []).map(summarizeSkillSourcePack);
+  const admittedRecordIds = new Set((receipts ?? []).flatMap((receipt) => receipt.sourcePackReceipt.admittedRecordIds));
+  const coveredDeclaredSkillRefs = declaredSkillRefs.filter((ref) => declaredSkillRefCovered(ref, admittedRecordIds));
+  const declaredOnlySkillRefs = declaredSkillRefs.filter((ref) => !coveredDeclaredSkillRefs.includes(ref));
+  const declaredOnlyBefore = declaredSkillRefs.length;
+  const declaredOnlyAfter = receipts?.length ? declaredOnlySkillRefs.length : declaredSkillRefs.length;
+  const dispatchReceipts = formalSkillDispatchReceipts(input, receipts);
+  const admittedFormalSkillCount = sourcePacks.reduce((sum, pack) => sum + pack.admittedFormalSkillCount, 0);
+  const runtimeDispatchedSkillCount = dispatchReceipts.filter((receipt) => receipt.ok).length;
+  const formalSkillRuntimeDebt = Math.max(0, admittedFormalSkillCount - runtimeDispatchedSkillCount);
+
+  return {
+    kind: 'LevWizardSkillIntakeSummary',
+    claimCeiling: runtimeDispatchedSkillCount > 0
+      ? 'formal_skill_loader_dispatch_not_live_worker_execution'
+      : 'source_pack_inventory_not_runtime_dispatch',
+    ran: Boolean(receipts?.length),
+    requestedPackCount: receipts?.length ?? 0,
+    sourcePacks,
+    totalSkillFilesFound: sourcePacks.reduce((sum, pack) => sum + pack.totalSkillFilesFound, 0),
+    recordsBuilt: sourcePacks.reduce((sum, pack) => sum + pack.recordsBuilt, 0),
+    admittedRecordCount: sourcePacks.reduce((sum, pack) => sum + pack.admittedRecordCount, 0),
+    referenceOrBlockedRecordCount: sourcePacks.reduce((sum, pack) => sum + pack.referenceOrBlockedRecordCount, 0),
+    findingCount: sourcePacks.reduce((sum, pack) => sum + pack.findingCount, 0),
+    purgatoryRecordCount: sourcePacks.reduce((sum, pack) => sum + pack.purgatoryRecordCount, 0),
+    formalSkillCandidateCount: sourcePacks.reduce((sum, pack) => sum + pack.formalSkillCandidateCount, 0),
+    admittedFormalSkillCount,
+    formalSkillBundleCount: sourcePacks.reduce((sum, pack) => sum + pack.formalSkillBundleCount, 0),
+    formalSkillFindingCount: sourcePacks.reduce((sum, pack) => sum + pack.formalSkillFindingCount, 0),
+    runtimeDispatchedSkillCount,
+    formalSkillRuntimeDebt,
+    formalSkillDispatchReceipts: dispatchReceipts,
+    declaredSkillRefs,
+    coveredDeclaredSkillRefs,
+    declaredOnlySkillRefs: receipts?.length ? declaredOnlySkillRefs : declaredSkillRefs,
+    declaredOnlyBefore,
+    declaredOnlyAfter,
+    improvementRatio: declaredOnlyBefore === 0 ? 1 : (declaredOnlyBefore - declaredOnlyAfter) / declaredOnlyBefore,
+  };
+}
