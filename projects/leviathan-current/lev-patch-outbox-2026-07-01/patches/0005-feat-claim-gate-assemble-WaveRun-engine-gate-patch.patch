+    `Graph mutation applied: ${result.execution.graphMutationApplied}`,
+    `Claim ceiling: ${result.execution.claimCeiling}`,
+    `Findings: ${result.execution.findings.length}`,
+    `Receipt: ${result.execution.receipt.id}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
