+export async function handler(args: string[]) {
+  const parsed = parseArgs(args);
+  if (parsed.rawTrustedEvidenceRefs.length > 0) {
+    return rawTrustedEvidenceRefResponse(parsed.rawTrustedEvidenceRefs, parsed.json);
+  }
+  if (parsed.trustedEvidenceRefs.length > 0) {
+    const issuedRefs = hostIssuedTrustRefs();
+    const unissuedRefs = parsed.trustedEvidenceRefs.filter((ref) => !issuedRefs.has(ref));
+    if (unissuedRefs.length > 0) {
+      return callerSuppliedHostTrustResponse(unissuedRefs, parsed.json);
+    }
+  }
+
+  if (parsed.subcommand === 'help' || parsed.subcommand === '--help' || parsed.subcommand === '-h') {
+    return {
+      success: true,
+      formatted_response: usage(),
+    };
+  }
+
+  if (parsed.subcommand !== 'demo') {
+    if (parsed.subcommand === 'consume') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let input: ClaimGateCouncilWaveInput;
+      let parentResult: ClaimGateLoopResult | undefined;
+      try {
+        parentResult = parsed.parentResult ? readJson<ClaimGateLoopResult>(parsed.parentResult) : undefined;
+        input = validateClaimGateCouncilWaveInput(readJson<unknown>(parsed.input), {
+          allowExternalRepairLineage: Boolean(parentResult),
+        });
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+      const result = runClaimGateCouncilWaveLoopWithHostTrustedEvidence(input, {
+        parentResult,
+        trustedEvidenceRefs: parsed.trustedEvidenceRefs,
+      });
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), result);
+      }
+      const passed = result.receipt.evalResults.every((evalResult) => evalResult.passed);
+      return {
+        success: passed,
+        formatted_response: parsed.json ? JSON.stringify(result, null, 2) : formatDemo(result, parsed.out),
+        data: result,
+        error_code: passed ? undefined : 'CLAIMGATE_LOOP_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'wave-run') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let input: ClaimGateWaveRunInput;
+      try {
+        input = readJson<ClaimGateWaveRunInput>(parsed.input);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      // hostConsume arrives as plain JSON content inside the input file, not a CLI
+      // flag, so it bypasses the top-level --host-trusted-evidence-ref check above.
+      // Without this gate a caller could write any receiptRef into the input file
+      // and mint a next-run seed the host never actually consumed. Require any
+      // supplied receiptRef to already exist in the host-issued ledger before it
+      // ever reaches the proof-layer function.
+      const suppliedHostConsumeReceiptRef = input.hostConsume?.receiptRef;
+      if (typeof suppliedHostConsumeReceiptRef === 'string' && suppliedHostConsumeReceiptRef.length > 0) {
+        const refs = hostWaveRunConsumeRefState();
+        if (!refs.issued.has(suppliedHostConsumeReceiptRef)) {
+          return callerSuppliedWaveRunHostConsumeResponse(suppliedHostConsumeReceiptRef, parsed.json);
+        }
+        if (refs.spent.has(suppliedHostConsumeReceiptRef)) {
+          return spentWaveRunHostConsumeResponse(suppliedHostConsumeReceiptRef, parsed.json);
+        }
+        markWaveRunHostConsumeRefSpent(suppliedHostConsumeReceiptRef);
+      }
+
+      const result = runClaimGateWaveRun({
+        ...input,
+        ...(parsed.realEngines ? { threeEngineRunner: createRealThreeEngineObligationRunner() } : {}),
+      });
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), result);
+      }
+      const passed = result.status !== 'blocked';
+      return {
+        success: passed,
+        formatted_response: parsed.json ? JSON.stringify(result, null, 2) : formatWaveRun(result, parsed.out),
+        data: result,
+        error_code: passed ? undefined : 'CLAIMGATE_WAVE_RUN_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'repair-plan') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let input: ClaimGateCouncilWaveInput;
+      let result: ClaimGateLoopResult;
+      try {
+        input = validateClaimGateCouncilWaveInput(readJson<unknown>(parsed.input));
+        result = readJson<ClaimGateLoopResult>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const repairPlan = buildClaimGateRepairWavePlan(input, result);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), repairPlan);
+      }
+      const passed = repairPlan.receipt.evalResults.every((evalResult) => evalResult.passed);
+      return {
+        success: passed,
+        formatted_response: parsed.json ? JSON.stringify(repairPlan, null, 2) : formatRepairPlan(repairPlan, parsed.out),
+        data: repairPlan,
+        error_code: passed ? undefined : 'CLAIMGATE_REPAIR_PLAN_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'repair-dispatch-plan') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let repairPlan: ClaimGateRepairWavePlan;
+      try {
+        repairPlan = readJson<ClaimGateRepairWavePlan>(parsed.input);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const dispatchPlan = buildClaimGateRepairDispatchPlan(repairPlan);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), dispatchPlan);
+      }
+      return {
+        success: dispatchPlan.ok,
+        formatted_response: parsed.json ? JSON.stringify(dispatchPlan, null, 2) : formatRepairDispatchPlan(dispatchPlan, parsed.out),
+        data: dispatchPlan,
+        error_code: dispatchPlan.ok ? undefined : 'CLAIMGATE_REPAIR_DISPATCH_PLAN_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'record-repair-dispatch-execution') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let dispatchPlan: ClaimGateRepairDispatchPlan;
+      let repairWaveInput: ClaimGateCouncilWaveInput;
+      try {
+        dispatchPlan = readJson<ClaimGateRepairDispatchPlan>(parsed.input);
+        repairWaveInput = validateClaimGateCouncilWaveInput(readJson<unknown>(parsed.result), {
+          allowExternalRepairLineage: true,
+        });
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const execution = recordClaimGateRepairDispatchExecution(dispatchPlan, repairWaveInput);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), execution);
+      }
+      return {
+        success: execution.ok,
+        formatted_response: parsed.json ? JSON.stringify(execution, null, 2) : formatRepairDispatchExecution(execution, parsed.out),
+        data: execution,
+        error_code: execution.ok ? undefined : 'CLAIMGATE_REPAIR_DISPATCH_EXECUTION_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'admit-graph-patch') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let result: ClaimGateLoopResult;
+      try {
+        result = readJson<ClaimGateLoopResult>(parsed.input);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const admission = consumeClaimGateGraphPatchProposal(result);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), admission);
+      }
+      return {
+        success: admission.ok,
+        formatted_response: parsed.json ? JSON.stringify(admission, null, 2) : formatGraphPatchAdmission(admission, parsed.out),
+        data: admission,
+        error_code: admission.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'apply-plan') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let result: ClaimGateLoopResult;
+      let admission: ClaimGateGraphPatchAdmission;
+      try {
+        result = readJson<ClaimGateLoopResult>(parsed.input);
+        admission = readJson<ClaimGateGraphPatchAdmission>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const applyPlan = buildClaimGateGraphPatchApplyPlan(result, admission);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), applyPlan);
+      }
+      return {
+        success: applyPlan.ok,
+        formatted_response: parsed.json ? JSON.stringify(applyPlan, null, 2) : formatGraphPatchApplyPlan(applyPlan, parsed.out),
+        data: applyPlan,
+        error_code: applyPlan.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_APPLY_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'apply-graph-patch') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+
+      let result: ClaimGateLoopResult;
+      let admission: ClaimGateGraphPatchAdmission;
+      try {
+        result = readJson<ClaimGateLoopResult>(parsed.input);
+        admission = readJson<ClaimGateGraphPatchAdmission>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const applyPlan = buildClaimGateGraphPatchApplyPlan(result, admission);
+      const bridge = await applyGraphPatchThroughHost(applyPlan);
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), bridge);
+      }
+      return {
+        success: bridge.ok,
+        formatted_response: parsed.json ? JSON.stringify(bridge, null, 2) : formatGraphPatchBridge(bridge, parsed.out),
+        data: bridge,
+        error_code: bridge.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_EXECUTION_BLOCKED',
+      };
+    }
+
+    if (parsed.subcommand === 'record-graph-execution') {
+      if (!parsed.input || !parsed.result) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'MISSING_INPUT',
+        };
+      }
+      if (parsed.trustedEvidenceRefs.length > 0) {
+        return callerSuppliedGraphEventTrustResponse(parsed.trustedEvidenceRefs, parsed.json);
+      }
+
+      let applyPlan: ClaimGateGraphPatchApplyPlan;
+      let graphResult: ClaimGateGraphPatchExecutionInput;
+      try {
+        applyPlan = readJson<ClaimGateGraphPatchApplyPlan>(parsed.input);
+        graphResult = readJson<ClaimGateGraphPatchExecutionInput>(parsed.result);
+      } catch (error) {
+        return invalidInputResponse(error, parsed.json);
+      }
+
+      const execution = recordClaimGateGraphPatchExecution(applyPlan, graphResult, {
+        trustedEvidenceRefs: parsed.trustedEvidenceRefs,
+      });
+      if (parsed.out) {
+        writeJson(resolve(parsed.out), execution);
+      }
+      return {
+        success: execution.ok,
+        formatted_response: parsed.json ? JSON.stringify(execution, null, 2) : formatGraphPatchExecution(execution, parsed.out),
+        data: execution,
+        error_code: execution.ok ? undefined : 'CLAIMGATE_GRAPH_PATCH_EXECUTION_BLOCKED',
+      };
+    }
+
+    return {
+      success: false,
+      formatted_response: usage(),
+      error_code: 'UNKNOWN_SUBCOMMAND',
+    };
+  }
+
+  const result = runClaimGateLoopFixture({
+    sessionId: 'claim-gate-loop-demo',
+    workstreamId: 'ws-claim-gate-loop-demo',
+    maxWaves: parsed.maxWaves,
+  });
+
+  if (parsed.out) {
+    writeJson(resolve(parsed.out), result);
+  }
+
+  return {
+    success: result.receipt.evalResults.every((evalResult) => evalResult.passed),
+    formatted_response: parsed.json ? JSON.stringify(result, null, 2) : formatDemo(result, parsed.out),
+    data: result,
+    error_code: result.receipt.evalResults.every((evalResult) => evalResult.passed)
+      ? undefined
+      : 'CLAIMGATE_LOOP_BLOCKED',
+  };
+}
