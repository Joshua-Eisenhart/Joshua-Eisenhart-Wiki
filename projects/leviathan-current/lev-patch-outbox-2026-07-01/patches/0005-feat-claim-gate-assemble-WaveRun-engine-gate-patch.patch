+function attachRealSourceEvidence(input: LevWizardRatchetRunInput, hostFalsifierState?: LevWizardHostFalsifierState): void {
+  const root = mkdtempSync(join(tmpdir(), 'lev-wizard-source-evidence-'));
+  input.sourceBoundGateEvidenceRefs = {
+    object_binding: writeSourceEvidenceFile(root, 'object_binding', input, hostFalsifierState),
+    evidence_manifest: writeSourceEvidenceFile(root, 'evidence_manifest', input, hostFalsifierState),
+    falsifier: writeSourceEvidenceFile(root, 'falsifier', input, hostFalsifierState),
+  };
+}
