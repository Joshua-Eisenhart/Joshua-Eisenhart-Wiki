+    && result.graphAdmission.ok
+    && result.steeringAdmission.status === 'host_consumed'
+    && result.steeringAdmission.consumption.projectedVerdict === 'pass'
+    && result.steeringAdmission.consumption.recomputedVerdict === 'pass'
+    && result.bindingMemory.survivorReceipt?.status === 'remerged_survivor';
