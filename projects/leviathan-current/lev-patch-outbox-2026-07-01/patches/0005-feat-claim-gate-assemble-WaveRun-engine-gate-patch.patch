+
+function stableStringify(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? 'null';
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`).join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(stableStringify(value)).digest('hex')}`;
+}
+
+function isSha256Ref(value: unknown): value is string {
+  return typeof value === 'string' && /^sha256:[a-f0-9]{64}$/.test(value);
+}
+
+function isThreeEngineObligationLane(value: unknown): value is ThreeEngineObligationLane {
+  return value === 'julia' || value === 'jax' || value === 'pytorch';
+}
+
+function allThreeLanesPresent(lanes: ThreeEngineObligationLane[]): boolean {
+  return ['julia', 'jax', 'pytorch'].every((lane) => lanes.includes(lane as ThreeEngineObligationLane));
+}
+
+function normalizeEngineObligation(input: {
+  obligation: ClaimGateWaveRunEngineObligation;
+  claim: ClaimGateCouncilWaveClaim;
+  sessionId: string;
+  workstreamId?: string;
+  sourceBoundEvidenceContext?: ClaimGateSourceBoundEvidenceContext;
+}): {
+  obligationHash: string;
+  findings: string[];
+} {
+  const { obligation, claim } = input;
+  const findings: string[] = [];
+  const requiredLanes = obligation.requiredLanes ?? [];
+  if (obligation.registryVersion !== undefined && obligation.registryVersion !== 'claim-gate-wave-run-engine-obligation-v0') {
+    findings.push(`Unsupported engine obligation registryVersion: ${obligation.registryVersion}.`);
+  }
+  if (obligation.engineMode !== undefined && obligation.engineMode !== 'all_three_required') {
+    findings.push(`Unsupported engine obligation engineMode: ${obligation.engineMode}.`);
+  }
+  if (requiredLanes.length === 0) {
+    findings.push('Engine obligation must declare requiredLanes.');
+  }
+  if (requiredLanes.some((lane) => !isThreeEngineObligationLane(lane))) {
+    findings.push('Engine obligation requiredLanes contains an unsupported lane.');
+  }
+  if (requiredLanes.length > 0 && !allThreeLanesPresent(requiredLanes)) {
+    findings.push('Engine obligation V0 requires julia, jax, and pytorch lanes.');
+  }
+  if (!obligation.negativeControlSpec || Object.keys(obligation.negativeControlSpec).length === 0) {
+    findings.push('Engine obligation must declare a negativeControlSpec.');
+  }
+  if (obligation.sourceHashes?.some((hash) => !isSha256Ref(hash))) {
+    findings.push('Engine obligation sourceHashes must be sha256 refs.');
+  }
+  if (obligation.inputHash !== undefined && !isSha256Ref(obligation.inputHash)) {
+    findings.push('Engine obligation inputHash must be a sha256 ref when supplied.');
+  }
+  if (obligation.graphStateHash !== undefined && obligation.graphStateHash !== null && !isSha256Ref(obligation.graphStateHash)) {
+    findings.push('Engine obligation graphStateHash must be null or a sha256 ref.');
+  }
+  if (
+    obligation.graphStateScope !== undefined
+    && !['not_scoped', 'pre_apply_snapshot', 'event_store_replay'].includes(obligation.graphStateScope)
+  ) {
+    findings.push(`Unsupported engine obligation graphStateScope: ${obligation.graphStateScope}.`);
+  }
+  if (
+    obligation.graphStateScope
+    && obligation.graphStateScope !== 'not_scoped'
+    && !obligation.graphStateHash
+  ) {
+    findings.push('Engine obligation graphStateScope requires graphStateHash unless it is not_scoped.');
+  }
+
+  const normalized = {
+    registryVersion: obligation.registryVersion ?? 'claim-gate-wave-run-engine-obligation-v0',
+    obligationId: obligation.obligationId,
+    claimId: obligation.claimId,
+    sessionId: obligation.sessionId ?? input.sessionId,
+    ...(obligation.waveId ? { waveId: obligation.waveId } : {}),
+    ...(obligation.workstreamId ?? input.workstreamId ? { workstreamId: obligation.workstreamId ?? input.workstreamId } : {}),
+    kind: obligation.kind,
+    engineMode: obligation.engineMode ?? 'all_three_required',
+    requiredLanes: [...requiredLanes].sort(),
+    sourceRefs: [...(obligation.sourceRefs ?? [])].sort(),
+    sourceHashes: [...(obligation.sourceHashes ?? [])].sort(),
+    inputHash: obligation.inputHash ?? sha256({
+      claimId: claim.claimId,
+      payload: claim.payload,
+    }),
+    graphStateHash: obligation.graphStateHash ?? null,
+    graphStateScope: obligation.graphStateScope ?? 'not_scoped',
+    expectedOutputSchema: obligation.expectedOutputSchema ?? null,
+    negativeControlSpec: obligation.negativeControlSpec ?? null,
+    claimCeiling: obligation.claimCeiling ?? 'engine_obligation_not_host_admission',
+    compilerId: obligation.compilerId ?? null,
+    canonicalizerId: obligation.canonicalizerId ?? null,
+    sourceBoundEvidenceContextHash: sha256(input.sourceBoundEvidenceContext ?? null),
+  };
+
+  return {
+    obligationHash: sha256(normalized),
+    findings,
+  };
+}
+
+function safeGraphIdComponent(value: string): string {
+  const normalized = value.trim().toLowerCase().replace(/[^a-z0-9._:-]+/g, '-').replace(/^-+|-+$/g, '');
+  return normalized || 'unknown';
+}
+
+function cloneWaveInput(input: ClaimGateCouncilWaveInput): ClaimGateCouncilWaveInput {
+  return {
+    kind: input.kind,
+    sessionId: input.sessionId,
+    workstreamId: input.workstreamId,
+    maxWaves: input.maxWaves,
+    requiredGateIds: input.requiredGateIds ? [...input.requiredGateIds] : undefined,
+    waves: input.waves.map((wave) => ({
+      ...wave,
+      members: wave.members?.map((member) => ({ ...member })),
+      claims: wave.claims.map((claim) => ({
+        ...claim,
+        gateChecks: claim.gateChecks.map((check) => ({
+          ...check,
+          evidenceRefs: check.evidenceRefs ? [...check.evidenceRefs] : undefined,
+        })),
+        repairOf: claim.repairOf ? { ...claim.repairOf } : undefined,
+      })),
+    })),
+  };
+}
+
+function claimsById(input: ClaimGateCouncilWaveInput): Map<string, ClaimGateCouncilWaveClaim> {
+  const out = new Map<string, ClaimGateCouncilWaveClaim>();
+  for (const wave of input.waves) {
+    for (const claim of wave.claims) out.set(claim.claimId, claim);
+  }
+  return out;
+}
+
+function addOrReplaceGateCheck(
+  claim: ClaimGateCouncilWaveClaim,
+  check: ClaimGateCouncilGateCheck,
+): ClaimGateCouncilWaveClaim {
+  const gateChecks = claim.gateChecks.filter((entry) => entry.gateId !== check.gateId);
+  gateChecks.push(check);
+  return { ...claim, gateChecks };
+}
+
+function runEngineObligations(
+  input: ClaimGateCouncilWaveInput,
+  obligations: ClaimGateWaveRunEngineObligation[],
+  runner: ClaimGateWaveRunThreeEngineRunner | undefined,
+  sessionId: string,
+  workstreamId: string | undefined,
+  sourceBoundEvidenceContext: ClaimGateSourceBoundEvidenceContext | undefined,
+): {
+  input: ClaimGateCouncilWaveInput;
+  results: ClaimGateWaveRunEngineObligationResult[];
+} {
+  if (obligations.length === 0) return { input, results: [] };
+
+  const claimIndex = claimsById(input);
+  const results: ClaimGateWaveRunEngineObligationResult[] = [];
+  const next = cloneWaveInput(input);
+  const obligationsByClaimId = new Map<string, ClaimGateWaveRunEngineObligation[]>();
+  const obligationIdCounts = new Map<string, number>();
+  for (const obligation of obligations) {
+    obligationsByClaimId.set(obligation.claimId, [...(obligationsByClaimId.get(obligation.claimId) ?? []), obligation]);
+    obligationIdCounts.set(obligation.obligationId, (obligationIdCounts.get(obligation.obligationId) ?? 0) + 1);
+  }
+  const emittedResultKeys = new Set<string>();
+
+  const emitBlockedResult = (
+    obligation: ClaimGateWaveRunEngineObligation,
+    claim: ClaimGateCouncilWaveClaim | undefined,
+    findings: string[],
+  ): ClaimGateWaveRunEngineObligationResult => {
+    const { obligationHash } = normalizeEngineObligation({
+      obligation,
+      claim: claim ?? {
+        claimId: obligation.claimId,
+        payload: '',
+        gateChecks: [],
+      },
+      sessionId,
+      ...(workstreamId ? { workstreamId } : {}),
+      ...(sourceBoundEvidenceContext ? { sourceBoundEvidenceContext } : {}),
+    });
+    const result = {
+      claimId: obligation.claimId,
+      obligationId: obligation.obligationId,
+      kind: obligation.kind,
+      obligationHash,
+      status: 'blocked' as const,
+      evidenceRefs: [],
+      findings,
+    };
+    results.push(result);
+    emittedResultKeys.add(`${obligation.claimId}\0${obligation.obligationId}`);
+    return result;
+  };
+
+  for (const obligation of obligations) {
+    if (!claimIndex.has(obligation.claimId)) {
+      emitBlockedResult(obligation, undefined, [
+        `Engine obligation ${obligation.obligationId} targets unknown claim ${obligation.claimId}.`,
+      ]);
+    }
+  }
+
+  for (const wave of next.waves) {
+    wave.claims = wave.claims.map((claim) => {
+      const claimObligations = obligationsByClaimId.get(claim.claimId) ?? [];
+      if (claimObligations.length === 0) return claim;
+
+      const sourceClaim = claimIndex.get(claim.claimId) ?? claim;
+      const registryFindings: string[] = [];
+      if (claimObligations.length > 1) {
+        registryFindings.push(`Engine obligation registry V0 accepts exactly one obligation per claim; ${claim.claimId} has ${claimObligations.length}.`);
+      }
+      for (const obligation of claimObligations) {
+        if ((obligationIdCounts.get(obligation.obligationId) ?? 0) > 1) {
+          registryFindings.push(`Engine obligation id ${obligation.obligationId} is duplicated in this WaveRun.`);
+        }
+      }
+      if (registryFindings.length > 0) {
+        for (const obligation of claimObligations) {
+          const resultKey = `${obligation.claimId}\0${obligation.obligationId}`;
+          if (!emittedResultKeys.has(resultKey)) emitBlockedResult(obligation, sourceClaim, registryFindings);
+        }
+        return addOrReplaceGateCheck(claim, {
+          gateId: 'sim_engine_probe',
+          status: 'fail',
+          reason: `Host three-engine obligation registry blocked claim ${claim.claimId}.`,
+          evidenceRefs: claimObligations.map((obligation) => `engine-obligation:${obligation.obligationId}`),
+        });
+      }
+
+      const obligation = claimObligations[0];
+      const normalized = normalizeEngineObligation({
+        obligation,
+        claim: sourceClaim,
+        sessionId,
+        ...(workstreamId ? { workstreamId } : {}),
+        ...(sourceBoundEvidenceContext ? { sourceBoundEvidenceContext } : {}),
+      });
+      const raw = runner
+        ? runner({
+            obligation,
+            obligationHash: normalized.obligationHash,
+            claim: sourceClaim,
+            sessionId,
+            ...(workstreamId ? { workstreamId } : {}),
+          })
+        : {
+            ok: false,
+            evidenceRefs: [],
+            findings: [`No host three-engine runner was supplied for obligation ${obligation.obligationId}.`],
+          };
+
+      const evidenceRefs = raw.evidenceRefs ?? [];
+      const findings = [...normalized.findings, ...(raw.findings ?? [])];
+      if (raw.ok && raw.obligationHash !== normalized.obligationHash) {
+        findings.push('Host three-engine obligation result did not bind the computed obligationHash.');
+      }
+      if (raw.ok && !evidenceRefs.includes(normalized.obligationHash)) {
+        findings.push('Host three-engine obligation evidence refs must include the computed obligationHash.');
+      }
+      if (raw.ok && evidenceRefs.length === 0) {
+        findings.push('Host three-engine obligation result passed without evidence refs.');
+      }
+      if (raw.ok && raw.threeEngineEnvelopeHash !== undefined && raw.threeEngineEnvelopeHash !== null && !isSha256Ref(raw.threeEngineEnvelopeHash)) {
+        findings.push('Host three-engine obligation returned a non-sha256 threeEngineEnvelopeHash.');
+      }
+      if (raw.ok && raw.engineSubstrateDigestHash !== undefined && raw.engineSubstrateDigestHash !== null && !isSha256Ref(raw.engineSubstrateDigestHash)) {
+        findings.push('Host three-engine obligation returned a non-sha256 engineSubstrateDigestHash.');
+      }
+      if (
+        raw.ok
+        && sourceBoundEvidenceContext?.threeEngineEnvelopeHash
+        && raw.threeEngineEnvelopeHash !== sourceBoundEvidenceContext.threeEngineEnvelopeHash
+      ) {
+        findings.push('Host three-engine obligation result did not match the source-bound threeEngineEnvelopeHash.');
+      }
+      if (
+        raw.ok
+        && sourceBoundEvidenceContext?.engineSubstrateDigestHash
+        && raw.engineSubstrateDigestHash !== sourceBoundEvidenceContext.engineSubstrateDigestHash
+      ) {
+        findings.push('Host three-engine obligation result did not match the source-bound engineSubstrateDigestHash.');
+      }
+
+      const passed = raw.ok && evidenceRefs.length > 0 && findings.length === 0;
+      results.push({
+        claimId: claim.claimId,
+        obligationId: obligation.obligationId,
+        kind: obligation.kind,
+        obligationHash: normalized.obligationHash,
+        status: passed ? 'passed' : 'blocked',
+        evidenceRefs,
+        findings,
+        ...(raw.threeEngineEnvelopeHash !== undefined ? { threeEngineEnvelopeHash: raw.threeEngineEnvelopeHash } : {}),
+        ...(raw.engineSubstrateDigestHash !== undefined ? { engineSubstrateDigestHash: raw.engineSubstrateDigestHash } : {}),
+      });
+
+      return addOrReplaceGateCheck(claim, {
+        gateId: 'sim_engine_probe',
+        status: passed ? 'pass' : 'fail',
+        reason: passed
+          ? `Host three-engine obligation ${obligation.obligationId} passed.`
+          : `Host three-engine obligation ${obligation.obligationId} blocked.`,
+        evidenceRefs: evidenceRefs.length ? evidenceRefs : [`engine-obligation:${obligation.obligationId}`],
+      });
+    });
+  }
+
+  return { input: next, results };
+}
+
+function validateRepairWaveInput(
+  repairInput: ClaimGateCouncilWaveInput,
+  repairPlan: ClaimGateRepairWavePlan,
+  dispatchPlan: ClaimGateRepairDispatchPlan,
+): ClaimGateWaveRunRepairFinding[] {
+  const findings: ClaimGateWaveRunRepairFinding[] = [];
+  const expectedFailurePackets = new Map(dispatchPlan.dispatchRequests.map((request) => [request.claimId, request.failurePacketId]));
+
+  for (const wave of repairInput.waves) {
+    for (const claim of wave.claims) {
+      const expectedFailurePacketId = expectedFailurePackets.get(claim.claimId);
+      if (!expectedFailurePacketId) {
+        findings.push({
+          severity: 'error',
+          code: 'wave_run.repair_output_unplanned_claim',
+          message: `Repair wave output claim ${claim.claimId} was not requested by the dispatch plan.`,
+          claimId: claim.claimId,
+        });
+        continue;
+      }
+      if (
+        claim.repairOf?.failurePacketId !== expectedFailurePacketId
+        || claim.repairOf.parentReceiptId !== repairPlan.parentReceiptId
+      ) {
+        findings.push({
+          severity: 'error',
+          code: 'wave_run.repair_output_unbound_failure_packet',
+          message: `Repair output for ${claim.claimId} must bind failure packet ${expectedFailurePacketId} and parent receipt ${repairPlan.parentReceiptId}.`,
+          claimId: claim.claimId,
+        });
+      }
+    }
+  }
+
+  return findings;
+}
+
+function makeNextRunSeed(
+  sessionId: string,
+  result: ClaimGateLoopResult,
+  hostConsume: ClaimGateWaveRunHostConsume | undefined,
+): ClaimGateWaveRunNextRunSeed | null {
+  const acceptedClaimIds = result.graphPatchProposal.acceptedClaimIds;
+  if (acceptedClaimIds.length === 0 || result.graphPatchProposal.withheldClaimIds.length > 0 || result.failurePackets.length > 0) {
+    return null;
+  }
+  // Host-consume gate: a next-run seed may only be emitted when the host actually
+  // consumed this run AND bound that consume to a receipt. Absent / adapter-only /
+  // blocked consume, or a host_consumed status with no receiptRef, yields no seed
+  // even though the deterministic gates passed. Deterministic gates and a
+  // receipt-bound host consume are separate obligations; the seed requires both.
+  // receiptRef must contain at least one visible character: strip Unicode "Format"
+  // category characters (zero-width space/joiner/non-joiner, BOM, soft hyphen, word
+  // joiner, etc. all fall under \p{Cf}) before the whitespace trim, so a
+  // blank-looking placeholder cannot pass String#trim's narrower whitespace
+  // grammar. This is defense in depth; the load-bearing check is the host-issued
+  // ledger validation the caller (handler layer) must perform before a receiptRef
+  // ever reaches this function — see hostIssuedWaveRunConsumeRefs in
+  // handlers/claim-gate-loop.ts.
+  const receiptRef = hostConsume?.receiptRef
+    ?.replace(/\p{Cf}/gu, '')
+    .trim();
+  if (
+    !hostConsume
+    || hostConsume.status !== 'host_consumed'
+    || typeof hostConsume.receiptRef !== 'string'
+    || !receiptRef
+  ) {
+    return null;
+  }
+  return {
+    kind: 'ClaimGateWaveRunNextRunSeed',
+    claimCeiling: 'accepted_survivor_seed_not_autonomous_execution',
+    sessionId,
+    sourceReceiptId: result.receipt.id,
+    acceptedClaimIds,
+    hostConsumeReceiptRef: receiptRef,
+  };
+}
+
+export function compileWaveRunEngineObligationGraphOperationProposal(input: {
+  sessionId: string;
+  workstreamId?: string;
+  sourceReceiptId: string;
+  acceptedClaimIds: string[];
+  withheldClaimIds: string[];
+  failurePackets: ClaimGateFailurePacket[];
+  engineObligationResults: ClaimGateWaveRunEngineObligationResult[];
+}): ClaimGateWaveRunEngineGraphOperationProposal | null {
+  const passedResults = input.engineObligationResults.filter((result) => result.status === 'passed');
+  const hasUnboundPassedResult = passedResults.some((result) => (
+    !isSha256Ref(result.obligationHash)
+    || result.evidenceRefs.length === 0
+    || !result.evidenceRefs.includes(result.obligationHash)
+  ));
+  if (
+    passedResults.length === 0
+    || hasUnboundPassedResult
+    || input.withheldClaimIds.length > 0
+    || input.failurePackets.length > 0
+  ) {
+    return null;
+  }
+
+  const timestamp = '1970-01-01T00:00:00.000Z';
+  const sessionId = safeGraphIdComponent(input.sessionId);
+  const operations: GraphOperation[] = passedResults.flatMap((result) => {
+    const obligationId = safeGraphIdComponent(result.obligationId);
+    const entityId = `claim-gate-engine-obligation:${sessionId}:${obligationId}`;
+    const evidenceRefs = [
+      `receipt:${input.sourceReceiptId}`,
+      `engine-obligation:${result.obligationId}`,
+      `claim:${result.claimId}`,
+      result.obligationHash,
+      ...result.evidenceRefs,
+    ];
+    return [
+      {
+        type: 'upsert_entity',
+        timestamp,
+        source: 'claim-gate-wave-runner',
+        entity_id: entityId,
+        payload: {
+          id: entityId,
+          type: 'engine_obligation_receipt',
+          source: 'claim-gate-wave-runner',
+          via: 'claim-gate.wave-run.engine-graph-operation-proposal',
+          depth: 'L1',
+          lifecycle_state: 'crystallizing',
+          last_classified: timestamp,
+          decay_rate: 0,
+          claims: [],
+          links: [],
+        },
+      },
+      {
+        type: 'add_claim',
+        timestamp,
+        source: 'claim-gate-wave-runner',
+        entity_id: entityId,
+        payload: {
+          id: `claim:${entityId}:obligation`,
+          kind: 'assertion',
+          subject: entityId,
+          predicate: 'has_engine_obligation_result',
+          object: {
+            claimId: result.claimId,
+            obligationId: result.obligationId,
+            kind: result.kind,
+            status: result.status,
+            obligationHash: result.obligationHash,
+            threeEngineEnvelopeHash: result.threeEngineEnvelopeHash ?? null,
+            engineSubstrateDigestHash: result.engineSubstrateDigestHash ?? null,
+          },
+          truth_state: 'accepted',
+          evidence_refs: evidenceRefs,
+          created_at: timestamp,
+        },
+      },
+    ];
+  });
+
+  return {
+    kind: 'ClaimGateWaveRunEngineGraphOperationProposal',
+    claimCeiling: 'engine_graph_operation_proposal_not_graph_apply',
+    graphMutationApplied: false,
+    sessionId: input.sessionId,
+    ...(input.workstreamId ? { workstreamId: input.workstreamId } : {}),
+    sourceReceiptId: input.sourceReceiptId,
+    operationHash: sha256(operations),
+    acceptedClaimIds: input.acceptedClaimIds,
+    obligationHashes: passedResults.map((result) => result.obligationHash),
+    operations,
+  };
+}
+
+function createWaveRunReceipt(input: {
+  sessionId: string;
+  workstreamId?: string;
+  status: ClaimGateWaveRunResult['status'];
+  waveResults: ClaimGateLoopResult[];
+  repairPlans: ClaimGateRepairWavePlan[];
+  dispatchPlans: ClaimGateRepairDispatchPlan[];
+  repairFindings: ClaimGateWaveRunRepairFinding[];
+  engineObligationResults: ClaimGateWaveRunEngineObligationResult[];
+  acceptedClaimIds: string[];
+  withheldClaimIds: string[];
+  engineGraphOperationProposal: ClaimGateWaveRunEngineGraphOperationProposal | null;
+  nextRunSeed: ClaimGateWaveRunNextRunSeed | null;
+}): Receipt {
+  const payload = {
+    status: input.status,
+    waveResultReceiptIds: input.waveResults.map((result) => result.receipt.id),
+    repairPlanReceiptIds: input.repairPlans.map((plan) => plan.receipt.id),
+    dispatchPlanReceiptIds: input.dispatchPlans.map((plan) => plan.receipt.id),
+    repairFindings: input.repairFindings,
+    engineObligationResults: input.engineObligationResults,
+    acceptedClaimIds: input.acceptedClaimIds,
+    withheldClaimIds: input.withheldClaimIds,
+    engineGraphOperationProposal: input.engineGraphOperationProposal,
+    nextRunSeed: input.nextRunSeed,
+  };
+  return createReceipt({
+    scope: 'session',
+    sessionId: input.sessionId,
+    workstreamId: input.workstreamId,
+    workUnitId: 'claim-gate-wave-run-v0',
+    contentHash: sha256(payload),
+    evalResults: [
+      {
+        id: 'eval-claim-gate-wave-runner',
+        strategy: 'gate-based',
+        timestamp: new Date().toISOString(),
+        passed: input.status !== 'blocked',
+        metric_value: input.status !== 'blocked' ? 1 : 0,
+        reasoning: 'WaveRun advances only deterministic ClaimGate survivors and blocks unresolved repair output.',
+        metadata: payload,
+      },
+    ],
+    provenance: {
+      surface: 'proof',
+      host: 'lev',
+      profile: 'claim-gate-wave-run-v0',
+    },
+  });
+}
+
+export function runClaimGateWaveRun(input: ClaimGateWaveRunInput): ClaimGateWaveRunResult {
+  if (input.kind !== undefined && input.kind !== 'ClaimGateWaveRunInput') {
+    throw new Error('ClaimGateWaveRunInput kind must be ClaimGateWaveRunInput when supplied.');
+  }
+
+  const sessionId = input.sessionId;
+  const workstreamId = input.workstreamId;
+  const gatePolicy = input.deterministicGatePolicy ?? {};
+  const maxWaves = Math.max(1, Math.floor(input.maxWaves ?? input.initial.maxWaves ?? 1));
+
+  const waveResults: ClaimGateLoopResult[] = [];
+  const repairPlans: ClaimGateRepairWavePlan[] = [];
+  const dispatchPlans: ClaimGateRepairDispatchPlan[] = [];
+  const repairFindings: ClaimGateWaveRunRepairFinding[] = [];
+  const engineObligationResults: ClaimGateWaveRunEngineObligationResult[] = [];
+
+  let currentInput = validateClaimGateCouncilWaveInput({
+    ...cloneWaveInput(input.initial),
+    sessionId: input.initial.sessionId ?? sessionId,
+    workstreamId: input.initial.workstreamId ?? workstreamId,
+    maxWaves: input.initial.maxWaves ?? 1,
+  });
+  let parentResult: ClaimGateLoopResult | undefined;
+  let repaired = false;
+
+  for (let attempt = 0; attempt < maxWaves; attempt += 1) {
+    const augmented = runEngineObligations(
+      currentInput,
+      input.engineObligations ?? [],
+      input.threeEngineRunner,
+      currentInput.sessionId ?? sessionId,
+      currentInput.workstreamId ?? workstreamId,
+      gatePolicy.sourceBoundEvidenceContext,
+    );
+    engineObligationResults.push(...augmented.results);
+
+    const loopResult = runClaimGateCouncilWaveLoopWithHostTrustedEvidence(augmented.input, {
+      sessionId: augmented.input.sessionId ?? sessionId,
+      workstreamId: augmented.input.workstreamId ?? workstreamId,
+      maxWaves: augmented.input.maxWaves ?? 1,
+      requiredGateIds: gatePolicy.requiredGateIds,
+      trustedEvidenceRefs: gatePolicy.trustedEvidenceRefs,
+      sourceBoundEvidenceContext: gatePolicy.sourceBoundEvidenceContext,
+      ...(parentResult ? { parentResult } : {}),
+    });
+    waveResults.push(loopResult);
+
+    if (loopResult.graphPatchProposal.withheldClaimIds.length === 0 && loopResult.failurePackets.length === 0) {
+      break;
+    }
+
+    const repairPlan = buildClaimGateRepairWavePlan(augmented.input, loopResult, {
+      workstreamId,
+    });
+    repairPlans.push(repairPlan);
+    const dispatchPlan = buildClaimGateRepairDispatchPlan(repairPlan, {
+      workstreamId,
+    });
+    dispatchPlans.push(dispatchPlan);
+
+    if (!input.repairExecutor || !dispatchPlan.ok || dispatchPlan.dispatchRequests.length === 0) {
+      break;
+    }
+
+    const repairInput = input.repairExecutor({ repairPlan, dispatchPlan, parentResult: loopResult });
+    if (!repairInput) break;
+    const repairValidationFindings = validateRepairWaveInput(repairInput, repairPlan, dispatchPlan);
+    repairFindings.push(...repairValidationFindings);
+    if (repairValidationFindings.some((finding) => finding.severity === 'error')) {
+      break;
+    }
+
+    currentInput = validateClaimGateCouncilWaveInput({
+      ...repairInput,
+      maxWaves: Math.max(repairInput.maxWaves ?? repairPlan.nextWave, repairPlan.nextWave),
+    }, {
+      allowExternalRepairLineage: true,
+    });
+    parentResult = loopResult;
+    repaired = true;
+  }
+
+  const finalResult = waveResults[waveResults.length - 1];
+  const acceptedClaimIds = finalResult?.graphPatchProposal.acceptedClaimIds ?? [];
+  const withheldClaimIds = finalResult?.graphPatchProposal.withheldClaimIds ?? [];
+  const nextRunSeed = finalResult ? makeNextRunSeed(sessionId, finalResult, input.hostConsume) : null;
+  const blocked = (
+    !finalResult
+    || withheldClaimIds.length > 0
+    || finalResult.failurePackets.length > 0
+    || engineObligationResults.some((result) => result.status === 'blocked')
+    || repairFindings.some((finding) => finding.severity === 'error')
+  );
+  const status: ClaimGateWaveRunResult['status'] = blocked ? 'blocked' : repaired ? 'passed_after_repair' : 'passed';
+  const engineGraphOperationProposal = (
+    !blocked && finalResult
+      ? compileWaveRunEngineObligationGraphOperationProposal({
+        sessionId,
+        ...(workstreamId ? { workstreamId } : {}),
+        sourceReceiptId: finalResult.receipt.id,
+        acceptedClaimIds,
+        withheldClaimIds,
+        failurePackets: finalResult.failurePackets,
+        engineObligationResults,
+      })
+      : null
+  );
+  const receipt = createWaveRunReceipt({
+    sessionId,
+    ...(workstreamId ? { workstreamId } : {}),
+    status,
+    waveResults,
+    repairPlans,
+    dispatchPlans,
+    repairFindings,
+    engineObligationResults,
+    acceptedClaimIds,
+    withheldClaimIds,
+    engineGraphOperationProposal,
+    nextRunSeed,
+  });
+
+  return {
+    kind: 'ClaimGateWaveRunResult',
+    sessionId,
+    ...(workstreamId ? { workstreamId } : {}),
+    status,
+    waveResults,
+    repairPlans,
+    dispatchPlans,
+    engineObligationResults,
+    failurePackets: waveResults.flatMap((result) => result.failurePackets),
+    requeueEvents: waveResults.flatMap((result) => result.requeueEvents),
+    repairFindings,
+    acceptedClaimIds,
+    withheldClaimIds,
+    engineGraphOperationProposal,
+    nextRunSeed,
+    receipt,
+  };
+}
+
+function buildDefaultEngineSubstrateDigestArtifacts() {
+  const digest = buildRealLevEngineSubstrateDigest();
+  return {
+    digest,
+    digestExecutionWitness: buildLevEngineSubstrateExecutionWitness(digest),
+  };
+}
+
+export function createRealThreeEngineObligationRunner(
+  options: ClaimGateWaveRunRealEngineRunnerOptions = {},
+): ClaimGateWaveRunThreeEngineRunner {
+  const buildEnvelopeAndDigest = options.buildEnvelopeAndDigest ?? buildRealThreeEngineEnvelopeAndDigest;
+  const buildEngineSubstrateDigest = options.buildEngineSubstrateDigest ?? buildDefaultEngineSubstrateDigestArtifacts;
+
+  return ({ obligation, obligationHash }) => {
+    if (obligation.kind !== 'lev_r0_quotient_refinement' && obligation.kind !== 'lev_engine_substrate_digest') {
+      return {
+        ok: false,
+        findings: [`Unsupported host three-engine obligation kind: ${obligation.kind}.`],
+      };
+    }
+
+    try {
+      if (obligation.kind === 'lev_engine_substrate_digest') {
+        const artifacts = buildEngineSubstrateDigest();
+        const engineSubstrateDigestHash = sha256(artifacts.digest);
+        const digestExecutionWitnessHash = sha256(artifacts.digestExecutionWitness);
+        return {
+          ok: true,
+          evidenceRefs: [
+            obligationHash,
+            engineSubstrateDigestHash,
+            digestExecutionWitnessHash,
+            ...Object.values(artifacts.digest.receiptHashes ?? {}),
+          ],
+          obligationHash,
+          engineSubstrateDigestHash,
+        };
+      }
+
+      const artifacts = buildEnvelopeAndDigest();
+      const threeEngineEnvelopeHash = sha256(artifacts.envelope);
+      const engineSubstrateDigestHash = sha256(artifacts.digest);
+      return {
+        ok: true,
+        evidenceRefs: [
+          obligationHash,
+          threeEngineEnvelopeHash,
+          engineSubstrateDigestHash,
+          sha256(artifacts.digestExecutionWitness),
+          ...Object.values(artifacts.envelope.mechanicalProbeRunReceiptHashes ?? {}),
+          ...Object.values(artifacts.digest.receiptHashes ?? {}),
+        ],
+        obligationHash,
+        threeEngineEnvelopeHash,
+        engineSubstrateDigestHash,
+      };
+    } catch (error) {
+      return {
+        ok: false,
+        findings: [
+          `Host three-engine obligation ${obligation.obligationId} failed: ${
+            error instanceof Error ? error.message : String(error)
+          }`,
+        ],
+      };
+    }
+  };
+}
