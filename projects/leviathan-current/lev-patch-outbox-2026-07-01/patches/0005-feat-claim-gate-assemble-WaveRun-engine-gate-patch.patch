+      carrierPath: '/Users/joshuaeisenhart/GitHub/lev/core/orchestration/src/probes/lev-sim-engine-carrier/graph-substrate',
+      pathSource: 'default:lev-native-sim-engine-carrier',
+      explicitOverride: false,
+      sourceRefs: {
+        julia: syncedLanes.julia.sourceRef,
+        jax: syncedLanes.jax.sourceRef,
+        pytorch: syncedLanes.pytorch.sourceRef,
+      },
+    },
+    receipts: { julia, jax, pytorch },
+    receiptHashes: {
+      julia: sha256Json(julia),
+      jax: sha256Json(jax),
+      pytorch: sha256Json(pytorch),
+    },
+    lanes: syncedLanes,
+    graphInvariants: {
+      nodeCount: 4,
+      edgeCount: 4,
+      juliaAlgebraicConnectivity: 2,
+      jaxMessagePassing: [6, 4, 6, 4],
+      pytorchAutogradGradient: [2, 2, 2, 2],
+    },
+  };
+}
