+    members: wave.councils.flatMap((council) => council.subcouncils.flatMap((subcouncil) => (
+      subcouncil.members.map((member) => ({
+        memberId: member.memberId,
+        kind: councilWaveMemberKind(member.kind),
+        role: member.role,
+        producer: subcouncil.subcouncilId,
+        cognitiveBinding: member.cognitiveBinding,
+        skillRefs: member.cognitiveBinding.skillRefs,
