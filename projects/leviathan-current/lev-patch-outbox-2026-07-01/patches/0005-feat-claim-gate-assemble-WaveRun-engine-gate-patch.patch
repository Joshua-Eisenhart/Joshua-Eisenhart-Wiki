+
+export function issueClaimGateHostGraphEventTrust(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+  graphResult: ClaimGateGraphPatchExecutionInput,
+  options: IssueClaimGateHostGraphEventTrustOptions = {},
+): ClaimGateHostGraphEventTrust | null {
+  const graphEventId = graphPatchExecutionGraphEventId(graphResult);
+  if (typeof graphEventId !== 'string' || !graphEventId.startsWith('ge-')) return null;
+
+  const unsigned = {
+    kind: 'ClaimGateHostGraphEventTrust',
+    claimCeiling: 'host_graph_event_trust_not_transferable_authority',
+    authority: 'lev_host_graph_patch_executor',
+    graphEventId,
+    applyPlanReceiptId: applyPlan.receipt.id,
+    graphResultHash: sha256(graphResult),
+    operationCount: applyPlan.operationCount,
+    sessionId: options.sessionId ?? `${applyPlan.sessionId}-graph-execution`,
+    ...(options.workstreamId ? { workstreamId: options.workstreamId } : {}),
+    nonce: randomBytes(16).toString('hex'),
+    issuedAt: new Date().toISOString(),
+  } satisfies Omit<ClaimGateHostGraphEventTrust, 'payloadHash' | 'mac'>;
+  const payloadHash = sha256(unsigned);
+  const trust: ClaimGateHostGraphEventTrust = {
+    ...unsigned,
+    payloadHash,
+    mac: hostGraphEventTrustMac(unsigned),
+  };
+  const ledgerPath = options.ledgerPath ?? defaultClaimGateHostGraphEventTrustLedgerPath();
+  mkdirSync(dirname(ledgerPath), { recursive: true });
+  appendFileSync(ledgerPath, `${JSON.stringify(trust)}\n`);
+  return trust;
+}
+
+function validHostGraphEventTrustEntry(value: unknown): value is ClaimGateHostGraphEventTrust {
+  if (!value || typeof value !== 'object') return false;
+  const entry = value as ClaimGateHostGraphEventTrust;
+  if (entry.kind !== 'ClaimGateHostGraphEventTrust') return false;
+  if (entry.claimCeiling !== 'host_graph_event_trust_not_transferable_authority') return false;
+  if (entry.authority !== 'lev_host_graph_patch_executor') return false;
+  if (typeof entry.graphEventId !== 'string' || !entry.graphEventId.startsWith('ge-')) return false;
+  if (typeof entry.applyPlanReceiptId !== 'string' || entry.applyPlanReceiptId.length === 0) return false;
+  if (typeof entry.graphResultHash !== 'string' || !entry.graphResultHash.startsWith('sha256:')) return false;
+  if (!Number.isInteger(entry.operationCount) || entry.operationCount < 0) return false;
+  if (typeof entry.sessionId !== 'string' || entry.sessionId.length === 0) return false;
+  if (entry.workstreamId !== undefined && typeof entry.workstreamId !== 'string') return false;
+  if (typeof entry.nonce !== 'string' || !/^[0-9a-f]{32}$/i.test(entry.nonce)) return false;
+  if (typeof entry.issuedAt !== 'string' || Number.isNaN(Date.parse(entry.issuedAt))) return false;
+  if (typeof entry.payloadHash !== 'string' || !entry.payloadHash.startsWith('sha256:')) return false;
+  if (typeof entry.mac !== 'string' || !entry.mac.startsWith('hmac-sha256:')) return false;
+
+  const payload = hostGraphEventTrustPayload(entry);
+  if (entry.payloadHash !== sha256(payload)) return false;
+  const expectedMac = hostGraphEventTrustMac(payload);
+  return timingSafeHexEqual(entry.mac.slice('hmac-sha256:'.length), expectedMac.slice('hmac-sha256:'.length));
+}
+
+function readClaimGateHostGraphEventTrustLedger(
+  ledgerPath: string,
+  findings: ClaimGateGraphPatchExecutionFinding[],
+): ClaimGateHostGraphEventTrust[] {
+  if (!existsSync(ledgerPath)) return [];
+  const entries: ClaimGateHostGraphEventTrust[] = [];
+  readFileSync(ledgerPath, 'utf8')
+    .split('\n')
+    .map((line) => line.trim())
+    .filter((line) => line.length > 0)
+    .forEach((line, index) => {
+      try {
+        const parsed = JSON.parse(line);
+        if (validHostGraphEventTrustEntry(parsed)) {
+          entries.push(parsed);
+        }
+      } catch (error) {
+        addGraphExecutionFinding(
+          findings,
+          'graph_execution.host_graph_event_trust_ledger_invalid_json',
+          `Host graph-event trust ledger ${ledgerPath} line ${index + 1} is not valid JSON (${error instanceof Error ? error.message : String(error)}).`,
+        );
+      }
+    });
+  return entries;
+}
+
+function trustedGraphEventRefsFromHostLedger(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+  graphResult: ClaimGateGraphPatchExecutionInput,
+  ledgerPath: string,
+  findings: ClaimGateGraphPatchExecutionFinding[],
+): string[] {
+  const graphEventId = graphPatchExecutionGraphEventId(graphResult);
+  if (typeof graphEventId !== 'string' || !graphEventId.startsWith('ge-')) return [];
+  const graphResultHash = sha256(graphResult);
+  const trust = readClaimGateHostGraphEventTrustLedger(ledgerPath, findings).find((entry) => (
+    entry.kind === 'ClaimGateHostGraphEventTrust'
+    && entry.claimCeiling === 'host_graph_event_trust_not_transferable_authority'
+    && entry.authority === 'lev_host_graph_patch_executor'
+    && entry.graphEventId === graphEventId
+    && entry.applyPlanReceiptId === applyPlan.receipt.id
+    && entry.graphResultHash === graphResultHash
+    && entry.operationCount === applyPlan.operationCount
+  ));
+  return trust ? [graphEventId] : [];
+}
+
+function validateGraphPatchExecutionInputs(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+  graphResult: ClaimGateGraphPatchExecutionInput,
+  trustedRefs: Set<string>,
+): ClaimGateGraphPatchExecutionFinding[] {
+  const findings: ClaimGateGraphPatchExecutionFinding[] = [];
+  const success = graphPatchExecutionSuccess(graphResult);
+  const status = graphPatchExecutionStatus(graphResult);
+  const applied = graphPatchExecutionApplied(graphResult);
+  const applyPlanReceiptId = graphPatchExecutionApplyPlanReceiptId(graphResult);
+  const graphEventId = graphPatchExecutionGraphEventId(graphResult);
+  const errors = graphPatchExecutionErrors(graphResult);
+
+  if (applyPlan.kind !== 'ClaimGateGraphPatchApplyPlan') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.invalid_apply_plan_kind',
+      'Apply plan artifact kind must be ClaimGateGraphPatchApplyPlan.',
+    );
+  }
+
+  if (!applyPlan.ok || applyPlan.status !== 'apply_ready') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_not_ready',
+      'Graph execution can only be recorded for an ok apply_ready plan.',
+    );
+  }
+
+  if (applyPlan.graphMutationApplied !== false) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.source_already_marked_applied',
+      'Apply plans must preserve graphMutationApplied:false; the host graph result is the mutation evidence.',
+    );
+  }
+
+  if (applyPlan.claimCeiling !== 'apply_plan_only_requires_graph_patch_execution') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.unexpected_apply_plan_ceiling',
+      'Apply plan claim ceiling must preserve the separate graph execution boundary.',
+    );
+  }
+
+  if (!applyPlan.receipt.evalResults.every((evalResult) => evalResult.passed)) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_receipt_failed_eval',
+      'Apply plan receipt must have all eval results passing before graph execution can be admitted.',
+    );
+  }
+
+  if (!receiptContentHashMatches(applyPlan.receipt, graphPatchApplyPlanReceiptPayload(applyPlan))) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_receipt_hash_mismatch',
+      'The apply plan receipt contentHash must match the current apply plan artifact before graph execution can be admitted.',
+    );
+  }
+
+  if (success !== true) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.result_not_successful',
+      'Graph patch execution result must report success:true.',
+    );
+  }
+
+  if (status !== 'applied') {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.result_not_applied',
+      'Graph patch execution result status must be applied.',
+    );
+  }
+
+  if (!Number.isFinite(applied) || applied !== applyPlan.operationCount) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.operation_count_mismatch',
+      'Graph patch applied count must match the apply plan operationCount.',
+    );
+  }
+
+  if (applyPlanReceiptId !== applyPlan.receipt.id) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.apply_plan_receipt_id_mismatch',
+      'Graph patch execution result must echo the apply plan receipt id it executed.',
+    );
+  }
+
+  if (typeof graphEventId !== 'string' || !graphEventId.startsWith('ge-')) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.graph_event_id_missing',
+      'Graph patch execution must return a graph_event_id beginning with ge-.',
+    );
+  } else if (!trustedRefs.has(graphEventId)) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.graph_event_untrusted',
+      'Graph patch execution graph_event_id must be supplied by a host-trusted graph event ref.',
+    );
+  }
+
+  if (errors.length > 0) {
+    addGraphExecutionFinding(
+      findings,
+      'graph_execution.result_errors_present',
+      'Graph patch execution result must not carry errors.',
+    );
+  }
+
+  return findings;
+}
