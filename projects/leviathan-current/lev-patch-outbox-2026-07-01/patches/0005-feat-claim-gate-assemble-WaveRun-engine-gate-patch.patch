+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return value !== null && typeof value === 'object' && !Array.isArray(value);
+}
+
+function stableStringify(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? 'null';
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`).join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(stableStringify(value)).digest('hex')}`;
+}
+
+function writeJson(file: string, value: unknown): void {
+  mkdirSync(dirname(file), { recursive: true });
+  writeFileSync(file, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+function byteLength(value: string): number {
+  return Buffer.byteLength(value, 'utf8');
+}
+
+function addViolation(
+  violations: ClaimGateWavegraphSliceInputViolation[],
+  path: string,
+  code: string,
+  message: string,
+): void {
+  violations.push({ path, code, message });
+}
+
+function validateString(
+  value: unknown,
+  path: string,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+  maxBytes = MAX_TEXT_BYTES,
+): value is string {
+  if (typeof value !== 'string' || value.trim().length === 0) {
+    addViolation(violations, path, 'missing_required_string', `${path} must be a non-empty string.`);
+    return false;
+  }
+  if (byteLength(value) > maxBytes) {
+    addViolation(violations, path, 'string_too_large', `${path} must be <= ${maxBytes} bytes.`);
+  }
+  return true;
+}
+
+function isReceiptRef(value: string): boolean {
+  return /^receipt:rcpt-[a-zA-Z0-9._:-]+$/.test(value);
+}
+
+function isDataExportApprovalRef(value: string): boolean {
+  return isReceiptRef(value) || /^approval:[a-zA-Z0-9._:-]+$/.test(value);
+}
+
+function isLocalOnlyProvider(provider: ClaimGateModelLaneProvider): boolean {
+  return provider === 'codex' || provider === 'local';
