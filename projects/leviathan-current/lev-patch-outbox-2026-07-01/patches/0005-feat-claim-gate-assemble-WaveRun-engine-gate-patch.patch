+      { operator: 'probe:three-engine', status: threeEngineValidation.ok ? 'passed' : 'failed' },
+      { operator: `quotient:${bindingMemory.families.objectBoundary}`, status: bindingMemory.transitions.objectBoundarySurvived ? 'survivor-class' : 'split' },
+      { operator: `quotient:${bindingMemory.families.evidenceMaterial}`, status: bindingMemory.transitions.evidenceMaterialSplit ? 'split-to-purgatory' : 'survivor-class' },
+      { operator: `purgatory:${bindingMemory.purgatoryRecord.id}`, status: bindingMemory.purgatoryRecord.status },
+      { operator: `quotient:${bindingMemory.families.authoritySurface}`, status: survivorStatus },
+      { operator: 'gate:claim-gate-loop', status: gateLoopResult.failurePackets.length === 0 ? 'clean' : 'failure-packets' },
+      { operator: 'proposal:graph-patch', status: graphAdmission.status },
+      { operator: 'gate:claimgate-steering-consume', status: steeringAdmission.status },
