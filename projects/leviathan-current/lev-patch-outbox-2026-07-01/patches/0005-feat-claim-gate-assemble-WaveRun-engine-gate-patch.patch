+
+  const withoutReceipt: Omit<LevWizardRatchetRunResult, 'receipt'> = {
+    kind: 'LevWizardRatchetRunResult',
+    sessionId: input.sessionId,
+    workstreamId: input.workstreamId,
+    task: input.task,
+    wizardVersion: input.wizardVersion,
+    claimCeiling: input.claimCeiling,
+    wavePhases,
+    councilTypes,
+    councilInstanceCount,
+    subcouncilCount,
+    memberCount,
+    skillRefs,
+    skillIntake,
+    memberSourceUseReceipts: memberSourceUse,
+    modelLaneIds,
+    modelLaneRuntime,
+    threeEngineValidation,
