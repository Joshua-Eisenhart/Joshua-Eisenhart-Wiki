+function validateInput(input: LevWizardRatchetRunInput): LevWizardRatchetFinding[] {
+  const findings: LevWizardRatchetFinding[] = [];
+  if (!input || typeof input !== 'object' || Array.isArray(input) || input.kind !== 'LevWizardRatchetRunInput') {
+    addFinding(findings, 'wizard_kind_invalid', 'kind must be LevWizardRatchetRunInput.', 'kind');
+    return findings;
+  }
+  if (!nonEmptyString(input.sessionId)) addFinding(findings, 'wizard_session_id_missing', 'sessionId is required.', 'sessionId');
+  if (!nonEmptyString(input.task)) addFinding(findings, 'wizard_task_missing', 'task is required.', 'task');
+  if (input.wizardVersion !== 'v4.3') addFinding(findings, 'wizard_version_invalid', 'Wizard is v4.3 for current runs.', 'wizardVersion');
+  if (input.claimCeiling !== 'fixture_or_dry_run_until_live_model_and_engine_receipts') {
+    addFinding(findings, 'wizard_claim_ceiling_invalid', 'claimCeiling must stay below live runtime proof.', 'claimCeiling');
+  }
+  validateC1Bounds(input, findings);
+  validateWaveTopology(input, findings);
+  validateContextBindings(input, findings);
+  validateModelLanes(input, findings);
+  return findings;
+}
