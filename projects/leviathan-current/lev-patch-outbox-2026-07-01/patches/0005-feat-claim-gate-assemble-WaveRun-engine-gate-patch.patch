+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function writeWaveRunSourceBoundGateEvidence(
+  root: string,
+  sessionId: string,
+  gateId: 'object_binding' | 'evidence_manifest' | 'falsifier',
+): string[] {
+  const file = join(root, `${gateId}-${Math.random().toString(36).slice(2)}.json`);
+  const body = `${JSON.stringify({
+    kind: 'ClaimGateSourceBoundGateEvidence',
+    claimCeiling: 'local_hash_bound_source_evidence_not_host_admission',
+    gateId,
+    sessionId,
+    taskHash: sha256Text('claim-gate-loop-handler-wave-run-host-consume-task'),
+    objectRef: 'claim-gate-loop-handler-wave-run-host-consume-object',
+    contextReceiptRefs: ['receipt:rcpt-handler-wave-run-host-consume-context'],
+    contextContentHashes: [sha256Text('handler-wave-run-host-consume-context')],
+    threeEngineEnvelopeHash: null,
+    engineSubstrateDigestHash: null,
+    falsifierStatus: 'closed',
+    openFalsifierCount: 0,
+  }, null, 2)}\n`;
+  writeFileSync(file, body);
+  return [`file:${file}`, sha256Text(body)];
+}
+
+function waveRunPassingGateChecks(root: string, sessionId: string) {
+  return [
+    { gateId: 'object_binding', status: 'pass' as const, evidenceRefs: writeWaveRunSourceBoundGateEvidence(root, sessionId, 'object_binding') },
+    { gateId: 'evidence_manifest', status: 'pass' as const, evidenceRefs: writeWaveRunSourceBoundGateEvidence(root, sessionId, 'evidence_manifest') },
+    { gateId: 'falsifier', status: 'pass' as const, evidenceRefs: writeWaveRunSourceBoundGateEvidence(root, sessionId, 'falsifier') },
+  ];
+}
+
+function makeTempDir(name: string): string {
+  const dir = join(tmpdir(), `lev-cg-loop-handler-${name}-${Date.now()}-${Math.random().toString(16).slice(2)}`);
+  mkdirSync(dir, { recursive: true });
+  return dir;
+}
