+      steeringAdmission: result.steeringAdmission.status,
+      projectedVerdict: result.steeringAdmission.consumption.projectedVerdict,
+      recomputedVerdict: result.steeringAdmission.consumption.recomputedVerdict,
+    },
+    inputPatch: {
+      sessionId: seedSessionId,
+      contextReceipts: [
+        ...input.contextReceipts,
+        seedContextReceipt,
+      ],
+    },
+  };
