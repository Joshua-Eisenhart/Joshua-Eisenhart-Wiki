+
+function validateC1Bounds(input: LevWizardRatchetRunInput, findings: LevWizardRatchetFinding[]): void {
+  if (input.waves.length === 0 || input.waves.length > MAX_WAVES) {
+    addFinding(findings, 'wizard_wave_count_out_of_bounds', `waves must contain 1 to ${MAX_WAVES} entries.`, 'waves');
+  }
+  if (input.modelLanes.length > MAX_MODEL_LANES) {
+    addFinding(findings, 'wizard_model_lane_count_out_of_bounds', `modelLanes must contain at most ${MAX_MODEL_LANES} entries.`, 'modelLanes');
+  }
+  if (input.contextReceipts.length > MAX_CONTEXT_RECEIPTS) {
+    addFinding(findings, 'wizard_context_receipt_count_out_of_bounds', `contextReceipts must contain at most ${MAX_CONTEXT_RECEIPTS} entries.`, 'contextReceipts');
+  }
+  if (Buffer.byteLength(input.task, 'utf8') > MAX_TEXT_BYTES) {
+    addFinding(findings, 'wizard_task_too_large', `task must be <= ${MAX_TEXT_BYTES} bytes.`, 'task');
+  }
