+
+function validateWaveTopology(input: LevWizardRatchetRunInput, findings: LevWizardRatchetFinding[]): void {
+  const phases = input.waves.slice().sort((a, b) => a.wave - b.wave).map((wave) => wave.phase);
+  if (stableJson(phases) !== stableJson(WAVE_PHASES)) {
+    addFinding(
+      findings,
+      'wizard_wave_phase_sequence_invalid',
+      `Lev Wizard Ratchet v0 requires the six wave phases in order: ${WAVE_PHASES.join(', ')}.`,
+      'waves',
+    );
+  }
+
+  input.waves.forEach((wave, waveIndex) => {
+    if (!Number.isInteger(wave.wave) || wave.wave !== waveIndex + 1) {
+      addFinding(findings, 'wizard_wave_order_invalid', 'wave numbers must be contiguous and start at 1.', `waves[${waveIndex}].wave`);
+    }
+    if (!wave.councils.length) {
+      addFinding(findings, 'wizard_wave_missing_councils', 'each Wizard wave must contain councils.', `waves[${waveIndex}].councils`);
+    }
+    if (wave.councils.length < MIN_TOP_LEVEL_COUNCILS_PER_WAVE || wave.councils.length > MAX_TOP_LEVEL_COUNCILS_PER_WAVE) {
+      addFinding(
+        findings,
+        'wizard_top_level_council_count_out_of_bounds',
+        `each Wizard wave must contain ${MIN_TOP_LEVEL_COUNCILS_PER_WAVE} to ${MAX_TOP_LEVEL_COUNCILS_PER_WAVE} top-level councils.`,
+        `waves[${waveIndex}].councils`,
+      );
+    }
+    const optionCells = new Set<string>();
+    wave.councils.forEach((council, councilIndex) => {
+      if ((council.councilType as string) === wave.phase) {
+        addFinding(
+          findings,
+          'wizard_council_wave_conflation',
+          'councilType must name a council, not repeat the wave phase.',
+          `waves[${waveIndex}].councils[${councilIndex}].councilType`,
+        );
+      }
+      if (!council.subcouncils.length) {
+        addFinding(findings, 'wizard_council_missing_subcouncils', 'each council must contain nested subcouncils.', `waves[${waveIndex}].councils[${councilIndex}].subcouncils`);
+      }
+      if (council.subcouncils.length < MIN_SUBCOUNCILS_PER_COUNCIL || council.subcouncils.length > MAX_SUBCOUNCILS_PER_COUNCIL) {
+        addFinding(
+          findings,
+          'wizard_subcouncil_count_out_of_bounds',
+          `each top-level council must contain ${MIN_SUBCOUNCILS_PER_COUNCIL} to ${MAX_SUBCOUNCILS_PER_COUNCIL} subcouncils.`,
+          `waves[${waveIndex}].councils[${councilIndex}].subcouncils`,
+        );
+      }
+      council.subcouncils.forEach((subcouncil, subcouncilIndex) => {
+        const subcouncilPath = `waves[${waveIndex}].councils[${councilIndex}].subcouncils[${subcouncilIndex}]`;
+        if (!COUNCIL_OPTION_AXES.includes(subcouncil.optionAxis)) {
+          addFinding(
+            findings,
+            'wizard_subcouncil_option_axis_invalid',
+            `subcouncil optionAxis must be one of ${COUNCIL_OPTION_AXES.join(', ')}.`,
+            `${subcouncilPath}.optionAxis`,
+          );
+        }
+        if (!COUNCIL_OPTION_SLOTS.includes(subcouncil.optionSlot)) {
+          addFinding(
+            findings,
+            'wizard_subcouncil_option_slot_invalid',
+            `subcouncil optionSlot must be one of ${COUNCIL_OPTION_SLOTS.join(', ')}.`,
+            `${subcouncilPath}.optionSlot`,
+          );
+        }
+        optionCells.add(`${subcouncil.optionAxis}:${subcouncil.optionSlot}`);
+        if (!subcouncil.members.length) {
+          addFinding(findings, 'wizard_subcouncil_missing_members', 'each subcouncil must contain formal members.', `${subcouncilPath}.members`);
+        }
+        if (subcouncil.members.length < MIN_MEMBERS_PER_SUBCOUNCIL || subcouncil.members.length > MAX_MEMBERS_PER_SUBCOUNCIL) {
+          addFinding(
+            findings,
+            'wizard_subcouncil_member_count_out_of_bounds',
+            `each subcouncil must contain ${MIN_MEMBERS_PER_SUBCOUNCIL} to ${MAX_MEMBERS_PER_SUBCOUNCIL} members, skills, or agents.`,
+            `${subcouncilPath}.members`,
+          );
+        }
+      });
+    });
+    if (optionCells.size < MIN_SUBCOUNCIL_OPTION_CELLS_PER_WAVE) {
+      addFinding(
+        findings,
+        'wizard_subcouncil_option_lattice_incomplete',
+        `each Wizard wave must expose at least the 3x3 subcouncil option lattice (${MIN_SUBCOUNCIL_OPTION_CELLS_PER_WAVE} cells): skill, voice, and repo axes across slots 1-3.`,
+        `waves[${waveIndex}].councils`,
+      );
+    }
+    COUNCIL_OPTION_AXES.forEach((axis) => {
+      COUNCIL_OPTION_SLOTS.forEach((slot) => {
+        if (!optionCells.has(`${axis}:${slot}`)) {
+          addFinding(
+            findings,
+            'wizard_subcouncil_option_lattice_missing_cell',
+            `Wizard wave ${wave.wave} is missing subcouncil option cell ${axis}:${slot}.`,
+            `waves[${waveIndex}].councils`,
+          );
+        }
+      });
+    });
+  });
+}
+
+function validateContextBindings(input: LevWizardRatchetRunInput, findings: LevWizardRatchetFinding[]): void {
+  const loadedSkills = loadedRefsByType(input, 'skill');
+  const loadedMmms = loadedRefsByType(input, 'mmm');
+  const loadedSources = loadedRefsByType(input, 'source');
+
+  input.contextReceipts.forEach((receipt, index) => {
+    if (!validateHashRef(receipt.contentHash)) {
+      addFinding(findings, 'wizard_context_receipt_missing_hash', 'context receipt contentHash must be a sha256 ref.', `contextReceipts[${index}].contentHash`);
+    }
+    if (!validateReceiptRef(receipt.receiptRef)) {
+      addFinding(findings, 'wizard_context_receipt_ref_invalid', 'context receiptRef must be receipt-bound.', `contextReceipts[${index}].receiptRef`);
+    }
+  });
+
+  input.waves.forEach((wave, waveIndex) => {
+    wave.councils.forEach((council, councilIndex) => {
+      council.subcouncils.forEach((subcouncil, subcouncilIndex) => {
+        subcouncil.members.forEach((member, memberIndex) => {
+          const path = `waves[${waveIndex}].councils[${councilIndex}].subcouncils[${subcouncilIndex}].members[${memberIndex}].cognitiveBinding`;
+          for (const ref of member.cognitiveBinding.skillRefs) {
+            if (!loadedSkills.has(ref)) addFinding(findings, 'wizard_declared_skill_not_loaded', `declared skill ${ref} has no load receipt.`, `${path}.skillRefs`);
+          }
+          for (const ref of member.cognitiveBinding.mmmRefs) {
+            if (!loadedMmms.has(ref)) addFinding(findings, 'wizard_declared_mmm_not_loaded', `declared MMM ${ref} has no load receipt.`, `${path}.mmmRefs`);
+          }
+          for (const ref of member.cognitiveBinding.sourceRefs) {
+            if (!loadedSources.has(ref)) addFinding(findings, 'wizard_declared_source_not_loaded', `declared source ${ref} has no load receipt.`, `${path}.sourceRefs`);
+          }
+        });
+      });
+    });
+  });
+}
+
+function validateModelLanes(input: LevWizardRatchetRunInput, findings: LevWizardRatchetFinding[]): void {
+  const laneIds = new Set<string>();
+  input.modelLanes.forEach((lane, index) => {
+    if (laneIds.has(lane.laneId)) {
+      addFinding(findings, 'wizard_model_lane_duplicate', `model lane ${lane.laneId} appears more than once.`, `modelLanes[${index}].laneId`);
+    }
+    laneIds.add(lane.laneId);
+    if (lane.authority !== 'advisory_only') {
+      addFinding(findings, 'wizard_model_lane_overclaims_authority', 'model lanes are advisory only.', `modelLanes[${index}].authority`);
+    }
+    if (!validateHashRef(lane.promptHash)) {
+      addFinding(findings, 'wizard_model_lane_prompt_hash_invalid', 'promptHash must be a sha256 ref.', `modelLanes[${index}].promptHash`);
+    }
+    if (!validateReceiptRef(lane.receiptRef)) {
+      addFinding(findings, 'wizard_model_lane_receipt_invalid', 'model lane must carry a receipt ref or availability receipt.', `modelLanes[${index}].receiptRef`);
+    }
+    if ((lane.status === 'blocked' || lane.status === 'unavailable') && !lane.reason) {
+      addFinding(findings, 'wizard_model_lane_missing_block_reason', 'blocked and unavailable model lanes need a reason.', `modelLanes[${index}].reason`);
+    }
+  });
+
+  input.waves.forEach((wave, waveIndex) => {
+    wave.councils.forEach((council, councilIndex) => {
+      council.subcouncils.forEach((subcouncil, subcouncilIndex) => {
+        subcouncil.members.forEach((member, memberIndex) => {
+          member.modelLaneIds?.forEach((laneId) => {
+            if (!laneIds.has(laneId)) {
+              addFinding(
+                findings,
+                'wizard_member_model_lane_not_declared',
+                `member references unknown model lane ${laneId}.`,
+                `waves[${waveIndex}].councils[${councilIndex}].subcouncils[${subcouncilIndex}].members[${memberIndex}].modelLaneIds`,
+              );
+            }
+          });
+        });
+      });
+    });
+  });
+}
