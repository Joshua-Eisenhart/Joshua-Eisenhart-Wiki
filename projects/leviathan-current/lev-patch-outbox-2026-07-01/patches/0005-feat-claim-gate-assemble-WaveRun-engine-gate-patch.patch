+    runtimeCarrierPath: digest.runtimeCarrier.carrierPath,
+    receiptHashes: { ...digest.receiptHashes },
+    outputHashes: {
+      julia: digest.receipts.julia.outputHash,
+      jax: digest.receipts.jax.outputHash,
+      pytorch: digest.receipts.pytorch.outputHash,
+    },
+    sourceRefs: {
+      julia: digest.receipts.julia.sourceRef,
+      jax: digest.receipts.jax.sourceRef,
+      pytorch: digest.receipts.pytorch.sourceRef,
+    },
+    commands: {
+      julia: digest.receipts.julia.command,
+      jax: digest.receipts.jax.command,
+      pytorch: digest.receipts.pytorch.command,
+    },
+  };
+}
