+function graphPayload(engine: 'julia' | 'jax' | 'pytorch', control = 'primary'): Record<string, unknown> {
+  const base = {
+    schema: 'lev.engine_substrate.graph_digest.v1',
+    object_id: control === 'primary' ? `lev_graph_digest_${engine}_v1` : `lev_graph_digest_${engine}_${control}_control_v1`,
+    engine,
+    runtime_owner: 'lev',
+    control,
+    promotion_allowed: false,
+    formal_admission_allowed: false,
+    reads_peer_result: false,
+    all_pass: true,
+    packages: { load_bearing: [engine] },
+  };
+  if (control !== 'primary') {
+    return {
+      ...base,
+      graph: {
+        node_count: 4,
+        edge_count: 0,
+        ...(engine === 'julia' ? { algebraic_connectivity: 0 } : {}),
+        ...(engine === 'jax' ? { message_passing: [0, 0, 0, 0] } : {}),
+        ...(engine === 'pytorch' ? { autograd_gradient: [0, 0, 0, 0] } : {}),
+      },
+    };
+  }
+  return {
+    ...base,
+    graph: {
+      node_count: 4,
+      edge_count: 4,
+      ...(engine === 'julia' ? { algebraic_connectivity: 2 } : {}),
+      ...(engine === 'jax' ? { message_passing: [6, 4, 6, 4] } : {}),
+      ...(engine === 'pytorch' ? { autograd_gradient: [2, 2, 2, 2] } : {}),
+    },
+  };
+}
