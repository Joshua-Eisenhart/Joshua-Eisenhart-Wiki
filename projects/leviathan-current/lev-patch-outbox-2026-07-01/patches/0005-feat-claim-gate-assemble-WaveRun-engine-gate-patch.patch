+function buildAcceptedSurvivorNextRunSeed(
+  input: LevWizardRatchetRunInput,
+  result: Omit<LevWizardRatchetRunResult, 'nextRunSeed'>,
+): LevWizardNextRunSeed | undefined {
+  if (!wizardResultEarnedSeed(result)) return undefined;
+
+  const survivorReceiptIds = uniqueStrings([
+    result.bindingMemory.survivorReceipt?.id,
+    result.projectionBinding.m1.survivorReceipt.id,
+    result.projectionBinding.m3.resurrection.survivorReceipt.id,
+  ]);
+  const seedSessionId = `${input.sessionId}:ratchet:1`;
+  const seedFacts = {
+    previousSessionId: input.sessionId,
+    seedSessionId,
+    sourceRunReceiptId: result.receipt.id,
+    graphAdmissionReceiptId: result.graphAdmission.receipt.id,
+    steeringAdmissionReceiptId: result.steeringAdmission.consumption.receipt.id,
+    survivorReceiptIds,
+    spinorCellHash: result.spinorCell.cellHash,
+  };
+  const seedContextReceipt: LevWizardContextReceipt = {
+    refType: 'source',
+    ref: 'source:lev-wizard-ratchet:accepted-survivor-seed',
+    receiptRef: result.receipt.id,
+    contentHash: sha256(seedFacts),
+  };
+
+  return {
+    kind: 'LevWizardNextRunSeed',
+    claimCeiling: 'accepted_survivor_seed_not_autonomous_execution',
+    previousSessionId: input.sessionId,
+    seedSessionId,
+    sourceRunReceiptId: result.receipt.id,
+    graphAdmissionReceiptId: result.graphAdmission.receipt.id,
+    steeringAdmissionReceiptId: result.steeringAdmission.consumption.receipt.id,
