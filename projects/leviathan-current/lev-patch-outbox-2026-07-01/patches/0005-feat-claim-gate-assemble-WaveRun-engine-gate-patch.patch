+// Builds a REAL three-engine probe envelope by running Lev-owned R0 mechanical
+// probes (Julia QuantumOptics / JAX quimb / PyTorch torch+geomstats) through the
+// Lev mechanical-probe-runner, gating the Julia lane through the pinned Lev R0
+// validator. Codex Ratchet/wiki remain reference/provenance, not runtime source.
+//
+// Ceiling: a real engine-run envelope, not proof authority. The default carrier
+// is stored in this Lev repo; override with LEV_SIM_ENGINE_CARRIER only when the
+// alternate carrier is itself Lev-owned/approved.
+import { createHash } from 'node:crypto';
+import { existsSync, mkdtempSync, readFileSync, realpathSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { dirname, join, resolve } from 'node:path';
+import { fileURLToPath } from 'node:url';
+import {
+  runMechanicalProbeLane,
+  validateMechanicalProbeRunReceipt,
+  type MechanicalProbeRunReceipt,
+} from '@lev-os/graph/probes/mechanical-probe-runner';
+import {
+  validateLevNativeR0QuotientProbeReceipt,
+  LEV_NATIVE_R0_QUOTIENT_SOURCE_SHA256,
+} from '@lev-os/graph/probes/lev-native-r0-probe';
+import {
+  validateLevEngineSubstrateDigest,
+  type LevEngineSubstrateDigest,
+  type LevEngineSubstrateExecutionWitness,
+  type ThreeEngineProbeEnvelope,
+} from '@lev-os/graph/contracts/projection-binding';
+
+const MODULE_DIR = dirname(fileURLToPath(import.meta.url));
+const DISALLOWED_REFERENCE_CARRIER_FRAGMENTS = [
+  '/Codex-Ratchet/',
+  '/Desktop/Codex Ratchet/',
+  '/wiki/',
+  '/workshop/intake/',
+];
+
+export function resolveLevOwnedSimEngineCarrierFromModuleDir(moduleDir: string, ...segments: string[]): string {
+  const candidates = [
+    resolve(moduleDir, '..', 'probes', 'lev-sim-engine-carrier', ...segments),
+    resolve(moduleDir, '..', '..', 'src', 'probes', 'lev-sim-engine-carrier', ...segments),
+  ];
+  return candidates.find((candidate) => existsSync(candidate)) ?? candidates[0];
+}
+
+export function resolveLevOwnedSimEngineCarrier(...segments: string[]): string {
+  return resolveLevOwnedSimEngineCarrierFromModuleDir(MODULE_DIR, ...segments);
+}
+
+const DEFAULT_CARRIER = resolveLevOwnedSimEngineCarrier('r0-quotient');
+const DEFAULT_GRAPH_CARRIER = resolveLevOwnedSimEngineCarrier('graph-substrate');
+
+function blockedCarrierFragment(carrier: string): string | undefined {
+  const candidates = [`${carrier}/`];
+  if (existsSync(carrier)) {
+    candidates.push(`${realpathSync(carrier)}/`);
+  }
+  const normalizedCandidates = candidates.map((candidate) => candidate.toLocaleLowerCase());
+  return DISALLOWED_REFERENCE_CARRIER_FRAGMENTS.find((fragment) =>
+    normalizedCandidates.some((candidate) => candidate.includes(fragment.toLocaleLowerCase())),
+  );
+}
+
+function realOrResolved(path: string): string {
+  return existsSync(path) ? realpathSync(path) : resolve(path);
+}
+
+function pathInside(child: string, parent: string): boolean {
+  const childReal = `${realOrResolved(child)}/`;
+  const parentReal = `${realOrResolved(parent)}/`;
+  return childReal === parentReal || childReal.startsWith(parentReal);
+}
+
+export function resolveEngineCarrierForRuntime(
+  envName: 'LEV_SIM_ENGINE_CARRIER' | 'LEV_ENGINE_SUBSTRATE_CARRIER',
+  defaultCarrier: string,
+): string {
+  const override = process.env[envName];
+  if (!override) return defaultCarrier;
+  const carrier = resolve(override);
+  const blocked = blockedCarrierFragment(carrier);
+  if (blocked) {
+    throw new Error(
+      `${envName} points at reference/provenance material (${blocked}); ` +
+        'Lev runtime carriers must be Lev-owned or explicitly approved.',
+    );
+  }
+  if (!pathInside(carrier, defaultCarrier)) {
+    throw new Error(
+      `${envName} points outside the Lev-owned runtime carrier root (${defaultCarrier}); ` +
+        'copied or path-laundered carriers are not runtime authority.',
+    );
+  }
+  return carrier;
+}
+
+const CARRIER_SOURCE = process.env.LEV_SIM_ENGINE_CARRIER
+  ? 'env:LEV_SIM_ENGINE_CARRIER'
+  : 'default:lev-native-sim-engine-carrier';
+const CARRIER = resolveEngineCarrierForRuntime('LEV_SIM_ENGINE_CARRIER', DEFAULT_CARRIER);
+const LEV_NATIVE_R0_JAX_QUOTIENT_SOURCE_SHA256 =
+  'sha256:5511b26c55fec296cb1f8d47c8c96003815b24e7a1ab6142c2f72b13bc2f95fe';
+const LEV_NATIVE_R0_PYTORCH_QUOTIENT_SOURCE_SHA256 =
+  'sha256:1fd00874624c3e815b69f985cfa592eb5458932c2fdaab1a3540547067c2e7c3';
+const GRAPH_CARRIER_SOURCE = process.env.LEV_ENGINE_SUBSTRATE_CARRIER
+  ? 'env:LEV_ENGINE_SUBSTRATE_CARRIER'
+  : 'default:lev-native-sim-engine-carrier';
+const GRAPH_CARRIER = resolveEngineCarrierForRuntime('LEV_ENGINE_SUBSTRATE_CARRIER', DEFAULT_GRAPH_CARRIER);
+const JULIA_BIN = process.env.LEV_JULIA_BIN ?? '/opt/homebrew/bin/julia';
+const PY = process.env.LEV_PY
+  ?? '/Users/joshuaeisenhart/.local/share/lev/sim-stack/bin/python3';
+const PY_ENV = {
+  JAX_ENABLE_X64: process.env.JAX_ENABLE_X64 ?? 'true',
+  NUMBA_CACHE_DIR: process.env.NUMBA_CACHE_DIR ?? '/private/tmp/codex_numba_cache',
+};
+const PYTORCH_ENV = {
+  ...PY_ENV,
+  GEOMSTATS_BACKEND: process.env.GEOMSTATS_BACKEND ?? 'pytorch',
+};
+
+function fail(label: string, findings: string[]): never {
+  throw new Error(`real ${label} probe failed validation: ${findings.join('; ')}`);
+}
+
+function receiptHash(receipt: MechanicalProbeRunReceipt): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(receipt)).digest('hex')}`;
+}
+
+function valueHash(value: unknown): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(value)).digest('hex')}`;
+}
+
+export function buildRealThreeEngineEnvelope(): ThreeEngineProbeEnvelope {
+  const juliaScript = `${CARRIER}/foundation_r0_probe_quotient_refinement_julia.jl`;
+  const juliaResultsDir = mkdtempSync(join(tmpdir(), 'lev-r0-julia-results-'));
+  const juliaResults = join(juliaResultsDir, 'foundation_r0_probe_quotient_refinement_julia_results.json');
+  const jaxScript = `${CARRIER}/foundation_r0_probe_quotient_refinement_jax.py`;
+  const pytorchScript = `${CARRIER}/foundation_r0_probe_quotient_refinement_pytorch.py`;
+
+  const julia = runMechanicalProbeLane({
+    engine: 'julia',
+    role: 'exact_algebraic_canon',
+    command: JULIA_BIN,
+    args: [`--project=${CARRIER}`, juliaScript],
+    cwd: CARRIER,
+    env: { LEV_R0_JULIA_RESULT_PATH: juliaResults },
+    sourceRef: `file:${juliaScript}`,
+    sourceText: readFileSync(juliaScript, 'utf8'),
+    expectedSourceHash: LEV_NATIVE_R0_QUOTIENT_SOURCE_SHA256,
+    input: { probe: 'r0-quotient-refinement' },
+    timeoutMs: 240_000,
+    alignedPackagesLoadBearing: ['QuantumOptics'],
+    negativeControl: 'embedded_negative_controls_must_pass',
+    gateEffect: 'can_resolve_uncertain',
+    executedNegativeControl: {
+      id: 'duplicate_Z_does_not_refine',
+      command: JULIA_BIN,
+      args: [`--project=${CARRIER}`, juliaScript],
+      cwd: CARRIER,
+      env: { LEV_R0_NEGATIVE_CONTROL: 'duplicate_Z_does_not_refine' },
+      sourceRef: `file:${juliaScript}`,
+      sourceText: readFileSync(juliaScript, 'utf8'),
+      expectedSourceHash: LEV_NATIVE_R0_QUOTIENT_SOURCE_SHA256,
+      input: { probe: 'r0-quotient-refinement', negativeControl: 'duplicate_Z_does_not_refine' },
+      timeoutMs: 240_000,
+      expectedOutputIncludes: ['NEGATIVE_CONTROL_DONE engine=julia', 'duplicate_Z_does_not_refine=true'],
+      expectedOutputExcludes: ['SCOUT_DONE'],
+    },
+    outputArtifacts: [{ id: 'result', path: juliaResults, required: true }],
+  });
+  const r0 = validateLevNativeR0QuotientProbeReceipt(julia);
+  if (!r0.ok) fail('Julia R0 (pinned validator)', r0.findings);
+
