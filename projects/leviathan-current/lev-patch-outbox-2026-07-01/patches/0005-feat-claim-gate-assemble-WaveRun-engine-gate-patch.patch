+function withModelLaneRuntimeReceipts(
+  lanes: LevWizardModelLaneReceipt[],
+  runtime: ClaimGateModelLaneRuntimeRunnerResult,
+): LevWizardModelLaneReceipt[] {
+  const compiledByLaneId = new Map(runtime.compilation.modelLanes.map((lane) => [lane.laneId, lane]));
+  return lanes.map((lane) => {
+    const compiled = compiledByLaneId.get(lane.laneId);
+    if (!compiled?.runtimeOutcome) return lane;
+    return {
+      ...lane,
+      status: compiled.status,
+      receiptRef: compiled.receiptRef,
+      ...(compiled.unavailableReason ? { reason: compiled.unavailableReason } : {}),
+      ...(compiled.runtimeOutcome.outputHash ? { outputHash: compiled.runtimeOutcome.outputHash } : {}),
+      runtimeStatus: compiled.runtimeOutcome.runtimeStatus,
+      runtimeReceiptRef: compiled.runtimeOutcome.receiptRef,
+      ...(compiled.runtimeOutcome.reason ? { runtimeReason: compiled.runtimeOutcome.reason } : {}),
+      ...(compiled.runtimeOutcome.costUsd !== undefined ? { runtimeCostUsd: compiled.runtimeOutcome.costUsd } : {}),
+    };
+  });
+}
+
+function nonEmptyString(value: unknown): value is string {
+  return typeof value === 'string' && value.trim().length > 0;
+}
+
+function addFinding(
+  findings: LevWizardRatchetFinding[],
+  code: string,
+  message: string,
+  path?: string,
+  severity: LevWizardRatchetFinding['severity'] = 'error',
+): void {
+  findings.push({ severity, code, message, ...(path ? { path } : {}) });
+}
+
+function validateHashRef(value: string): boolean {
+  return value.startsWith('sha256:') && value.length > 'sha256:'.length;
+}
+
+function validateReceiptRef(value: string): boolean {
+  return value.startsWith('receipt:') || value.startsWith('rcpt-');
+}
+
+function loadedRefsByType(input: LevWizardRatchetRunInput, refType: LevWizardContextReceipt['refType']): Set<string> {
+  return new Set(input.contextReceipts.filter((receipt) => receipt.refType === refType).map((receipt) => receipt.ref));
+}
+
+function collectSkillRefs(input: LevWizardRatchetRunInput): string[] {
+  return [...new Set(input.waves.flatMap((wave) => wave.councils.flatMap((council) => (
+    council.subcouncils.flatMap((subcouncil) => (
+      subcouncil.members.flatMap((member) => member.cognitiveBinding.skillRefs)
+    ))
+  ))))].sort();
+}
+
+function countByCode(findings: FormalExecutionSkillSetRunReceipt['sourcePackReceipt']['findings']): Record<string, number> {
+  const counts: Record<string, number> = {};
+  for (const finding of findings) {
+    counts[finding.code] = (counts[finding.code] ?? 0) + 1;
+  }
+  return counts;
