+    workstreamId: input.workstreamId,
+    maxWaves: input.waves.length,
+    requiredGateIds: input.requiredGateIds ?? REQUIRED_GATE_IDS,
+    trustedEvidenceRefs: options.trustedEvidenceRefs,
+    sourceBoundEvidenceContext: sourceBoundEvidenceContextForInput(input, options.hostFalsifierState),
+  });
+  const graphAdmission = consumeClaimGateGraphPatchProposal(gateLoopResult, {
+    sessionId: `${input.sessionId}-graph-admission`,
+    workstreamId: input.workstreamId,
+  });
+  const steeringAdmission = consumeWizardSteeringProjection(
+    input,
+    threeEngineValidation,
+    engineSubstrateValidation,
+    gateLoopResult,
+    graphAdmission,
+    { overclaimProbe: options.steeringOverclaimProbe },
+  );
+  const oxRickerLoop = buildOxRickerLoopBinding(councilWaveInput, gateLoopResult);
+  const formalAgentSubstrate = buildOhMyFormalAgentBinding(input);
+
+  const wavePhases = input.waves.slice().sort((a, b) => a.wave - b.wave).map((wave) => wave.phase);
+  const councilTypes = [...new Set(input.waves.flatMap((wave) => wave.councils.flatMap((council) => [
+    council.councilType,
+    ...council.subcouncils.map((subcouncil) => subcouncil.subcouncilType),
+  ])))].sort();
+  const councilInstanceCount = input.waves.reduce((sum, wave) => sum + wave.councils.length, 0);
+  const subcouncilCount = input.waves.reduce(
+    (sum, wave) => sum + wave.councils.reduce((councilSum, council) => councilSum + council.subcouncils.length, 0),
+    0,
+  );
+  const memberCount = input.waves.reduce(
+    (waveSum, wave) => waveSum + wave.councils.reduce(
+      (councilSum, council) => councilSum + council.subcouncils.reduce(
+        (subcouncilSum, subcouncil) => subcouncilSum + subcouncil.members.length,
+        0,
+      ),
+      0,
+    ),
+    0,
+  );
+  const skillRefs = collectSkillRefs(input);
+  const skillIntake = buildSkillIntakeSummary(input, skillRefs, input.skillSourcePackReceipts);
+  const memberSourceUse = memberSourceUseReceipts(input);
