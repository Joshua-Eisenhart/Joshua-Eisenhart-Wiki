+
+function modelLaneRuntimeSummary(
+  runtime: ClaimGateModelLaneRuntimeRunnerResult | undefined,
+): LevWizardModelLaneRuntimeSummary {
+  const outcomes = runtime?.outcomes ?? [];
+  const count = (status: ClaimGateModelLaneRuntimeStatus): number => (
+    outcomes.filter((outcome) => outcome.runtimeStatus === status).length
+  );
+  return {
+    kind: 'LevWizardModelLaneRuntimeSummary',
+    claimCeiling: 'advisory_model_lane_runtime_receipts_not_proof',
+    ran: runtime !== undefined,
+    outcomeCount: outcomes.length,
+    successCount: count('success'),
+    blockedCount: count('blocked'),
+    unavailableCount: count('unavailable'),
+    timeoutCount: count('timeout'),
+    schemaInvalidCount: count('schema_invalid'),
+    providerErrorCount: count('provider_error'),
+    laneReceiptRefs: runtime?.compilation.modelAggregation.laneReceiptRefs ?? [],
+    outputHashes: outcomes.flatMap((outcome) => outcome.outputHash ? [outcome.outputHash] : []),
+    costUsd: outcomes.reduce((sum, outcome) => sum + (outcome.costUsd ?? 0), 0),
+  };
+}
