@@ -0,0 +1,177 @@
+import { mkdirSync, mkdtempSync, readFileSync, writeFileSync } from 'node:fs';
+import { join } from 'node:path';
+
+import { produceClaimGateSteeringRun } from './claim-gate-steering-produce.js';
+import {
+  consumeClaimGateSteeringRun,
+  consumeClaimGateSteeringRunWithHostWitness,
+  type ClaimGateConsumptionResult,
+} from './claim-gate-steering-run.js';
+
+export type SpinorMemoryCellCandidate = {
+  kind: 'SpinorMemoryCellCandidate';
+  claimId: string;
+  orientedHistory: Array<{ operator: string; gateStatus: string; reason?: string }>;
+  claimCeiling: 'source_pack_orientation_model_not_runtime_proof';
+  promotionAllowed: false;
+};
+
+export type ClaimGateFailurePacket = {
+  kind: 'ClaimGateFailurePacket';
+  claimId: string;
+  gate: 'host_consume';
+  findings: unknown[];
+  repairRoute: string;
+};
+
+type HarnessObligation = {
+  constraintId: string;
+  status: 'passed' | 'failed' | 'timeout';
+};
+
+type EvalOutputProjection = {
+  verdict?: unknown;
+  evidence?: Array<Record<string, unknown>>;
+  [key: string]: unknown;
+};
+
+type EvalJobProjection = {
+  output?: EvalOutputProjection;
+  [key: string]: unknown;
+};
+
+type RunRatchetHarnessFlowOptions = {
+  targetRef: string;
+  inputReceiptId: string;
+  obligations: HarnessObligation[];
+  outRoot: string;
+  generatedAt?: string;
+};
+
+function readJson<T>(filePath: string): T {
+  return JSON.parse(readFileSync(filePath, 'utf8')) as T;
+}
+
+function writeJson(filePath: string, value: unknown): void {
+  writeFileSync(filePath, `${JSON.stringify(value, null, 2)}\n`);
+}
+
+function tamperProjectedVerdict(runDir: string): void {
+  const outputPath = join(runDir, 'eval-job-output.json');
+  const output = readJson<EvalOutputProjection>(outputPath);
+  if (!Array.isArray(output.evidence) || output.evidence.length === 0) {
+    throw new Error('runRatchetHarnessFlow: produced projection has no evidence to tamper');
+  }
+
+  output.verdict = 'pass';
+  output.evidence[0] = { ...output.evidence[0], status: 'failed' };
+  writeJson(outputPath, output);
+
+  const evalJobPath = join(runDir, 'eval-job.json');
+  const evalJob = readJson<EvalJobProjection>(evalJobPath);
+  evalJob.output = output;
+  writeJson(evalJobPath, evalJob);
+}
+
+function findingCodes(findings: Array<{ code?: unknown }>): string {
+  const codes = findings
+    .map((finding) => finding.code)
+    .filter((code): code is string => typeof code === 'string');
+  return codes.length > 0 ? codes.join(', ') : 'no findings';
+}
+
+function verdictSummary(receipt: ClaimGateConsumptionResult): string {
+  return `status=${receipt.status}, projected=${receipt.projectedVerdict ?? 'unknown'}, recomputed=${receipt.recomputedVerdict ?? 'unknown'}`;
+}
+
+function consumedPasses(receipt: ClaimGateConsumptionResult): boolean {
+  return (
+    receipt.status === 'host_consumed'
+    && receipt.projectedVerdict === 'pass'
+    && receipt.recomputedVerdict === 'pass'
+  );
+}
+
+export async function runRatchetHarnessFlow(opts: RunRatchetHarnessFlowOptions) {
+  mkdirSync(opts.outRoot, { recursive: true });
+  const claimId = `${opts.targetRef}:${opts.inputReceiptId}`;
+  const proposalRoot = mkdtempSync(join(opts.outRoot, 'proposal-'));
+  const repairRoot = mkdtempSync(join(opts.outRoot, 'repair-'));
+
+  const proposal = produceClaimGateSteeringRun(
+    {
+      targetRef: opts.targetRef,
+      inputReceiptId: opts.inputReceiptId,
+      obligations: opts.obligations,
+      generatedAt: opts.generatedAt,
+    },
+    proposalRoot,
+  );
+
+  tamperProjectedVerdict(proposal.runDir);
+  const blockedReceipt = consumeClaimGateSteeringRun({ runDir: proposal.runDir, writeReceipt: true });
+  if (blockedReceipt.status !== 'host_blocked') {
+    throw new Error(`runRatchetHarnessFlow: expected host_blocked, received ${blockedReceipt.status}`);
+  }
+
+  const failurePacket: ClaimGateFailurePacket = {
+    kind: 'ClaimGateFailurePacket',
+    claimId,
+    gate: 'host_consume',
+    findings: blockedReceipt.findings,
+    repairRoute: 'evidence/verdict-mismatch -> reproduce honestly',
+  };
+
+  const repairedProposal = produceClaimGateSteeringRun(
+    {
+      targetRef: opts.targetRef,
+      inputReceiptId: opts.inputReceiptId,
+      obligations: opts.obligations,
+      generatedAt: opts.generatedAt,
+    },
+    repairRoot,
+  );
+  const consumedReceipt = consumeClaimGateSteeringRunWithHostWitness({
+    runDir: repairedProposal.runDir,
+    writeReceipt: true,
+    hostWitnessLedgerPath: join(repairRoot, 'host-witnesses.jsonl'),
+  });
+  if (!consumedPasses(consumedReceipt)) {
+    throw new Error(`runRatchetHarnessFlow: expected host_consumed pass/pass, received ${verdictSummary(consumedReceipt)}`);
+  }
+
+  const spinorCell: SpinorMemoryCellCandidate = {
+    kind: 'SpinorMemoryCellCandidate',
+    claimId,
+    claimCeiling: 'source_pack_orientation_model_not_runtime_proof',
+    promotionAllowed: false,
+    orientedHistory: [
+      { operator: 'produce', gateStatus: proposal.verdict, reason: `projected verdict ${proposal.verdict}` },
+      { operator: 'tamper', gateStatus: 'overclaimed', reason: 'projected pass with failed evidence' },
+      {
+        operator: 'host_consume:blocked',
+        gateStatus: blockedReceipt.status,
+        reason: findingCodes(blockedReceipt.findings),
+      },
+      {
+        operator: 'repair:reproduce',
+        gateStatus: repairedProposal.verdict,
+        reason: `projected verdict ${repairedProposal.verdict}`,
+      },
+      {
+        operator: 'host_consume:consumed',
+        gateStatus: consumedReceipt.status,
+        reason: `${verdictSummary(consumedReceipt)}; ${findingCodes(consumedReceipt.findings)}`,
+      },
+    ],
+  };
+
+  return {
+    proposal,
+    failurePacket,
+    repairedProposal,
+    blockedReceipt,
+    consumedReceipt,
+    spinorCell,
+  };
+}
