@@ -0,0 +1,242 @@
+import { mkdirSync, mkdtempSync, writeFileSync } from 'node:fs';
+import { createHash } from 'node:crypto';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+import { describe, expect, it } from 'vitest';
+import {
+  formalSkillToProjectionSurface,
+  validateFormalSkillSet,
+  type FormalSkill,
+  type FormalSkillSet,
+} from '../contracts/formal-skill-set.js';
+import {
+  validateSkillSourcePack,
+  type SkillSourcePack,
+  type SkillSourceRecord,
+} from '../contracts/source-pack-intake.js';
+
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function writeSource(root: string, id: string): { path: string; hash: string } {
+  const dir = join(root, id);
+  mkdirSync(dir, { recursive: true });
+  const path = join(dir, 'SKILL.md');
+  const text = `---\nname: ${id}\n---\n# ${id}\n`;
+  writeFileSync(path, text);
+  return { path, hash: sha256Text(text) };
+}
+
+function sourceRecord(root: string, id: string): SkillSourceRecord {
+  const source = writeSource(root, id);
+  return {
+    id,
+    title: id,
+    sourceRoot: root,
+    sourcePath: source.path,
+    lifecycle: 'active',
+    sha256: source.hash,
+    targetDomain: 'skill',
+    authority: 'advisory_source_pack_only',
+    procedure: {
+      trigger: 'bounded skill use',
+      readOrder: ['SKILL.md'],
+      requiredOutput: 'receipt-backed finding',
+      promotionRule: 'proposal_only_until_loader_receipt',
+      minimalTest: 'source hash verifies',
+    },
+  };
+}
+
+function sourcePack(record: SkillSourceRecord): SkillSourcePack {
+  return {
+    schemaVersion: 'skill_source_pack_v1',
+    id: 'hermes-formal-skill-source-pack',
+    claimCeiling: 'reference_source_inventory_not_admitted',
+    authority: 'advisory_source_pack_only',
+    records: [record],
+  };
+}
+
+function formalSkill(sourceRecordId: string, id = 'premortem_falsifier'): FormalSkill {
+  return {
+    id,
+    sourceRecordId,
+    name: 'Premortem Falsifier',
+    role: 'find likely failure before promotion',
+    authorityBoundary: 'advisory_skill_outputs_must_hit_deterministic_gates',
+    capabilityRefs: ['premortem', 'loophole-audit', 'overclaim-detection'],
+    mmmRefs: ['claimgate-boundary', 'failure-taxonomy'],
+    sourceRefs: [`skill-source:${sourceRecordId}`],
+    toolRefs: ['graph.probe', 'claimgate.receipt'],
+    inputContract: {
+      requiredFields: ['candidateClaim', 'objectRef', 'claimCeiling'],
+    },
+    outputContract: {
+      kind: 'failure_packet',
+      graphMutation: 'proposal_only',
+      requiredFields: ['failureCode', 'evidenceRefs', 'requeueRoute'],
+    },
+    gateContract: {
+      gateIds: ['evidence-bound', 'overclaim-block'],
+      failureCodes: ['missing_evidence', 'overclaim'],
+      promotionBoundary: 'cannot_promote_without_host_receipt',
+    },
+    requeuePolicy: {
+      routes: ['source-mining', 'claim-narrowing'],
+      maxAttempts: 2,
+    },
+    receiptTarget: 'receipts/premortem_falsifier.json',
+  };
+}
+
+function formalSkillSet(sourcePackId: string, skill: FormalSkill): FormalSkillSet {
+  return {
+    schemaVersion: 'formal_skill_set_v1',
+    id: 'wizard-core-skills',
+    claimCeiling: 'formal_skill_set_candidate_not_runtime_loaded',
+    authority: 'proposal_only_until_loader_receipt',
+    sourcePackId,
+    skills: [skill],
+    bundles: [
+      {
+        id: 'falsification-council',
+        kind: 'council',
+        purpose: 'run bounded failure/falsification skills before admission',
+        skillIds: [skill.id],
+      },
+    ],
+  };
+}
+
+describe('formal skill set contracts', () => {
+  it('admits a formal skill only after its source record is admitted and contracts are complete', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-formal-skills-'));
+    const record = sourceRecord(root, 'premortem');
+    const pack = sourcePack(record);
+    const sourceReceipt = validateSkillSourcePack(pack);
+    const skill = formalSkill(record.id);
+
+    const receipt = validateFormalSkillSet(formalSkillSet(pack.id, skill), pack, sourceReceipt);
+
+    expect(receipt).toEqual({
+      kind: 'FormalSkillSetReceipt',
+      claimCeiling: 'formal_skill_set_candidate_not_runtime_loaded',
+      authority: 'proposal_only_until_loader_receipt',
+      ok: true,
+      admittedSkillIds: ['premortem_falsifier'],
+      admittedBundleIds: ['falsification-council'],
+      skillSetHash: expect.stringMatching(/^sha256:/),
+      findings: [],
+    });
+
+    expect(formalSkillToProjectionSurface(skill, 'wizard-core-skills')).toEqual(expect.objectContaining({
+      id: 'formal-skill:wizard-core-skills:premortem_falsifier',
+      surfaceKind: 'skill',
+      label: 'Premortem Falsifier',
+      probeOutputs: expect.objectContaining({
+        sourceRecordId: 'premortem',
+        graphMutation: 'proposal_only',
+        promotion_allowed: false,
+        formal_admission_allowed: false,
+      }),
+    }));
+  });
+
+  it('rejects formal skills whose source record failed source-pack gates', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-formal-skills-bad-source-'));
+    const record = {
+      ...sourceRecord(root, 'krypton'),
+      declaredClaims: { host_consumed: true },
+    };
+    const pack = sourcePack(record);
+    const sourceReceipt = validateSkillSourcePack(pack);
+
+    const receipt = validateFormalSkillSet(
+      formalSkillSet(pack.id, formalSkill(record.id, 'krypton_detector')),
+      pack,
+      sourceReceipt,
+    );
+
+    expect(sourceReceipt.ok).toBe(false);
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedSkillIds).toEqual([]);
+    expect(receipt.findings.map((finding) => finding.code)).toEqual(expect.arrayContaining([
+      'source_pack_receipt_not_clean',
+      'skill_source_not_admitted',
+      'bundle_skill_not_admitted',
+    ]));
+  });
+
+  it('rejects missing contracts, direct graph apply, and unbounded requeue budgets', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-formal-skills-bad-contract-'));
+    const record = sourceRecord(root, 'gate-digger');
+    const pack = sourcePack(record);
+    const sourceReceipt = validateSkillSourcePack(pack);
+    const skill = {
+      ...formalSkill(record.id, 'gate_digger'),
+      capabilityRefs: [],
+      inputContract: { requiredFields: [] },
+      outputContract: {
+        kind: 'proposal',
+        graphMutation: 'direct_apply',
+        requiredFields: [],
+      },
+      gateContract: {
+        gateIds: [],
+        failureCodes: [],
+        promotionBoundary: '',
+      },
+      requeuePolicy: {
+        routes: [],
+        maxAttempts: Number.POSITIVE_INFINITY,
+      },
+    } as FormalSkill;
+
+    const receipt = validateFormalSkillSet(formalSkillSet(pack.id, skill), pack, sourceReceipt);
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedSkillIds).toEqual([]);
+    expect(receipt.findings.map((finding) => finding.code)).toEqual(expect.arrayContaining([
+      'skill_missing_capability_refs',
+      'skill_missing_input_contract',
+      'skill_missing_output_contract',
+      'skill_direct_graph_apply_blocked',
+      'skill_missing_gate_contract',
+      'skill_missing_failure_codes',
+      'skill_missing_promotion_boundary',
+      'skill_missing_requeue_routes',
+      'skill_invalid_requeue_budget',
+    ]));
+  });
+
+  it('rejects bundles that reference missing or non-admitted skills', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-formal-skills-bad-bundle-'));
+    const record = sourceRecord(root, 'source-hunter');
+    const pack = sourcePack(record);
+    const sourceReceipt = validateSkillSourcePack(pack);
+    const set = formalSkillSet(pack.id, formalSkill(record.id, 'source_hunter'));
+    set.bundles = [
+      {
+        id: 'orientation-council',
+        kind: 'council',
+        purpose: 'load source truth and context',
+        skillIds: ['source_hunter', 'missing_skill'],
+      },
+    ];
+
+    const receipt = validateFormalSkillSet(set, pack, sourceReceipt);
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedSkillIds).toEqual(['source_hunter']);
+    expect(receipt.admittedBundleIds).toEqual([]);
+    expect(receipt.findings).toEqual([
+      {
+        code: 'bundle_unknown_skill',
+        bundleId: 'orientation-council',
+        detail: 'missing_skill',
+      },
+    ]);
+  });
+});
