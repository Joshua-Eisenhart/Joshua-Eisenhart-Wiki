+    receiptRefs: [
+      gateLoopResult.receipt.id,
+      graphAdmission.receipt.id,
+      steeringAdmission.consumption.receipt.id,
+      projectionBinding.m1.survivorReceipt.id,
+      projectionBinding.m2.purgatory.id,
+      projectionBinding.m3.resurrection.trigger.id,
+      projectionBinding.m3.resurrection.survivorReceipt.id,
+      ...modelLaneRuntime.laneReceiptRefs,
+      ...input.contextReceipts.map((receipt) => receipt.receiptRef),
+      ...skillIntake.formalSkillDispatchReceipts.map((receipt) => receipt.receiptRef),
+      ...memberSourceUse.map((receipt) => receipt.receiptRef),
