+function hasJsonResult(receipt: MechanicalProbeRunReceipt | undefined): boolean {
+  return !!receipt && !!parseJsonObjectLine(receipt.stdout);
+}
+
+function hasJsonExecutedControl(receipt: MechanicalProbeRunReceipt | undefined): boolean {
+  return !!receipt?.executedNegativeControl && !!parseJsonObjectLine(receipt.executedNegativeControl.stdout);
