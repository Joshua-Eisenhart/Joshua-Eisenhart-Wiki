+  const input = createDefaultLevWizardRatchetInput(
+    {
+      ...(engineArtifacts
+        ? {
+            threeEngineEnvelope: engineArtifacts.envelope,
+            levEngineSubstrateDigest: engineArtifacts.digest,
+            levEngineSubstrateExecutionWitness: engineArtifacts.digestExecutionWitness,
+          }
+        : {}),
+    },
+  );
+  if (realSkills) {
+    input.skillSourcePackReceipts = runDefaultWizardSkillSourcePackIntake();
+  }
+  if (invalidSim && input.threeEngineEnvelope) {
+    input.threeEngineEnvelope = {
+      ...input.threeEngineEnvelope,
+      engines: {
+        ...input.threeEngineEnvelope.engines,
+        jax: {
+          ...input.threeEngineEnvelope.engines.jax,
+          negativeControl: '',
+        },
+      },
+    };
+  }
+  if (realSourceEvidence) {
+    attachRealSourceEvidence(input, hostFalsifierState);
+  }
+  return input;
+}
+
+function resultRuntimeStatus(result: LevWizardRatchetRunResult): string {
+  if (result.steeringAdmission.status === 'host_blocked') return 'host_blocked';
+  if (result.steeringAdmission.consumption.recomputedVerdict !== 'pass') return 'blocked';
+  if (!result.threeEngineValidation.ok || !result.graphAdmission.ok) return 'blocked';
+  if (result.gateLoopResult.failurePackets.length > 0) return 'blocked';
+  if (!result.skillIntake.ran) return 'fixture_proposal_only';
+  if (result.skillIntake.formalSkillRuntimeDebt > 0) return 'source_pack_inventory_only';
+  if (!result.graphAdmission.graphMutationApplied) return 'proposal_only_host_reviewed';
+  return 'runtime_completed';
+}
+
+function steeringDisplayStatus(result: LevWizardRatchetRunResult): string {
+  if (
+    result.steeringAdmission.status === 'host_consumed'
+    && result.steeringAdmission.consumption.recomputedVerdict !== 'pass'
+  ) {
+    return 'consistency_consumed_failed_projection';
+  }
+  return result.steeringAdmission.status;
+}
+
+function steeringAdmissionPassed(result: LevWizardRatchetRunResult): boolean {
+  return result.steeringAdmission.status === 'host_consumed'
+    && result.steeringAdmission.consumption.projectedVerdict === 'pass'
+    && result.steeringAdmission.consumption.recomputedVerdict === 'pass';
+}
+
+function wizardRunPassedForGraphApply(result: LevWizardRatchetRunResult): boolean {
+  return result.threeEngineValidation.ok
+    && result.gateLoopResult.failurePackets.length === 0
+    && result.graphAdmission.ok
+    && result.steeringAdmission.ok
+    && steeringAdmissionPassed(result);
+}
+
+function graphResultEventId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const direct = (result as { graph_event_id?: unknown }).graph_event_id;
+  if (typeof direct === 'string') return direct;
+  const nested = (result as { data?: { graph_event_id?: unknown } }).data?.graph_event_id;
+  return typeof nested === 'string' ? nested : undefined;
+}
+
+function graphResultSuccess(result: ClaimGateGraphPatchExecutionInput): boolean | undefined {
+  const direct = (result as { success?: unknown }).success;
+  if (typeof direct === 'boolean') return direct;
+  const nested = (result as { data?: { success?: unknown } }).data?.success;
+  return typeof nested === 'boolean' ? nested : undefined;
+}
+
+function graphResultStatus(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const direct = (result as { status?: unknown }).status;
+  if (typeof direct === 'string') return direct;
+  const nested = (result as { data?: { status?: unknown } }).data?.status;
+  return typeof nested === 'string' ? nested : undefined;
+}
+
+function graphResultApplied(result: ClaimGateGraphPatchExecutionInput): number | undefined {
+  const direct = (result as { applied?: unknown }).applied;
+  if (typeof direct === 'number') return direct;
+  const nested = (result as { data?: { applied?: unknown } }).data?.applied;
+  return typeof nested === 'number' ? nested : undefined;
+}
+
+function graphResultApplyPlanReceiptId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const direct = (result as { apply_plan_receipt_id?: unknown; applyPlanReceiptId?: unknown });
+  if (typeof direct.apply_plan_receipt_id === 'string') return direct.apply_plan_receipt_id;
+  if (typeof direct.applyPlanReceiptId === 'string') return direct.applyPlanReceiptId;
+  const nested = (result as { data?: { apply_plan_receipt_id?: unknown; applyPlanReceiptId?: unknown } }).data;
+  if (typeof nested?.apply_plan_receipt_id === 'string') return nested.apply_plan_receipt_id;
+  return typeof nested?.applyPlanReceiptId === 'string' ? nested.applyPlanReceiptId : undefined;
+}
+
+function graphPatchApplyPlanReceiptContentHash(applyPlan: ClaimGateGraphPatchApplyPlan): string {
+  return sha256Value({
+    kind: 'ClaimGateGraphPatchApplyPlanReceiptPayload',
+    artifactKind: 'ClaimGateGraphPatchApplyPlan',
+    sessionId: applyPlan.sessionId,
+    sourceReceiptId: applyPlan.sourceReceiptId,
+    admissionReceiptId: applyPlan.admissionReceiptId,
+    status: applyPlan.status,
+    ok: applyPlan.ok,
+    acceptedClaimIds: applyPlan.acceptedClaimIds,
+    withheldClaimIds: applyPlan.withheldClaimIds,
+    operationCount: applyPlan.operationCount,
+    findings: applyPlan.findings,
+    graphOperations: applyPlan.graphOperations,
+    claimCeiling: 'apply_plan_only_requires_graph_patch_execution',
+    graphMutationApplied: applyPlan.graphMutationApplied,
+  });
+}
+
+function graphAppliedBridgeExecutionFindings(
+  bridge: LevWizardRatchetGraphApplyBridgeResult,
+): string[] {
+  const findings: string[] = [];
+  const graphExecution = bridge.graphExecution;
+  const graphEventId = graphResultEventId(bridge.graphResult);
+  const success = graphResultSuccess(bridge.graphResult);
+  const status = graphResultStatus(bridge.graphResult);
+  const applied = graphResultApplied(bridge.graphResult);
+  const applyPlanReceiptId = graphResultApplyPlanReceiptId(bridge.graphResult);
+
+  if (graphExecution.kind !== 'ClaimGateGraphPatchExecutionReceipt') {
+    findings.push('graph execution receipt kind must be ClaimGateGraphPatchExecutionReceipt');
+  }
+  if (graphExecution.status !== 'graph_patch_executed') {
+    findings.push('graph execution receipt status must be graph_patch_executed');
+  }
+  if (graphExecution.ok !== true) {
+    findings.push('graph execution receipt ok must be true');
+  }
+  if (graphExecution.graphMutationApplied !== true) {
+    findings.push('graph execution receipt must report graphMutationApplied:true');
+  }
+  if (graphExecution.claimCeiling !== 'graph_patch_executed_by_explicit_host_action') {
+    findings.push('graph execution receipt must preserve the explicit host graph-patch ceiling');
+  }
+  if (bridge.applyPlan.kind !== 'ClaimGateGraphPatchApplyPlan') {
+    findings.push('apply plan kind must be ClaimGateGraphPatchApplyPlan');
+  }
+  if (bridge.applyPlan.status !== 'apply_ready' || bridge.applyPlan.ok !== true) {
+    findings.push('apply plan must be apply_ready and ok before a graph-applied bridge can seed the next run');
+  }
+  if (bridge.applyPlan.claimCeiling !== 'apply_plan_only_requires_graph_patch_execution') {
+    findings.push('apply plan must preserve the separate graph execution ceiling');
+  }
+  if (bridge.applyPlan.graphMutationApplied !== false) {
+    findings.push('apply plan must not self-claim graphMutationApplied');
+  }
+  if (bridge.applyPlan.operationCount !== bridge.applyPlan.graphOperations.length) {
+    findings.push('apply plan operationCount must match graphOperations length');
+  }
+  if (!Array.isArray(bridge.applyPlan.findings) || bridge.applyPlan.findings.length > 0) {
+    findings.push('apply plan must carry no findings before a graph-applied bridge can seed the next run');
+  }
+  if (!bridge.applyPlan.receipt || bridge.applyPlan.receipt.workUnitId !== 'claim-gate-graph-patch-apply-plan') {
+    findings.push('apply plan receipt must be a claim-gate graph-patch apply-plan receipt');
+  } else if (bridge.applyPlan.receipt.contentHash !== graphPatchApplyPlanReceiptContentHash(bridge.applyPlan)) {
+    findings.push('apply plan receipt contentHash must match the bridge apply plan');
+  }
+  if (graphExecution.sourceReceiptId !== bridge.applyPlan.sourceReceiptId) {
+    findings.push('graph execution sourceReceiptId must match the apply plan');
+  }
+  if (graphExecution.admissionReceiptId !== bridge.applyPlan.admissionReceiptId) {
+    findings.push('graph execution admissionReceiptId must match the apply plan');
+  }
+  if (graphExecution.applyPlanReceiptId !== bridge.applyPlan.receipt.id) {
+    findings.push('graph execution applyPlanReceiptId must match the apply plan receipt id');
+  }
+  if (graphExecution.operationCount !== bridge.applyPlan.operationCount) {
+    findings.push('graph execution operationCount must match the apply plan operationCount');
+  }
+  if (typeof graphEventId !== 'string' || !graphEventId.startsWith('ge-')) {
+    findings.push('graph result must include a graph_event_id beginning with ge-');
+  }
+  if (graphExecution.graphEventId !== graphEventId) {
+    findings.push('graph execution graphEventId must match the graph result graph_event_id');
+  }
+  if (success !== true) {
+    findings.push('graph result must report success:true');
+  }
+  if (status !== 'applied') {
+    findings.push('graph result status must be applied');
+  }
+  if (applied !== bridge.applyPlan.operationCount) {
+    findings.push('graph result applied count must match the apply plan operationCount');
+  }
+  if (applyPlanReceiptId !== bridge.applyPlan.receipt.id) {
+    findings.push('graph result apply plan receipt id must match the apply plan receipt id');
+  }
+  if (!Array.isArray(graphExecution.findings) || graphExecution.findings.length > 0) {
+    findings.push('graph execution receipt must carry no findings before it can seed the next run');
+  }
+  if (!graphExecution.receipt || graphExecution.receipt.workUnitId !== 'claim-gate-graph-patch-execution') {
+    findings.push('graph execution receipt must be a claim-gate graph-patch execution receipt');
+  }
+
+  return findings;
+}
+
+function buildGraphAppliedNextRunSeed(
+  wizardResult: LevWizardRatchetRunResult,
+  graphExecution: ClaimGateGraphPatchExecutionReceipt,
+): LevWizardGraphAppliedNextRunSeed | undefined {
+  if (!wizardResult.nextRunSeed || !graphExecution.ok || !graphExecution.graphMutationApplied || !graphExecution.graphEventId) {
+    return undefined;
+  }
+  const seedFacts = {
+    sourceSeedSessionId: wizardResult.nextRunSeed.seedSessionId,
+    sourceRunReceiptId: wizardResult.receipt.id,
+    graphAdmissionReceiptId: wizardResult.graphAdmission.receipt.id,
+    steeringAdmissionReceiptId: wizardResult.steeringAdmission.consumption.receipt.id,
+    graphExecutionReceiptId: graphExecution.receipt.id,
+    graphEventId: graphExecution.graphEventId,
+    applyPlanReceiptId: graphExecution.applyPlanReceiptId,
+    graphOperationCount: graphExecution.operationCount,
+  };
+  const graphAppliedContextReceipt: LevWizardContextReceipt = {
+    refType: 'source',
+    ref: 'source:lev-wizard-ratchet:graph-applied-survivor-seed',
+    receiptRef: graphExecution.receipt.id,
+    contentHash: sha256Value(seedFacts),
+  };
+  return {
+    kind: 'LevWizardGraphAppliedNextRunSeed',
+    claimCeiling: 'graph_applied_seed_not_autonomous_execution',
+    sourceSeedSessionId: wizardResult.nextRunSeed.seedSessionId,
+    graphExecutionReceiptId: graphExecution.receipt.id,
+    graphEventId: graphExecution.graphEventId,
+    applyPlanReceiptId: graphExecution.applyPlanReceiptId,
+    graphOperationCount: graphExecution.operationCount,
+    inputPatch: {
+      sessionId: wizardResult.nextRunSeed.seedSessionId,
+      contextReceipts: [
+        ...wizardResult.nextRunSeed.inputPatch.contextReceipts,
+        graphAppliedContextReceipt,
+      ],
+    },
+  };
+}
+
+async function graphAppliedEventStoreFindings(
+  bridge: LevWizardRatchetGraphApplyBridgeResult,
+  graphExecution: ClaimGateGraphPatchExecutionReceipt,
+): Promise<string[]> {
+  const graphEventId = graphExecution.graphEventId;
+  if (!graphEventId) return ['graph execution did not produce a graph event id'];
+  const graphRuntime = await import('@lev-os/graph') as unknown as GraphEventStoreModule;
+  let events: Awaited<ReturnType<ReturnType<GraphEventStoreModule['getEventStore']>['query']>>;
+  try {
+    events = await graphRuntime.getEventStore().query({ type: 'graph.operations_applied' });
+  } catch (err) {
+    return [`graph event store could not be queried: ${err instanceof Error ? err.message : String(err)}`];
+  }
+  const event = events.find((candidate) => candidate.id === graphEventId);
+  if (!event) return [`graph event store is missing applied event '${graphEventId}'`];
+  if (!isRecord(event.payload)) return [`graph event '${graphEventId}' payload is not an object`];
+  const operations = event.payload.operations;
+  if (!Array.isArray(operations)) return [`graph event '${graphEventId}' payload is missing operations[]`];
+  if (stableJson(operations) !== stableJson(bridge.applyPlan.graphOperations)) {
+    return [`graph event '${graphEventId}' operations do not match the apply plan`];
+  }
+  return [];
+}
+
+async function graphAppliedStateFindings(
+  bridge: LevWizardRatchetGraphApplyBridgeResult,
+  graphExecution: ClaimGateGraphPatchExecutionReceipt,
+): Promise<string[]> {
+  const graphEventId = graphExecution.graphEventId;
+  if (!graphEventId) return ['graph execution did not produce a graph event id'];
+  const graphHandlers = await import('@lev-os/graph/handlers') as unknown as GraphEntityReadHandlerModule;
+  const findings: string[] = [];
+  const operations = bridge.applyPlan.graphOperations;
+  const entityIds = [...new Set(operations
+    .filter((operation) => operation.type === 'upsert_entity')
+    .map((operation) => operation.entity_id))];
+  const entityResults = new Map<string, Awaited<ReturnType<GraphEntityReadHandlerModule['getEntity']>>>();
+  for (const entityId of entityIds) {
+    const result = await graphHandlers.getEntity(['--entity-id', entityId]);
+    entityResults.set(entityId, result);
+    if (!result.found) findings.push(`graph state is missing applied entity '${entityId}'`);
+  }
+  for (const operation of operations.filter((candidate) => candidate.type === 'add_claim')) {
+    const result = entityResults.get(operation.entity_id)
+      ?? await graphHandlers.getEntity(['--entity-id', operation.entity_id]);
+    entityResults.set(operation.entity_id, result);
+    if (!result.found || !result.entity) {
+      findings.push(`graph state is missing claim target entity '${operation.entity_id}'`);
+      continue;
+    }
+    const payload = operation.payload as {
+      predicate?: unknown;
+      object?: unknown;
+      truth_state?: unknown;
+    };
+    const matchingClaim = result.entity.claims?.some((claim) => (
+      claim.predicate === payload.predicate
+      && claim.object === payload.object
+      && claim.truth_state === payload.truth_state
+      && Array.isArray(claim.evidence_refs)
+      && claim.evidence_refs.includes(graphEventId)
+    ));
+    if (!matchingClaim) {
+      findings.push(`graph state is missing applied claim '${operation.entity_id}' with graph event '${graphEventId}'`);
+    }
+  }
+  return findings;
+}
+
+async function applyWizardGraphPatchThroughHost(result: LevWizardRatchetRunResult): Promise<LevWizardRatchetGraphApplyBridgeResult> {
+  const applyPlan = buildClaimGateGraphPatchApplyPlan(
+    result.gateLoopResult,
+    result.graphAdmission,
+    {
+      sessionId: `${result.sessionId}-wizard-graph-apply-plan`,
+      workstreamId: result.workstreamId,
+    },
+  );
+  const graphHandlers = await import('@lev-os/graph/handlers') as unknown as GraphPatchHandlerModule;
+  const eligibleForHostApply = wizardRunPassedForGraphApply(result);
+  const applyPlanAuthority = graphHandlers.issueClaimGateGraphApplyPlanAuthority({
+    applyPlanReceiptId: applyPlan.receipt.id,
+    operations: applyPlan.graphOperations,
+  });
+  const graphResult = applyPlan.ok && eligibleForHostApply
+    ? await graphHandlers.patch([
+        '--operations',
+        JSON.stringify(applyPlan.graphOperations),
+        '--apply-plan-receipt-id',
+        applyPlan.receipt.id,
+        '--apply-plan-authority',
+        JSON.stringify(applyPlanAuthority),
+      ])
+    : {
+        success: false,
+        status: 'skipped',
+        applied: 0,
+        apply_plan_receipt_id: applyPlan.receipt.id,
+        errors: [
+          eligibleForHostApply
+            ? 'wizard_graph_apply_plan_blocked_before_graph_handler'
+            : 'wizard_run_blocked_before_graph_handler',
+        ],
+      };
+
+  const graphExecution = recordHostClaimGateGraphPatchExecution(applyPlan, graphResult, {
+    sessionId: `${result.sessionId}-wizard-graph-execution`,
+    workstreamId: result.workstreamId,
+  });
+
+  return {
+    kind: 'LevWizardRatchetGraphApplyBridgeResult',
+    wizardResult: result,
+    applyPlan,
+    graphResult,
+    graphExecution,
+    graphAppliedNextRunSeed: buildGraphAppliedNextRunSeed(result, graphExecution),
+  };
+}
