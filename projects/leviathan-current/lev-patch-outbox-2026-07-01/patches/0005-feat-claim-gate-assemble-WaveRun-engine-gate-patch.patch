+
+export function createSeededLevWizardRatchetInput(
+  previousResult: LevWizardRatchetRunResult,
+  baseInput: LevWizardRatchetRunInput,
+): LevWizardRatchetRunInput {
+  const seed = previousResult.nextRunSeed;
+  const findings: LevWizardRatchetFinding[] = [];
+
+  if (!seed) {
+    addFinding(findings, 'wizard_next_run_seed_missing', 'previous Wizard result did not emit an accepted survivor seed.', 'nextRunSeed');
+  } else {
+    if (seed.previousSessionId !== previousResult.sessionId) {
+      addFinding(findings, 'wizard_next_run_seed_session_mismatch', 'seed previousSessionId must match the previous result sessionId.', 'nextRunSeed.previousSessionId');
+    }
+    if (seed.sourceRunReceiptId !== previousResult.receipt.id) {
+      addFinding(findings, 'wizard_next_run_seed_source_receipt_mismatch', 'seed sourceRunReceiptId must match the previous result receipt id.', 'nextRunSeed.sourceRunReceiptId');
+    }
+    if (seed.graphAdmissionReceiptId !== previousResult.graphAdmission.receipt.id) {
+      addFinding(findings, 'wizard_next_run_seed_graph_receipt_mismatch', 'seed graphAdmissionReceiptId must match the previous graph admission receipt id.', 'nextRunSeed.graphAdmissionReceiptId');
+    }
+    if (seed.steeringAdmissionReceiptId !== previousResult.steeringAdmission.consumption.receipt.id) {
+      addFinding(findings, 'wizard_next_run_seed_steering_receipt_mismatch', 'seed steeringAdmissionReceiptId must match the previous steering consumption receipt id.', 'nextRunSeed.steeringAdmissionReceiptId');
+    }
+    if (seed.spinorCellHash !== previousResult.spinorCell.cellHash) {
+      addFinding(findings, 'wizard_next_run_seed_spinor_hash_mismatch', 'seed spinorCellHash must match the previous Spinor cell hash.', 'nextRunSeed.spinorCellHash');
+    }
+    if (seed.inputPatch.sessionId !== seed.seedSessionId) {
+      addFinding(findings, 'wizard_next_run_seed_input_patch_session_mismatch', 'seed inputPatch.sessionId must match seedSessionId.', 'nextRunSeed.inputPatch.sessionId');
+    }
+    if (baseInput.sessionId !== previousResult.sessionId && baseInput.sessionId !== seed.seedSessionId) {
+      addFinding(
+        findings,
+        'wizard_next_run_seed_base_session_replay',
+        'base input sessionId must be the previous session or the seed session before a next-run seed can be applied.',
+        'baseInput.sessionId',
+      );
+    }
+    if (!wizardResultEarnedSeed(previousResult)) {
+      addFinding(findings, 'wizard_next_run_seed_not_earned', 'previous Wizard result did not satisfy pass/pass admission and survivor conditions for seeding.', 'nextRunSeed');
+    }
+
+    const expectedSeedFacts = {
+      previousSessionId: previousResult.sessionId,
+      seedSessionId: seed.seedSessionId,
+      sourceRunReceiptId: previousResult.receipt.id,
+      graphAdmissionReceiptId: previousResult.graphAdmission.receipt.id,
+      steeringAdmissionReceiptId: previousResult.steeringAdmission.consumption.receipt.id,
+      survivorReceiptIds: seed.survivorReceiptIds,
+      spinorCellHash: previousResult.spinorCell.cellHash,
+    };
+    const expectedSeedHash = sha256(expectedSeedFacts);
+    const seedContextReceipt = seed.inputPatch.contextReceipts.find((receipt) => (
+      receipt.ref === 'source:lev-wizard-ratchet:accepted-survivor-seed'
+    ));
+    if (!seedContextReceipt) {
+      addFinding(findings, 'wizard_next_run_seed_context_receipt_missing', 'seed input patch must carry an accepted-survivor source receipt.', 'nextRunSeed.inputPatch.contextReceipts');
+    } else {
+      if (seedContextReceipt.receiptRef !== previousResult.receipt.id) {
+        addFinding(findings, 'wizard_next_run_seed_context_receipt_ref_mismatch', 'seed context receipt must point at the previous run receipt id.', 'nextRunSeed.inputPatch.contextReceipts');
+      }
+      if (seedContextReceipt.contentHash !== expectedSeedHash) {
+        addFinding(findings, 'wizard_next_run_seed_context_hash_mismatch', 'seed context receipt hash must match the previous survivor seed facts.', 'nextRunSeed.inputPatch.contextReceipts');
+      }
+    }
+  }
+
+  if (findings.length > 0) throw new LevWizardRatchetInputError(findings);
+
+  const nextInput: LevWizardRatchetRunInput = {
+    ...baseInput,
+    sessionId: seed!.inputPatch.sessionId,
+    contextReceipts: seed!.inputPatch.contextReceipts.map((receipt) => ({ ...receipt })),
+    sourceBoundGateEvidenceRefs: undefined,
+  };
+  const inputFindings = validateInput(nextInput);
+  if (inputFindings.some((finding) => finding.severity === 'error')) {
+    throw new LevWizardRatchetInputError(inputFindings);
+  }
+  return nextInput;
+}
+
+function projectionSurfacesForRun(
+  input: LevWizardRatchetRunInput,
+  threeEngineValidation: EnvelopeValidationResult,
+  gateLoopResult: ClaimGateLoopResult,
+  graphAdmission: ClaimGateGraphPatchAdmission,
+  wavePhases: LevWizardWavePhase[],
+): ProjectionSurface[] {
+  const proposalOnly = graphAdmission.graphMutationApplied === false;
+  const admissionStatus = `${graphAdmission.status}:${proposalOnly ? 'proposal_only' : 'mutated'}`;
+  const objectFamily = 'lev-wizard-ratchet-memory';
+  const objectRole = 'proposal_only_graph_patch';
+  const councilHash = sha256({
+    sessionId: input.sessionId,
+    wavePhases,
+    acceptedClaimIds: gateLoopResult.graphPatchProposal.acceptedClaimIds,
+    failurePacketCount: gateLoopResult.failurePackets.length,
+  });
+  const probeHash = sha256({
+    threeEngineValidation,
+    envelopeHash: input.threeEngineEnvelope ? sha256(input.threeEngineEnvelope) : 'missing',
+  });
+
+  return [
+    {
+      id: `surface:${input.sessionId}:wizard-council`,
+      surfaceKind: 'graph_view',
+      label: 'Lev Wizard council graph-patch proposal',
+      contentHash: councilHash,
+      declaredContentHash: councilHash,
+      geometry: { kind: 'graph_tensor', spinorType: 'density_matrix', axis: 'lev-wizard-ratchet' },
+      probeOutputs: {
+        object_family: objectFamily,
+        object_role: objectRole,
+        evidence_material: 'wizard_council_claims',
+        mechanical_probe_status: 'not_mechanical_probe',
+        admission_surface: admissionStatus,
+        promotion_allowed: false,
+      },
+    },
+    {
+      id: `surface:${input.sessionId}:sim-engine-probe`,
+      surfaceKind: 'receipt',
+      label: 'Lev-native sim-engine PROBE receipt bundle',
+      contentHash: probeHash,
+      declaredContentHash: probeHash,
+      geometry: { kind: 'finite_density_channel', spinorType: 'density_matrix', axis: 'lev-native-r0' },
+      probeOutputs: {
+        object_family: objectFamily,
+        object_role: objectRole,
+        evidence_material: threeEngineValidation.ok ? 'lev_native_three_engine_r0_receipts' : 'invalid_three_engine_receipts',
+        mechanical_probe_status: threeEngineValidation.ok ? 'passed' : 'failed',
+        admission_surface: admissionStatus,
+        promotion_allowed: false,
+      },
+    },
+  ];
+}
+
+function buildProjectionBindingMemory(
+  input: LevWizardRatchetRunInput,
+  threeEngineValidation: EnvelopeValidationResult,
+  gateLoopResult: ClaimGateLoopResult,
+  graphAdmission: ClaimGateGraphPatchAdmission,
+  wavePhases: LevWizardWavePhase[],
+): LevWizardProjectionBindingMemory {
+  const surfaces = projectionSurfacesForRun(input, threeEngineValidation, gateLoopResult, graphAdmission, wavePhases);
+  const scope = evaluateScopeAdmission(surfaces);
+  const surfaceIds = scope.admitted.map((surface) => surface.id);
+  const bindingCandidate: SurfaceBindingCandidate = {
+    id: `binding:${input.sessionId}:wizard-sim`,
+    surfaceIds,
+    claimCeiling: 'family_local_nonterminal',
+    proposedBy: 'lev-wizard-ratchet',
+  };
+  const objectBoundaryFamily: ProbeFamily = {
+    id: 'family:lev-wizard-object-boundary',
+    probes: [
+      { id: 'probe:object-family', outputKey: 'object_family' },
+      { id: 'probe:object-role', outputKey: 'object_role' },
+    ],
+  };
+  const evidenceMaterialFamily: ProbeFamily = {
+    id: 'family:evidence-material-distinguishability',
+    probes: [
+      { id: 'probe:evidence-material', outputKey: 'evidence_material' },
+      { id: 'probe:mechanical-probe-status', outputKey: 'mechanical_probe_status' },
+    ],
+  };
+  const authoritySurfaceFamily: ProbeFamily = {
+    id: 'family:authority-surface-remerge',
+    probes: [
+      { id: 'probe:admission-surface', outputKey: 'admission_surface' },
+      { id: 'probe:promotion-allowed', outputKey: 'promotion_allowed' },
+    ],
+  };
+  const quotients = {
+    objectBoundary: quotientSurfaces(scope.admitted, objectBoundaryFamily),
+    evidenceMaterial: quotientSurfaces(scope.admitted, evidenceMaterialFamily),
+    authoritySurface: quotientSurfaces(scope.admitted, authoritySurfaceFamily),
+  };
+  const [leftId, rightId] = surfaceIds;
+  const objectBoundarySurvived = sameSurvivorClass(scope.admitted, objectBoundaryFamily, leftId, rightId);
+  const evidenceMaterialSplit = !sameSurvivorClass(scope.admitted, evidenceMaterialFamily, leftId, rightId);
+  const authoritySurfaceRemerged = sameSurvivorClass(scope.admitted, authoritySurfaceFamily, leftId, rightId);
+  const objectBoundarySurvivorReceipt: SurvivorReceipt = {
+    kind: 'SurvivorReceipt',
+    id: `survivor:${bindingCandidate.id}:${objectBoundaryFamily.id}`,
+    bindingCandidateId: bindingCandidate.id,
+    surfaceIds,
+    familyId: objectBoundaryFamily.id,
+    status: 'provisional_survivor',
+  };
+  const purgatoryRecord = createPurgatoryRecord(bindingCandidate, evidenceMaterialFamily, scope.admitted, {
+    reopenBudgetMax: 2,
+    obstructionDepthMax: 4,
+  });
+  const resurrection = attemptResurrection(purgatoryRecord, authoritySurfaceFamily, scope.admitted);
+  if (!objectBoundarySurvived || !evidenceMaterialSplit || !authoritySurfaceRemerged || !resurrection.trigger || !resurrection.survivorReceipt) {
+    throw new Error('Lev Wizard projection binding failed to produce the expected M1 survivor, M2 split, and M3 remerge trace.');
+  }
+  const projectionBinding: LevWizardProjectionBindingTrace = {
+    kind: 'LevWizardProjectionBindingTrace',
+    claimCeiling: 'family_local_nonterminal',
+    candidate: bindingCandidate,
+    scopeAdmission: scope,
+    m1: {
+      familyId: objectBoundaryFamily.id,
+      quotient: quotients.objectBoundary,
+      sameSurvivorClass: true,
+      survivorReceipt: objectBoundarySurvivorReceipt,
+    },
+    m2: {
+      familyId: evidenceMaterialFamily.id,
+      quotient: quotients.evidenceMaterial,
+      sameSurvivorClass: false,
+      purgatory: purgatoryRecord,
+    },
+    m3: {
+      familyId: authoritySurfaceFamily.id,
+      sameSurvivorClass: true,
+      resurrection: {
+        purgatory: resurrection.purgatory,
+        trigger: resurrection.trigger,
+        survivorReceipt: resurrection.survivorReceipt,
+      },
+    },
+    operatorTrace: [
+      `quotient:${objectBoundaryFamily.id}:survivor`,
+      `quotient:${evidenceMaterialFamily.id}:split`,
+      `purgatory:${purgatoryRecord.id}:suspended`,
+      `quotient:${authoritySurfaceFamily.id}:remerged`,
+    ],
+  };
+
+  return {
+    kind: 'LevWizardProjectionBindingMemory',
+    claimCeiling: 'family_local_nonterminal',
+    candidate: bindingCandidate,
+    scopeAdmission: scope,
+    bindingCandidateId: bindingCandidate.id,
+    surfaceIds,
+    scopeBlocks: scope.scopeBlocks,
+    families: {
+      objectBoundary: objectBoundaryFamily.id,
+      evidenceMaterial: evidenceMaterialFamily.id,
+      authoritySurface: authoritySurfaceFamily.id,
+    },
+    quotients,
+    transitions: {
+      objectBoundarySurvived,
+      evidenceMaterialSplit,
+      authoritySurfaceRemerged: Boolean(authoritySurfaceRemerged && resurrection.trigger && resurrection.survivorReceipt),
+    },
+    purgatoryRecord: resurrection.purgatory,
+    ...(resurrection.trigger ? { resurrectionTrigger: resurrection.trigger } : {}),
+    ...(resurrection.survivorReceipt ? { survivorReceipt: resurrection.survivorReceipt } : {}),
+    projectionBinding,
+  };
+}
+
+function buildOxRickerLoopBinding(
+  councilWaveInput: ClaimGateCouncilWaveInput,
+  gateLoopResult: ClaimGateLoopResult,
+): LevWizardOxRickerLoopBinding {
+  const requeueRules = [...new Set(councilWaveInput.waves.map((wave) => wave.contract.requeueRule))].sort();
+  return {
+    kind: 'LevWizardOxRickerLoopBinding',
+    topologyRef: OXRICKER_TOPOLOGY_REF,
+    gateContractRef: OXRICKER_GATE_CONTRACT_REF,
+    requeuePolicyRef: OXRICKER_REQUEUE_POLICY_REF,
+    appliesTo: 'every_wizard_wave_contract',
+    authority: 'deterministic_gate_loop_not_swarm_authority',
+    waveCount: councilWaveInput.waves.length,
+    requeueRules,
+    failurePacketCount: gateLoopResult.failurePackets.length,
+    status: gateLoopResult.failurePackets.length === 0 ? 'clean' : 'failure_packets',
+  };
+}
+
+function buildOhMyFormalAgentBinding(input: LevWizardRatchetRunInput): LevWizardOhMyFormalAgentBinding {
+  const members = input.waves.flatMap((wave) => wave.councils.flatMap((council) => (
+    council.subcouncils.flatMap((subcouncil) => subcouncil.members)
+  )));
+  const loadedSourceReceipt = input.contextReceipts.some((receipt) => (
+    receipt.refType === 'source' && receipt.ref === OHMY_OPENAGENT_TEAMMODE_SOURCE_REF
+  ));
+  const membersWithOxRickerGate = members.filter((member) => (
+    member.cognitiveBinding.gateContractRefs.includes(OXRICKER_GATE_CONTRACT_REF)
+      && member.cognitiveBinding.requeuePolicyRef === OXRICKER_REQUEUE_POLICY_REF
+  )).length;
+  return {
+    kind: 'LevWizardOhMyFormalAgentBinding',
+    sourceRef: OHMY_OPENAGENT_TEAMMODE_SOURCE_REF,
+    releaseUrl: OHMY_OPENAGENT_TEAMMODE_RELEASE_URL,
+    authority: 'teammode_prior_art_not_runtime_authority',
+    appliesTo: 'wizard_member_execution_profile_guardrails',
+    requiredGuardrails: [...OHMY_OPENAGENT_TEAMMODE_GUARDRAILS],
+    memberCount: members.length,
+    loadedSourceReceipt,
+    membersWithOxRickerGate,
+    status: loadedSourceReceipt && membersWithOxRickerGate === members.length ? 'bound' : 'incomplete',
+  };
+}
+
+function produceStatus(ok: boolean): ProduceObligationStatus {
+  return ok ? 'passed' : 'failed';
+}
+
+function isSha256Ref(value: string | undefined): boolean {
+  return typeof value === 'string' && /^sha256:[0-9a-f]{64}$/.test(value);
+}
+
+function threeEngineSteeringEvidenceRefs(envelope: ThreeEngineProbeEnvelope | undefined): string[] {
+  if (!envelope) return [];
+  const receiptHashes = envelope.mechanicalProbeRunReceiptHashes;
+  if (!receiptHashes) return [];
+
+  if (envelope.mode === 'all_three_full_sims' && (!envelope.engines.pytorch || !receiptHashes.pytorch)) {
+    return [];
+  }
+
+  const entries = [
+    ['julia', envelope.engines.julia, receiptHashes.julia],
+    ['jax', envelope.engines.jax, receiptHashes.jax],
+    ['pytorch', envelope.engines.pytorch, receiptHashes.pytorch],
+  ] as const;
+  const refs = [`hash:${sha256(envelope)}`];
+
+  for (const [engine, lane, receiptHash] of entries) {
+    if (!lane) continue;
+    if (!lane.sourceRef.startsWith('file:')) return [];
+    if (!isSha256Ref(lane.inputHash) || !isSha256Ref(lane.outputHash) || !isSha256Ref(receiptHash)) return [];
+    refs.push(`mechanical-probe:${engine}:receipt:${receiptHash}`);
+    refs.push(`mechanical-probe:${engine}:source:${lane.sourceRef}`);
+    refs.push(`mechanical-probe:${engine}:input:${lane.inputHash}`);
+    refs.push(`mechanical-probe:${engine}:output:${lane.outputHash}`);
+  }
+
+  return refs;
+}
+
+function engineSubstrateSteeringEvidenceRefs(
+  digest: LevEngineSubstrateDigest | undefined,
+  witness: LevEngineSubstrateExecutionWitness | undefined,
+): string[] {
+  if (!digest) return [];
+  if (!validateLevEngineSubstrateDigest(digest, { hostExecutionWitness: witness }).ok) return [];
+
+  const refs = [
+    `hash:${sha256(digest)}`,
+    `engine-substrate:witness:${sha256(witness)}`,
+    `engine-substrate:owner:${digest.runtimeOwner}`,
+    `engine-substrate:domain:graph`,
+  ];
+
+  const lanes = [
+    ['julia', digest.receiptHashes.julia, digest.receipts.julia?.sourceRef],
+    ['jax', digest.receiptHashes.jax, digest.receipts.jax?.sourceRef],
+    ['pytorch', digest.receiptHashes.pytorch, digest.receipts.pytorch?.sourceRef],
+  ] as const;
+
+  for (const [engine, receiptHash, scriptPath] of lanes) {
+    if (!isSha256Ref(receiptHash) || !scriptPath?.startsWith('file:')) return [];
+    refs.push(`engine-substrate:${engine}:receipt:${receiptHash}`);
+    refs.push(`engine-substrate:${engine}:source:${scriptPath}`);
+  }
+
+  return refs;
+}
+
+function safeRunIdPart(value: string): string {
+  return value.replace(/[^a-zA-Z0-9._-]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 96) || 'wizard';
+}
+
+const WIZARD_STEERING_INTERNAL_GATES = [
+  'claim_card_validity',
+  'effect_envelope_validity',
+  'object_binding',
+  'self_attestation_policy',
+  'scope',
+  'evidence',
+  'evidence_manifest',
+  'signed_manifest_gate',
+  'required_checks',
+  'falsifier',
+  'overclaim',
+  'risk_policy',
+  'rerun_commands',
+  'hashes',
+] as const;
+
+function wizardSteeringObligations(
+  input: LevWizardRatchetRunInput,
+  threeEngineValidation: EnvelopeValidationResult,
+  engineSubstrateValidation: EnvelopeValidationResult,
+  gateLoopResult: ClaimGateLoopResult,
+  graphAdmission: ClaimGateGraphPatchAdmission,
+): ProduceClaimGateObligation[] {
+  const threeEngineEvidenceRefs = threeEngineSteeringEvidenceRefs(input.threeEngineEnvelope);
+  const engineSubstrateEvidenceRefs = engineSubstrateSteeringEvidenceRefs(
+    input.levEngineSubstrateDigest,
+    input.levEngineSubstrateExecutionWitness,
+  );
+  const engineSubstrateOk = engineSubstrateValidation.ok
+    && (!input.levEngineSubstrateDigest || engineSubstrateEvidenceRefs.length > 0);
+  const wizardReady = threeEngineValidation.ok
+    && threeEngineEvidenceRefs.length > 0
+    && engineSubstrateOk
+    && gateLoopResult.failurePackets.length === 0
+    && graphAdmission.ok;
+  const evidenceRefs = [
+    ...threeEngineEvidenceRefs,
+    ...engineSubstrateEvidenceRefs,
+    `receipt:${gateLoopResult.receipt.id}`,
+    `hash:${gateLoopResult.receipt.contentHash}`,
+    `receipt:${graphAdmission.receipt.id}`,
+    `hash:${graphAdmission.receipt.contentHash}`,
+  ];
+
+  return WIZARD_STEERING_INTERNAL_GATES.map((gateId) => ({
+    constraintId: `claimgate.${gateId}`,
+    status: produceStatus(wizardReady),
+    elapsedMs: 0,
+    evidenceRefs,
+  }));
+}
+
+function consumeWizardSteeringProjection(
+  input: LevWizardRatchetRunInput,
+  threeEngineValidation: EnvelopeValidationResult,
+  engineSubstrateValidation: EnvelopeValidationResult,
+  gateLoopResult: ClaimGateLoopResult,
+  graphAdmission: ClaimGateGraphPatchAdmission,
+  options: { overclaimProbe?: boolean } = {},
+): LevWizardSteeringAdmission {
+  const outRoot = mkdtempSync(join(tmpdir(), 'lev-wizard-steering-'));
+  const runId = `cg-${safeRunIdPart(input.sessionId)}-wizard-steering${options.overclaimProbe ? '-overclaim' : ''}`;
+  const produced = produceClaimGateSteeringRun(
+    {
+      targetRef: 'claimgate.wizard-ratchet',
+      suiteId: 'claimgate.wizard-ratchet',
+      inputReceiptId: graphAdmission.receipt.id,
+      obligations: wizardSteeringObligations(input, threeEngineValidation, engineSubstrateValidation, gateLoopResult, graphAdmission),
+      runId,
+      generatedAt: input.generatedAt,
+    },
+    outRoot,
+  );
+
+  if (options.overclaimProbe) {
+    const runJsonPath = join(produced.runDir, 'run.json');
+    const runJson = JSON.parse(readFileSync(runJsonPath, 'utf8')) as Record<string, unknown>;
+    runJson.release_admission_allowed = true;
+    writeFileSync(runJsonPath, `${JSON.stringify(runJson, null, 2)}\n`);
+  }
+
+  const hostWitnessLedgerPath = join(outRoot, 'host-witnesses.jsonl');
+  const consumption = options.overclaimProbe
+    ? consumeClaimGateSteeringRun({
+        runDir: produced.runDir,
+        writeReceipt: true,
+        hostWitnessLedgerPath,
+      })
+    : consumeClaimGateSteeringRunWithHostWitness({
+        runDir: produced.runDir,
+        writeReceipt: true,
+        hostWitnessLedgerPath,
+      });
+
+  return {
+    kind: 'LevWizardSteeringAdmission',
+    claimCeiling: 'host_consumption_receipt_not_runtime_autonomy',
+    targetRef: 'claimgate.wizard-ratchet',
+    overclaimProbe: Boolean(options.overclaimProbe),
+    produced,
+    consumption,
+    status: consumption.status,
+    ok: consumption.ok,
+  };
+}
+
+export function runLevWizardRatchetCouncil(
+  input: LevWizardRatchetRunInput,
+  options: RunLevWizardRatchetCouncilOptions = {},
+): LevWizardRatchetRunResult {
+  const inputFindings = validateInput(input);
+  if (inputFindings.some((finding) => finding.severity === 'error')) {
+    throw new LevWizardRatchetInputError(inputFindings);
+  }
+
+  const threeEngineValidation = validateThreeEngineEvidence(input.threeEngineEnvelope);
+  const engineSubstrateValidation = validateEngineSubstrateDigestEvidence(input.levEngineSubstrateDigest, {
+    required: threeEngineValidation.ok,
+    hostExecutionWitness: input.levEngineSubstrateExecutionWitness,
+  });
+  const simEngineFindings = [
+    ...threeEngineValidation.findings,
+    ...engineSubstrateValidation.findings,
+  ];
+  const simEngineEvidenceRefs = input.levEngineSubstrateDigest
+    ? [
+        'receipt:rcpt-sim-engine-envelope',
+        `hash:${sha256(input.threeEngineEnvelope)}`,
+        `hash:${sha256(input.levEngineSubstrateDigest)}`,
+      ]
+    : [
+        'receipt:rcpt-sim-engine-envelope',
+        `hash:${sha256(input.threeEngineEnvelope)}`,
+      ];
+  const simEngineGateCheck: ClaimGateCouncilWaveClaim['gateChecks'][number] = threeEngineValidation.ok && engineSubstrateValidation.ok
+    ? {
+        gateId: 'sim_engine_probe',
+        status: 'pass',
+        reason: input.levEngineSubstrateDigest
+          ? 'three-engine PROBE envelope and Lev engine substrate digest passed Lev validation; receipts are evidence, not proof authority'
+          : 'three-engine PROBE envelope passed Lev validation; receipt is evidence, not proof authority',
+        evidenceRefs: simEngineEvidenceRefs,
+      }
+    : {
+        gateId: 'sim_engine_probe',
+        status: 'fail',
+        reason: simEngineFindings.join('; '),
+        evidenceRefs: ['probe:three-engine', 'receipt:missing-or-invalid-sim-engine-envelope'],
+      };
