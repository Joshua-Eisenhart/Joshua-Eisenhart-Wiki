+    return 'simulation';
+  }
+  if (haystack.includes('wiki')) return 'wiki';
+  if (haystack.includes('memory')) return 'memory';
+  if (haystack.includes('research')) return 'research';
+  if (haystack.includes('graph') || haystack.includes('gate') || haystack.includes('probe') || haystack.includes('receipt')) {
+    return 'graph_probe_gate';
+  }
+  if (haystack.includes('tribunal') || haystack.includes('moa') || haystack.includes('mixture of agents') || haystack.includes('subagent') || haystack.includes('worker') || haystack.includes('cli coding agent')) {
+    return 'execution';
+  }
+  return 'skill';
+}
+
+function executionProfileFor(id: string, haystack: string): ExecutionProfileFamily | undefined {
+  if (id === 'tribunal' || haystack.includes('independent comparison')) {
+    return 'hermes.tribunal.independent_comparison';
+  }
+  if (id === 'subagent-driven-development' || haystack.includes('delegate_task')) {
