+
+function hashText(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function stableJson(value: unknown): string {
+  return JSON.stringify(normalizeForStableJson(value));
+}
+
+function normalizeForStableJson(value: unknown): unknown {
+  if (Array.isArray(value)) {
+    return value.map((entry) => normalizeForStableJson(entry));
+  }
+
+  if (value && typeof value === 'object') {
+    return Object.fromEntries(
+      Object.entries(value as Record<string, unknown>)
+        .sort(([left], [right]) => left.localeCompare(right))
+        .map(([key, entry]) => [key, normalizeForStableJson(entry)]),
+    );
+  }
+
+  return value;
+}
+
+type ProcessRun = {
+  args: string[];
+  inputHash: string;
+  outputHash: string;
+  stderrHash: string;
+  exitCode: number | null;
+  signal: string | null;
+  timedOut: boolean;
+  durationMs: number;
+  stdout: string;
+  stderr: string;
+};
+
+function runProcess(request: {
+  command: string;
+  args?: string[];
+  cwd?: string;
+  env?: Record<string, string>;
+  input: unknown;
+  timeoutMs: number;
+}): ProcessRun {
+  const startedAt = Date.now();
+  const args = request.args ?? [];
+  const inputText = stableJson(request.input);
+  const result = spawnSync(request.command, args, {
+    cwd: request.cwd,
+    env: request.env ? { ...process.env, ...request.env } : process.env,
+    input: inputText,
+    encoding: 'utf8',
+    timeout: request.timeoutMs,
+    maxBuffer: 1024 * 1024,
+  });
+  const durationMs = Date.now() - startedAt;
+  const timedOut = (result.error as NodeJS.ErrnoException | undefined)?.code === 'ETIMEDOUT';
+  const stdout = typeof result.stdout === 'string' ? result.stdout : String(result.stdout ?? '');
+  const stderrParts = [
+    typeof result.stderr === 'string' ? result.stderr : String(result.stderr ?? ''),
+    result.error ? String(result.error.message) : '',
+  ].filter(Boolean);
+  const stderr = stderrParts.join('\n');
+  const exitCode = typeof result.status === 'number' ? result.status : null;
+  const inputHash = hashText(inputText);
+  const outputHash = hashText(stdout);
+
+  return {
+    args,
+    inputHash,
+    outputHash,
+    stderrHash: hashText(stderr),
+    exitCode,
+    signal: result.signal ?? null,
+    timedOut,
+    durationMs,
+    stdout,
+    stderr,
+  };
+}
+
+function filePathFromSourceRef(sourceRef: string): string | undefined {
+  return sourceRef.startsWith('file:') ? sourceRef.slice('file:'.length) : undefined;
+}
+
+function sourceEvidenceFrom(request: { sourceRef: string; sourceText?: string }): {
+  sourceFilePath?: string;
+  sourceHash: string;
+  sourceRefFileRead?: boolean;
+  sourceTextMatchesFile?: boolean;
+} {
+  const filePath = filePathFromSourceRef(request.sourceRef);
+  if (!filePath) {
+    return { sourceHash: hashText(request.sourceText ?? request.sourceRef) };
+  }
+
+  try {
+    const fileText = readFileSync(filePath, 'utf8');
+    return {
+      sourceFilePath: filePath,
+      sourceHash: hashText(fileText),
+      sourceRefFileRead: true,
+      sourceTextMatchesFile: request.sourceText === undefined ? undefined : request.sourceText === fileText,
+    };
+  } catch {
+    return {
+      sourceFilePath: filePath,
+      sourceHash: hashText(request.sourceText ?? request.sourceRef),
+      sourceRefFileRead: false,
+    };
+  }
+}
+
+function sourceHashMatches(sourceHash: string, expectedSourceHash?: string): boolean | undefined {
+  return expectedSourceHash ? sourceHash === expectedSourceHash : undefined;
+}
+
+function commandBindsSourceRef(request: { command: string; args?: string[] }, sourceFilePath?: string): boolean | undefined {
+  if (!sourceFilePath) return undefined;
+  return [request.command, ...(request.args ?? [])].includes(sourceFilePath);
+}
+
+type OutputArtifactSnapshot = {
+  read: boolean;
+  hash?: string;
+  mtimeMs?: number;
+  error?: string;
+};
+
+function snapshotOutputArtifact(path: string): OutputArtifactSnapshot {
+  try {
+    const text = readFileSync(path, 'utf8');
+    const stat = statSync(path);
+    return {
+      read: true,
+      hash: hashText(text),
+      mtimeMs: stat.mtimeMs,
+    };
+  } catch (error) {
+    return {
+      read: false,
+      error: error instanceof Error ? error.message : String(error),
+    };
+  }
+}
+
+function captureOutputArtifact(
+  artifact: MechanicalProbeOutputArtifactRequest,
+  before: OutputArtifactSnapshot,
+): MechanicalProbeOutputArtifactReceipt {
+  const required = artifact.required ?? true;
+  try {
+    const text = readFileSync(artifact.path, 'utf8');
+    const stat = statSync(artifact.path);
+    const hash = hashText(text);
+    const producedDuringRun = !before.read
+      || before.hash !== hash
+      || (before.mtimeMs !== undefined && stat.mtimeMs > before.mtimeMs);
+    return {
+      id: artifact.id,
+      path: artifact.path,
+      required,
+      existedBefore: before.read,
+      read: true,
+      producedDuringRun,
+      hashBefore: before.hash,
+      hash,
+      mtimeMsBefore: before.mtimeMs,
+      mtimeMsAfter: stat.mtimeMs,
+      expectedHash: artifact.expectedHash,
+      hashMatchesExpected: artifact.expectedHash ? hash === artifact.expectedHash : undefined,
+      text,
+    };
+  } catch (error) {
+    return {
+      id: artifact.id,
+      path: artifact.path,
+      required,
+      existedBefore: before.read,
+      read: false,
+      producedDuringRun: false,
+      hashBefore: before.hash,
+      mtimeMsBefore: before.mtimeMs,
+      expectedHash: artifact.expectedHash,
+      error: error instanceof Error ? error.message : String(error),
+    };
+  }
+}
+
+function runExecutedNegativeControl(
+  control: MechanicalProbeExecutedNegativeControlRequest,
+  primaryOutputHash: string,
+  defaultTimeoutMs: number,
+): MechanicalProbeExecutedNegativeControlReceipt {
+  const controlRun = runProcess({
+    command: control.command,
+    args: control.args,
+    cwd: control.cwd,
+    env: control.env,
+    input: control.input,
+    timeoutMs: control.timeoutMs ?? defaultTimeoutMs,
+  });
+  const sourceEvidence = sourceEvidenceFrom(control);
+  const sourceHash = sourceEvidence.sourceHash;
+  const sourceRefBoundToCommand = commandBindsSourceRef(control, sourceEvidence.sourceFilePath);
+  const expectedOutputIncludes = control.expectedOutputIncludes ?? [];
+  const expectedOutputExcludes = control.expectedOutputExcludes ?? [];
+  const outputDiffersFromPrimary = controlRun.outputHash !== primaryOutputHash;
+  const includesOk = expectedOutputIncludes.every((fragment) => controlRun.stdout.includes(fragment));
+  const excludesOk = expectedOutputExcludes.every((fragment) => !controlRun.stdout.includes(fragment));
+  const sourceMatches = sourceHashMatches(sourceHash, control.expectedSourceHash);
+  const sourceOk = Boolean(sourceEvidence.sourceFilePath)
+    && sourceMatches !== false
+    && sourceEvidence.sourceRefFileRead !== false
+    && sourceEvidence.sourceTextMatchesFile !== false
+    && sourceRefBoundToCommand !== false;
+  const passed = controlRun.exitCode === 0
+    && !controlRun.timedOut
+    && outputDiffersFromPrimary
+    && includesOk
+    && excludesOk
+    && sourceOk;
+
+  return {
+    id: control.id,
+    command: control.command,
+    args: controlRun.args,
+    sourceRef: control.sourceRef,
+    sourceFilePath: sourceEvidence.sourceFilePath,
+    sourceHash,
+    expectedSourceHash: control.expectedSourceHash,
+    sourceHashMatchesExpected: sourceMatches,
+    sourceRefFileRead: sourceEvidence.sourceRefFileRead,
+    sourceTextMatchesFile: sourceEvidence.sourceTextMatchesFile,
+    sourceRefBoundToCommand,
+    inputHash: controlRun.inputHash,
+    outputHash: controlRun.outputHash,
+    stderrHash: controlRun.stderrHash,
+    exitCode: controlRun.exitCode,
+    signal: controlRun.signal,
+    timedOut: controlRun.timedOut,
+    durationMs: controlRun.durationMs,
+    stdout: controlRun.stdout,
+    stderr: controlRun.stderr,
+    expectedOutputIncludes,
+    expectedOutputExcludes,
+    outputDiffersFromPrimary,
+    passed,
+  };
+}
+
+export function runMechanicalProbeLane(request: MechanicalProbeRunRequest): MechanicalProbeRunReceipt {
+  const artifactRequests = request.outputArtifacts ?? [];
+  const artifactSnapshots = new Map(
+    artifactRequests.map((artifact) => [artifact.id, snapshotOutputArtifact(artifact.path)]),
+  );
+  const run = runProcess(request);
+  const sourceEvidence = sourceEvidenceFrom(request);
+  const sourceHash = sourceEvidence.sourceHash;
+  const sourceMatches = sourceHashMatches(sourceHash, request.expectedSourceHash);
+  const sourceRefBoundToCommand = commandBindsSourceRef(request, sourceEvidence.sourceFilePath);
+  const ranCleanly = run.exitCode === 0
+    && !run.timedOut
+    && Boolean(sourceEvidence.sourceFilePath)
+    && sourceMatches !== false
+    && sourceEvidence.sourceRefFileRead !== false
+    && sourceEvidence.sourceTextMatchesFile !== false
+    && sourceRefBoundToCommand !== false;
+  const executedNegativeControl = request.executedNegativeControl
+    ? runExecutedNegativeControl(request.executedNegativeControl, run.outputHash, request.timeoutMs)
+    : undefined;
+  const outputArtifacts = artifactRequests.map((artifact) => captureOutputArtifact(
+    artifact,
+    artifactSnapshots.get(artifact.id) ?? { read: false },
+  ));
+
+  return {
+    kind: 'MechanicalProbeRunReceipt',
+    claimCeiling: 'mechanical_probe_run_receipt_not_proof_authority',
+    engine: request.engine,
+    command: request.command,
+    args: run.args,
+    sourceRef: request.sourceRef,
+    sourceFilePath: sourceEvidence.sourceFilePath,
+    sourceHash,
+    expectedSourceHash: request.expectedSourceHash,
+    sourceHashMatchesExpected: sourceMatches,
+    sourceRefFileRead: sourceEvidence.sourceRefFileRead,
+    sourceTextMatchesFile: sourceEvidence.sourceTextMatchesFile,
+    sourceRefBoundToCommand,
+    inputHash: run.inputHash,
+    outputHash: run.outputHash,
+    stderrHash: run.stderrHash,
+    exitCode: run.exitCode,
+    signal: run.signal,
+    timedOut: run.timedOut,
+    durationMs: run.durationMs,
+    stdout: run.stdout,
+    stderr: run.stderr,
+    lane: {
+      role: request.role,
+      ran: ranCleanly,
+      sourceRef: request.sourceRef,
+      inputHash: run.inputHash,
+      outputHash: run.outputHash,
+      readsPeerResult: false,
+      alignedPackagesLoadBearing: request.alignedPackagesLoadBearing,
+      negativeControl: request.negativeControl,
+      gateEffect: request.gateEffect,
+    },
+    executedNegativeControl,
+    outputArtifacts,
+  };
+}
+
+export function validateMechanicalProbeRunReceipt(
+  receipt: MechanicalProbeRunReceipt,
+  options: MechanicalProbeRunValidationOptions = {},
+): MechanicalProbeRunValidation {
+  const findings: string[] = [];
+  void options;
+
+  if (receipt.kind !== 'MechanicalProbeRunReceipt') findings.push('kind must be MechanicalProbeRunReceipt');
+  if (receipt.claimCeiling !== 'mechanical_probe_run_receipt_not_proof_authority') {
+    findings.push('claimCeiling must be mechanical_probe_run_receipt_not_proof_authority');
+  }
+  if (receipt.expectedSourceHash && receipt.sourceHash !== receipt.expectedSourceHash) {
+    findings.push('sourceHash must match expectedSourceHash');
+  }
+  if (!receipt.sourceFilePath) findings.push('sourceRef must be a file ref');
+  if (receipt.sourceRefFileRead === false) findings.push('sourceRef file must be readable');
+  if (receipt.sourceTextMatchesFile === false) findings.push('sourceText must match sourceRef file bytes');
+  const sourceRefBoundToCommand = commandBindsSourceRef(receipt, receipt.sourceFilePath);
+  if (receipt.sourceFilePath && sourceRefBoundToCommand !== true) {
+    findings.push('sourceRef must be bound to executed command args');
+  }
+  if (receipt.sourceFilePath && receipt.sourceRefBoundToCommand !== sourceRefBoundToCommand) {
+    findings.push('sourceRefBoundToCommand must match command args');
+  }
+  if (receipt.exitCode !== 0) findings.push('process exitCode must be 0');
+  if (receipt.timedOut) findings.push('process must not time out');
+  if (receipt.outputHash !== hashText(receipt.stdout)) findings.push('outputHash must match stdout');
+  if (receipt.stderrHash !== hashText(receipt.stderr)) findings.push('stderrHash must match stderr');
+  if (receipt.lane.ran !== true) findings.push('lane.ran must be true');
+  if (receipt.lane.inputHash !== receipt.inputHash) findings.push('lane.inputHash must match receipt inputHash');
+  if (receipt.lane.outputHash !== receipt.outputHash) findings.push('lane.outputHash must match receipt outputHash');
+  if (receipt.lane.sourceRef !== receipt.sourceRef) findings.push('lane.sourceRef must match receipt sourceRef');
+  if (receipt.lane.readsPeerResult !== false) findings.push('lane.readsPeerResult must be false');
+  if (!receipt.lane.negativeControl) findings.push('lane.negativeControl is required');
+  if (!receipt.lane.alignedPackagesLoadBearing.length) findings.push('lane.alignedPackagesLoadBearing is required');
+  if (receipt.lane.gateEffect !== 'can_resolve_uncertain') findings.push('lane.gateEffect must be can_resolve_uncertain');
+
+  if (!receipt.executedNegativeControl) {
+    findings.push('executedNegativeControl is required');
+  }
+
+  if (receipt.executedNegativeControl) {
+    const control = receipt.executedNegativeControl;
+    const controlSourceRefBoundToCommand = commandBindsSourceRef(control, control.sourceFilePath);
+    const outputDiffersFromPrimary = control.outputHash !== receipt.outputHash;
+    const expectedIncludesOk = control.expectedOutputIncludes.every((fragment) => control.stdout.includes(fragment));
+    const expectedExcludesOk = control.expectedOutputExcludes.every((fragment) => !control.stdout.includes(fragment));
+    const expectedSourceHashOk = !control.expectedSourceHash || control.sourceHash === control.expectedSourceHash;
+    const sourceOk = Boolean(control.sourceFilePath)
+      && expectedSourceHashOk
+      && control.sourceRefFileRead !== false
+      && control.sourceTextMatchesFile !== false
+      && controlSourceRefBoundToCommand === true
+      && control.sourceRefBoundToCommand === controlSourceRefBoundToCommand;
+    const controlPassed = control.exitCode === 0
+      && !control.timedOut
+      && outputDiffersFromPrimary
+      && expectedIncludesOk
+      && expectedExcludesOk
+      && sourceOk;
+    if (control.expectedSourceHash && control.sourceHash !== control.expectedSourceHash) {
+      findings.push('executedNegativeControl.sourceHash must match expectedSourceHash');
+    }
+    if (!control.sourceFilePath) findings.push('executedNegativeControl.sourceRef must be a file ref');
+    if (control.sourceRefFileRead === false) findings.push('executedNegativeControl.sourceRef file must be readable');
+    if (control.sourceTextMatchesFile === false) {
+      findings.push('executedNegativeControl.sourceText must match sourceRef file bytes');
+    }
+    if (control.sourceFilePath && controlSourceRefBoundToCommand !== true) {
+      findings.push('executedNegativeControl.sourceRef must be bound to executed command args');
+    }
+    if (control.sourceFilePath && control.sourceRefBoundToCommand !== controlSourceRefBoundToCommand) {
+      findings.push('executedNegativeControl.sourceRefBoundToCommand must match command args');
+    }
+    if (control.exitCode !== 0) findings.push('executedNegativeControl exitCode must be 0');
+    if (control.timedOut) findings.push('executedNegativeControl must not time out');
+    if (control.outputHash !== hashText(control.stdout)) findings.push('executedNegativeControl.outputHash must match stdout');
+    if (control.stderrHash !== hashText(control.stderr)) findings.push('executedNegativeControl.stderrHash must match stderr');
+    if (control.outputDiffersFromPrimary !== outputDiffersFromPrimary) {
+      findings.push('executedNegativeControl.outputDiffersFromPrimary must match output hashes');
+    }
+    if (!outputDiffersFromPrimary) findings.push('executedNegativeControl output must differ from primary output');
+    if (!expectedIncludesOk) findings.push('executedNegativeControl stdout must include expected output fragments');
+    if (!expectedExcludesOk) findings.push('executedNegativeControl stdout must exclude expected output fragments');
+    if (control.passed !== controlPassed) findings.push('executedNegativeControl.passed must match recomputed status');
+    if (!controlPassed) findings.push('executedNegativeControl must pass');
+  }
+
+  for (const artifact of receipt.outputArtifacts) {
+    if (artifact.required && !artifact.read) findings.push(`outputArtifacts.${artifact.id} must be readable`);
+    if (artifact.required && !artifact.producedDuringRun) {
+      findings.push(`outputArtifacts.${artifact.id} must be produced during run`);
+    }
+    if (artifact.text && artifact.hash !== hashText(artifact.text)) {
+      findings.push(`outputArtifacts.${artifact.id} hash must match text`);
+    }
+    if (artifact.expectedHash && artifact.hash !== artifact.expectedHash) {
+      findings.push(`outputArtifacts.${artifact.id} hash must match expectedHash`);
+    }
+  }
+
+  return {
+    ok: findings.length === 0,
+    findings,
+  };
+}
