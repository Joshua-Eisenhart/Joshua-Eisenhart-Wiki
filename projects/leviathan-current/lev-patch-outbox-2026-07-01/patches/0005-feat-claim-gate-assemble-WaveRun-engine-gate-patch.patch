+    .join('/');
+  const title = frontmatter.name?.trim() || basename(join(path, '..'));
+  const haystack = lowerHaystack(id, text, frontmatter);
+  const targetDomain = targetDomainFor(haystack);
+  const executionProfile = executionProfileFor(id, haystack);
+  const stat = statSync(path);
+
+  return {
+    id,
+    title,
+    sourceRoot: rootDir,
+    sourcePath: path,
+    lifecycle: isArchived(rootDir, path) ? 'archived' : 'active',
+    sha256: sha256Text(text),
+    targetDomain,
+    authority: 'advisory_source_pack_only',
+    tags: frontmatter.tags.length ? frontmatter.tags : defaultTags(targetDomain, executionProfile),
+    executionProfile,
+    procedure: {
+      trigger: frontmatter.description || `Use ${id} when its source skill trigger matches the task.`,
+      readOrder: [relative(rootDir, path)],
+      requiredOutput: 'bounded receipt with source refs, authority boundary, and verification result',
+      promotionRule: 'proposal_only_until_lev_gate_and_loader_receipt',
+      minimalTest: 'source file re-read and sha256 verified by Lev source-pack intake',
+    },
+    declaredClaims: {
+      promotion_allowed: false,
+      formal_admission_allowed: false,
+    },
+    sourceMtimeMs: stat.mtimeMs,
+    verifiedAtMs: Math.max(Date.now(), stat.mtimeMs),
+  };
+}
+
+export function buildSkillSourcePackFromDirectory(options: SkillSourcePackBuildOptions): SkillSourcePack {
+  const skillFiles = walkSkillFiles(options.rootDir);
+  const records = skillFiles
+    .map((path) => recordFromSkillFile(options.rootDir, path))
+    .filter((record) => options.includeArchived || record.lifecycle === 'active')
+    .slice(0, options.maxRecords);
+
+  return {
+    schemaVersion: 'skill_source_pack_v1',
+    id: options.packId ?? `skill-source-pack:${options.rootDir}`,
+    claimCeiling: 'reference_source_inventory_not_admitted',
+    authority: 'advisory_source_pack_only',
+    records,
+  };
+}
+
+export function runSkillSourcePackIntake(options: SkillSourcePackBuildOptions): SkillSourcePackRunReceipt {
+  const totalSkillFilesFound = walkSkillFiles(options.rootDir).length;
+  const pack = buildSkillSourcePackFromDirectory(options);
+  const sourcePackReceipt = validateSkillSourcePack(pack, { maxRecords: options.maxRecords });
+  return {
+    kind: 'SkillSourcePackRunReceipt',
+    rootDir: options.rootDir,
+    packId: pack.id,
+    totalSkillFilesFound,
+    recordsBuilt: pack.records.length,
+    includedArchived: options.includeArchived === true,
+    sourcePackReceipt,
+  };
+}
+
+function roleForProfile(profile: ExecutionProfileFamily): string {
+  switch (profile) {
+    case 'hermes.moa.reference_synthesis':
+      return 'model mixture reference synthesis with advisory aggregator context';
+    case 'hermes.tribunal.independent_comparison':
+      return 'independent comparison that preserves dissent and convergence';
+    case 'hermes.subagent_development.plan_execute_review':
+      return 'bounded plan execute review worker loop';
+    case 'external.cli_coding_agent_worker':
+      return 'external terminal-native worker with controller verification';
+  }
+}
+
+function formalSkillFromRecord(record: SkillSourceRecord): FormalSkill | undefined {
+  if (!record.executionProfile) return undefined;
+  const profile = record.executionProfile;
+  return {
+    id: record.id.replace(/[^A-Za-z0-9_]+/g, '_'),
+    sourceRecordId: record.id,
+    name: record.title ?? record.id,
+    role: roleForProfile(profile),
+    authorityBoundary: 'advisory_until_controller_recomputes_receipts_and_lev_gates_admit',
+    capabilityRefs: [profile, ...(record.tags ?? [])],
+    mmmRefs: ['hermes-skill-source-pack', 'lev-execution-profile-boundary'],
+    sourceRefs: [`skill-source:${record.id}`],
+    toolRefs: ['graph.source-pack-intake', 'graph.formal-skill-set'],
+    inputContract: {
+      requiredFields: ['task', 'sourceRefs', 'claimCeiling'],
+    },
+    outputContract: {
+      kind: 'receipt',
+      graphMutation: 'proposal_only',
+      requiredFields: ['profile', 'evidenceRefs', 'findings', 'controllerVerification'],
+    },
+    gateContract: {
+      gateIds: ['source_hash', 'profile_schema', 'no_self_promotion', 'controller_recompute'],
+      failureCodes: ['source_missing', 'profile_conflation', 'self_promotion', 'unverified_worker_claim'],
+      promotionBoundary: 'cannot_promote_without_lev_loader_and_host_receipt',
+    },
+    requeuePolicy: {
+      routes: ['source-pack-repair', 'profile-narrowing', 'controller-verification'],
+      maxAttempts: 2,
+    },
+    receiptTarget: `receipts/${record.id}.json`,
+    executionProfile: profile,
+  };
+}
+
+export function createExecutionProfileFormalSkillSet(
+  pack: SkillSourcePack,
+  sourceReceipt: SourcePackAdmissionReceipt,
+): FormalSkillSet {
+  const admitted = new Set(sourceReceipt.ok ? sourceReceipt.admittedRecordIds : []);
+  const skills = pack.records
+    .filter((record) => admitted.has(record.id))
+    .map((record) => formalSkillFromRecord(record))
+    .filter((skill): skill is FormalSkill => Boolean(skill));
+
+  const byProfile = new Map<ExecutionProfileFamily, string[]>();
+  for (const skill of skills) {
+    if (!skill.executionProfile) continue;
+    byProfile.set(skill.executionProfile, [...(byProfile.get(skill.executionProfile) ?? []), skill.id]);
+  }
+
+  const bundles: FormalSkillBundle[] = [...byProfile.entries()].map(([profile, skillIds]) => ({
+    id: profile.replace(/[^A-Za-z0-9_]+/g, '_'),
+    kind: 'execution_profile',
+    purpose: roleForProfile(profile),
+    skillIds: skillIds.sort(),
+    executionProfile: profile,
+  }));
+
+  return {
+    schemaVersion: 'formal_skill_set_v1',
+    id: `${pack.id}:execution-profiles`,
+    claimCeiling: 'formal_skill_set_candidate_not_runtime_loaded',
+    authority: 'proposal_only_until_loader_receipt',
+    sourcePackId: pack.id,
+    skills: skills.sort((left, right) => left.id.localeCompare(right.id)),
+    bundles: bundles.sort((left, right) => left.id.localeCompare(right.id)),
+  };
+}
+
+export function runExecutionProfileFormalSkillSetIntake(
+  options: SkillSourcePackBuildOptions,
+): FormalExecutionSkillSetRunReceipt {
+  const base = runSkillSourcePackIntake(options);
+  const pack = buildSkillSourcePackFromDirectory(options);
+  if (!base.sourcePackReceipt.ok) return base;
+  const formalSkillSet = createExecutionProfileFormalSkillSet(pack, base.sourcePackReceipt);
+  const formalSkillSetReceipt = validateFormalSkillSet(formalSkillSet, pack, base.sourcePackReceipt);
+  return {
+    ...base,
+    formalSkillSet,
+    formalSkillSetReceipt,
+  };
+}
