+function graphPatchExecutionApplyPlanReceiptId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.apply_plan_receipt_id
+    ?? data.applyPlanReceiptId
+    ?? result.apply_plan_receipt_id
+    ?? result.applyPlanReceiptId;
+}
+
+function graphPatchExecutionGraphEventId(result: ClaimGateGraphPatchExecutionInput): string | undefined {
+  const data = graphPatchExecutionData(result);
+  return data.graph_event_id ?? data.graphEventId ?? result.graph_event_id ?? result.graphEventId;
+}
