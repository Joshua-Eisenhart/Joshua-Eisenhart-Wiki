+import { existsSync, mkdirSync, mkdtempSync, symlinkSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { dirname, join } from 'node:path';
+import { fileURLToPath } from 'node:url';
+
+import { describe, expect, it } from 'vitest';
+
+import {
+  resolveEngineCarrierForRuntime,
+  resolveLevOwnedSimEngineCarrierFromModuleDir,
+} from './real-three-engine-envelope.js';
+
+const repoRoot = join(dirname(fileURLToPath(import.meta.url)), '..', '..', '..', '..');
+
+describe('real three-engine carrier provenance', () => {
+  it('resolves built dist runtime back to the Lev-owned source carrier scripts', () => {
+    const distProofDir = join(repoRoot, 'core', 'orchestration', 'dist', 'proof');
+    const carrier = resolveLevOwnedSimEngineCarrierFromModuleDir(distProofDir, 'graph-substrate');
+
+    expect(carrier).toBe(join(repoRoot, 'core', 'orchestration', 'src', 'probes', 'lev-sim-engine-carrier', 'graph-substrate'));
+    expect(existsSync(join(carrier, 'graph_substrate_digest_julia.jl'))).toBe(true);
+    expect(existsSync(join(carrier, 'graph_substrate_digest_jax.py'))).toBe(true);
+    expect(existsSync(join(carrier, 'graph_substrate_digest_pytorch.py'))).toBe(true);
+  });
+
+  it('rejects env carrier overrides that copy carrier files into a clean external path', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-carrier-copy-launder-'));
+    const levOwnedDefault = join(root, 'lev-owned-runtime-carrier');
+    const cleanCopiedCarrier = join(root, 'clean-copied-carrier');
+    mkdirSync(levOwnedDefault, { recursive: true });
+    mkdirSync(cleanCopiedCarrier, { recursive: true });
+
+    const previous = process.env.LEV_SIM_ENGINE_CARRIER;
+    process.env.LEV_SIM_ENGINE_CARRIER = cleanCopiedCarrier;
+    try {
+      expect(() => resolveEngineCarrierForRuntime('LEV_SIM_ENGINE_CARRIER', levOwnedDefault))
+        .toThrow(/outside the Lev-owned runtime carrier root/);
+    } finally {
+      if (previous === undefined) {
+        delete process.env.LEV_SIM_ENGINE_CARRIER;
+      } else {
+        process.env.LEV_SIM_ENGINE_CARRIER = previous;
+      }
+    }
+  });
+
+  it('allows env carrier overrides inside the Lev-owned default carrier root', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-carrier-owned-override-'));
+    const levOwnedDefault = join(root, 'lev-owned-runtime-carrier');
+    const ownedOverride = join(levOwnedDefault, 'variant');
+    mkdirSync(ownedOverride, { recursive: true });
+
+    const previous = process.env.LEV_SIM_ENGINE_CARRIER;
+    process.env.LEV_SIM_ENGINE_CARRIER = ownedOverride;
+    try {
+      expect(resolveEngineCarrierForRuntime('LEV_SIM_ENGINE_CARRIER', levOwnedDefault)).toBe(ownedOverride);
+    } finally {
+      if (previous === undefined) {
+        delete process.env.LEV_SIM_ENGINE_CARRIER;
+      } else {
+        process.env.LEV_SIM_ENGINE_CARRIER = previous;
+      }
+    }
+  });
+
+  it('rejects env carrier overrides whose symlink target is reference/provenance material', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-carrier-provenance-'));
+    const referenceCarrier = join(root, 'Codex-Ratchet', 'system_v5');
+    const allowedLookingCarrier = join(root, 'lev-owned-looking-carrier');
+    mkdirSync(referenceCarrier, { recursive: true });
+    symlinkSync(referenceCarrier, allowedLookingCarrier, 'dir');
+
+    const previous = process.env.LEV_SIM_ENGINE_CARRIER;
+    process.env.LEV_SIM_ENGINE_CARRIER = allowedLookingCarrier;
+    try {
+      expect(() => resolveEngineCarrierForRuntime('LEV_SIM_ENGINE_CARRIER', join(root, 'lev-default')))
+        .toThrow(/reference\/provenance material/);
+    } finally {
+      if (previous === undefined) {
+        delete process.env.LEV_SIM_ENGINE_CARRIER;
+      } else {
+        process.env.LEV_SIM_ENGINE_CARRIER = previous;
+      }
+    }
+  });
+
+  it('rejects env carrier overrides with case-folded reference path fragments', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-carrier-casefold-'));
+    const referenceCarrier = join(root, 'codex-ratchet', 'system_v5');
+    mkdirSync(referenceCarrier, { recursive: true });
+
+    const previous = process.env.LEV_SIM_ENGINE_CARRIER;
+    process.env.LEV_SIM_ENGINE_CARRIER = referenceCarrier;
+    try {
+      expect(() => resolveEngineCarrierForRuntime('LEV_SIM_ENGINE_CARRIER', join(root, 'lev-default')))
+        .toThrow(/reference\/provenance material/);
+    } finally {
+      if (previous === undefined) {
+        delete process.env.LEV_SIM_ENGINE_CARRIER;
+      } else {
+        process.env.LEV_SIM_ENGINE_CARRIER = previous;
+      }
+    }
+  });
+});
