+async function applyGraphPatchThroughHost(
+  applyPlan: ClaimGateGraphPatchApplyPlan,
+): Promise<ClaimGateGraphPatchBridgeResult> {
+  const graphHandlers = await import('@lev-os/graph/handlers') as unknown as GraphPatchHandlerModule;
+  const applyPlanAuthority = graphHandlers.issueClaimGateGraphApplyPlanAuthority({
+    applyPlanReceiptId: applyPlan.receipt.id,
+    operations: applyPlan.graphOperations,
+  });
+  const graphResult = applyPlan.ok
+    ? await graphHandlers.patch([
+        '--operations',
+        JSON.stringify(applyPlan.graphOperations),
+        '--apply-plan-receipt-id',
+        applyPlan.receipt.id,
+        '--apply-plan-authority',
+        JSON.stringify(applyPlanAuthority),
+      ]) as ClaimGateGraphPatchExecutionInput
+    : {
+        success: false,
+        status: 'skipped',
+        applied: 0,
+        apply_plan_receipt_id: applyPlan.receipt.id,
+        errors: ['apply_plan_blocked_before_graph_handler'],
+      };
+
+  const execution = recordHostClaimGateGraphPatchExecution(applyPlan, graphResult);
+
+  return {
+    kind: 'ClaimGateGraphPatchBridgeResult',
+    status: execution.status,
+    ok: execution.ok,
+    applyPlan,
+    graphResult,
+    execution,
+  };
+}
