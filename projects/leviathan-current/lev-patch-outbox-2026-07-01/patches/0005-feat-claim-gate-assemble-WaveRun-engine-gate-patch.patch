+import { createHash } from 'node:crypto';
+import { readFile } from 'node:fs/promises';
+import { join } from 'node:path';
+
+import type {
+  ClaimGateContextLoadResolver,
+  ClaimGateLoadedContextRefType,
+} from './claim-gate-wavegraph-slice.js';
+
+export interface ClaimGateContextLoaderRegistryCandidate {
+  sourceRef: string;
+  absolutePath?: string;
+  rootPath?: string;
+  relativePath?: string;
+  receiptRef?: string;
+}
+
+export interface ClaimGateContextLoaderRegistryEntry {
+  refType: ClaimGateLoadedContextRefType;
+  ref: string;
+  candidates: ClaimGateContextLoaderRegistryCandidate[];
+}
+
+export interface ClaimGateContextLoaderRegistryRoot {
+  rootPath: string;
+  sourceRefPrefix: string;
+}
+
+export interface ClaimGateCanonicalContextLoadRegistryOptions {
+  registryVersion: string;
+  repoRoot: ClaimGateContextLoaderRegistryRoot;
+  skillRoots?: ClaimGateContextLoaderRegistryRoot[];
+  sourceRoots?: ClaimGateContextLoaderRegistryRoot[];
+}
+
+export type ClaimGateContextLoaderReadTextFile = (
+  absolutePath: string,
+) => Promise<string | undefined>;
+
+export interface ClaimGateFilesystemContextLoadResolverOptions {
+  registry: ClaimGateContextLoaderRegistryEntry[];
+  readTextFile: ClaimGateContextLoaderReadTextFile;
+}
+
+export interface ClaimGateNodeFilesystemContextLoadResolverOptions {
+  registry: ClaimGateContextLoaderRegistryEntry[];
+}
+
+export type ClaimGateContextLoadRegistryInspectionStatus = 'available' | 'missing';
+
+export interface ClaimGateContextLoadRegistryCandidateInspection {
+  sourceRef: string;
+  status: ClaimGateContextLoadRegistryInspectionStatus;
+  absolutePath?: string;
+  contentHash?: string;
+  receiptRef?: string;
+}
+
+export interface ClaimGateContextLoadRegistryEntryInspection {
+  refType: ClaimGateLoadedContextRefType;
+  ref: string;
+  status: ClaimGateContextLoadRegistryInspectionStatus;
+  candidateCount: number;
+  candidates: ClaimGateContextLoadRegistryCandidateInspection[];
+  availableSourceRef?: string;
+  availableContentHash?: string;
+}
+
+export interface ClaimGateContextLoadRegistryInspectionReceipt {
+  kind: 'ClaimGateContextLoadRegistryInspectionReceipt';
+  registryVersion: string;
+  loaderRef: string;
+  inspectedEntryCount: number;
+  availableRefCount: number;
+  missingRequiredRefs: string[];
+  entries: ClaimGateContextLoadRegistryEntryInspection[];
+  claimCeiling: 'context_registry_inspection_receipt_not_loaded_context';
+}
+
+export interface ClaimGateUnavailableContextLoadReceipt {
+  kind: 'ClaimGateUnavailableContextLoadReceipt';
+  refType: ClaimGateLoadedContextRefType;
+  ref: string;
+  receiptRef: string;
+  loaderRef: string;
+  registryVersion: string;
+  reason: 'configured_source_missing';
+  candidateSourceRefs: string[];
+  missingCandidateCount: number;
+  claimCeiling: 'unavailable_context_receipt_not_loaded_context';
+  retryPolicy: 'requires_explicit_registry_root_or_source_file';
+}
+
+export interface InspectClaimGateContextLoadRegistryOptions {
+  registryVersion: string;
+  loaderRef: string;
+  registry: ClaimGateContextLoaderRegistryEntry[];
+  readTextFile: ClaimGateContextLoaderReadTextFile;
+}
+
+function sha256Text(content: string): string {
+  return `sha256:${createHash('sha256').update(content).digest('hex')}`;
+}
+
+function safeReceiptFragment(value: string): string {
+  return value.replace(/[^a-zA-Z0-9._-]+/g, '-').replace(/^-+|-+$/g, '').slice(0, 120) || 'context';
+}
+
+function candidateAbsolutePath(candidate: ClaimGateContextLoaderRegistryCandidate): string | undefined {
+  if (candidate.absolutePath) return candidate.absolutePath;
+  if (candidate.rootPath && candidate.relativePath) return join(candidate.rootPath, candidate.relativePath);
+  return undefined;
+}
+
+function versionedSourceRef(
+  root: ClaimGateContextLoaderRegistryRoot,
+  registryVersion: string,
+  relativePath: string,
+): string {
+  return `${root.sourceRefPrefix}@${registryVersion}:${relativePath}`;
+}
+
+function candidatesFromRoots(
+  roots: ClaimGateContextLoaderRegistryRoot[],
+  registryVersion: string,
+  relativePaths: string[],
+): ClaimGateContextLoaderRegistryCandidate[] {
+  return roots.flatMap((root) => relativePaths.map((relativePath) => ({
+    rootPath: root.rootPath,
+    relativePath,
+    sourceRef: versionedSourceRef(root, registryVersion, relativePath),
+  })));
+}
+
+export function createClaimGateCanonicalContextLoadRegistry(
+  options: ClaimGateCanonicalContextLoadRegistryOptions,
+): ClaimGateContextLoaderRegistryEntry[] {
+  const repoRoots = [options.repoRoot];
+  const skillRoots = options.skillRoots ?? [];
+  const sourceRoots = options.sourceRoots ?? [];
+
+  return [
+    {
+      refType: 'mmm',
+      ref: 'mmm:dna/graph',
+      candidates: candidatesFromRoots(repoRoots, options.registryVersion, [
+        'dna/graph.yaml',
+      ]),
+    },
+    {
+      refType: 'skill',
+      ref: 'skill:premortem',
+      candidates: candidatesFromRoots(skillRoots, options.registryVersion, [
+        'premortem/SKILL.md',
+        'skills/premortem/SKILL.md',
+      ]),
+    },
+    {
+      refType: 'skill',
+      ref: 'skill:autoresearch',
+      candidates: candidatesFromRoots(skillRoots, options.registryVersion, [
+        'codex-autoresearch/SKILL.md',
+        'autoresearch/SKILL.md',
+        'skills/codex-autoresearch/SKILL.md',
+        'skills/autoresearch/SKILL.md',
+      ]),
+    },
+    {
+      refType: 'source',
+      ref: 'source:claim-gate-v58',
+      candidates: candidatesFromRoots(sourceRoots, options.registryVersion, [
+        'claim-gate-v58.md',
+        'ClaimGate_CoreLevOS_COMPLETE_SINGLE_ZIP_codex_v58_live_swarm_honesty_delta/AUDIT_CODEX_V58_LIVE_SWARM_HONESTY_DELTA.md',
+        'ClaimGate_CoreLevOS_COMPLETE_SINGLE_ZIP_codex_v58_live_swarm_honesty_delta/SOURCE_TO_COUNCIL_RUNTIME_MAP.md',
+      ]),
+    },
+    {
+      refType: 'source',
+      ref: 'source:lev-dna',
+      candidates: candidatesFromRoots(repoRoots, options.registryVersion, [
+        'docs/design/design-codex-ratchet-claim-gate-bridge.md',
+        'dna/graph.yaml',
+      ]),
+    },
+  ];
+}
+
+export async function inspectClaimGateContextLoadRegistry(
+  options: InspectClaimGateContextLoadRegistryOptions,
+): Promise<ClaimGateContextLoadRegistryInspectionReceipt> {
+  const entries: ClaimGateContextLoadRegistryEntryInspection[] = [];
+
+  for (const entry of options.registry) {
+    const candidates: ClaimGateContextLoadRegistryCandidateInspection[] = [];
+    let availableSourceRef: string | undefined;
+    let availableContentHash: string | undefined;
+
+    for (const candidate of entry.candidates) {
+      const absolutePath = candidateAbsolutePath(candidate);
+      const content = absolutePath ? await options.readTextFile(absolutePath) : undefined;
+      const contentHash = content === undefined ? undefined : sha256Text(content);
+      const status: ClaimGateContextLoadRegistryInspectionStatus = content === undefined ? 'missing' : 'available';
+      candidates.push({
+        sourceRef: candidate.sourceRef,
+        status,
+        ...(absolutePath ? { absolutePath } : {}),
+        ...(contentHash ? { contentHash } : {}),
+        ...(candidate.receiptRef ? { receiptRef: candidate.receiptRef } : {}),
+      });
+
+      if (!availableSourceRef && status === 'available') {
+        availableSourceRef = candidate.sourceRef;
+        availableContentHash = contentHash;
+      }
+    }
+
+    entries.push({
+      refType: entry.refType,
+      ref: entry.ref,
+      status: availableSourceRef ? 'available' : 'missing',
+      candidateCount: entry.candidates.length,
+      candidates,
+      ...(availableSourceRef ? { availableSourceRef } : {}),
+      ...(availableContentHash ? { availableContentHash } : {}),
+    });
+  }
+
+  const missingRequiredRefs = entries
+    .filter((entry) => entry.status === 'missing')
+    .map((entry) => entry.ref);
+
+  return {
+    kind: 'ClaimGateContextLoadRegistryInspectionReceipt',
+    registryVersion: options.registryVersion,
+    loaderRef: options.loaderRef,
+    inspectedEntryCount: entries.length,
+    availableRefCount: entries.length - missingRequiredRefs.length,
+    missingRequiredRefs,
+    entries,
+    claimCeiling: 'context_registry_inspection_receipt_not_loaded_context',
+  };
+}
+
+export function createClaimGateUnavailableContextLoadReceipts(
+  inspection: ClaimGateContextLoadRegistryInspectionReceipt,
+): ClaimGateUnavailableContextLoadReceipt[] {
+  return inspection.entries
+    .filter((entry) => entry.status === 'missing')
+    .map((entry) => ({
+      kind: 'ClaimGateUnavailableContextLoadReceipt',
+      refType: entry.refType,
+      ref: entry.ref,
+      receiptRef: `receipt:rcpt-context-unavailable-${safeReceiptFragment(entry.ref)}`,
+      loaderRef: inspection.loaderRef,
+      registryVersion: inspection.registryVersion,
+      reason: 'configured_source_missing',
+      candidateSourceRefs: entry.candidates.map((candidate) => candidate.sourceRef),
+      missingCandidateCount: entry.candidates.length,
+      claimCeiling: 'unavailable_context_receipt_not_loaded_context',
+      retryPolicy: 'requires_explicit_registry_root_or_source_file',
+    }));
+}
+
+export function createClaimGateFilesystemContextLoadResolver(
+  options: ClaimGateFilesystemContextLoadResolverOptions,
+): ClaimGateContextLoadResolver {
+  return async ({ refType, ref }) => {
+    const entry = options.registry.find((candidate) => (
+      candidate.refType === refType && candidate.ref === ref
+    ));
+    if (!entry) return undefined;
+
+    for (const candidate of entry.candidates) {
+      const absolutePath = candidateAbsolutePath(candidate);
+      if (!absolutePath) continue;
+      const content = await options.readTextFile(absolutePath);
+      if (content !== undefined) {
+        return {
+          content,
+          sourceRef: candidate.sourceRef,
+          ...(candidate.receiptRef ? { receiptRef: candidate.receiptRef } : {}),
+        };
+      }
+    }
+
+    return undefined;
+  };
+}
+
+export function createClaimGateNodeFilesystemContextLoadResolver(
+  options: ClaimGateNodeFilesystemContextLoadResolverOptions,
+): ClaimGateContextLoadResolver {
+  return createClaimGateFilesystemContextLoadResolver({
+    registry: options.registry,
+    readTextFile: async (absolutePath) => {
+      try {
+        return await readFile(absolutePath, 'utf8');
+      } catch (error) {
+        if (
+          typeof error === 'object'
+          && error !== null
+          && 'code' in error
+          && (error as { code?: unknown }).code === 'ENOENT'
+        ) {
+          return undefined;
+        }
+        throw error;
+      }
+    },
+  });
+}
