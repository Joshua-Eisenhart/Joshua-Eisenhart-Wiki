+function validateWorkflowSpec(spec: ClaimGateWavegraphWorkflowSpec): void {
+  const violations: ClaimGateWavegraphSliceInputViolation[] = [];
+  if (!isRecord(spec)) {
+    throw new ClaimGateWavegraphSliceInputError([{
+      path: '$',
+      code: 'expected_object',
+      message: 'ClaimGate wavegraph workflow spec must be an object.',
+    }]);
+  }
+  if (spec.kind !== 'ClaimGateWavegraphWorkflowSpec') {
+    addViolation(violations, 'kind', 'invalid_kind', 'kind must be ClaimGateWavegraphWorkflowSpec.');
+  }
+  validateString(spec.workflowId, 'workflowId', violations, MAX_ID_BYTES);
+
+  const graph = spec.executionContract;
+  if (!isRecord(graph)) {
+    addViolation(violations, 'executionContract', 'missing_execution_contract', 'A FlowMind/GraphDocument execution contract is required.');
+  } else {
+    validateString(graph.name, 'executionContract.name', violations, MAX_ID_BYTES);
+    validateString(graph.entry, 'executionContract.entry', violations, MAX_ID_BYTES);
+    if (!isRecord(graph.nodes) || Object.keys(graph.nodes).length === 0) {
+      addViolation(violations, 'executionContract.nodes', 'missing_execution_contract_nodes', 'executionContract.nodes must be a non-empty node map.');
+    }
+  }
+
+  if (!isRecord(spec.nodeRefs)) {
+    addViolation(violations, 'nodeRefs', 'missing_workflow_node_refs', 'Workflow node refs are required.');
+  } else {
+    for (const field of ['modelLaneGate', 'contextLoadGate', 'claimGateLoop', 'receiptBundle'] as const) {
+      if (validateString(spec.nodeRefs[field], `nodeRefs.${field}`, violations, MAX_ID_BYTES) && isRecord(graph?.nodes) && !graph.nodes[spec.nodeRefs[field]]) {
+        addViolation(
+          violations,
+          `nodeRefs.${field}`,
+          'missing_execution_contract_node_ref',
+          `nodeRefs.${field} must reference a node in executionContract.nodes.`,
+        );
+      }
+    }
+    if (isRecord(graph) && typeof graph.entry === 'string' && spec.nodeRefs.modelLaneGate && graph.entry !== spec.nodeRefs.modelLaneGate) {
+      addViolation(
+        violations,
+        'executionContract.entry',
+        'workflow_entry_must_be_model_lane_gate',
+        'The workflow must enter through the Gate 0A model-lane formation node.',
+      );
+    }
+  }
+
+  if (isRecord(graph) && typeof graph.name === 'string' && typeof graph.entry === 'string' && isRecord(graph.nodes)) {
+    const topology = validateExecutionContractTopology(graph as unknown as GraphDocument);
+    if (!topology.valid) {
+      addViolation(
+        violations,
+        'executionContract',
+        'invalid_execution_contract_topology',
+        `Execution contract topology failed validation: ${topology.errors.join('; ')}`,
+      );
+    }
+  }
+
+  if (spec.slice !== undefined) {
+    addViolation(
+      violations,
+      'slice',
+      'ambiguous_workflow_slice_source',
+      'Workflow specs must compile model lanes, loaded context, and waves from workflow fields instead of accepting a prebuilt opaque slice.',
+    );
+  }
+  if (spec.loadedContextReceipts !== undefined) {
+    addViolation(
+      violations,
+      'loadedContextReceipts',
+      'ambiguous_workflow_loaded_context_receipts',
+      'Workflow specs must compile loaded context receipts from contextLoadPlan instead of accepting pre-minted loaded context receipts.',
+    );
+  }
+  if (spec.gateLoopReopenDecisions !== undefined) {
+    addViolation(
+      violations,
+      'gateLoopReopenDecisions',
+      'ambiguous_workflow_gate_loop_reopen_decisions',
+      'Workflow specs must evaluate Gate 3 reopen requests instead of accepting pre-minted reopen decisions.',
+    );
+  }
+  if (spec.gateLoopStateReceipt !== undefined) {
+    addViolation(
+      violations,
+      'gateLoopStateReceipt',
+      'ambiguous_workflow_gate_loop_state_receipt',
+      'Workflow specs must compile Gate 3 reopen state from explicit gate records instead of accepting a pre-minted reopen state receipt.',
+    );
+  }
+
+  if (violations.length > 0) {
+    throw new ClaimGateWavegraphSliceInputError(violations);
+  }
+}
+
+function validateGateLoopReopenPlan(input: ClaimGateWavegraphSliceInput, violations: ClaimGateWavegraphSliceInputViolation[]): void {
+  if (input.gateLoopReopenRequests !== undefined && !Array.isArray(input.gateLoopReopenRequests)) {
+    addViolation(
+      violations,
+      'gateLoopReopenRequests',
+      'invalid_gate_loop_reopen_requests',
+      'gateLoopReopenRequests must be an array when provided.',
+    );
+    return;
+  }
+
+  if ((input.gateLoopReopenRequests?.length ?? 0) > 0 && !isRecord(input.gateLoopState)) {
+    addViolation(
+      violations,
+      'gateLoopState',
+      'missing_gate_loop_state_for_reopen_requests',
+      'Gate 3 reopen requests require explicit gate loop state records to evaluate.',
+    );
+    return;
+  }
+
+  if (input.gateLoopState !== undefined) {
+    if (!isRecord(input.gateLoopState)) {
+      addViolation(violations, 'gateLoopState', 'invalid_gate_loop_state', 'gateLoopState must be an object when provided.');
+    } else {
+      if (input.gateLoopState.kind !== 'ClaimGateLoopState') {
+        addViolation(violations, 'gateLoopState.kind', 'invalid_gate_loop_state_kind', 'gateLoopState.kind must be ClaimGateLoopState.');
+      }
+      validateString(input.gateLoopState.sessionId, 'gateLoopState.sessionId', violations, MAX_ID_BYTES);
+      if (!Array.isArray(input.gateLoopState.gates) || input.gateLoopState.gates.length === 0) {
+        addViolation(violations, 'gateLoopState.gates', 'missing_gate_loop_state_gates', 'gateLoopState.gates must be a non-empty array.');
+      }
+    }
+  }
+
+  for (const [index, request] of (input.gateLoopReopenRequests ?? []).entries()) {
+    const path = `gateLoopReopenRequests[${index}]`;
+    if (!isRecord(request)) {
+      addViolation(violations, path, 'invalid_gate_loop_reopen_request', 'Gate loop reopen request must be an object.');
+      continue;
+    }
+    validateString(request.requestId, `${path}.requestId`, violations, MAX_ID_BYTES);
+    validateString(request.targetGateId, `${path}.targetGateId`, violations, MAX_ID_BYTES);
+    validateString(request.targetReceiptId, `${path}.targetReceiptId`, violations, MAX_TEXT_BYTES);
+    validateString(request.reopenAuthorityGateId, `${path}.reopenAuthorityGateId`, violations, MAX_ID_BYTES);
+    if (!Number.isInteger(request.tickBudget) || request.tickBudget <= 0) {
+      addViolation(violations, `${path}.tickBudget`, 'invalid_gate_loop_reopen_tick_budget', 'Gate loop reopen tickBudget must be a positive integer.');
