+function validateClaimGateWavegraphSliceInput(input: ClaimGateWavegraphSliceInput): void {
+  const violations: ClaimGateWavegraphSliceInputViolation[] = [];
+  if (!isRecord(input)) {
+    throw new ClaimGateWavegraphSliceInputError([{
+      path: '$',
+      code: 'expected_object',
+      message: 'ClaimGate wavegraph slice input must be an object.',
