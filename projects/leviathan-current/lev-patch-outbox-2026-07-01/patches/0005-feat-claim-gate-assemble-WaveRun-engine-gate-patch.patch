+import { execFileSync } from 'node:child_process';
+import { createHmac } from 'node:crypto';
+import { mkdtempSync, readFileSync, rmSync, statSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+import { afterEach, describe, expect, it } from 'vitest';
+
+import {
+  deriveHostTrustDomainKey,
+  hostTrustDomainMac,
+  hostTrustRootSecretPath,
+  loadOrCreateHostTrustRootSecret,
+  resetHostTrustRootSecretCacheForTests,
+  timingSafeMacEqual,
+} from './host-trust-secret.js';
+
+function freshRoot(): string {
+  return mkdtempSync(join(tmpdir(), 'lev-host-trust-secret-'));
+}
+
+afterEach(() => {
+  resetHostTrustRootSecretCacheForTests();
+});
+
+describe('host-trust cross-process root secret', () => {
+  it('creates a 32-byte 0600 secret file on first use', () => {
+    const root = freshRoot();
+    try {
+      const secret = loadOrCreateHostTrustRootSecret(root);
+      expect(secret).toHaveLength(32);
+      const file = hostTrustRootSecretPath(root);
+      const onDisk = readFileSync(file);
+      expect(onDisk.equals(secret)).toBe(true);
+      // 0600: owner read/write only.
+      expect(statSync(file).mode & 0o777).toBe(0o600);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('returns the same secret within a process (cache) and after a simulated process restart (file)', () => {
+    const root = freshRoot();
+    try {
+      const first = loadOrCreateHostTrustRootSecret(root);
+      const sameProcess = loadOrCreateHostTrustRootSecret(root);
+      expect(sameProcess.equals(first)).toBe(true);
+
+      // Simulate a fresh process: drop the in-memory cache, re-load from the file.
+      resetHostTrustRootSecretCacheForTests();
+      const afterRestart = loadOrCreateHostTrustRootSecret(root);
+      expect(afterRestart.equals(first)).toBe(true);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('LOAD-BEARING: a MAC minted in one process validates after a simulated process boundary, and does NOT validate under a different root', () => {
+    const root = freshRoot();
+    const otherRoot = freshRoot();
+    try {
+      const domain = 'host-graph-event-trust';
+      const payload = JSON.stringify({ ref: 'graph_event:ge-abc', nonce: 'deadbeef' });
+
+      // "Process 1" mints the MAC.
+      const mac = hostTrustDomainMac(root, domain, payload);
+
+      // "Process 2": empty cache, re-load secret from the file, re-verify.
+      resetHostTrustRootSecretCacheForTests();
+      const reVerify = hostTrustDomainMac(root, domain, payload);
+      expect(timingSafeMacEqual(mac, reVerify)).toBe(true);
+
+      // Control: a DIFFERENT project root (different persisted secret) must NOT validate.
+      resetHostTrustRootSecretCacheForTests();
+      const foreign = hostTrustDomainMac(otherRoot, domain, payload);
+      expect(timingSafeMacEqual(mac, foreign)).toBe(false);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+      rmSync(otherRoot, { recursive: true, force: true });
+    }
+  });
+
+  it('REAL cross-process: a separate OS node process reproduces the MAC from the same secret file', () => {
+    const root = freshRoot();
+    try {
+      const domain = 'wave-run-host-consume';
+      const payload = JSON.stringify({ receiptRef: 'receipt:rcpt-xyz', issuedAt: '2026-06-30T00:00:00.000Z' });
+      const parentMac = hostTrustDomainMac(root, domain, payload);
+      const secretPath = hostTrustRootSecretPath(root);
+
+      // Child reimplements the derivation from the file alone (no TS import), proving
+      // the persisted file is a sufficient shared root across real OS processes.
+      const childScript = [
+        "const { createHmac } = require('node:crypto');",
+        "const { readFileSync } = require('node:fs');",
+        `const rootSecret = readFileSync(${JSON.stringify(secretPath)});`,
+        `const domainKey = createHmac('sha256', rootSecret).update('lev-host-trust-domain:' + ${JSON.stringify(domain)}).digest();`,
+        `const mac = 'hmac-sha256:' + createHmac('sha256', domainKey).update(${JSON.stringify(payload)}).digest('hex');`,
+        'process.stdout.write(mac);',
+      ].join('\n');
+
+      const childMac = execFileSync(process.execPath, ['-e', childScript]).toString();
+      expect(childMac).toBe(parentMac);
+      expect(timingSafeMacEqual(childMac, parentMac)).toBe(true);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('derives independent keys per domain (domain separation)', () => {
+    const root = freshRoot();
+    try {
+      const a = deriveHostTrustDomainKey(root, 'host-trust');
+      const aAgain = deriveHostTrustDomainKey(root, 'host-trust');
+      const b = deriveHostTrustDomainKey(root, 'host-witness');
+      expect(a.equals(aAgain)).toBe(true);
+      expect(a.equals(b)).toBe(false);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('refuses to derive keys from a malformed (wrong-length) secret file', () => {
+    const root = freshRoot();
+    try {
+      const file = hostTrustRootSecretPath(root);
+      // mkdir the parent then write a too-short secret.
+      loadOrCreateHostTrustRootSecret(root);
+      resetHostTrustRootSecretCacheForTests();
+      writeFileSync(file, Buffer.alloc(16, 7));
+      expect(() => loadOrCreateHostTrustRootSecret(root)).toThrow(/expected 32/);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('an empty domain label is rejected', () => {
+    const root = freshRoot();
+    try {
+      expect(() => deriveHostTrustDomainKey(root, '')).toThrow(/non-empty domain/);
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+});
