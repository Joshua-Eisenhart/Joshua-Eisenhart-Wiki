+      sourceText: 'console.log("clean")',
+      expectedSourceHash: sha256Text('console.log("clean")'),
+      input: { fixture: 'wrong-source' },
+      timeoutMs: 10_000,
+      alignedPackagesLoadBearing: ['Base'],
+      negativeControl: 'source_ref_must_be_executed',
