+function testStableStringify(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value);
+  if (Array.isArray(value)) return `[${value.map(testStableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${testStableStringify(record[key])}`).join(',')}}`;
+}
+
+function testSha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(testStableStringify(value)).digest('hex')}`;
