+
+function validateTopology(
+  input: ClaimGateWavegraphSliceInput,
+  loadedRefs: Set<string>,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): void {
+  if (!Array.isArray(input.waves) || input.waves.length === 0) {
+    addViolation(violations, 'waves', 'missing_waves', 'A wavegraph slice requires waves.');
+    return;
+  }
+  if (input.waves.length < 2) {
+    addViolation(violations, 'waves', 'missing_two_wave_fixture', 'The first executable slice must contain at least two waves.');
+  }
+
+  input.waves.forEach((wave, waveIndex) => {
+    const wavePath = `waves[${waveIndex}]`;
+    if (!isRecord(wave)) {
+      addViolation(violations, wavePath, 'expected_wave_object', `${wavePath} must be an object.`);
+      return;
+    }
+    validateString(wave.phase, `${wavePath}.phase`, violations, MAX_TEXT_BYTES);
+    if (!Number.isInteger(wave.wave) || wave.wave <= 0) {
+      addViolation(violations, `${wavePath}.wave`, 'invalid_wave_number', `${wavePath}.wave must be a positive integer.`);
+    }
+
+    const waveMemberIds = new Set<string>();
+    if (!Array.isArray(wave.councils) || wave.councils.length === 0) {
+      addViolation(violations, `${wavePath}.councils`, 'missing_wave_councils', 'A wave must contain councils; raw claim fanout is not a wave.');
+    } else {
+      wave.councils.forEach((council, councilIndex) => {
+        const councilPath = `${wavePath}.councils[${councilIndex}]`;
+        if (!isRecord(council)) {
+          addViolation(violations, councilPath, 'expected_council_object', `${councilPath} must be an object.`);
+          return;
+        }
+        validateString(council.councilId, `${councilPath}.councilId`, violations, MAX_ID_BYTES);
+        validateString(council.role, `${councilPath}.role`, violations, MAX_TEXT_BYTES);
+        if (!Array.isArray(council.members) || council.members.length === 0) {
+          addViolation(violations, `${councilPath}.members`, 'missing_council_members', `${councilPath}.members must be non-empty.`);
+          return;
+        }
+        council.members.forEach((member, memberIndex) => {
+          const memberPath = `${councilPath}.members[${memberIndex}]`;
+          if (validateMember(member, memberPath, loadedRefs, violations)) {
+            waveMemberIds.add(member.memberId);
+          }
+        });
+      });
+    }
+
+    if (!Array.isArray(wave.managementSidecars) || wave.managementSidecars.length === 0) {
+      addViolation(violations, `${wavePath}.managementSidecars`, 'missing_management_sidecar', 'Each wave in the first slice needs at least one management sidecar.');
+    } else {
+      wave.managementSidecars.forEach((member, memberIndex) => {
+        validateMember(member, `${wavePath}.managementSidecars[${memberIndex}]`, loadedRefs, violations);
+      });
+    }
+
+    if (!Array.isArray(wave.claims) || wave.claims.length === 0) {
+      addViolation(violations, `${wavePath}.claims`, 'missing_wave_claims', `${wavePath}.claims must be non-empty.`);
+    } else {
+      wave.claims.forEach((claim, claimIndex) => {
+        const claimPath = `${wavePath}.claims[${claimIndex}]`;
+        if (!isRecord(claim)) {
+          addViolation(violations, claimPath, 'expected_claim_object', `${claimPath} must be an object.`);
+          return;
+        }
+        if (typeof claim.memberId === 'string' && !waveMemberIds.has(claim.memberId)) {
+          addViolation(
+            violations,
+            `${claimPath}.memberId`,
+            'unknown_claim_member',
+            `${claimPath}.memberId must reference a member in one of the wave councils.`,
+          );
+        }
+      });
+    }
+  });
+}
+
+function validateStringArray(
+  value: unknown,
+  path: string,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+  code: string,
+): value is string[] {
+  if (!Array.isArray(value) || value.length === 0) {
+    addViolation(violations, path, code, `${path} must be a non-empty string array.`);
+    return false;
+  }
+  value.forEach((item, index) => {
+    validateString(item, `${path}[${index}]`, violations, MAX_TEXT_BYTES);
+  });
+  return true;
+}
+
+function validateManagementActions(input: ClaimGateWavegraphSliceInput, violations: ClaimGateWavegraphSliceInputViolation[]): void {
+  const sidecarsByWave = new Map<number, Set<string>>();
+  for (const wave of input.waves) {
+    if (!isRecord(wave) || !Number.isInteger(wave.wave) || !Array.isArray(wave.managementSidecars)) continue;
+    sidecarsByWave.set(wave.wave, new Set(wave.managementSidecars
+      .filter((sidecar) => isRecord(sidecar) && typeof sidecar.memberId === 'string')
+      .map((sidecar) => sidecar.memberId)));
+  }
+
+  if (!Array.isArray(input.managementActions) || input.managementActions.length === 0) {
+    addViolation(violations, 'managementActions', 'missing_management_actions', 'Gate 6 requires receipt-bearing management actions for management sidecars.');
+    return;
+  }
+
+  const actionIds = new Set<string>();
+  const actionSidecars = new Set<string>();
+  input.managementActions.forEach((action, index) => {
+    const path = `managementActions[${index}]`;
+    if (!isRecord(action)) {
+      addViolation(violations, path, 'expected_management_action_object', `${path} must be an object.`);
+      return;
+    }
+    if (validateString(action.actionId, `${path}.actionId`, violations, MAX_ID_BYTES)) {
+      if (actionIds.has(action.actionId)) {
+        addViolation(violations, `${path}.actionId`, 'duplicate_management_action_id', `${path}.actionId must be unique.`);
+      }
+      actionIds.add(action.actionId);
+    }
+    validateString(action.sidecarMemberId, `${path}.sidecarMemberId`, violations, MAX_ID_BYTES);
+    if (!Number.isInteger(action.wave) || action.wave <= 0) {
+      addViolation(violations, `${path}.wave`, 'invalid_management_action_wave', `${path}.wave must be a positive integer.`);
+    }
+    if (!['context_load', 'resource_budget', 'laggard_watch', 'reroute_failure', 'receipt_audit', 'claim_ceiling_watch'].includes(action.purpose)) {
+      addViolation(violations, `${path}.purpose`, 'invalid_management_action_purpose', `${path}.purpose is not valid.`);
+    }
+    validateStringArray(action.inputRefs, `${path}.inputRefs`, violations, 'missing_management_action_input_refs');
+    validateStringArray(action.outputRefs, `${path}.outputRefs`, violations, 'missing_management_action_output_refs');
+    validateReceiptRef(action.receiptRef, `${path}.receiptRef`, violations);
+    if (action.authority !== 'route_or_quarantine_only') {
+      addViolation(
+        violations,
+        `${path}.authority`,
+        'management_authority_overclaim',
+        `${path}.authority must be route_or_quarantine_only; management sidecars cannot promote, rewrite, or suppress work-plane receipts.`,
+      );
+    }
+    if (action.claimCeiling !== 'management_sidecar_not_promotion') {
+      addViolation(
+        violations,
+        `${path}.claimCeiling`,
+        'management_claim_ceiling_overclaim',
+        `${path}.claimCeiling must be management_sidecar_not_promotion.`,
+      );
+    }
+
+    const sidecarsForWave = sidecarsByWave.get(action.wave);
+    if (typeof action.sidecarMemberId === 'string') {
+      if (!sidecarsForWave?.has(action.sidecarMemberId)) {
+        addViolation(
+          violations,
+          `${path}.sidecarMemberId`,
+          'unknown_management_sidecar',
+          `${path}.sidecarMemberId must reference a management sidecar in the same wave.`,
+        );
+      }
+      actionSidecars.add(`${action.wave}:${action.sidecarMemberId}`);
+    }
+  });
+
+  for (const [wave, sidecarIds] of sidecarsByWave) {
+    for (const sidecarId of sidecarIds) {
+      if (!actionSidecars.has(`${wave}:${sidecarId}`)) {
+        addViolation(
+          violations,
+          'managementActions',
+          'missing_management_action_for_sidecar',
+          `Management sidecar ${sidecarId} in wave ${wave} has no receipt-bearing management action.`,
+        );
+      }
+    }
+  }
+}
