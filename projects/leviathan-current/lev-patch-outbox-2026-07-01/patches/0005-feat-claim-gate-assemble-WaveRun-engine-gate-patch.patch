+  const findings: LevWizardRatchetFinding[] = [
+    ...inputFindings,
+    ...(skillIntake.ran ? [] : [{
+      severity: 'warning' as const,
+      code: 'wizard_skill_intake_not_run',
+      message: 'Wizard skill refs are declared from context receipts, but no real source-pack intake receipts were attached.',
+      path: 'skillSourcePackReceipts',
+    }]),
+    ...(skillIntake.ran && skillIntake.declaredOnlyAfter > 0 ? [{
+      severity: 'warning' as const,
+      code: 'wizard_declared_skill_refs_still_source_only',
