+    contextReceiptRefs: evidenceContext.contextReceiptRefs,
+    contextContentHashes: evidenceContext.contextContentHashes,
+    threeEngineEnvelopeHash: input.threeEngineEnvelope ? sha256Value(input.threeEngineEnvelope) : null,
+    engineSubstrateDigestHash: input.levEngineSubstrateDigest ? sha256Value(input.levEngineSubstrateDigest) : null,
+    falsifierStatus: hostFalsifierState.falsifierStatus,
+    openFalsifierCount: hostFalsifierState.openFalsifierCount,
+  }, null, 2)}\n`;
+  writeFileSync(file, body);
+  return [`file:${file}`, sha256Text(body)];
