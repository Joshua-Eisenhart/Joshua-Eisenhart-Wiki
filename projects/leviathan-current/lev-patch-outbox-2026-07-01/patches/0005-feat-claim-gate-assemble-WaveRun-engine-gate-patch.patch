@@ -0,0 +1,1096 @@
+import { createHash } from 'node:crypto';
+import { describe, expect, it } from 'vitest';
+import {
+  attemptResurrection,
+  createNegativeReconstructionHandle,
+  createPurgatoryRecord,
+  createSpinorMemoryCellCandidate,
+  evaluateScopeAdmission,
+  quotientSurfaces,
+  sameSurvivorClass,
+  validateLevEngineSubstrateDigest,
+  validateThreeEngineProbeEnvelope,
+  type LevEngineSubstrateExecutionWitness,
+  type LevEngineSubstrateDigest,
+  type ProbeFamily,
+  type ProjectionSurface,
+  type SurfaceBindingCandidate,
+  type MechanicalProbeReceiptEvidence,
+  type ThreeEngineProbeEnvelope,
+} from '../contracts/projection-binding.js';
+
+const carrier = {
+  kind: 'finite_density_channel',
+  gTowerRung: 'U3',
+  spinorType: 'weyl',
+  axis: 'axis_0',
+} as const;
+
+const surfaces: ProjectionSurface[] = [
+  {
+    id: 'a',
+    surfaceKind: 'code_symbol',
+    label: 'x_plus_y',
+    contentHash: 'sha256:a',
+    declaredContentHash: 'sha256:a',
+    geometry: carrier,
+    probeOutputs: {
+      shape: 'binop:int,int->int',
+      arity: 2,
+      behavior_3_3: 6,
+      behavior_1_0: 1,
+      behavior_2_2: 4,
+      behavior_0_0: 0,
+    },
+  },
+  {
+    id: 'b',
+    surfaceKind: 'code_symbol',
+    label: 'x_times_y',
+    contentHash: 'sha256:b',
+    declaredContentHash: 'sha256:b',
+    geometry: carrier,
+    probeOutputs: {
+      shape: 'binop:int,int->int',
+      arity: 2,
+      behavior_3_3: 9,
+      behavior_1_0: 0,
+      behavior_2_2: 4,
+      behavior_0_0: 0,
+    },
+  },
+  {
+    id: 'c',
+    surfaceKind: 'code_symbol',
+    label: 'y_plus_x',
+    contentHash: 'sha256:c',
+    declaredContentHash: 'sha256:c',
+    geometry: carrier,
+    probeOutputs: {
+      shape: 'binop:int,int->int',
+      arity: 2,
+      behavior_3_3: 6,
+      behavior_1_0: 1,
+      behavior_2_2: 4,
+      behavior_0_0: 0,
+    },
+  },
+  {
+    id: 'z',
+    surfaceKind: 'code_symbol',
+    label: 'tampered_plus',
+    contentHash: 'sha256:z-real',
+    declaredContentHash: 'sha256:z-declared',
+    geometry: carrier,
+    probeOutputs: {
+      shape: 'binop:int,int->int',
+      arity: 2,
+      behavior_3_3: 6,
+    },
+  },
+];
+
+const M1: ProbeFamily = {
+  id: 'M1_structural',
+  probes: [
+    { id: 'shape', outputKey: 'shape' },
+    { id: 'arity', outputKey: 'arity' },
+  ],
+};
+
+const M2: ProbeFamily = {
+  id: 'M2_behavior_split',
+  probes: [
+    { id: 'shape', outputKey: 'shape' },
+    { id: 'arity', outputKey: 'arity' },
+    { id: 'behavior_3_3', outputKey: 'behavior_3_3' },
+    { id: 'behavior_1_0', outputKey: 'behavior_1_0' },
+  ],
+};
+
+const M3: ProbeFamily = {
+  id: 'M3_behavior_remerge',
+  probes: [
+    { id: 'shape', outputKey: 'shape' },
+    { id: 'arity', outputKey: 'arity' },
+    { id: 'behavior_2_2', outputKey: 'behavior_2_2' },
+    { id: 'behavior_0_0', outputKey: 'behavior_0_0' },
+  ],
+};
+
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function sha256Json(value: unknown): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(value)).digest('hex')}`;
+}
+
+function probeReceipt(
+  engine: 'julia' | 'jax' | 'pytorch',
+  lane: ThreeEngineProbeEnvelope['engines']['julia'],
+): MechanicalProbeReceiptEvidence {
+  const stdout = `${engine}:real-probe-ok\n`;
+  const stderr = '';
+  const sourcePath = lane.sourceRef.startsWith('file:') ? lane.sourceRef.slice('file:'.length) : `/tmp/${engine}-probe`;
+  const controlStdout = `${engine}:negative-control-ok\n`;
+  const controlSourcePath = `${sourcePath}.negative-control`;
+  const controlSourceText = `${engine}:negative-control-source`;
+  const sourceHash = sha256Text(`${engine}:source`);
+  return {
+    kind: 'MechanicalProbeRunReceipt',
+    claimCeiling: 'mechanical_probe_run_receipt_not_proof_authority',
+    engine,
+    command: engine,
+    args: [sourcePath],
+    sourceRef: lane.sourceRef,
+    sourceFilePath: sourcePath,
+    sourceHash,
+    sourceRefFileRead: true,
+    sourceTextMatchesFile: true,
+    sourceRefBoundToCommand: true,
+    inputHash: lane.inputHash,
+    outputHash: sha256Text(stdout),
+    stderrHash: sha256Text(stderr),
+    exitCode: 0,
+    signal: null,
+    timedOut: false,
+    durationMs: 1,
+    stdout,
+    stderr,
+    lane: {
+      ...lane,
+      outputHash: sha256Text(stdout),
+    },
+    executedNegativeControl: {
+      id: `${engine}-negative-control`,
+      command: engine,
+      args: [controlSourcePath],
+      sourceRef: `file:${controlSourcePath}`,
+      sourceFilePath: controlSourcePath,
+      sourceHash: sha256Text(controlSourceText),
+      sourceRefFileRead: true,
+      sourceTextMatchesFile: true,
+      sourceRefBoundToCommand: true,
+      inputHash: sha256Text(`${engine}:negative-input`),
+      outputHash: sha256Text(controlStdout),
+      stderrHash: sha256Text(stderr),
+      exitCode: 0,
+      signal: null,
+      timedOut: false,
+      durationMs: 1,
+      stdout: controlStdout,
+      stderr,
+      expectedOutputIncludes: ['negative-control-ok'],
+      expectedOutputExcludes: ['real-probe-ok'],
+      outputDiffersFromPrimary: true,
+      passed: true,
+    },
+    outputArtifacts: [],
+  };
+}
+
+function withMechanicalReceipts(envelope: ThreeEngineProbeEnvelope): ThreeEngineProbeEnvelope {
+  const julia = probeReceipt('julia', envelope.engines.julia);
+  const jax = probeReceipt('jax', envelope.engines.jax);
+  const pytorch = envelope.engines.pytorch ? probeReceipt('pytorch', envelope.engines.pytorch) : undefined;
+  return {
+    ...envelope,
+    engines: {
+      julia: { ...envelope.engines.julia, outputHash: julia.outputHash },
+      jax: { ...envelope.engines.jax, outputHash: jax.outputHash },
+      ...(pytorch ? { pytorch: { ...envelope.engines.pytorch!, outputHash: pytorch.outputHash } } : {}),
+    },
+    mechanicalProbeReceipts: { julia, jax, ...(pytorch ? { pytorch } : {}) },
+    mechanicalProbeRunReceiptHashes: {
+      julia: sha256Json(julia),
+      jax: sha256Json(jax),
+      ...(pytorch ? { pytorch: sha256Json(pytorch) } : {}),
+    },
+  };
+}
+
+function graphPayload(engine: 'julia' | 'jax' | 'pytorch', control = 'primary'): Record<string, unknown> {
+  const base = {
+    schema: 'lev.engine_substrate.graph_digest.v1',
+    object_id: control === 'primary' ? `lev_graph_digest_${engine}_v1` : `lev_graph_digest_${engine}_${control}_control_v1`,
+    engine,
+    runtime_owner: 'lev',
+    control,
+    promotion_allowed: false,
+    formal_admission_allowed: false,
+    reads_peer_result: false,
+    all_pass: true,
+    packages: { load_bearing: [engine] },
+  };
+  if (control !== 'primary') {
+    return {
+      ...base,
+      graph: {
+        node_count: 4,
+        edge_count: 0,
+        ...(engine === 'julia' ? { algebraic_connectivity: 0 } : {}),
+        ...(engine === 'jax' ? { message_passing: [0, 0, 0, 0] } : {}),
+        ...(engine === 'pytorch' ? { autograd_gradient: [0, 0, 0, 0] } : {}),
+      },
+    };
+  }
+  return {
+    ...base,
+    graph: {
+      node_count: 4,
+      edge_count: 4,
+      ...(engine === 'julia' ? { algebraic_connectivity: 2 } : {}),
+      ...(engine === 'jax' ? { message_passing: [6, 4, 6, 4] } : {}),
+      ...(engine === 'pytorch' ? { autograd_gradient: [2, 2, 2, 2] } : {}),
+    },
+  };
+}
+
+function graphSubstrateReceipt(
+  engine: 'julia' | 'jax' | 'pytorch',
+  lane: ThreeEngineProbeEnvelope['engines']['julia'],
+): MechanicalProbeReceiptEvidence {
+  const stdout = `${JSON.stringify(graphPayload(engine))}\nENGINE_DIGEST_DONE engine=${engine}\n`;
+  const stderr = '';
+  const sourcePath = lane.sourceRef.startsWith('file:') ? lane.sourceRef.slice('file:'.length) : `/tmp/${engine}-graph`;
+  const controlId = engine === 'julia'
+    ? 'zero_edges_changes_spectrum'
+    : engine === 'jax'
+      ? 'zero_edges_changes_message'
+      : 'zero_edges_changes_gradient';
+  const controlStdout = `${JSON.stringify(graphPayload(engine, controlId))}\nNEGATIVE_CONTROL_DONE engine=${engine} ${controlId}=true\n`;
+  const controlPath = `${sourcePath}.negative-control`;
+  return {
+    kind: 'MechanicalProbeRunReceipt',
+    claimCeiling: 'mechanical_probe_run_receipt_not_proof_authority',
+    engine,
+    command: engine,
+    args: [sourcePath],
+    sourceRef: lane.sourceRef,
+    sourceFilePath: sourcePath,
+    sourceHash: sha256Text(`${engine}:graph-source`),
+    sourceRefFileRead: true,
+    sourceTextMatchesFile: true,
+    sourceRefBoundToCommand: true,
+    inputHash: lane.inputHash,
+    outputHash: sha256Text(stdout),
+    stderrHash: sha256Text(stderr),
+    exitCode: 0,
+    signal: null,
+    timedOut: false,
+    durationMs: 1,
+    stdout,
+    stderr,
+    lane: {
+      ...lane,
+      outputHash: sha256Text(stdout),
+    },
+    executedNegativeControl: {
+      id: controlId,
+      command: engine,
+      args: [controlPath],
+      sourceRef: `file:${controlPath}`,
+      sourceFilePath: controlPath,
+      sourceHash: sha256Text(`${engine}:graph-control-source`),
+      sourceRefFileRead: true,
+      sourceTextMatchesFile: true,
+      sourceRefBoundToCommand: true,
+      inputHash: sha256Text(`${engine}:graph-control-input`),
+      outputHash: sha256Text(controlStdout),
+      stderrHash: sha256Text(stderr),
+      exitCode: 0,
+      signal: null,
+      timedOut: false,
+      durationMs: 1,
+      stdout: controlStdout,
+      stderr,
+      expectedOutputIncludes: ['NEGATIVE_CONTROL_DONE', controlId],
+      expectedOutputExcludes: ['ENGINE_DIGEST_DONE'],
+      outputDiffersFromPrimary: true,
+      passed: true,
+    },
+    outputArtifacts: [],
+  };
+}
+
+function validLevEngineSubstrateDigest(): LevEngineSubstrateDigest {
+  const lanes: LevEngineSubstrateDigest['lanes'] = {
+    julia: {
+      role: 'exact_algebraic_canon',
+      ran: true,
+      sourceRef: 'file:/Users/joshuaeisenhart/GitHub/lev/core/orchestration/src/probes/lev-sim-engine-carrier/graph-substrate/graph_substrate_digest_julia.jl',
+      inputHash: 'sha256:j-in',
+      outputHash: 'sha256:j-out',
+      readsPeerResult: false,
+      alignedPackagesLoadBearing: ['LinearAlgebra'],
+      negativeControl: 'zero_edges_changes_spectrum',
+      gateEffect: 'can_resolve_uncertain',
+    },
+    jax: {
+      role: 'batched_geometry_workhorse',
+      ran: true,
+      sourceRef: 'file:/Users/joshuaeisenhart/GitHub/lev/core/orchestration/src/probes/lev-sim-engine-carrier/graph-substrate/graph_substrate_digest_jax.py',
+      inputHash: 'sha256:x-in',
+      outputHash: 'sha256:x-out',
+      readsPeerResult: false,
+      alignedPackagesLoadBearing: ['jax', 'jax.numpy'],
+      negativeControl: 'zero_edges_changes_message',
+      gateEffect: 'can_resolve_uncertain',
+    },
+    pytorch: {
+      role: 'graph_tensor_autograd_probe',
+      ran: true,
+      sourceRef: 'file:/Users/joshuaeisenhart/GitHub/lev/core/orchestration/src/probes/lev-sim-engine-carrier/graph-substrate/graph_substrate_digest_pytorch.py',
+      inputHash: 'sha256:t-in',
+      outputHash: 'sha256:t-out',
+      readsPeerResult: false,
+      alignedPackagesLoadBearing: ['torch'],
+      negativeControl: 'zero_edges_changes_gradient',
+      gateEffect: 'can_resolve_uncertain',
+    },
+  };
+  const julia = graphSubstrateReceipt('julia', lanes.julia);
+  const jax = graphSubstrateReceipt('jax', lanes.jax);
+  const pytorch = graphSubstrateReceipt('pytorch', lanes.pytorch);
+  const syncedLanes = {
+    julia: julia.lane,
+    jax: jax.lane,
+    pytorch: pytorch.lane,
+  };
+  return {
+    kind: 'LevEngineSubstrateDigest',
+    schemaVersion: 'lev_engine_substrate_digest_v1',
+    claimCeiling: 'engine_substrate_digest_not_proof_authority',
+    runtimeOwner: 'lev',
