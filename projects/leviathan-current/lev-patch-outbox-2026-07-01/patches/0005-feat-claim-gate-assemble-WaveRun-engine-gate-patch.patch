+function sourceBoundFileRefs(input: LevWizardRatchetRunInput): string[] {
+  return Object.values(input.sourceBoundGateEvidenceRefs ?? {})
+    .flatMap((refs) => refs ?? [])
+    .filter((ref) => ref.startsWith('file:'));
+}
+
+function realpathOrNull(path: string): string | null {
+  try {
+    return realpathSync(path);
+  } catch {
+    return null;
+  }
+}
+
+function pathWithinRoot(filePath: string, rootPath: string): boolean {
+  const fileRealpath = realpathOrNull(filePath);
+  const rootRealpath = existsSync(rootPath) ? realpathOrNull(rootPath) : null;
+  if (!fileRealpath || !rootRealpath) return false;
+  return fileRealpath === rootRealpath || fileRealpath.startsWith(`${rootRealpath}/`);
+}
+
+function validateExternalFileEvidenceRoots(input: LevWizardRatchetRunInput, rootArgs: string[]): string[] {
+  const refs = sourceBoundFileRefs(input);
+  if (refs.length === 0) return [];
+  if (rootArgs.length === 0) {
+    return ['external consume with sourceBoundGateEvidenceRefs file: refs requires --file-evidence-root'];
+  }
+  const roots = rootArgs.map((root) => resolve(root));
+  return refs.flatMap((ref) => {
+    const filePath = resolve(ref.slice('file:'.length));
+    if (roots.some((root) => pathWithinRoot(filePath, root))) return [];
+    return [`file evidence ref outside allowed roots: ${ref}`];
+  });
+}
+
+function hostFalsifierStateForParsed(parsed: ParsedArgs): LevWizardHostFalsifierState | undefined {
+  const status = parsed.hostFalsifierStatus;
+  const rawCount = parsed.hostOpenFalsifierCount;
+  if (status === undefined && rawCount === undefined) return undefined;
+  if (rawCount !== undefined && (!Number.isInteger(rawCount) || rawCount < 0)) {
+    throw new Error('--host-open-falsifier-count must be a non-negative integer.');
+  }
+  const openFalsifierCount = rawCount ?? (status === 'open' ? 1 : 0);
+  const falsifierStatus = status ?? (openFalsifierCount > 0 ? 'open' : 'closed');
+  if (falsifierStatus === 'closed' && openFalsifierCount !== 0) {
+    throw new Error('--host-falsifier-status=closed requires --host-open-falsifier-count=0.');
+  }
+  if (falsifierStatus === 'open' && openFalsifierCount === 0) {
+    throw new Error('--host-falsifier-status=open requires --host-open-falsifier-count greater than 0.');
+  }
+  return {
+    falsifierStatus,
+    openFalsifierCount,
+  };
+}
