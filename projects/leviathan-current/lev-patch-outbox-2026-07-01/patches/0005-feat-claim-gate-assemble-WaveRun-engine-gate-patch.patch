+  };
+  outputHashes: {
+    julia: string;
+    jax: string;
+    pytorch: string;
+  };
+  sourceRefs: {
+    julia: string;
+    jax: string;
+    pytorch: string;
+  };
+  commands: {
+    julia: string;
+    jax: string;
+    pytorch: string;
+  };
+};
+
+export type LevEngineSubstrateDigestValidationOptions = {
+  hostExecutionWitness?: LevEngineSubstrateExecutionWitness;
+};
+
+export type EnvelopeValidationResult = {
+  ok: boolean;
+  findings: string[];
+};
+
+function stableJson(value: unknown): string {
+  return JSON.stringify(normalizeForStableJson(value));
+}
+
+function normalizeForStableJson(value: unknown): unknown {
+  if (Array.isArray(value)) {
+    return value.map((entry) => normalizeForStableJson(entry));
+  }
+
+  if (value && typeof value === 'object') {
+    return Object.fromEntries(
+      Object.entries(value as Record<string, unknown>)
+        .sort(([left], [right]) => left.localeCompare(right))
+        .map(([key, entry]) => [key, normalizeForStableJson(entry)]),
+    );
+  }
+
+  return value;
+}
+
+function probeValue(surface: ProjectionSurface, probe: TransformProbe): unknown {
+  return surface.probeOutputs[probe.outputKey];
+}
+
+function fingerprint(surface: ProjectionSurface, family: ProbeFamily): string {
+  return stableJson(family.probes.map((probe) => [probe.id, probeValue(surface, probe)]));
+}
+
+function stableProbeEqual(left: unknown, right: unknown): boolean {
+  return stableJson(left) === stableJson(right);
+}
+
+function finiteNonNegativeInteger(value: number): number {
+  return Number.isFinite(value) && value >= 0 ? Math.floor(value) : 0;
+}
+
+function hasAuthorityOverclaim(surface: ProjectionSurface): boolean {
+  const outputs = surface.probeOutputs as Record<string, unknown>;
+  return outputs.promotion_allowed === true
+    || outputs.promotionAllowed === true
+    || outputs.formal_admission_allowed === true
+    || outputs.formalAdmissionAllowed === true
+    || outputs.host_consumed === true
+    || outputs.hostConsumed === true
+    || outputs.release_admission_allowed === true
+    || outputs.releaseAdmissionAllowed === true;
+}
+
+function findSurface(surfaces: ProjectionSurface[], id: string): ProjectionSurface {
+  const surface = surfaces.find((candidate) => candidate.id === id);
+  if (!surface) throw new Error(`Unknown projection surface: ${id}`);
+  return surface;
+}
+
+export function evaluateScopeAdmission(surfaces: ProjectionSurface[]): ScopeAdmissionResult {
+  const admitted: ProjectionSurface[] = [];
+  const scopeBlocks: ScopeBlockReceipt[] = [];
+
+  for (const surface of surfaces) {
+    if (surface.declaredContentHash && surface.declaredContentHash !== surface.contentHash) {
+      scopeBlocks.push({
+        kind: 'ScopeBlockReceipt',
+        surfaceId: surface.id,
+        blockKind: 'integrity',
+        reason: 'content_hash_mismatch',
+        terminal: true,
+      });
+      continue;
+    }
+    if (hasAuthorityOverclaim(surface)) {
+      scopeBlocks.push({
+        kind: 'ScopeBlockReceipt',
+        surfaceId: surface.id,
+        blockKind: 'authority',
+        reason: 'projection_surface_self_asserted_authority',
+        terminal: true,
+      });
+      continue;
+    }
+    admitted.push(surface);
+  }
+
+  return { admitted, scopeBlocks };
+}
+
+export function quotientSurfaces(surfaces: ProjectionSurface[], family: ProbeFamily): QuotientResult {
+  const byFingerprint = new Map<string, string[]>();
+  for (const surface of surfaces) {
+    const key = fingerprint(surface, family);
+    byFingerprint.set(key, [...(byFingerprint.get(key) ?? []), surface.id]);
+  }
+
+  return {
+    familyId: family.id,
+    classes: [...byFingerprint.entries()].map(([key, surfaceIds]) => ({
+      kind: 'SurvivorClass',
+      familyId: family.id,
+      fingerprint: key,
+      surfaceIds: surfaceIds.sort(),
+    })),
+  };
+}
+
+export function sameSurvivorClass(
+  surfaces: ProjectionSurface[],
+  family: ProbeFamily,
+  leftId: string,
+  rightId: string,
+): boolean {
+  return fingerprint(findSurface(surfaces, leftId), family) === fingerprint(findSurface(surfaces, rightId), family);
+}
+
+function distinguishingProbes(
+  surfaces: ProjectionSurface[],
+  family: ProbeFamily,
+  leftId: string,
+  rightId: string,
+): TransformProbe[] {
+  const left = findSurface(surfaces, leftId);
+  const right = findSurface(surfaces, rightId);
+  return family.probes.filter((probe) => !stableProbeEqual(probeValue(left, probe), probeValue(right, probe)));
+}
+
+export function createPurgatoryRecord(
+  candidate: SurfaceBindingCandidate,
+  splitFamily: ProbeFamily,
+  surfaces: ProjectionSurface[],
+  options: { reopenBudgetMax: number; obstructionDepthMax: number },
+): PurgatoryRecord {
+  const [leftId, rightId] = candidate.surfaceIds;
+  const splitProbes = distinguishingProbes(surfaces, splitFamily, leftId, rightId);
+  const obstructionDepthMax = finiteNonNegativeInteger(options.obstructionDepthMax);
+  const reopenBudgetMax = finiteNonNegativeInteger(options.reopenBudgetMax);
+  const obstructionDepth = Math.min(splitProbes.length, obstructionDepthMax);
+
+  return {
+    kind: 'PurgatoryRecord',
+    id: `purgatory:${candidate.id}:${splitFamily.id}`,
+    bindingCandidateId: candidate.id,
+    surfaceIds: [...candidate.surfaceIds],
+    splitFamilyId: splitFamily.id,
+    splitReason: 'probe_family_distinguished_surfaces',
+    distinguishingProbeIds: splitProbes.map((probe) => probe.id),
+    obstructionDepth,
+    obstructionDepthMax,
+    reopenBudgetRemaining: reopenBudgetMax,
+    reopenBudgetMax,
+    status: reopenBudgetMax === 0 || obstructionDepth >= obstructionDepthMax
+      ? 'exhausted_in_scope'
+      : 'suspended_by_family',
+    terminal: false,
+    claimCeiling: 'family_local_nonterminal',
+  };
+}
+
+export function attemptResurrection(
+  record: PurgatoryRecord,
+  triggerFamily: ProbeFamily,
+  surfaces: ProjectionSurface[],
+): ResurrectionResult {
+  const safeRemaining = finiteNonNegativeInteger(record.reopenBudgetRemaining);
+  const nextRecord: PurgatoryRecord = {
+    ...record,
+    reopenBudgetRemaining: Math.max(0, safeRemaining - 1),
+    reopenBudgetMax: finiteNonNegativeInteger(record.reopenBudgetMax),
+    obstructionDepth: finiteNonNegativeInteger(record.obstructionDepth),
+    obstructionDepthMax: finiteNonNegativeInteger(record.obstructionDepthMax),
+    status: safeRemaining <= 1 ? 'exhausted_in_scope' : record.status,
+  };
+
+  if (safeRemaining <= 0 || record.status === 'exhausted_in_scope') {
+    return { purgatory: nextRecord };
+  }
+
+  const [leftId, rightId] = record.surfaceIds;
+  if (!sameSurvivorClass(surfaces, triggerFamily, leftId, rightId)) {
+    return { purgatory: nextRecord };
+  }
+
+  const trigger: ResurrectionTrigger = {
+    kind: 'ResurrectionTrigger',
+    id: `resurrection:${record.bindingCandidateId}:${triggerFamily.id}`,
+    purgatoryRecordId: record.id,
+    triggerFamilyId: triggerFamily.id,
+  };
+
+  const survivorReceipt: SurvivorReceipt = {
+    kind: 'SurvivorReceipt',
+    id: `survivor:${record.bindingCandidateId}:${triggerFamily.id}`,
+    bindingCandidateId: record.bindingCandidateId,
+    surfaceIds: [...record.surfaceIds],
+    familyId: triggerFamily.id,
+    status: 'remerged_survivor',
+  };
+
+  return { purgatory: nextRecord, trigger, survivorReceipt };
+}
+
+export function createNegativeReconstructionHandle(options: {
+  id: string;
+  bindingCandidateId: string;
+  probeFamilyId: string;
+  reason: string;
+  reopenBudgetMax: number;
+}): NegativeReconstructionHandle {
+  const reopenBudgetMax = finiteNonNegativeInteger(options.reopenBudgetMax);
+  return {
+    kind: 'NegativeReconstructionHandle',
+    id: options.id,
+    bindingCandidateId: options.bindingCandidateId,
+    probeFamilyId: options.probeFamilyId,
+    reason: options.reason,
+    reopenable: true,
+    terminal: false,
+    reopenBudgetRemaining: reopenBudgetMax,
+    reopenBudgetMax,
+  };
+}
+
+export function createSpinorMemoryCellCandidate(options: Omit<SpinorMemoryCellCandidate, 'kind' | 'cellHash' | 'promotionAllowed'>): SpinorMemoryCellCandidate {
+  const cellHash = createHash('sha256')
+    .update(stableJson(options))
+    .digest('hex');
+
+  return {
+    ...options,
+    kind: 'SpinorMemoryCellCandidate',
+    promotionAllowed: false,
+    cellHash: `sha256:${cellHash}`,
+  };
+}
+
+function validateLane(name: string, lane: ThreeEngineLane | undefined): string[] {
+  const findings: string[] = [];
+  if (!lane) return [`${name} lane is required`];
+  if (lane.ran !== true) findings.push(`${name}.ran must be true`);
+  if (!lane.sourceRef) findings.push(`${name}.sourceRef is required`);
+  if (!lane.inputHash) findings.push(`${name}.inputHash is required`);
+  if (!lane.outputHash) findings.push(`${name}.outputHash is required`);
+  if (lane.readsPeerResult !== false) findings.push(`${name}.readsPeerResult must be false`);
+  if (!lane.alignedPackagesLoadBearing.length) findings.push(`${name}.alignedPackagesLoadBearing is required`);
+  if (!lane.negativeControl) findings.push(`${name}.negativeControl is required`);
+  if (lane.gateEffect !== 'can_resolve_uncertain') findings.push(`${name}.gateEffect must be can_resolve_uncertain`);
+  return findings;
+}
+
+function hashEvidence(value: unknown): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(value)).digest('hex')}`;
+}
+
+function hashText(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function validSha256Ref(value: unknown): value is string {
+  return typeof value === 'string' && /^sha256:[0-9a-f]{64}$/.test(value);
+}
+
+function recordOrEmpty(value: unknown): Record<string, unknown> {
+  return value && typeof value === 'object' && !Array.isArray(value)
+    ? value as Record<string, unknown>
+    : {};
+}
+
+const REFERENCE_RUNTIME_CARRIER_FRAGMENTS = [
+  '/codex-ratchet/',
+  '/desktop/codex ratchet/',
+  '/wiki/',
+  '/workshop/intake/',
+];
+
+function referenceRuntimeCarrierFragment(value: unknown): string | undefined {
+  if (typeof value !== 'string') return undefined;
+  const normalized = `${value}/`.toLocaleLowerCase();
+  return REFERENCE_RUNTIME_CARRIER_FRAGMENTS.find((fragment) => normalized.includes(fragment));
+}
+
+function validateReceiptEvidence(
+  name: 'julia' | 'jax' | 'pytorch',
+  lane: ThreeEngineLane | undefined,
+  receipt: MechanicalProbeReceiptEvidence | undefined,
+  expectedReceiptHash: string | undefined,
+): string[] {
+  const findings: string[] = [];
+  if (!receipt) return [`mechanicalProbeReceipts.${name} is required`];
+  const receiptValidation = validateMechanicalProbeRunReceipt(
+    receipt,
+    { requireExecutedNegativeControl: true },
+  );
+  findings.push(...receiptValidation.findings.map((finding) => `mechanicalProbeReceipts.${name}.${finding}`));
+  if (!validSha256Ref(expectedReceiptHash)) {
+    findings.push(`mechanicalProbeRunReceiptHashes.${name} must be a sha256 ref`);
+  } else if (hashEvidence(receipt) !== expectedReceiptHash) {
+    findings.push(`mechanicalProbeReceipts.${name} hash must match mechanicalProbeRunReceiptHashes.${name}`);
+  }
+
+  if (receipt.kind !== 'MechanicalProbeRunReceipt') findings.push(`mechanicalProbeReceipts.${name}.kind must be MechanicalProbeRunReceipt`);
+  if (receipt.engine !== name) findings.push(`mechanicalProbeReceipts.${name}.engine must be ${name}`);
+  if (receipt.exitCode !== 0) findings.push(`mechanicalProbeReceipts.${name}.exitCode must be 0`);
+  if (receipt.timedOut !== false) findings.push(`mechanicalProbeReceipts.${name}.timedOut must be false`);
+  if (receipt.outputHash !== hashText(receipt.stdout)) {
+    findings.push(`mechanicalProbeReceipts.${name}.outputHash must match stdout`);
+  }
+  if (receipt.stderrHash !== hashText(receipt.stderr)) {
+    findings.push(`mechanicalProbeReceipts.${name}.stderrHash must match stderr`);
+  }
+
+  if (!lane) return findings;
+  if (receipt.lane.ran !== true) findings.push(`mechanicalProbeReceipts.${name}.lane.ran must be true`);
+  if (receipt.sourceRef !== lane.sourceRef) findings.push(`mechanicalProbeReceipts.${name}.sourceRef must match lane.sourceRef`);
+  if (receipt.inputHash !== lane.inputHash) findings.push(`mechanicalProbeReceipts.${name}.inputHash must match lane.inputHash`);
+  if (receipt.outputHash !== lane.outputHash) findings.push(`mechanicalProbeReceipts.${name}.outputHash must match lane.outputHash`);
+  if (receipt.lane.sourceRef !== lane.sourceRef) findings.push(`mechanicalProbeReceipts.${name}.lane.sourceRef must match lane.sourceRef`);
+  if (receipt.lane.inputHash !== lane.inputHash) findings.push(`mechanicalProbeReceipts.${name}.lane.inputHash must match lane.inputHash`);
+  if (receipt.lane.outputHash !== lane.outputHash) findings.push(`mechanicalProbeReceipts.${name}.lane.outputHash must match lane.outputHash`);
+  if (receipt.lane.role !== lane.role) findings.push(`mechanicalProbeReceipts.${name}.lane.role must match lane.role`);
+  if (receipt.lane.readsPeerResult !== false) findings.push(`mechanicalProbeReceipts.${name}.lane.readsPeerResult must be false`);
+  if (receipt.lane.gateEffect !== 'can_resolve_uncertain') {
+    findings.push(`mechanicalProbeReceipts.${name}.lane.gateEffect must be can_resolve_uncertain`);
+  }
+  if (stableJson(receipt.lane) !== stableJson(lane)) {
+    findings.push(`mechanicalProbeReceipts.${name}.lane must match envelope lane`);
+  }
+  return findings;
+}
+
+function validateRuntimeCarrier(
+  carrier: EngineSubstrateRuntimeCarrier | undefined,
+  mode: ThreeEngineProbeEnvelope['mode'],
+): string[] {
+  const findings: string[] = [];
+  if (!carrier) return findings;
+
+  if (carrier.claimCeiling !== 'carrier_path_receipted_not_current_corpus_proof') {
+    findings.push('runtimeCarrier.claimCeiling must be carrier_path_receipted_not_current_corpus_proof');
+  }
+  if (!carrier.carrierPath) findings.push('runtimeCarrier.carrierPath is required');
+  const carrierPathReference = referenceRuntimeCarrierFragment(carrier.carrierPath);
+  if (carrierPathReference) {
+    findings.push(`runtimeCarrier.carrierPath points at reference/provenance material (${carrierPathReference})`);
+  }
+  if (!carrier.sourceRefs?.julia) findings.push('runtimeCarrier.sourceRefs.julia is required');
+  if (!carrier.sourceRefs?.jax) findings.push('runtimeCarrier.sourceRefs.jax is required');
+  if (
+    (mode === 'all_three_full_sims' || mode === 'julia_canon_jax_with_pytorch_graph')
+    && !carrier.sourceRefs?.pytorch
+  ) {
+    findings.push('runtimeCarrier.sourceRefs.pytorch is required');
+  }
+  for (const [name, ref] of Object.entries(carrier.sourceRefs ?? {})) {
+    const reference = referenceRuntimeCarrierFragment(ref);
+    if (reference) findings.push(`runtimeCarrier.sourceRefs.${name} points at reference/provenance material (${reference})`);
+  }
+  if (carrier.pathSource === 'default:codex-ratchet-system-v5') {
+    findings.push('runtimeCarrier.pathSource default:codex-ratchet-system-v5 is reference-only, not a Lev runtime carrier');
+  }
+  if (carrier.pathSource === 'env:CODEX_RATCHET_CARRIER') {
+    findings.push('runtimeCarrier.pathSource env:CODEX_RATCHET_CARRIER is reference-only, not a Lev runtime carrier');
+  }
+
+  return findings;
+}
+
+function parseJsonObjectLine(stdout: string): Record<string, unknown> | undefined {
+  for (const line of stdout.split(/\r?\n/)) {
+    const trimmed = line.trim();
+    if (!trimmed.startsWith('{')) continue;
+    try {
+      const parsed = JSON.parse(trimmed) as unknown;
+      if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) {
+        return parsed as Record<string, unknown>;
+      }
+    } catch {
+      continue;
+    }
+  }
+  return undefined;
+}
+
+function numberArrayEquals(value: unknown, expected: number[]): boolean {
+  return Array.isArray(value)
+    && value.length === expected.length
+    && value.every((entry, index) => typeof entry === 'number' && Math.abs(entry - expected[index]) < 1e-9);
+}
+
+function validateGraphSubstrateReceipt(
+  name: 'julia' | 'jax' | 'pytorch',
+  receipt: MechanicalProbeReceiptEvidence | undefined,
+  expectedReceiptHash: string | undefined,
+  lane: ThreeEngineLane | undefined,
+): string[] {
+  const findings = validateReceiptEvidence(name, lane, receipt, expectedReceiptHash);
+  if (!receipt) return findings;
+
+  const validation = validateMechanicalProbeRunReceipt(receipt, { requireExecutedNegativeControl: true });
+  findings.push(...validation.findings.map((finding) => `graphSubstrateReceipts.${name}.${finding}`));
+
+  const result = parseJsonObjectLine(receipt.stdout);
+  if (!result) {
+    findings.push(`graphSubstrateReceipts.${name}.stdout must include a JSON result line`);
+    return findings;
+  }
+  if (result.schema !== 'lev.engine_substrate.graph_digest.v1') {
+    findings.push(`graphSubstrateReceipts.${name}.schema must be lev.engine_substrate.graph_digest.v1`);
+  }
+  if (result.engine !== name) findings.push(`graphSubstrateReceipts.${name}.engine must be ${name}`);
+  if (result.runtime_owner !== 'lev') findings.push(`graphSubstrateReceipts.${name}.runtime_owner must be lev`);
+  if (result.promotion_allowed !== false) findings.push(`graphSubstrateReceipts.${name}.promotion_allowed must be false`);
+  if (result.formal_admission_allowed !== false) {
+    findings.push(`graphSubstrateReceipts.${name}.formal_admission_allowed must be false`);
+  }
+  if (result.reads_peer_result !== false) findings.push(`graphSubstrateReceipts.${name}.reads_peer_result must be false`);
+  if (result.all_pass !== true) findings.push(`graphSubstrateReceipts.${name}.all_pass must be true`);
+
+  const graph = result.graph && typeof result.graph === 'object' && !Array.isArray(result.graph)
+    ? result.graph as Record<string, unknown>
+    : undefined;
+  if (!graph) {
+    findings.push(`graphSubstrateReceipts.${name}.graph is required`);
+    return findings;
+  }
+  if (graph.node_count !== 4) findings.push(`graphSubstrateReceipts.${name}.graph.node_count must be 4`);
+  if (graph.edge_count !== 4) findings.push(`graphSubstrateReceipts.${name}.graph.edge_count must be 4`);
+  if (name === 'julia' && graph.algebraic_connectivity !== 2) {
+    findings.push('graphSubstrateReceipts.julia.graph.algebraic_connectivity must be 2');
+  }
+  if (name === 'jax' && !numberArrayEquals(graph.message_passing, [6, 4, 6, 4])) {
+    findings.push('graphSubstrateReceipts.jax.graph.message_passing must be [6,4,6,4]');
+  }
+  if (name === 'pytorch' && !numberArrayEquals(graph.autograd_gradient, [2, 2, 2, 2])) {
+    findings.push('graphSubstrateReceipts.pytorch.graph.autograd_gradient must be [2,2,2,2]');
+  }
+  return findings;
+}
+
+function validateLevEngineSubstrateExecutionWitness(
+  digest: Partial<LevEngineSubstrateDigest>,
+  witness: LevEngineSubstrateExecutionWitness | undefined,
+): string[] {
+  const findings: string[] = [];
+  if (!witness) {
+    return ['hostExecutionWitness is required to prove the engine substrate receipts were host-spawned'];
+  }
+
+  if (witness.kind !== 'LevEngineSubstrateExecutionWitness') {
+    findings.push('hostExecutionWitness.kind must be LevEngineSubstrateExecutionWitness');
+  }
+  if (witness.claimCeiling !== 'host_execution_witness_not_transferable_authority') {
+    findings.push('hostExecutionWitness.claimCeiling must be host_execution_witness_not_transferable_authority');
+  }
+  if (witness.authority !== 'lev_host_mechanical_probe_runner') {
+    findings.push('hostExecutionWitness.authority must be lev_host_mechanical_probe_runner');
+  }
+  if (witness.digestHash !== hashEvidence(digest)) {
+    findings.push('hostExecutionWitness.digestHash must match the validated digest');
+  }
+  if (witness.runtimeCarrierPath !== digest.runtimeCarrier?.carrierPath) {
+    findings.push('hostExecutionWitness.runtimeCarrierPath must match digest.runtimeCarrier.carrierPath');
+  }
+
+  for (const engine of ['julia', 'jax', 'pytorch'] as const) {
+    const receipt = digest.receipts?.[engine];
+    if (witness.receiptHashes[engine] !== digest.receiptHashes?.[engine]) {
+      findings.push(`hostExecutionWitness.receiptHashes.${engine} must match digest.receiptHashes.${engine}`);
+    }
+    if (witness.outputHashes[engine] !== receipt?.outputHash) {
+      findings.push(`hostExecutionWitness.outputHashes.${engine} must match digest receipt outputHash`);
+    }
+    if (witness.sourceRefs[engine] !== receipt?.sourceRef) {
+      findings.push(`hostExecutionWitness.sourceRefs.${engine} must match digest receipt sourceRef`);
+    }
+    if (witness.commands[engine] !== receipt?.command) {
+      findings.push(`hostExecutionWitness.commands.${engine} must match digest receipt command`);
+    }
+  }
+
+  return findings;
+}
+
+export function validateThreeEngineProbeEnvelope(envelope: ThreeEngineProbeEnvelope): EnvelopeValidationResult {
+  const findings: string[] = [];
+
+  if (envelope.schemaVersion !== 'three_engine_probe_envelope_v1') {
+    findings.push('schemaVersion must be three_engine_probe_envelope_v1');
+  }
+  if (envelope.claimCeiling !== 'mechanical_probe_evidence_not_proof_authority') {
+    findings.push('claimCeiling must be mechanical_probe_evidence_not_proof_authority');
+  }
+  if (!envelope.transformClaim) findings.push('transformClaim is required');
+  if (envelope.divergence.juliaAuthoritative !== true) findings.push('divergence.juliaAuthoritative must be true');
+  if (!envelope.mechanicalProbeRunReceiptHashes) findings.push('mechanicalProbeRunReceiptHashes is required');
+
+  findings.push(...validateRuntimeCarrier(envelope.runtimeCarrier, envelope.mode));
+  findings.push(...validateLane('julia', envelope.engines.julia));
+  findings.push(...validateLane('jax', envelope.engines.jax));
+  if (envelope.mode === 'all_three_full_sims' || envelope.mode === 'julia_canon_jax_with_pytorch_graph') {
+    findings.push(...validateLane('pytorch', envelope.engines.pytorch));
+  }
+  if (!envelope.mechanicalProbeReceipts) {
+    findings.push('mechanicalProbeReceipts is required');
+  } else {
+    findings.push(...validateReceiptEvidence(
+      'julia',
+      envelope.engines.julia,
+      envelope.mechanicalProbeReceipts.julia,
+      envelope.mechanicalProbeRunReceiptHashes?.julia,
+    ));
+    findings.push(...validateReceiptEvidence(
+      'jax',
+      envelope.engines.jax,
+      envelope.mechanicalProbeReceipts.jax,
+      envelope.mechanicalProbeRunReceiptHashes?.jax,
+    ));
+    if (envelope.mode === 'all_three_full_sims' || envelope.mode === 'julia_canon_jax_with_pytorch_graph') {
+      findings.push(...validateReceiptEvidence(
+        'pytorch',
+        envelope.engines.pytorch,
+        envelope.mechanicalProbeReceipts.pytorch,
+        envelope.mechanicalProbeRunReceiptHashes?.pytorch,
+      ));
+    }
+  }
+
+  return {
+    ok: findings.length === 0,
+    findings,
+  };
+}
+
+export function validateLevEngineSubstrateDigest(
+  digest: LevEngineSubstrateDigest,
+  options: LevEngineSubstrateDigestValidationOptions = {},
+): EnvelopeValidationResult {
+  const findings: string[] = [];
+  const candidate = recordOrEmpty(digest) as Partial<LevEngineSubstrateDigest>;
+  const sourcePolicy = recordOrEmpty(candidate.sourcePolicy);
+  const graphInvariants = recordOrEmpty(candidate.graphInvariants);
+  const computeDomains = Array.isArray(candidate.computeDomains) ? candidate.computeDomains : [];
+  const intendedConsumers = Array.isArray(candidate.intendedConsumers) ? candidate.intendedConsumers : [];
+  const receipts = recordOrEmpty(candidate.receipts) as Partial<LevEngineSubstrateDigest['receipts']>;
+  const receiptHashes = recordOrEmpty(candidate.receiptHashes) as Partial<LevEngineSubstrateDigest['receiptHashes']>;
+  const lanes = recordOrEmpty(candidate.lanes) as Partial<LevEngineSubstrateDigest['lanes']>;
+
+  if (candidate.kind !== 'LevEngineSubstrateDigest') findings.push('kind must be LevEngineSubstrateDigest');
+  if (candidate.schemaVersion !== 'lev_engine_substrate_digest_v1') {
+    findings.push('schemaVersion must be lev_engine_substrate_digest_v1');
+  }
+  if (candidate.claimCeiling !== 'engine_substrate_digest_not_proof_authority') {
+    findings.push('claimCeiling must be engine_substrate_digest_not_proof_authority');
+  }
+  if (candidate.runtimeOwner !== 'lev') findings.push('runtimeOwner must be lev');
+  if (!Array.isArray(candidate.computeDomains)) findings.push('computeDomains must be an array');
+  if (!computeDomains.includes('graph')) findings.push('computeDomains must include graph');
+  if (!Array.isArray(candidate.intendedConsumers)) findings.push('intendedConsumers must be an array');
+  if (!intendedConsumers.includes('graph')) findings.push('intendedConsumers must include graph');
+  if (sourcePolicy.codexRatchet !== 'reference_only') findings.push('sourcePolicy.codexRatchet must be reference_only');
+  if (sourcePolicy.wiki !== 'reference_only') findings.push('sourcePolicy.wiki must be reference_only');
+  if (sourcePolicy.hermes !== 'skill_procedure_only') {
+    findings.push('sourcePolicy.hermes must be skill_procedure_only');
+  }
+
+  if (!candidate.runtimeCarrier) findings.push('runtimeCarrier is required');
+  findings.push(...validateRuntimeCarrier(candidate.runtimeCarrier, 'all_three_full_sims'));
+  findings.push(...validateLane('julia', lanes.julia));
+  findings.push(...validateLane('jax', lanes.jax));
+  findings.push(...validateLane('pytorch', lanes.pytorch));
+  findings.push(...validateGraphSubstrateReceipt('julia', receipts.julia, receiptHashes.julia, lanes.julia));
+  findings.push(...validateGraphSubstrateReceipt('jax', receipts.jax, receiptHashes.jax, lanes.jax));
+  findings.push(...validateGraphSubstrateReceipt(
+    'pytorch',
+    receipts.pytorch,
+    receiptHashes.pytorch,
+    lanes.pytorch,
+  ));
+
+  if (graphInvariants.nodeCount !== 4) findings.push('graphInvariants.nodeCount must be 4');
+  if (graphInvariants.edgeCount !== 4) findings.push('graphInvariants.edgeCount must be 4');
+  if (graphInvariants.juliaAlgebraicConnectivity !== 2) {
+    findings.push('graphInvariants.juliaAlgebraicConnectivity must be 2');
+  }
+  if (!numberArrayEquals(graphInvariants.jaxMessagePassing, [6, 4, 6, 4])) {
+    findings.push('graphInvariants.jaxMessagePassing must be [6,4,6,4]');
+  }
+  if (!numberArrayEquals(graphInvariants.pytorchAutogradGradient, [2, 2, 2, 2])) {
+    findings.push('graphInvariants.pytorchAutogradGradient must be [2,2,2,2]');
+  }
+  findings.push(...validateLevEngineSubstrateExecutionWitness(candidate, options.hostExecutionWitness));
+
+  return {
+    ok: findings.length === 0,
+    findings,
+  };
+}
diff --git a/core/graph/src/contracts/source-pack-intake.ts b/core/graph/src/contracts/source-pack-intake.ts
new file mode 100644
index 000000000..9f1e08c45
--- /dev/null
+++ b/core/graph/src/contracts/source-pack-intake.ts
@@ -0,0 +1,424 @@
+import { createHash } from 'node:crypto';
+import { readFileSync, realpathSync, statSync } from 'node:fs';
+import { isAbsolute, relative, resolve } from 'node:path';
+import type { ProjectionSurface } from './projection-binding.js';
+
+export type SourcePackClaimCeiling = 'reference_source_inventory_not_admitted';
+export type SourcePackAuthority = 'advisory_source_pack_only';
+
+export type SkillSourceLifecycle = 'active' | 'archived';
+
+export type LevSourcePackTarget =
+  | 'skill'
+  | 'context'
+  | 'execution'
+  | 'memory'
+  | 'research'
+  | 'simulation'
+  | 'wiki'
+  | 'graph_probe_gate'
+  | 'parking_lot';
+
+export type ExecutionProfileFamily =
+  | 'hermes.moa.reference_synthesis'
+  | 'hermes.tribunal.independent_comparison'
+  | 'hermes.subagent_development.plan_execute_review'
+  | 'external.cli_coding_agent_worker';
+
+export type SkillSourceProcedure = {
+  trigger: string;
+  readOrder: string[];
+  requiredOutput: string;
+  promotionRule: string;
+  minimalTest: string;
+};
+
+export type SourceGateResult = {
+  gateId: string;
+  status: 'pass' | 'fail' | 'uncertain';
+  recordIds: string[];
+  reason: string;
+};
+
+export type CrossGateSynthesis = {
+  id: string;
+  gateIds: string[];
+  claimedSurvivorRecordIds: string[];
+};
+
+export type ReadOnlyArtifactReceipt = {
+  id: string;
+  path: string;
+  hashBefore?: string;
+  hashAfter?: string;
+  mtimeMsBefore?: number;
+  mtimeMsAfter?: number;
+};
+
+export type SkillSourceRecord = {
+  id: string;
+  title?: string;
+  sourceRoot: string;
+  sourcePath: string;
+  lifecycle: SkillSourceLifecycle;
+  sha256: string;
+  targetDomain: LevSourcePackTarget;
+  authority: SourcePackAuthority;
+  tags?: string[];
+  executionProfile?: ExecutionProfileFamily;
+  procedure?: Partial<SkillSourceProcedure>;
+  declaredClaims?: Record<string, unknown>;
+  sourceMtimeMs?: number;
+  verifiedAtMs?: number;
+  readOnlyAudit?: ReadOnlyArtifactReceipt[];
+};
+
+export type SkillSourcePack = {
+  schemaVersion: 'skill_source_pack_v1';
+  id: string;
+  claimCeiling: SourcePackClaimCeiling;
+  authority: SourcePackAuthority;
+  records: SkillSourceRecord[];
+  gateResults?: SourceGateResult[];
+  syntheses?: CrossGateSynthesis[];
+};
+
+export type SourcePackFinding = {
+  code: string;
+  recordId?: string;
+  detail: string;
+};
+
+export type SkillSourcePurgatoryRecord = {
+  kind: 'SkillSourcePurgatoryRecord';
+  recordId: string;
+  reason: 'active_archive_conflict';
+  sourcePaths: string[];
+  terminal: false;
+};
+
+export type SourcePackAdmissionReceipt = {
+  kind: 'SourcePackAdmissionReceipt';
+  claimCeiling: SourcePackClaimCeiling;
+  authority: SourcePackAuthority;
+  ok: boolean;
+  admittedRecordIds: string[];
+  purgatory: SkillSourcePurgatoryRecord[];
+  findings: SourcePackFinding[];
+};
+
+export type SourcePackValidationOptions = {
+  maxRecords?: number;
+};
+
+const DEFAULT_MAX_RECORDS = 500;
+const REQUIRED_PROCEDURE_FIELDS: Array<keyof SkillSourceProcedure> = [
+  'trigger',
+  'readOrder',
+  'requiredOutput',
+  'promotionRule',
+  'minimalTest',
+];
+
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function hasText(value: unknown): value is string {
+  return typeof value === 'string' && value.trim().length > 0;
+}
+
+function pathContainedBy(child: string, parent: string): boolean {
+  const rel = relative(parent, child);
+  return Boolean(rel) && !rel.startsWith('..') && !isAbsolute(rel);
+}
+
+function readContainedSource(record: SkillSourceRecord): {
+  ok: boolean;
+  text?: string;
+  actualHash?: string;
+  actualMtimeMs?: number;
+  finding?: SourcePackFinding;
+} {
+  try {
+    const root = realpathSync(record.sourceRoot);
+    const sourcePath = realpathSync(resolve(record.sourcePath));
+    if (!pathContainedBy(sourcePath, root)) {
+      return {
+        ok: false,
+        finding: {
+          code: 'source_path_outside_root',
+          recordId: record.id,
+          detail: `${record.sourcePath} resolves outside ${record.sourceRoot}`,
+        },
+      };
+    }
+    const text = readFileSync(sourcePath, 'utf8');
+    const stat = statSync(sourcePath);
+    return {
+      ok: true,
+      text,
+      actualHash: sha256Text(text),
+      actualMtimeMs: stat.mtimeMs,
+    };
+  } catch (error) {
+    return {
+      ok: false,
+      finding: {
+        code: 'source_unreadable',
+        recordId: record.id,
+        detail: error instanceof Error ? error.message : String(error),
+      },
+    };
+  }
+}
+
+function hasSelfPromotingClaim(claims: Record<string, unknown> | undefined): boolean {
+  if (!claims) return false;
+  return claims.promotion_allowed === true
+    || claims.promotionAllowed === true
+    || claims.formal_admission_allowed === true
+    || claims.formalAdmissionAllowed === true
+    || claims.host_consumed === true
+    || claims.hostConsumed === true
+    || claims.release_admission_allowed === true
+    || claims.releaseAdmissionAllowed === true;
+}
+
+function missingProcedureFields(record: SkillSourceRecord): string[] {
+  const procedure = record.procedure ?? {};
+  return REQUIRED_PROCEDURE_FIELDS.filter((field) => {
+    const value = procedure[field];
+    if (field === 'readOrder') return !Array.isArray(value) || value.length === 0;
+    return !hasText(value);
+  });
+}
+
+function sameStringSet(left: string[], right: string[]): boolean {
+  const a = [...new Set(left)].sort();
+  const b = [...new Set(right)].sort();
+  return a.length === b.length && a.every((value, idx) => value === b[idx]);
+}
+
+function passIntersection(results: SourceGateResult[]): string[] {
+  const passing = results.filter((result) => result.status === 'pass');
+  if (passing.length === 0) return [];
+  let survivor = new Set(passing[0].recordIds);
+  for (const result of passing.slice(1)) {
+    survivor = new Set(result.recordIds.filter((id) => survivor.has(id)));
+  }
+  return [...survivor].sort();
+}
+
+function validateGateEvidence(pack: SkillSourcePack): SourcePackFinding[] {
+  const findings: SourcePackFinding[] = [];
+  const byGate = new Map<string, SourceGateResult>();
+
+  for (const result of pack.gateResults ?? []) {
+    if (!hasText(result.reason)) {
+      findings.push({
+        code: 'blank_reason_field_veto',
+        detail: `${result.gateId} has an empty reason`,
+      });
+    }
+    byGate.set(result.gateId, result);
+  }
+
+  for (const synthesis of pack.syntheses ?? []) {
+    const selected = synthesis.gateIds.map((gateId) => byGate.get(gateId));
+    if (selected.some((result) => !result)) {
+      findings.push({
+        code: 'cross_gate_synthesis_unknown_gate',
+        detail: `${synthesis.id} references a missing gate result`,
+      });
+      continue;
+    }
+    const computed = passIntersection(selected as SourceGateResult[]);
+    if (!sameStringSet(computed, synthesis.claimedSurvivorRecordIds)) {
+      findings.push({
+        code: 'cross_gate_synthesis_mismatch',
+        detail: `${synthesis.id} claimed ${synthesis.claimedSurvivorRecordIds.join(',')} but computed ${computed.join(',')}`,
+      });
+    }
+  }
+
+  return findings;
+}
+
+function validateReadOnlyAudit(record: SkillSourceRecord): SourcePackFinding[] {
+  const findings: SourcePackFinding[] = [];
+
+  if (
+    record.sourceMtimeMs !== undefined
+    && record.verifiedAtMs !== undefined
+    && record.verifiedAtMs < record.sourceMtimeMs
+  ) {
+    findings.push({
+      code: 'audit_older_than_source',
+      recordId: record.id,
+      detail: 'verifiedAtMs must be newer than sourceMtimeMs',
+    });
+  }
+
+  for (const artifact of record.readOnlyAudit ?? []) {
+    if (artifact.hashBefore && artifact.hashAfter && artifact.hashBefore !== artifact.hashAfter) {
+      findings.push({
+        code: 'read_only_audit_modified_hash',
+        recordId: record.id,
+        detail: `${artifact.id} changed hash during read-only audit`,
+      });
+    }
+    if (
+      artifact.mtimeMsBefore !== undefined
+      && artifact.mtimeMsAfter !== undefined
+      && artifact.mtimeMsAfter !== artifact.mtimeMsBefore
+    ) {
+      findings.push({
+        code: 'read_only_audit_touched_mtime',
+        recordId: record.id,
+        detail: `${artifact.id} changed mtime during read-only audit`,
+      });
+    }
+  }
+
+  return findings;
+}
+
+function conflictedRecordIds(records: SkillSourceRecord[]): Map<string, SkillSourceRecord[]> {
+  const grouped = new Map<string, SkillSourceRecord[]>();
+  for (const record of records) {
+    grouped.set(record.id, [...(grouped.get(record.id) ?? []), record]);
+  }
+
+  const conflicts = new Map<string, SkillSourceRecord[]>();
+  for (const [id, group] of grouped.entries()) {
+    const hasActive = group.some((record) => record.lifecycle === 'active');
+    const hasArchived = group.some((record) => record.lifecycle === 'archived');
+    if (hasActive && hasArchived) conflicts.set(id, group);
+  }
+  return conflicts;
+}
+
+export function validateSkillSourcePack(
+  pack: SkillSourcePack,
+  options: SourcePackValidationOptions = {},
+): SourcePackAdmissionReceipt {
+  const findings: SourcePackFinding[] = [];
+  const maxRecords = options.maxRecords ?? DEFAULT_MAX_RECORDS;
+
+  if (pack.schemaVersion !== 'skill_source_pack_v1') {
+    findings.push({ code: 'invalid_schema_version', detail: 'schemaVersion must be skill_source_pack_v1' });
+  }
+  if (pack.claimCeiling !== 'reference_source_inventory_not_admitted') {
+    findings.push({ code: 'invalid_claim_ceiling', detail: 'claimCeiling must stay reference-only' });
+  }
+  if (pack.authority !== 'advisory_source_pack_only') {
+    findings.push({ code: 'invalid_authority', detail: 'authority must be advisory_source_pack_only' });
+  }
+  if (pack.records.length > maxRecords) {
+    findings.push({ code: 'record_budget_exceeded', detail: `records ${pack.records.length} exceeds max ${maxRecords}` });
+  }
+
+  findings.push(...validateGateEvidence(pack));
+  const packLevelFindingCount = findings.length;
+
+  const conflicts = conflictedRecordIds(pack.records);
+  const conflicted = new Set(conflicts.keys());
+  const purgatory: SkillSourcePurgatoryRecord[] = [...conflicts.entries()].map(([recordId, group]) => ({
+    kind: 'SkillSourcePurgatoryRecord',
+    recordId,
+    reason: 'active_archive_conflict',
+    sourcePaths: group.map((record) => record.sourcePath),
+    terminal: false,
+  }));
+
+  const admittedRecordIds: string[] = [];
+  for (const record of pack.records) {
+    const beforeCount = findings.length;
+
+    if (record.authority !== 'advisory_source_pack_only') {
+      findings.push({
+        code: 'record_authority_must_be_advisory',
+        recordId: record.id,
+        detail: 'record authority must be advisory_source_pack_only',
+      });
+    }
+    if (record.lifecycle === 'archived') {
+      findings.push({
+        code: 'archived_record_reference_only',
+        recordId: record.id,
+        detail: 'archived records cannot be admitted as active procedures',
+      });
+    }
+    if (conflicted.has(record.id)) {
+      findings.push({
+        code: 'active_archive_conflict',
+        recordId: record.id,
+        detail: 'active and archived records share an id',
+      });
+    }
+    if (hasSelfPromotingClaim(record.declaredClaims)) {
+      findings.push({
+        code: 'source_self_promotion_blocked',
+        recordId: record.id,
+        detail: 'source records cannot self-assert promotion or host authority',
+      });
+    }
+
+    const source = readContainedSource(record);
+    if (!source.ok) {
+      if (source.finding) findings.push(source.finding);
+    } else {
+      if (source.actualHash !== record.sha256) {
+        findings.push({
+          code: 'source_hash_mismatch',
+          recordId: record.id,
+          detail: `expected ${record.sha256} got ${source.actualHash}`,
+        });
+      }
+    }
+
+    const missing = missingProcedureFields(record);
+    if (record.targetDomain !== 'parking_lot' && missing.length > 0) {
+      findings.push({
+        code: 'procedure_extract_missing_fields',
+        recordId: record.id,
+        detail: missing.join(','),
+      });
+    }
+
+    findings.push(...validateReadOnlyAudit(record));
+
+    if (packLevelFindingCount === 0 && findings.length === beforeCount && record.lifecycle === 'active') {
+      admittedRecordIds.push(record.id);
+    }
+  }
+
+  return {
+    kind: 'SourcePackAdmissionReceipt',
+    claimCeiling: 'reference_source_inventory_not_admitted',
+    authority: 'advisory_source_pack_only',
+    ok: findings.length === 0,
+    admittedRecordIds: admittedRecordIds.sort(),
+    purgatory,
+    findings,
+  };
+}
+
+export function skillSourceRecordToProjectionSurface(record: SkillSourceRecord): ProjectionSurface {
+  return {
+    id: `skill-source:${record.id}`,
+    surfaceKind: 'skill',
+    label: record.title ?? record.id,
+    contentHash: record.sha256,
+    declaredContentHash: record.sha256,
+    probeOutputs: {
+      lifecycle: record.lifecycle,
+      targetDomain: record.targetDomain,
+      executionProfile: record.executionProfile ?? null,
+      sourcePath: record.sourcePath,
+      authority: record.authority,
+      ...(record.declaredClaims ?? {}),
+    },
+  };
+}
diff --git a/core/graph/src/handlers/graph-patch.ts b/core/graph/src/handlers/graph-patch.ts
index c860929d5..8fe6c0f02 100644
--- a/core/graph/src/handlers/graph-patch.ts
+++ b/core/graph/src/handlers/graph-patch.ts
@@ -8,19 +8,230 @@
  * the FlowMind graph.patch noop stub with real EntityGraph apply.
  */
 
+import { createHash, createHmac, randomBytes, timingSafeEqual } from 'node:crypto';
+
 import type { GraphOperation } from '../types.js';
 
 export interface PatchArgs {
   operations: string;
+  applyPlanReceiptId?: string;
+  applyPlanAuthority?: string;
+}
+
+export interface ClaimGateGraphApplyPlanAuthority {
+  kind: 'ClaimGateGraphApplyPlanAuthority';
+  claimCeiling: 'host_graph_apply_plan_authority_not_transferable';
+  authority: 'lev_graph_patch_handler';
+  applyPlanReceiptId: string;
+  operationHash: string;
+  operationCount: number;
+  nonce: string;
+  issuedAt: string;
+  payloadHash: string;
+  mac: string;
+}
+
+const HOST_GRAPH_PATCH_PROCESS_SECRET = randomBytes(32);
+const spentClaimGateGraphApplyAuthorityNonces = new Set<string>();
+
+function stableStringify(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? 'null';
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`).join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(stableStringify(value)).digest('hex')}`;
+}
+
+function mac(value: unknown): string {
+  return `hmac-sha256:${createHmac('sha256', HOST_GRAPH_PATCH_PROCESS_SECRET).update(stableStringify(value)).digest('hex')}`;
+}
+
+function timingSafeHexEqual(left: string, right: string): boolean {
+  const leftBuffer = Buffer.from(left, 'hex');
+  const rightBuffer = Buffer.from(right, 'hex');
+  return leftBuffer.length === rightBuffer.length && timingSafeEqual(leftBuffer, rightBuffer);
 }
 
-export async function handler(args: PatchArgs) {
+export function graphPatchOperationHash(operations: GraphOperation[]): string {
+  return sha256(operations);
+}
+
+function authorityPayload(authority: Omit<ClaimGateGraphApplyPlanAuthority, 'payloadHash' | 'mac'>) {
+  return authority;
+}
+
+export function issueClaimGateGraphApplyPlanAuthority(input: {
+  applyPlanReceiptId: string;
+  operations: GraphOperation[];
+}): ClaimGateGraphApplyPlanAuthority {
+  const unsigned = {
+    kind: 'ClaimGateGraphApplyPlanAuthority',
+    claimCeiling: 'host_graph_apply_plan_authority_not_transferable',
+    authority: 'lev_graph_patch_handler',
+    applyPlanReceiptId: input.applyPlanReceiptId,
+    operationHash: graphPatchOperationHash(input.operations),
+    operationCount: input.operations.length,
+    nonce: randomBytes(16).toString('hex'),
+    issuedAt: new Date().toISOString(),
+  } satisfies Omit<ClaimGateGraphApplyPlanAuthority, 'payloadHash' | 'mac'>;
+  const payloadHash = sha256(authorityPayload(unsigned));
+  return {
+    ...unsigned,
+    payloadHash,
+    mac: mac(authorityPayload(unsigned)),
+  };
+}
+
+function parsePatchArgs(args: PatchArgs | string[] | undefined): PatchArgs | null {
+  if (!args) return null;
+  if (Array.isArray(args)) {
+    if (args.includes('--help') || args.includes('-h')) return null;
+    const applyPlanReceiptFlag = args.find((arg) => arg.startsWith('--apply-plan-receipt-id='));
+    let applyPlanReceiptId = applyPlanReceiptFlag
+      ? applyPlanReceiptFlag.slice('--apply-plan-receipt-id='.length)
+      : undefined;
+    const applyPlanReceiptIndex = args.indexOf('--apply-plan-receipt-id');
+    if (!applyPlanReceiptId && applyPlanReceiptIndex >= 0 && args[applyPlanReceiptIndex + 1]) {
+      applyPlanReceiptId = args[applyPlanReceiptIndex + 1];
+    }
+    const applyPlanAuthorityFlag = args.find((arg) => arg.startsWith('--apply-plan-authority='));
+    let applyPlanAuthority = applyPlanAuthorityFlag
+      ? applyPlanAuthorityFlag.slice('--apply-plan-authority='.length)
+      : undefined;
+    const applyPlanAuthorityIndex = args.indexOf('--apply-plan-authority');
+    if (!applyPlanAuthority && applyPlanAuthorityIndex >= 0 && args[applyPlanAuthorityIndex + 1]) {
+      applyPlanAuthority = args[applyPlanAuthorityIndex + 1];
+    }
+    const operationsFlag = args.find((arg) => arg.startsWith('--operations='));
+    if (operationsFlag) return { operations: operationsFlag.slice('--operations='.length), applyPlanReceiptId, applyPlanAuthority };
+    const operationsIndex = args.indexOf('--operations');
+    if (operationsIndex >= 0 && args[operationsIndex + 1]) {
+      return { operations: args[operationsIndex + 1], applyPlanReceiptId, applyPlanAuthority };
+    }
+    const firstPositional = args.find((arg, index) => (
+      !arg.startsWith('--')
+      && index !== applyPlanReceiptIndex + 1
+      && index !== applyPlanAuthorityIndex + 1
+    ));
+    return firstPositional ? { operations: firstPositional, applyPlanReceiptId, applyPlanAuthority } : null;
+  }
+  if (typeof args.operations === 'string' && args.operations.trim().length > 0) return args;
+  return null;
+}
+
+function usage() {
+  return [
+    'Usage:',
+    '  lev graph graph-patch <operations-json>',
+    '  lev graph graph-patch --operations <operations-json>',
+    '  lev graph graph-patch --operations <operations-json> --apply-plan-receipt-id <receipt-id> --apply-plan-authority <json>',
+    '',
+    'Applies GraphOperation[] through the EntityGraph compositor pipeline.',
+  ].join('\n');
+}
+
+function hasVisibleText(value: string | undefined): value is string {
+  return typeof value === 'string' && value.replace(/\p{Cf}/gu, '').trim().length > 0;
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
