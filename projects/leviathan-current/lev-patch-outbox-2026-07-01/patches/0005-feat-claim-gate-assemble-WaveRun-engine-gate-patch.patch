+import { createHash } from 'node:crypto';
+import { mkdirSync, mkdtempSync, symlinkSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+import { describe, expect, it } from 'vitest';
+import {
+  skillSourceRecordToProjectionSurface,
+  validateSkillSourcePack,
+  type SkillSourcePack,
+  type SkillSourceRecord,
+} from '../contracts/source-pack-intake.js';
+
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function writeSkill(root: string, id: string, text = `---\nname: ${id}\n---\n# ${id}\n`): { path: string; text: string; hash: string } {
+  const dir = join(root, id);
+  mkdirSync(dir, { recursive: true });
+  const path = join(dir, 'SKILL.md');
+  writeFileSync(path, text);
+  return { path, text, hash: sha256Text(text) };
+}
+
+function goodRecord(root: string, id = 'tribunal'): SkillSourceRecord {
+  const skill = writeSkill(root, id);
+  return {
+    id,
+    title: id,
+    sourceRoot: root,
+    sourcePath: skill.path,
+    lifecycle: 'active',
+    sha256: skill.hash,
+    targetDomain: 'execution',
+    authority: 'advisory_source_pack_only',
+    executionProfile: 'hermes.tribunal.independent_comparison',
+    procedure: {
+      trigger: 'compare independent lanes',
+      readOrder: ['SKILL.md'],
+      requiredOutput: 'structured comparison receipt',
+      promotionRule: 'advisory_only_until_lev_receipt',
+      minimalTest: 'same prompt hash across lanes',
+    },
+    declaredClaims: {
+      promotion_allowed: false,
+    },
+  };
+}
+
+function pack(records: SkillSourceRecord[]): SkillSourcePack {
+  return {
+    schemaVersion: 'skill_source_pack_v1',
+    id: 'hermes-skills-fixture',
+    claimCeiling: 'reference_source_inventory_not_admitted',
+    authority: 'advisory_source_pack_only',
+    records,
+  };
+}
+
+describe('source-pack intake contracts', () => {
+  it('admits a hash-bound active Hermes skill only as reference source material', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-pack-'));
+    const record = goodRecord(root, 'tribunal');
+
+    const receipt = validateSkillSourcePack(pack([record]));
+
+    expect(receipt).toEqual({
+      kind: 'SourcePackAdmissionReceipt',
+      claimCeiling: 'reference_source_inventory_not_admitted',
+      authority: 'advisory_source_pack_only',
+      ok: true,
+      admittedRecordIds: ['tribunal'],
+      purgatory: [],
+      findings: [],
+    });
+
+    expect(skillSourceRecordToProjectionSurface(record)).toEqual(expect.objectContaining({
+      id: 'skill-source:tribunal',
+      surfaceKind: 'skill',
+      contentHash: record.sha256,
+      declaredContentHash: record.sha256,
+      probeOutputs: expect.objectContaining({
+        lifecycle: 'active',
+        targetDomain: 'execution',
+        executionProfile: 'hermes.tribunal.independent_comparison',
+      }),
+    }));
+  });
+
+  it('blocks hash mismatch, self-promotion, and missing procedure fields', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-bad-'));
+    const record = {
+      ...goodRecord(root, 'moa'),
+      sha256: 'sha256:not-the-file',
+      declaredClaims: {
+        host_consumed: true,
+      },
+      procedure: {
+        trigger: '',
+        readOrder: [],
+      },
+    };
+
+    const receipt = validateSkillSourcePack(pack([record]));
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedRecordIds).toEqual([]);
+    expect(receipt.findings.map((finding) => finding.code)).toEqual(expect.arrayContaining([
+      'source_hash_mismatch',
+      'source_self_promotion_blocked',
+      'procedure_extract_missing_fields',
+    ]));
+  });
+
+  it('routes active/archive collisions into nonterminal purgatory instead of merging them', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-conflict-'));
+    const active = goodRecord(root, 'wizard');
+    const archivedSkill = writeSkill(root, 'archive-wizard', 'archived wizard\n');
+    const archived: SkillSourceRecord = {
+      ...active,
+      sourcePath: archivedSkill.path,
+      sha256: archivedSkill.hash,
+      lifecycle: 'archived',
+    };
+
+    const receipt = validateSkillSourcePack(pack([active, archived]));
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedRecordIds).toEqual([]);
+    expect(receipt.purgatory).toEqual([
+      expect.objectContaining({
+        kind: 'SkillSourcePurgatoryRecord',
+        recordId: 'wizard',
+        reason: 'active_archive_conflict',
+        terminal: false,
+      }),
+    ]);
+    expect(receipt.findings.map((finding) => finding.code)).toEqual(expect.arrayContaining([
+      'active_archive_conflict',
+      'archived_record_reference_only',
+    ]));
+  });
+
+  it('rejects symlink escapes outside the declared source root', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-root-'));
+    const outside = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-outside-'));
+    const outsideSkill = writeSkill(outside, 'outside');
+    const linkDir = join(root, 'linked-outside');
+    symlinkSync(outsideSkill.path, linkDir);
+
+    const record: SkillSourceRecord = {
+      ...goodRecord(root, 'inside'),
+      id: 'escape',
+      sourcePath: linkDir,
+      sha256: outsideSkill.hash,
+    };
+
+    const receipt = validateSkillSourcePack(pack([record]));
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.findings.map((finding) => finding.code)).toContain('source_path_outside_root');
+  });
+
+  it('uses deterministic cross-gate joins and vetoes blank reasons', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-gates-'));
+    const left = goodRecord(root, 'tribunal');
+    const right = goodRecord(root, 'moa');
+    const input = pack([left, right]);
+    input.gateResults = [
+      { gateId: 'source_hash', status: 'pass', recordIds: ['tribunal', 'moa'], reason: 'hashes verified' },
+      { gateId: 'execution_profile', status: 'pass', recordIds: ['tribunal'], reason: 'tribunal profile only' },
+      { gateId: 'blank', status: 'uncertain', recordIds: ['moa'], reason: '' },
+    ];
+    input.syntheses = [
+      {
+        id: 'fabricated_join',
+        gateIds: ['source_hash', 'execution_profile'],
+        claimedSurvivorRecordIds: ['tribunal', 'moa'],
+      },
+    ];
+
+    const receipt = validateSkillSourcePack(input);
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedRecordIds).toEqual([]);
+    expect(receipt.findings.map((finding) => finding.code)).toEqual(expect.arrayContaining([
+      'blank_reason_field_veto',
+      'cross_gate_synthesis_mismatch',
+    ]));
+    expect(receipt.findings.find((finding) => finding.code === 'cross_gate_synthesis_mismatch')?.detail)
+      .toContain('computed tribunal');
+  });
+
+  it('fails stale and mutating read-only audit receipts', () => {
+    const root = mkdtempSync(join(tmpdir(), 'lev-hermes-skill-freshness-'));
+    const record = {
+      ...goodRecord(root, 'freshness'),
+      sourceMtimeMs: 200,
+      verifiedAtMs: 100,
+      readOnlyAudit: [
+        {
+          id: 'inventory-json',
+          path: '/tmp/inventory.json',
+          hashBefore: 'sha256:before',
+          hashAfter: 'sha256:after',
+          mtimeMsBefore: 10,
+          mtimeMsAfter: 11,
+        },
+      ],
+    };
+
+    const receipt = validateSkillSourcePack(pack([record]));
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.findings.map((finding) => finding.code)).toEqual(expect.arrayContaining([
+      'audit_older_than_source',
+      'read_only_audit_modified_hash',
+      'read_only_audit_touched_mtime',
+    ]));
+  });
+});
diff --git a/core/graph/src/contracts/formal-skill-set.ts b/core/graph/src/contracts/formal-skill-set.ts
new file mode 100644
index 000000000..02341d968
--- /dev/null
+++ b/core/graph/src/contracts/formal-skill-set.ts
@@ -0,0 +1,340 @@
+import { createHash } from 'node:crypto';
+import type { ProjectionSurface } from './projection-binding.js';
+import type {
+  ExecutionProfileFamily,
+  SkillSourcePack,
+  SourcePackAdmissionReceipt,
+} from './source-pack-intake.js';
+
+export type FormalSkillSetClaimCeiling = 'formal_skill_set_candidate_not_runtime_loaded';
+export type FormalSkillSetAuthority = 'proposal_only_until_loader_receipt';
+
+export type FormalSkillOutputKind =
+  | 'finding'
+  | 'failure_packet'
+  | 'proposal'
+  | 'receipt'
+  | 'repair_plan';
+
+export type GraphMutationBoundary = 'none' | 'proposal_only' | 'direct_apply';
+
+export type FormalSkillContract = {
+  requiredFields: string[];
+  schemaRef?: string;
+};
+
+export type FormalSkillOutputContract = FormalSkillContract & {
+  kind: FormalSkillOutputKind;
+  graphMutation: GraphMutationBoundary;
+};
+
+export type FormalSkillGateContract = {
+  gateIds: string[];
+  failureCodes: string[];
+  promotionBoundary: string;
+};
+
+export type FormalSkillRequeuePolicy = {
+  routes: string[];
+  maxAttempts: number;
+};
+
+export type FormalSkill = {
+  id: string;
+  sourceRecordId: string;
+  name: string;
+  role: string;
+  authorityBoundary: string;
+  capabilityRefs: string[];
+  mmmRefs: string[];
+  sourceRefs: string[];
+  toolRefs: string[];
+  inputContract: FormalSkillContract;
+  outputContract: FormalSkillOutputContract;
+  gateContract: FormalSkillGateContract;
+  requeuePolicy: FormalSkillRequeuePolicy;
+  receiptTarget: string;
+  executionProfile?: ExecutionProfileFamily;
+};
+
+export type FormalSkillBundleKind =
+  | 'council'
+  | 'subcouncil'
+  | 'team'
+  | 'execution_profile';
+
+export type FormalSkillBundle = {
+  id: string;
+  kind: FormalSkillBundleKind;
+  purpose: string;
+  skillIds: string[];
+  executionProfile?: ExecutionProfileFamily;
+};
+
+export type FormalSkillSet = {
+  schemaVersion: 'formal_skill_set_v1';
+  id: string;
+  claimCeiling: FormalSkillSetClaimCeiling;
+  authority: FormalSkillSetAuthority;
+  sourcePackId: string;
+  skills: FormalSkill[];
+  bundles: FormalSkillBundle[];
+};
+
+export type FormalSkillSetFinding = {
+  code: string;
+  skillId?: string;
+  bundleId?: string;
+  detail: string;
+};
+
+export type FormalSkillSetReceipt = {
+  kind: 'FormalSkillSetReceipt';
+  claimCeiling: FormalSkillSetClaimCeiling;
+  authority: FormalSkillSetAuthority;
+  ok: boolean;
+  admittedSkillIds: string[];
+  admittedBundleIds: string[];
+  skillSetHash: string;
+  findings: FormalSkillSetFinding[];
+};
+
+export type FormalSkillSetValidationOptions = {
+  maxSkills?: number;
+  maxBundleSize?: number;
+  maxRequeueAttempts?: number;
+};
+
+const DEFAULT_MAX_SKILLS = 200;
+const DEFAULT_MAX_BUNDLE_SIZE = 40;
+const DEFAULT_MAX_REQUEUE_ATTEMPTS = 10;
+
+function stableJson(value: unknown): string {
+  return JSON.stringify(normalizeForStableJson(value));
+}
+
+function normalizeForStableJson(value: unknown): unknown {
+  if (Array.isArray(value)) {
+    return value.map((entry) => normalizeForStableJson(entry));
+  }
+
+  if (value && typeof value === 'object') {
+    return Object.fromEntries(
+      Object.entries(value as Record<string, unknown>)
+        .sort(([left], [right]) => left.localeCompare(right))
+        .map(([key, entry]) => [key, normalizeForStableJson(entry)]),
+    );
+  }
+
+  return value;
+}
+
+function hashStable(value: unknown): string {
+  return `sha256:${createHash('sha256').update(stableJson(value)).digest('hex')}`;
+}
+
+function hasText(value: unknown): value is string {
+  return typeof value === 'string' && value.trim().length > 0;
+}
+
+function nonEmptyStringArray(value: unknown): value is string[] {
+  return Array.isArray(value) && value.length > 0 && value.every(hasText);
+}
+
+function finiteAttempts(value: number, max: number): boolean {
+  return Number.isInteger(value) && value >= 0 && value <= max;
+}
+
+function addMissingText(findings: FormalSkillSetFinding[], skill: FormalSkill, field: keyof FormalSkill): void {
+  if (!hasText(skill[field])) {
+    findings.push({
+      code: 'skill_missing_required_field',
+      skillId: skill.id,
+      detail: String(field),
+    });
+  }
+}
+
+function admittedSourceIds(sourceReceipt: SourcePackAdmissionReceipt): Set<string> {
+  return new Set(sourceReceipt.ok ? sourceReceipt.admittedRecordIds : []);
+}
+
+export function validateFormalSkillSet(
+  skillSet: FormalSkillSet,
+  sourcePack: SkillSourcePack,
+  sourceReceipt: SourcePackAdmissionReceipt,
+  options: FormalSkillSetValidationOptions = {},
+): FormalSkillSetReceipt {
+  const findings: FormalSkillSetFinding[] = [];
+  const maxSkills = options.maxSkills ?? DEFAULT_MAX_SKILLS;
+  const maxBundleSize = options.maxBundleSize ?? DEFAULT_MAX_BUNDLE_SIZE;
+  const maxRequeueAttempts = options.maxRequeueAttempts ?? DEFAULT_MAX_REQUEUE_ATTEMPTS;
+
+  if (skillSet.schemaVersion !== 'formal_skill_set_v1') {
+    findings.push({ code: 'invalid_schema_version', detail: 'schemaVersion must be formal_skill_set_v1' });
+  }
+  if (skillSet.claimCeiling !== 'formal_skill_set_candidate_not_runtime_loaded') {
+    findings.push({ code: 'invalid_claim_ceiling', detail: 'claimCeiling must stay below runtime loading' });
+  }
+  if (skillSet.authority !== 'proposal_only_until_loader_receipt') {
+    findings.push({ code: 'invalid_authority', detail: 'formal skills cannot self-load or self-promote' });
+  }
+  if (skillSet.sourcePackId !== sourcePack.id) {
+    findings.push({ code: 'source_pack_id_mismatch', detail: 'skill set must bind to the source pack it was extracted from' });
+  }
+  if (!sourceReceipt.ok) {
+    findings.push({ code: 'source_pack_receipt_not_clean', detail: 'formal skills require a clean source-pack receipt' });
+  }
+  if (skillSet.skills.length > maxSkills) {
+    findings.push({ code: 'skill_budget_exceeded', detail: `skills ${skillSet.skills.length} exceeds max ${maxSkills}` });
+  }
+
+  const admittedSources = admittedSourceIds(sourceReceipt);
+  const knownSourceRecords = new Set(sourcePack.records.map((record) => record.id));
+  const skillIds = new Set<string>();
+  const admittedSkillIds: string[] = [];
+
+  for (const skill of skillSet.skills) {
+    const before = findings.length;
+
+    if (skillIds.has(skill.id)) {
+      findings.push({ code: 'duplicate_skill_id', skillId: skill.id, detail: 'skill ids must be unique' });
+    }
+    skillIds.add(skill.id);
+
+    addMissingText(findings, skill, 'id');
+    addMissingText(findings, skill, 'sourceRecordId');
+    addMissingText(findings, skill, 'name');
+    addMissingText(findings, skill, 'role');
+    addMissingText(findings, skill, 'authorityBoundary');
+    addMissingText(findings, skill, 'receiptTarget');
+
+    if (!knownSourceRecords.has(skill.sourceRecordId)) {
+      findings.push({
+        code: 'skill_unknown_source_record',
+        skillId: skill.id,
+        detail: skill.sourceRecordId,
+      });
+    }
+    if (!admittedSources.has(skill.sourceRecordId)) {
+      findings.push({
+        code: 'skill_source_not_admitted',
+        skillId: skill.id,
+        detail: skill.sourceRecordId,
+      });
+    }
+
+    if (!nonEmptyStringArray(skill.capabilityRefs)) {
+      findings.push({ code: 'skill_missing_capability_refs', skillId: skill.id, detail: 'capabilityRefs must be non-empty' });
+    }
+    if (!nonEmptyStringArray(skill.mmmRefs)) {
+      findings.push({ code: 'skill_missing_mmm_refs', skillId: skill.id, detail: 'mmmRefs must be non-empty' });
+    }
+    if (!nonEmptyStringArray(skill.sourceRefs)) {
+      findings.push({ code: 'skill_missing_source_refs', skillId: skill.id, detail: 'sourceRefs must be non-empty' });
+    }
+    if (!nonEmptyStringArray(skill.toolRefs)) {
+      findings.push({ code: 'skill_missing_tool_refs', skillId: skill.id, detail: 'toolRefs must be non-empty' });
+    }
+    if (!nonEmptyStringArray(skill.inputContract.requiredFields)) {
+      findings.push({ code: 'skill_missing_input_contract', skillId: skill.id, detail: 'inputContract.requiredFields must be non-empty' });
+    }
+    if (!nonEmptyStringArray(skill.outputContract.requiredFields)) {
+      findings.push({ code: 'skill_missing_output_contract', skillId: skill.id, detail: 'outputContract.requiredFields must be non-empty' });
+    }
+    if (skill.outputContract.graphMutation === 'direct_apply') {
+      findings.push({
+        code: 'skill_direct_graph_apply_blocked',
+        skillId: skill.id,
+        detail: 'formal skills may output proposal_only graph mutations, never direct apply',
+      });
+    }
+    if (!nonEmptyStringArray(skill.gateContract.gateIds)) {
+      findings.push({ code: 'skill_missing_gate_contract', skillId: skill.id, detail: 'gateContract.gateIds must be non-empty' });
+    }
+    if (!nonEmptyStringArray(skill.gateContract.failureCodes)) {
+      findings.push({ code: 'skill_missing_failure_codes', skillId: skill.id, detail: 'gateContract.failureCodes must be non-empty' });
+    }
+    if (!hasText(skill.gateContract.promotionBoundary)) {
+      findings.push({ code: 'skill_missing_promotion_boundary', skillId: skill.id, detail: 'gateContract.promotionBoundary is required' });
+    }
+    if (!nonEmptyStringArray(skill.requeuePolicy.routes)) {
+      findings.push({ code: 'skill_missing_requeue_routes', skillId: skill.id, detail: 'requeuePolicy.routes must be non-empty' });
+    }
+    if (!finiteAttempts(skill.requeuePolicy.maxAttempts, maxRequeueAttempts)) {
+      findings.push({
+        code: 'skill_invalid_requeue_budget',
+        skillId: skill.id,
+        detail: `maxAttempts must be an integer between 0 and ${maxRequeueAttempts}`,
+      });
+    }
+
+    if (findings.length === before) admittedSkillIds.push(skill.id);
+  }
+
+  const admittedSkillSet = new Set(admittedSkillIds);
+  const bundleIds = new Set<string>();
+  const admittedBundleIds: string[] = [];
+
+  for (const bundle of skillSet.bundles) {
+    const before = findings.length;
+
+    if (bundleIds.has(bundle.id)) {
+      findings.push({ code: 'duplicate_bundle_id', bundleId: bundle.id, detail: 'bundle ids must be unique' });
+    }
+    bundleIds.add(bundle.id);
+
+    if (!hasText(bundle.id)) findings.push({ code: 'bundle_missing_id', bundleId: bundle.id, detail: 'id is required' });
+    if (!hasText(bundle.purpose)) findings.push({ code: 'bundle_missing_purpose', bundleId: bundle.id, detail: 'purpose is required' });
+    if (!nonEmptyStringArray(bundle.skillIds)) {
+      findings.push({ code: 'bundle_missing_skill_ids', bundleId: bundle.id, detail: 'skillIds must be non-empty' });
+    }
+    if (bundle.skillIds.length > maxBundleSize) {
+      findings.push({ code: 'bundle_budget_exceeded', bundleId: bundle.id, detail: `skillIds exceeds max ${maxBundleSize}` });
+    }
+    for (const skillId of bundle.skillIds) {
+      if (!skillIds.has(skillId)) {
+        findings.push({ code: 'bundle_unknown_skill', bundleId: bundle.id, detail: skillId });
+      } else if (!admittedSkillSet.has(skillId)) {
+        findings.push({ code: 'bundle_skill_not_admitted', bundleId: bundle.id, detail: skillId });
+      }
+    }
+
+    if (findings.length === before) admittedBundleIds.push(bundle.id);
+  }
+
+  return {
+    kind: 'FormalSkillSetReceipt',
+    claimCeiling: 'formal_skill_set_candidate_not_runtime_loaded',
+    authority: 'proposal_only_until_loader_receipt',
+    ok: findings.length === 0,
+    admittedSkillIds: admittedSkillIds.sort(),
+    admittedBundleIds: admittedBundleIds.sort(),
+    skillSetHash: hashStable(skillSet),
+    findings,
+  };
+}
+
+export function formalSkillToProjectionSurface(skill: FormalSkill, skillSetId: string): ProjectionSurface {
+  return {
+    id: `formal-skill:${skillSetId}:${skill.id}`,
+    surfaceKind: 'skill',
+    label: skill.name,
+    contentHash: hashStable(skill),
+    declaredContentHash: hashStable(skill),
+    probeOutputs: {
+      sourceRecordId: skill.sourceRecordId,
+      role: skill.role,
+      authorityBoundary: skill.authorityBoundary,
+      capabilityRefs: skill.capabilityRefs,
+      mmmRefs: skill.mmmRefs,
+      sourceRefs: skill.sourceRefs,
+      toolRefs: skill.toolRefs,
+      executionProfile: skill.executionProfile ?? null,
+      outputKind: skill.outputContract.kind,
+      graphMutation: skill.outputContract.graphMutation,
+      promotion_allowed: false,
+      formal_admission_allowed: false,
+    },
+  };
+}
