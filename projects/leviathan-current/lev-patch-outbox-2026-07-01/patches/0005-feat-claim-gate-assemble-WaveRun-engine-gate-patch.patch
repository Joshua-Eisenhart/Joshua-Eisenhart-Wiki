@@ -0,0 +1,350 @@
+import { createHash } from 'node:crypto';
+import { mkdirSync, mkdtempSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+import { describe, expect, it } from 'vitest';
+import {
+  validateLevEngineSubstrateDigest,
+  validateThreeEngineProbeEnvelope,
+  type LevEngineSubstrateDigest,
+  type MechanicalProbeReceiptEvidence,
+  type ThreeEngineLane,
+  type ThreeEngineProbeEnvelope,
+} from '../contracts/projection-binding.js';
+import {
+  validateSkillSourcePack,
+  type SkillSourcePack,
+  type SkillSourceRecord,
+} from '../contracts/source-pack-intake.js';
+import {
+  validateMechanicalProbeRunReceipt,
+  type MechanicalProbeRunReceipt,
+} from '../probes/mechanical-probe-runner.js';
+
+function sha256Text(value: string): string {
+  return `sha256:${createHash('sha256').update(value).digest('hex')}`;
+}
+
+function sha256Json(value: unknown): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(value)).digest('hex')}`;
+}
+
+function writeSkillSource(root: string, id: string): { path: string; text: string; hash: string } {
+  const skillDir = join(root, id);
+  mkdirSync(skillDir, { recursive: true });
+  const text = `---\nname: ${id}\n---\n# ${id}\n`;
+  const path = join(skillDir, 'SKILL.md');
+  writeFileSync(path, text);
+  return { path, text, hash: sha256Text(text) };
+}
+
+function skillSourcePack(record: SkillSourceRecord): SkillSourcePack {
+  return {
+    schemaVersion: 'skill_source_pack_v1',
+    id: 'claim-gate-redteam-skill-source-pack',
+    claimCeiling: 'reference_source_inventory_not_admitted',
+    authority: 'advisory_source_pack_only',
+    records: [record],
+  };
+}
+
+function laneFor(
+  engine: 'julia' | 'jax' | 'pytorch',
+  role: ThreeEngineLane['role'],
+  sourceRef: string,
+  stdout: string,
+): ThreeEngineLane {
+  return {
+    role,
+    ran: true,
+    sourceRef,
+    inputHash: sha256Text(`${engine}:input`),
+    outputHash: sha256Text(stdout),
+    readsPeerResult: false,
+    alignedPackagesLoadBearing: [`${engine}:runtime`],
+    negativeControl: `${engine}:negative-control`,
+    gateEffect: 'can_resolve_uncertain',
+  };
+}
+
+function receiptFor(
+  engine: 'julia' | 'jax' | 'pytorch',
+  role: ThreeEngineLane['role'],
+  sourcePath: string,
+  stdout = `${engine}:primary-ok\n`,
+): MechanicalProbeReceiptEvidence {
+  const sourceRef = `file:${sourcePath}`;
+  const lane = laneFor(engine, role, sourceRef, stdout);
+  const stderr = '';
+  const controlStdout = `${engine}:control-ok\n`;
+  const controlPath = `${sourcePath}.negative-control`;
+
+  return {
+    kind: 'MechanicalProbeRunReceipt',
+    claimCeiling: 'mechanical_probe_run_receipt_not_proof_authority',
+    engine,
+    command: `/usr/bin/${engine}`,
+    args: [sourcePath],
+    sourceRef,
+    sourceFilePath: sourcePath,
+    sourceHash: sha256Text(`${engine}:source`),
+    sourceRefFileRead: true,
+    sourceTextMatchesFile: true,
+    sourceRefBoundToCommand: true,
+    inputHash: lane.inputHash,
+    outputHash: lane.outputHash,
+    stderrHash: sha256Text(stderr),
+    exitCode: 0,
+    signal: null,
+    timedOut: false,
+    durationMs: 1,
+    stdout,
+    stderr,
+    lane,
+    executedNegativeControl: {
+      id: `${engine}:executed-negative-control`,
+      command: `/usr/bin/${engine}`,
+      args: [controlPath],
+      sourceRef: `file:${controlPath}`,
+      sourceFilePath: controlPath,
+      sourceHash: sha256Text(`${engine}:control-source`),
+      sourceRefFileRead: true,
+      sourceTextMatchesFile: true,
+      sourceRefBoundToCommand: true,
+      inputHash: sha256Text(`${engine}:control-input`),
+      outputHash: sha256Text(controlStdout),
+      stderrHash: sha256Text(stderr),
+      exitCode: 0,
+      signal: null,
+      timedOut: false,
+      durationMs: 1,
+      stdout: controlStdout,
+      stderr,
+      expectedOutputIncludes: [],
+      expectedOutputExcludes: [],
+      outputDiffersFromPrimary: true,
+      passed: true,
+    },
+    outputArtifacts: [],
+  };
+}
+
+function envelopeFor(carrierPath: string): ThreeEngineProbeEnvelope {
+  const julia = receiptFor(
+    'julia',
+    'exact_algebraic_canon',
+    `${carrierPath}/probe.jl`,
+  );
+  const jax = receiptFor(
+    'jax',
+    'batched_geometry_workhorse',
+    `${carrierPath}/probe.py`,
+  );
+  const pytorch = receiptFor(
+    'pytorch',
+    'graph_tensor_autograd_probe',
+    `${carrierPath}/probe_torch.py`,
+  );
+
+  return {
+    schemaVersion: 'three_engine_probe_envelope_v1',
+    mode: 'all_three_full_sims',
+    claimCeiling: 'mechanical_probe_evidence_not_proof_authority',
+    transformClaim: 'reference carrier paths are not Lev runtime authority',
+    runtimeCarrier: {
+      claimCeiling: 'carrier_path_receipted_not_current_corpus_proof',
+      carrierPath,
+      pathSource: 'default:lev-native-sim-engine-carrier',
+      explicitOverride: false,
+      sourceRefs: {
+        julia: julia.sourceRef,
+        jax: jax.sourceRef,
+        pytorch: pytorch.sourceRef,
+      },
+    },
+    mechanicalProbeRunReceiptHashes: {
+      julia: sha256Json(julia),
+      jax: sha256Json(jax),
+      pytorch: sha256Json(pytorch),
+    },
+    mechanicalProbeReceipts: {
+      julia,
+      jax,
+      pytorch,
+    },
+    engines: {
+      julia: julia.lane,
+      jax: jax.lane,
+      pytorch: pytorch.lane,
+    },
+    divergence: {
+      juliaAuthoritative: true,
+      maxDivergence: 0,
+    },
+  };
+}
+
+describe('ClaimGate red-team graph targets', () => {
+  it('A1 rejects self-attested sourceRefBoundToCommand when command args do not execute that source', () => {
+    const receipt = receiptFor('julia', 'exact_algebraic_canon', '/tmp/lev-a1/probe.jl');
+    const forged = {
+      ...receipt,
+      args: ['/tmp/lev-a1/different-probe.jl'],
+      sourceRefBoundToCommand: true,
+    };
+
+    expect(validateMechanicalProbeRunReceipt(forged, { requireExecutedNegativeControl: true })).toEqual({
+      ok: false,
+      findings: expect.arrayContaining([
+        'sourceRef must be bound to executed command args',
+        'sourceRefBoundToCommand must match command args',
+      ]),
+    });
+  });
+
+  it('A2 rejects embedded negative-control labels when no executed control receipt exists', () => {
+    const receipt = receiptFor('julia', 'exact_algebraic_canon', '/tmp/lev-a2/probe.jl');
+    const forged = {
+      ...receipt,
+      executedNegativeControl: undefined,
+      allowEmbeddedNegativeControl: true,
+    } as unknown as MechanicalProbeRunReceipt;
+
+    expect(validateMechanicalProbeRunReceipt(forged, { requireExecutedNegativeControl: true })).toEqual({
+      ok: false,
+      findings: expect.arrayContaining([
+        'executedNegativeControl is required',
+      ]),
+    });
+  });
+
+  it('A4/A5 rejects self-attested negative-control success when the control output equals the primary output', () => {
+    const receipt = receiptFor('jax', 'batched_geometry_workhorse', '/tmp/lev-a4-a5/probe.py');
+    const forged = {
+      ...receipt,
+      executedNegativeControl: {
+        ...receipt.executedNegativeControl!,
+        stdout: receipt.stdout,
+        outputHash: receipt.outputHash,
+        outputDiffersFromPrimary: true,
+        passed: true,
+      },
+    };
+
+    expect(validateMechanicalProbeRunReceipt(forged, { requireExecutedNegativeControl: true })).toEqual({
+      ok: false,
+      findings: expect.arrayContaining([
+        'executedNegativeControl.outputDiffersFromPrimary must match output hashes',
+        'executedNegativeControl output must differ from primary output',
+        'executedNegativeControl.passed must match recomputed status',
+        'executedNegativeControl must pass',
+      ]),
+    });
+  });
+
+  it('A11 rejects skill source-pack refs that resolve outside the declared root into a reference repo tree', () => {
+    const declaredRoot = mkdtempSync(join(tmpdir(), 'lev-a11-source-root-'));
+    const referenceRoot = mkdtempSync(join(tmpdir(), 'Codex-Ratchet-a11-reference-'));
+    const skill = writeSkillSource(referenceRoot, 'route-laundered-skill');
+    const record: SkillSourceRecord = {
+      id: 'route-laundered-skill',
+      title: 'route-laundered-skill',
+      sourceRoot: declaredRoot,
+      sourcePath: skill.path,
+      lifecycle: 'active',
+      sha256: skill.hash,
+      targetDomain: 'execution',
+      authority: 'advisory_source_pack_only',
+      executionProfile: 'external.cli_coding_agent_worker',
+      procedure: {
+        trigger: 'attempt to launder an outside reference repo through a skill source pack',
+        readOrder: ['SKILL.md'],
+        requiredOutput: 'should never be admitted',
+        promotionRule: 'blocked_when_source_path_is_outside_declared_root',
+        minimalTest: 'source root containment must fail closed',
+      },
+    };
+
+    const receipt = validateSkillSourcePack(skillSourcePack(record));
+
+    expect(receipt.ok).toBe(false);
+    expect(receipt.admittedRecordIds).toEqual([]);
+    expect(receipt.findings.map((finding) => finding.code)).toContain('source_path_outside_root');
+  });
+
+  it('A8 rejects reference repositories as three-engine runtime carriers even when pathSource claims Lev-native provenance', () => {
+    const envelope = envelopeFor('/Users/joshuaeisenhart/CoDeX-RaTcHeT/system_v5/julia_carrier');
+
+    expect(validateThreeEngineProbeEnvelope(envelope)).toEqual({
+      ok: false,
+      findings: expect.arrayContaining([
+        'runtimeCarrier.carrierPath points at reference/provenance material (/codex-ratchet/)',
+        'runtimeCarrier.sourceRefs.julia points at reference/provenance material (/codex-ratchet/)',
+        'runtimeCarrier.sourceRefs.jax points at reference/provenance material (/codex-ratchet/)',
+        'runtimeCarrier.sourceRefs.pytorch points at reference/provenance material (/codex-ratchet/)',
+      ]),
+    });
+  });
+
+  it('A9 rejects a CR carrierPath even when pathSource is the non-blocklisted Lev-native default', () => {
+    const envelope = envelopeFor('/Users/joshuaeisenhart/Codex-Ratchet/system_v5/julia_carrier');
+
+    expect(envelope.runtimeCarrier?.pathSource).toBe('default:lev-native-sim-engine-carrier');
+    expect(validateThreeEngineProbeEnvelope(envelope)).toEqual({
+      ok: false,
+      findings: expect.arrayContaining([
+        'runtimeCarrier.carrierPath points at reference/provenance material (/codex-ratchet/)',
+        'runtimeCarrier.sourceRefs.julia points at reference/provenance material (/codex-ratchet/)',
+      ]),
+    });
+  });
+
+  it('A8 rejects reference repositories as Lev engine-substrate runtime carriers', () => {
+    const envelope = envelopeFor('/Users/joshuaeisenhart/Codex-Ratchet/system_v5/julia_carrier');
+    const digest: LevEngineSubstrateDigest = {
+      kind: 'LevEngineSubstrateDigest',
+      schemaVersion: 'lev_engine_substrate_digest_v1',
+      claimCeiling: 'engine_substrate_digest_not_proof_authority',
+      runtimeOwner: 'lev',
+      computeDomains: ['graph'],
+      intendedConsumers: ['graph'],
+      sourcePolicy: {
+        codexRatchet: 'reference_only',
+        wiki: 'reference_only',
+        hermes: 'skill_procedure_only',
+      },
+      runtimeCarrier: envelope.runtimeCarrier!,
+      receipts: {
+        julia: envelope.mechanicalProbeReceipts!.julia!,
+        jax: envelope.mechanicalProbeReceipts!.jax!,
+        pytorch: envelope.mechanicalProbeReceipts!.pytorch!,
+      },
+      receiptHashes: {
+        julia: envelope.mechanicalProbeRunReceiptHashes!.julia,
+        jax: envelope.mechanicalProbeRunReceiptHashes!.jax,
+        pytorch: envelope.mechanicalProbeRunReceiptHashes!.pytorch!,
+      },
+      lanes: {
+        julia: envelope.engines.julia,
+        jax: envelope.engines.jax,
+        pytorch: envelope.engines.pytorch!,
+      },
+      graphInvariants: {
+        nodeCount: 4,
+        edgeCount: 4,
+        juliaAlgebraicConnectivity: 2,
+        jaxMessagePassing: [6, 4, 6, 4],
+        pytorchAutogradGradient: [2, 2, 2, 2],
+      },
+    };
+
+    expect(validateLevEngineSubstrateDigest(digest)).toEqual({
