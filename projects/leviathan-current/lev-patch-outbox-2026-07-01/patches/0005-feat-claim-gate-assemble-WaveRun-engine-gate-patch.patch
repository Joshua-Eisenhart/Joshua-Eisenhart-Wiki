index 000000000..ea8e03b17
--- /dev/null
+++ b/core/orchestration/src/proof/host-trust-secret.ts
@@ -0,0 +1,130 @@
+import { createHmac, randomBytes, timingSafeEqual } from 'node:crypto';
+import { chmodSync, existsSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';
+import { dirname, join } from 'node:path';
+
+/**
+ * Cross-process host-trust root secret.
+ *
+ * The ClaimGate trust ledgers (host-trust, host-graph-event-trust, host-witness,
+ * wave-run-host-consume) each currently sign their entries with a module-level
+ * `randomBytes(32)` generated fresh per process. That makes every ledger entry
+ * unforgeable by a caller — but ALSO unverifiable in any OTHER process, because a
+ * second process generates a different secret. So trust does not survive a process
+ * boundary: a host-consumed receipt minted by one `lev` invocation cannot be
+ * validated by the next, which blocks the recursive WaveRun "next-seed wave"
+ * (seed -> new process -> re-validate prior host consume).
+ *
+ * This module provides the smallest fix: a single persisted, file-sealed root
+ * secret per Lev project root, plus domain-separated subkeys derived from it. A
+ * MAC minted in one process now validates in another, because both load the same
+ * persisted root. Domain separation (HKDF-style HMAC over a domain label) keeps the
+ * four ledgers cryptographically independent, so a signing-surface weakness in one
+ * domain does not transfer to another.
+ *
+ * SECURITY POSTURE / TRADEOFF (read before wiring): persisting the secret moves the
+ * threat model from "unforgeable even by the operator within a single process" to
+ * "unforgeable unless you can read a host-owned 0600 file". That is the correct
+ * boundary for the gate's actual job — stop caller-supplied JSON and adapter
+ * placeholder refs from minting trust — because the secret file is outside the
+ * caller's JSON-input path. It is NOT isolation against the host OS user. If a
+ * stronger posture is required, the alternative is asymmetric: persist a sealed
+ * private key, sign ledger entries with it, verify with a published public key, so
+ * "can verify" (any process) is separated from "can mint" (private-key holder only).
+ * That is deliberately NOT built here — this is the smallest persisted-shared-secret
+ * change that makes the existing symmetric-MAC ledgers cross-process.
+ *
+ * This module is pure with respect to the rest of the spine: it imports nothing from
+ * claim-gate-loop.ts / claim-gate-wave-runner.ts / claim-gate-steering-run.ts and
+ * takes `projectRoot` as a parameter, so it can be wired into each ledger without a
+ * circular dependency and without touching files another builder owns.
+ */
+
+const SECRET_BYTES = 32;
+
+/** Path of the sealed root secret relative to the Lev project root. */
+export const HOST_TRUST_ROOT_SECRET_REL_PATH = join('.lev', 'context', '.host-trust-root-secret');
+
+/**
+ * In-process cache keyed by the absolute secret-file path, so repeated calls within
+ * one process return the same buffer without re-reading the file. A fresh process
+ * starts with an empty cache and re-loads from the file -- which is exactly how the
+ * secret crosses the process boundary.
+ */
+const rootSecretCache = new Map<string, Buffer>();
+
+export function hostTrustRootSecretPath(projectRoot: string): string {
+  return join(projectRoot, HOST_TRUST_ROOT_SECRET_REL_PATH);
+}
+
+/**
+ * Load the persisted host-trust root secret for a project root, creating it (0600)
+ * on first use. The returned 32-byte secret is stable within a process AND across
+ * processes that share the same project root, so HMACs minted in one process
+ * validate in the next.
+ */
+export function loadOrCreateHostTrustRootSecret(projectRoot: string): Buffer {
+  const file = hostTrustRootSecretPath(projectRoot);
+  const cached = rootSecretCache.get(file);
+  if (cached) return cached;
+
+  let secret: Buffer;
+  if (existsSync(file)) {
+    secret = readFileSync(file);
+    if (secret.length !== SECRET_BYTES) {
+      throw new Error(
+        `Host trust root secret at ${file} is ${secret.length} bytes; expected ${SECRET_BYTES}. Refusing to derive trust keys from a malformed secret.`,
+      );
+    }
+  } else {
+    secret = randomBytes(SECRET_BYTES);
+    mkdirSync(dirname(file), { recursive: true });
+    // wx => fail if another process created it between existsSync and write,
+    // so two racing processes converge on a single secret rather than clobbering.
+    try {
+      writeFileSync(file, secret, { mode: 0o600, flag: 'wx' });
+    } catch {
+      secret = readFileSync(file);
+      if (secret.length !== SECRET_BYTES) {
+        throw new Error(
+          `Host trust root secret at ${file} is ${secret.length} bytes after a concurrent create; expected ${SECRET_BYTES}.`,
+        );
+      }
+    }
+    // Enforce 0600 even if a widened umask or the concurrent writer left it broader.
+    chmodSync(file, 0o600);
+  }
+
+  rootSecretCache.set(file, secret);
+  return secret;
+}
+
+/**
+ * Domain-separated subkey for a single ledger, derived from the shared root secret.
+ * Each ledger passes a stable domain label (e.g. 'host-trust', 'host-graph-event-trust',
+ * 'host-witness', 'wave-run-host-consume'); the derived 32-byte key replaces that
+ * ledger's per-process `randomBytes(32)` while keeping the existing
+ * `hmac-sha256:<hex>` entry format unchanged.
+ */
+export function deriveHostTrustDomainKey(projectRoot: string, domain: string): Buffer {
+  if (!domain) throw new Error('deriveHostTrustDomainKey requires a non-empty domain label.');
+  const root = loadOrCreateHostTrustRootSecret(projectRoot);
+  return createHmac('sha256', root).update(`lev-host-trust-domain:${domain}`).digest();
+}
+
+/** Convenience: the canonical `hmac-sha256:<hex>` tag used by every existing ledger. */
+export function hostTrustDomainMac(projectRoot: string, domain: string, payload: string): string {
+  return `hmac-sha256:${createHmac('sha256', deriveHostTrustDomainKey(projectRoot, domain)).update(payload).digest('hex')}`;
+}
+
+/** Constant-time comparison of two `hmac-sha256:<hex>` tags. */
+export function timingSafeMacEqual(left: string, right: string): boolean {
+  const l = left.startsWith('hmac-sha256:') ? left.slice('hmac-sha256:'.length) : left;
+  const r = right.startsWith('hmac-sha256:') ? right.slice('hmac-sha256:'.length) : right;
+  if (!/^[0-9a-f]{64}$/i.test(l) || !/^[0-9a-f]{64}$/i.test(r)) return false;
+  return timingSafeEqual(Buffer.from(l, 'hex'), Buffer.from(r, 'hex'));
+}
+
+/** Test-only: clear the in-process cache to simulate a fresh process re-loading the file. */
+export function resetHostTrustRootSecretCacheForTests(): void {
+  rootSecretCache.clear();
+}
