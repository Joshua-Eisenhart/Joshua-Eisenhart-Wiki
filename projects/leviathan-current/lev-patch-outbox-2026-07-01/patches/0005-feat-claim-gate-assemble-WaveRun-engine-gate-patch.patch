+function evaluateGateLoopReopenDecisions(input: ClaimGateWavegraphSliceInput): ClaimGateLoopStateReopenDecision[] {
+  const requests = input.gateLoopReopenRequests ?? [];
+  if (requests.length === 0) return [];
+  if (!input.gateLoopState) return [];
+
+  const decisions: ClaimGateLoopStateReopenDecision[] = [];
+  let state = input.gateLoopState;
+  for (const request of requests) {
+    const decision = evaluateClaimGateLoopReopenRequest(state, request);
+    decisions.push(decision);
+    state = decision.nextState;
+  }
+  return decisions;
