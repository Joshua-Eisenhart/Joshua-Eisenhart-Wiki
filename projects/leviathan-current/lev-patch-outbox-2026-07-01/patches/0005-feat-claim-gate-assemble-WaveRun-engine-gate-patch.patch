+  )));
+}
+
+function dispatchTargetsForFormalSkill(input: LevWizardRatchetRunInput, skill: FormalSkillCandidate): {
+  targetMemberIds: string[];
+  targetModelLaneIds: string[];
+} {
+  const profileSkillRef = profileSurfaceSkillRef(skill);
+  const targetMemberIds = allWizardMembers(input)
+    .filter((member) => member.cognitiveBinding.skillRefs.some((ref) => (
+      formalSkillMatchesRef(skill, ref) || (profileSkillRef !== undefined && ref === profileSkillRef)
+    )))
+    .map((member) => member.memberId)
+    .sort();
+  const targetModelLaneIds = profileSurfaceModelLaneIds(input, skill).sort();
+  return { targetMemberIds, targetModelLaneIds };
+}
+
+function formalSkillSetReceiptFindings(receipt: FormalExecutionSkillSetRunReceipt): string[] {
+  const findings: string[] = [];
+  if (receipt.formalSkillSet && receipt.formalSkillSetReceipt) {
+    const expectedHash = sha256(receipt.formalSkillSet);
+    if (receipt.formalSkillSetReceipt.skillSetHash !== expectedHash) {
+      findings.push('formal_skill_set_hash_mismatch');
+    }
+  }
+  return findings;
+}
+
+function formalSkillSetReceiptIsConsistent(receipt: FormalExecutionSkillSetRunReceipt): boolean {
+  return formalSkillSetReceiptFindings(receipt).length === 0;
+}
+
+function formalSkillDispatchReceipts(
+  input: LevWizardRatchetRunInput,
+  receipts: FormalExecutionSkillSetRunReceipt[] | undefined,
+): LevWizardFormalSkillDispatchReceipt[] {
+  const dispatchReceipts: LevWizardFormalSkillDispatchReceipt[] = [];
+  for (const receipt of receipts ?? []) {
+    const formalSkillSet = receipt.formalSkillSet;
+    const formalReceipt = receipt.formalSkillSetReceipt;
+    if (!formalSkillSet || !formalReceipt?.ok) continue;
+    if (!formalSkillSetReceiptIsConsistent(receipt)) continue;
+    const admitted = new Set(formalReceipt.admittedSkillIds);
+    for (const skill of formalSkillSet.skills) {
+      if (!skill.executionProfile || !admitted.has(skill.id)) continue;
+      const { targetMemberIds, targetModelLaneIds } = dispatchTargetsForFormalSkill(input, skill);
+      const ok = targetMemberIds.length > 0 || targetModelLaneIds.length > 0;
+      const receiptRef = `receipt:formal-skill-dispatch:${receipt.packId}:${skill.id}`;
+      const payload = {
+        kind: 'LevWizardFormalSkillDispatchReceipt' as const,
+        receiptRef,
+        skillId: skill.id,
+        sourceRecordId: skill.sourceRecordId,
+        executionProfile: skill.executionProfile,
+        sourcePackId: receipt.packId,
+        skillSetHash: formalReceipt.skillSetHash,
+        targetMemberIds,
+        targetModelLaneIds,
+        ok,
+      };
+      dispatchReceipts.push({
+        ...payload,
+        claimCeiling: 'formal_skill_loader_dispatch_not_live_worker_execution',
+        authority: 'loader_receipt_only_not_model_or_agent_output',
+        contentHash: sha256(payload),
+        ...(ok ? {} : { reason: 'No Wizard member or advisory model lane is bound to this formal skill execution profile.' }),
+      });
+    }
+  }
+  return dispatchReceipts.sort((left, right) => left.skillId.localeCompare(right.skillId));
+}
+
+export function wizardEvidenceManifestContextForInput(input: LevWizardRatchetRunInput): {
+  contextReceiptRefs: string[];
+  contextContentHashes: string[];
+} {
+  const dispatchReceipts = formalSkillDispatchReceipts(input, input.skillSourcePackReceipts)
+    .filter((receipt) => receipt.ok);
+  const memberUseReceipts = memberSourceUseReceipts(input);
+  return {
+    contextReceiptRefs: [
+      ...input.contextReceipts.map((receipt) => receipt.receiptRef),
+      ...dispatchReceipts.map((receipt) => receipt.receiptRef),
+      ...memberUseReceipts.map((receipt) => receipt.receiptRef),
+    ].sort(),
+    contextContentHashes: [
+      ...input.contextReceipts.map((receipt) => receipt.contentHash),
+      ...dispatchReceipts.map((receipt) => receipt.contentHash),
+      ...memberUseReceipts.map((receipt) => receipt.contentHash),
+    ].sort(),
+  };
+}
+
+function loadedContextForRefs(input: LevWizardRatchetRunInput, refs: string[]): LevWizardContextReceipt[] {
+  const wanted = new Set(refs);
+  return input.contextReceipts
+    .filter((receipt) => wanted.has(receipt.ref))
+    .sort((left, right) => left.ref.localeCompare(right.ref));
+}
+
+function memberSourceUseReceipts(input: LevWizardRatchetRunInput): LevWizardMemberSourceUseReceipt[] {
+  const dispatchReceipts = formalSkillDispatchReceipts(input, input.skillSourcePackReceipts)
+    .filter((receipt) => receipt.ok);
+  const receipts: LevWizardMemberSourceUseReceipt[] = [];
+
+  for (const wave of input.waves) {
+    for (const council of wave.councils) {
+      for (const subcouncil of council.subcouncils) {
+        for (const member of subcouncil.members) {
+          const bindingRefs = [
+            ...member.cognitiveBinding.mmmRefs,
+            ...member.cognitiveBinding.skillRefs,
+            ...member.cognitiveBinding.sourceRefs,
+          ];
+          const loadedContext = loadedContextForRefs(input, bindingRefs);
+          const memberDispatchReceipts = dispatchReceipts.filter((receipt) => (
+            receipt.targetMemberIds.includes(member.memberId)
+          ));
+          const receiptRef = `receipt:wizard-member-source-use:${wave.wave}:${member.memberId}`;
+          const payload = {
+            kind: 'LevWizardMemberSourceUseReceipt' as const,
+            receiptRef,
+            wave: wave.wave,
+            phase: wave.phase,
+            councilId: council.councilId,
+            subcouncilId: subcouncil.subcouncilId,
+            memberId: member.memberId,
+            mmmRefs: member.cognitiveBinding.mmmRefs.slice().sort(),
+            skillRefs: member.cognitiveBinding.skillRefs.slice().sort(),
+            sourceRefs: member.cognitiveBinding.sourceRefs.slice().sort(),
+            contextReceiptRefs: loadedContext.map((receipt) => receipt.receiptRef).sort(),
+            contextContentHashes: loadedContext.map((receipt) => receipt.contentHash).sort(),
+            formalSkillDispatchReceiptRefs: memberDispatchReceipts.map((receipt) => receipt.receiptRef).sort(),
+          };
+          receipts.push({
+            ...payload,
+            claimCeiling: 'member_source_use_receipt_not_live_worker_execution',
+            authority: 'context_loader_receipt_only_not_model_output',
+            contentHash: sha256(payload),
+          });
+        }
+      }
+    }
+  }
+
+  return receipts.sort((left, right) => left.receiptRef.localeCompare(right.receiptRef));
+}
