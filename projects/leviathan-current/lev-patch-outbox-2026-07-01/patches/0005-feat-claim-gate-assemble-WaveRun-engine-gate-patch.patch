+function outcomeFromLane(
+  lane: ClaimGateModelLaneManifest,
+  runtimeStatus: ClaimGateModelLaneRuntimeStatus,
+  patch: Partial<ClaimGateModelLaneRuntimeOutcome> = {},
+): ClaimGateModelLaneRuntimeOutcome {
+  return {
+    kind: 'ClaimGateModelLaneRuntimeOutcome',
+    laneId: lane.laneId,
+    provider: lane.provider,
+    model: lane.model,
+    family: lane.family,
+    purpose: lane.purpose,
+    promptHash: lane.promptHash,
+    inputDisclosure: lane.inputDisclosure,
+    outputSchema: lane.outputSchema,
+    costBudgetUsd: lane.costBudgetUsd,
+    authority: 'advisory_only',
+    runtimeStatus,
+    ...(lane.dataExportApprovalRef ? { dataExportApprovalRef: lane.dataExportApprovalRef } : {}),
+    ...patch,
+  };
+}
+
+async function runSingleModelLaneRuntimeRunner(options: {
+  lane: ClaimGateModelLaneManifest;
+  runner: ClaimGateModelLaneRunner;
+  prompt: string;
+  timeoutMs: number;
+  validateOutput?: RunClaimGateModelLaneRuntimeRunnersOptions['validateOutput'];
+}): Promise<ClaimGateModelLaneRuntimeOutcome> {
+  const { lane, runner, prompt, timeoutMs } = options;
+  const startedAt = Date.now();
+  const controller = new AbortController();
+  const timeoutSentinel = Symbol('ClaimGateModelLaneTimeout');
+  let timeoutHandle: ReturnType<typeof setTimeout> | undefined;
+  const runnerPromise = Promise.resolve().then(() => runner({
+    lane,
+    prompt,
+    timeoutMs,
+    signal: controller.signal,
+  }));
+  void runnerPromise.catch(() => undefined);
+  const timeoutPromise = new Promise<typeof timeoutSentinel>((resolve) => {
+    timeoutHandle = setTimeout(() => {
+      controller.abort();
+      resolve(timeoutSentinel);
+    }, timeoutMs);
+  });
+
+  try {
+    const output = await Promise.race([runnerPromise, timeoutPromise]);
+    if (timeoutHandle) clearTimeout(timeoutHandle);
+    if (output === timeoutSentinel) {
+      return outcomeFromLane(lane, 'timeout', {
+        receiptRef: `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-timeout`,
+        reason: `${lane.provider}/${lane.model} exceeded ${timeoutMs}ms model-lane timeout.`,
+        elapsedMs: elapsedFrom(startedAt),
+      });
+    }
+
+    if (output.runtimeStatus && output.runtimeStatus !== 'success') {
+      return outcomeFromLane(lane, output.runtimeStatus, {
+        receiptRef: output.receiptRef ?? `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-${safePacketIdFragment(output.runtimeStatus)}`,
+        reason: output.reason ?? `${lane.provider}/${lane.model} returned ${output.runtimeStatus}.`,
+        outputHash: output.outputHash ?? (output.outputText ? sha256({
+          laneId: lane.laneId,
+          provider: lane.provider,
+          model: lane.model,
+          outputText: output.outputText,
+        }) : undefined),
+        elapsedMs: output.elapsedMs ?? elapsedFrom(startedAt),
+        costUsd: output.costUsd,
+      });
+    }
+
+    const schemaValid = output.schemaValid ?? options.validateOutput?.({ lane, output }) ?? true;
+    if (!schemaValid) {
+      return outcomeFromLane(lane, 'schema_invalid', {
+        receiptRef: output.receiptRef,
+        reason: output.reason ?? `${lane.provider}/${lane.model} output did not satisfy ${lane.outputSchema}.`,
+        outputHash: output.outputHash ?? (output.outputText ? sha256({
+          laneId: lane.laneId,
+          provider: lane.provider,
+          model: lane.model,
+          outputText: output.outputText,
+        }) : undefined),
+        elapsedMs: output.elapsedMs ?? elapsedFrom(startedAt),
+        costUsd: output.costUsd,
+      });
+    }
+
+    return outcomeFromLane(lane, 'success', {
+      receiptRef: output.receiptRef,
+      reason: output.reason,
+      outputHash: output.outputHash ?? sha256({
+        laneId: lane.laneId,
+        provider: lane.provider,
+        model: lane.model,
+        outputText: output.outputText ?? '',
+      }),
+      elapsedMs: output.elapsedMs ?? elapsedFrom(startedAt),
+      costUsd: output.costUsd,
+    });
+  } catch (error) {
+    if (timeoutHandle) clearTimeout(timeoutHandle);
+    return outcomeFromLane(lane, 'provider_error', {
+      receiptRef: `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-provider-error`,
+      reason: errorMessage(error),
+      elapsedMs: elapsedFrom(startedAt),
+    });
+  }
+}
+
+export async function runClaimGateModelLaneRuntimeRunners(
+  options: RunClaimGateModelLaneRuntimeRunnersOptions,
+): Promise<ClaimGateModelLaneRuntimeRunnerResult> {
+  if (!Number.isFinite(options.timeoutMs) || options.timeoutMs <= 0) {
+    throw new ClaimGateWavegraphSliceInputError([{
+      path: 'timeoutMs',
+      code: 'invalid_model_lane_runner_timeout',
+      message: 'timeoutMs must be a positive finite number.',
+    }]);
+  }
+
+  const outcomes = await Promise.all(options.modelLanes.map(async (lane) => {
+    if (typeof lane.outputSchema !== 'string' || lane.outputSchema.trim().length === 0) {
+      return outcomeFromLane(lane, 'blocked', {
+        receiptRef: `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-missing-output-schema`,
+        reason: `${lane.provider}/${lane.model} cannot run without an explicit output schema.`,
+      });
+    }
+    if (!Number.isFinite(lane.costBudgetUsd) || lane.costBudgetUsd < 0) {
+      return outcomeFromLane(lane, 'blocked', {
+        receiptRef: `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-missing-quota`,
+        reason: `${lane.provider}/${lane.model} cannot run without a finite non-negative cost budget.`,
+      });
+    }
+    if (lane.status === 'blocked') {
+      return outcomeFromLane(lane, 'blocked', {
+        receiptRef: lane.receiptRef,
+        reason: lane.unavailableReason ?? `${lane.provider}/${lane.model} was blocked before model-lane execution.`,
+      });
+    }
+    if (lane.status === 'unavailable') {
+      return outcomeFromLane(lane, 'unavailable', {
+        receiptRef: lane.receiptRef,
+        reason: lane.unavailableReason ?? `${lane.provider}/${lane.model} was unavailable before model-lane execution.`,
+      });
+    }
+    if (
+      lane.inputDisclosure === 'private_approved'
+      && !isLocalOnlyProvider(lane.provider)
+      && !lane.dataExportApprovalRef
+    ) {
+      return outcomeFromLane(lane, 'blocked', {
+        receiptRef: `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-data-export-blocked`,
+        reason: `Data export approval is required before running outside provider ${lane.provider} with private_approved context.`,
+      });
+    }
+
+    const runner = options.runners[lane.provider];
+    if (!runner) {
+      return outcomeFromLane(lane, 'unavailable', {
+        receiptRef: `receipt:rcpt-runtime-${safePacketIdFragment(lane.laneId)}-missing-runner`,
+        reason: `No model-lane runner registered for provider ${lane.provider}.`,
+      });
+    }
+
+    return runSingleModelLaneRuntimeRunner({
+      lane,
+      runner,
+      prompt: options.promptsByLaneId?.[lane.laneId] ?? options.defaultPrompt ?? '',
+      timeoutMs: options.timeoutMs,
+      validateOutput: options.validateOutput,
+    });
+  }));
+
+  return {
+    kind: 'ClaimGateModelLaneRuntimeRunnerResult',
+    outcomes,
+    compilation: compileClaimGateModelLaneRuntimeCompilation({
+      aggregateId: options.aggregateId,
+      outcomes,
+    }),
+  };
+}
+
+function validateReceiptRef(
+  value: unknown,
+  path: string,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): value is string {
+  if (!validateString(value, path, violations, MAX_ID_BYTES)) return false;
+  if (!isReceiptRef(value)) {
+    addViolation(violations, path, 'invalid_receipt_ref', `${path} must be a host-style receipt:rcpt-* ref.`);
+    return false;
+  }
+  return true;
+}
+
+function validateHash(
+  value: unknown,
+  path: string,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): value is string {
+  if (!validateString(value, path, violations, MAX_ID_BYTES)) return false;
+  if (!value.startsWith('sha256:')) {
+    addViolation(violations, path, 'invalid_hash_ref', `${path} must start with sha256:.`);
+    return false;
+  }
+  return true;
+}
+
+function validateModelLanes(input: ClaimGateWavegraphSliceInput, violations: ClaimGateWavegraphSliceInputViolation[]): void {
+  if (!Array.isArray(input.modelLanes) || input.modelLanes.length === 0) {
+    addViolation(violations, 'modelLanes', 'missing_model_lanes', 'Gate 0A requires declared model lanes.');
+    return;
+  }
+
+  const laneIds = new Set<string>();
+  const receiptRefs = new Set<string>();
+  const providers = new Set<ClaimGateModelLaneProvider>();
+  const chineseFamilies = new Set<string>();
+  const chineseModelIds = new Set<string>();
+  let claudeBridgeLaneCount = 0;
+  let hasGoogleGeminiTuiLane = false;
+
+  input.modelLanes.forEach((lane, index) => {
+    const path = `modelLanes[${index}]`;
+    if (!isRecord(lane)) {
+      addViolation(violations, path, 'expected_model_lane_object', `${path} must be an object.`);
+      return;
+    }
+
+    if (validateString(lane.laneId, `${path}.laneId`, violations, MAX_ID_BYTES)) {
+      if (laneIds.has(lane.laneId)) {
+        addViolation(violations, `${path}.laneId`, 'duplicate_model_lane_id', `${path}.laneId must be unique.`);
+      }
+      laneIds.add(lane.laneId);
+    }
+    validateString(lane.model, `${path}.model`, violations, MAX_TEXT_BYTES);
+    validateString(lane.family, `${path}.family`, violations, MAX_ID_BYTES);
+    validateString(lane.outputSchema, `${path}.outputSchema`, violations, MAX_ID_BYTES);
+    validateHash(lane.promptHash, `${path}.promptHash`, violations);
+    if (validateReceiptRef(lane.receiptRef, `${path}.receiptRef`, violations)) {
+      receiptRefs.add(lane.receiptRef);
+    }
+    if (!['claude', 'openrouter', 'xai', 'google', 'codex', 'local'].includes(lane.provider)) {
+      addViolation(violations, `${path}.provider`, 'invalid_model_provider', `${path}.provider is not supported by Gate 0A.`);
+    } else {
+      providers.add(lane.provider);
+    }
+    if (lane.provider === 'claude') {
+      claudeBridgeLaneCount += 1;
+    }
+    if (
+      lane.provider === 'google'
+      && [lane.family, lane.model, lane.laneId].some((value) => value.toLowerCase().includes('gemini'))
+      && [lane.family, lane.model, lane.laneId, lane.receiptRef].some((value) => value.toLowerCase().includes('tui'))
+    ) {
+      hasGoogleGeminiTuiLane = true;
+    }
+    if (!['generation', 'critique', 'falsifier', 'repair', 'synthesis', 'management_audit'].includes(lane.purpose)) {
+      addViolation(violations, `${path}.purpose`, 'invalid_model_lane_purpose', `${path}.purpose is not a valid lane purpose.`);
+    }
+    if (!['public', 'redacted', 'private_approved', 'local_only'].includes(lane.inputDisclosure)) {
+      addViolation(violations, `${path}.inputDisclosure`, 'invalid_input_disclosure', `${path}.inputDisclosure is not valid.`);
+    }
+    if (lane.authority !== 'advisory_only') {
+      addViolation(violations, `${path}.authority`, 'model_lane_authority_overclaim', `${path}.authority must be advisory_only.`);
+    }
+    if (!['available', 'blocked', 'unavailable'].includes(lane.status)) {
+      addViolation(violations, `${path}.status`, 'invalid_model_lane_status', `${path}.status is not valid.`);
+    }
+    if ((lane.status === 'blocked' || lane.status === 'unavailable') && !lane.unavailableReason) {
+      addViolation(violations, `${path}.unavailableReason`, 'missing_unavailable_reason', `${path}.unavailableReason is required for blocked/unavailable lanes.`);
+    }
+    if (lane.dataExportApprovalRef !== undefined && !isDataExportApprovalRef(lane.dataExportApprovalRef)) {
+      addViolation(
+        violations,
+        `${path}.dataExportApprovalRef`,
+        'invalid_data_export_approval_ref',
+        `${path}.dataExportApprovalRef must be approval:* or receipt:rcpt-* when present.`,
+      );
+    }
+    if (
+      lane.inputDisclosure === 'private_approved'
+      && ['claude', 'openrouter', 'xai', 'google'].includes(lane.provider)
+      && !lane.dataExportApprovalRef
+    ) {
+      addViolation(
+        violations,
+        `${path}.dataExportApprovalRef`,
+        'missing_data_export_approval',
+        `${path}.dataExportApprovalRef is required before exporting private context to ${lane.provider}.`,
+      );
+    }
+    if (!Number.isFinite(lane.costBudgetUsd) || lane.costBudgetUsd < 0) {
+      addViolation(violations, `${path}.costBudgetUsd`, 'invalid_cost_budget', `${path}.costBudgetUsd must be a non-negative finite number.`);
+    }
+    if (lane.provider === 'openrouter' && REQUIRED_CHINESE_MODEL_FAMILIES.has(lane.family)) {
+      chineseFamilies.add(lane.family);
+      if (REQUIRED_CHINESE_MODEL_IDS.has(lane.model)) {
+        chineseModelIds.add(lane.model);
+      }
+    }
+  });
+
+  for (const provider of REQUIRED_MODEL_PROVIDERS) {
+    if (!providers.has(provider)) {
+      addViolation(
+        violations,
+        'modelLanes',
+        'missing_required_model_provider',
+        `Gate 0A requires a ${provider} model lane receipt or availability receipt.`,
+      );
+    }
+  }
+  if (!providers.has('codex') && !providers.has('local')) {
+    addViolation(
+      violations,
+      'modelLanes',
+      'missing_required_model_provider',
+      'Gate 0A requires a Codex/local verification lane receipt.',
+    );
+  }
+  if (claudeBridgeLaneCount < MIN_CLAUDE_BRIDGE_CONTROLLER_LANES) {
+    addViolation(
+      violations,
+      'modelLanes',
+      'missing_claude_bridge_controller_lanes',
+      `Gate 0A requires at least ${MIN_CLAUDE_BRIDGE_CONTROLLER_LANES} Claude Bridge lanes so controller/adversarial roles do not collapse into one model receipt.`,
+    );
+  }
+  if (!hasGoogleGeminiTuiLane) {
+    addViolation(
+      violations,
+      'modelLanes',
+      'missing_google_gemini_tui_lane',
+      'Gate 0A requires a Google/Gemini TUI lane receipt or availability failure receipt.',
+    );
+  }
+  const missingChineseModels = REQUIRED_CHINESE_MODEL_LANES
+    .filter((lane) => !chineseModelIds.has(lane.model))
+    .map((lane) => lane.model)
+    .sort();
+  if (missingChineseModels.length > 0) {
+    addViolation(
+      violations,
+      'modelLanes',
+      'missing_top_chinese_model_lanes',
+      `Gate 0A requires exact top Chinese-family OpenRouter lanes for DeepSeek, GLM, Kimi, MiniMax, Qwen Plus, and Qwen Max. Missing: ${missingChineseModels.join(', ')}.`,
+    );
+  }
+
+  const aggregation = input.modelAggregation;
+  if (!isRecord(aggregation)) {
+    addViolation(violations, 'modelAggregation', 'missing_model_aggregation', 'Gate 0A requires an aggregate record preserving per-lane receipts.');
+    return;
+  }
+  validateString(aggregation.aggregateId, 'modelAggregation.aggregateId', violations, MAX_ID_BYTES);
+  if (aggregation.claimCeiling !== 'advisory_model_synthesis_not_proof') {
+    addViolation(
+      violations,
+      'modelAggregation.claimCeiling',
+      'model_aggregation_overclaim',
+      'modelAggregation.claimCeiling must be advisory_model_synthesis_not_proof.',
+    );
+  }
+  if (!Array.isArray(aggregation.laneReceiptRefs)) {
+    addViolation(violations, 'modelAggregation.laneReceiptRefs', 'expected_lane_receipt_ref_array', 'modelAggregation.laneReceiptRefs must be an array.');
+    return;
+  }
+  const aggregatedRefs = new Set<string>();
+  aggregation.laneReceiptRefs.forEach((ref, index) => {
+    if (validateReceiptRef(ref, `modelAggregation.laneReceiptRefs[${index}]`, violations)) {
+      aggregatedRefs.add(ref);
+    }
+  });
+  for (const ref of receiptRefs) {
+    if (!aggregatedRefs.has(ref)) {
+      addViolation(
+        violations,
+        'modelAggregation.laneReceiptRefs',
+        'model_aggregation_dropped_lane_receipt',
+        `Model aggregation omitted lane receipt ${ref}.`,
+      );
+    }
+  }
+}
+
+function validateLoadedContextReceipts(
+  input: ClaimGateWavegraphSliceInput,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): Set<string> {
+  const loadedRefs = new Set<string>();
+  if (!Array.isArray(input.loadedContextReceipts) || input.loadedContextReceipts.length === 0) {
+    addViolation(violations, 'loadedContextReceipts', 'missing_loaded_context_receipts', 'Gate 2 requires loaded context receipts.');
+    return loadedRefs;
+  }
+
+  input.loadedContextReceipts.forEach((receipt, index) => {
+    const path = `loadedContextReceipts[${index}]`;
+    if (!isRecord(receipt)) {
+      addViolation(violations, path, 'expected_loaded_context_receipt_object', `${path} must be an object.`);
+      return;
+    }
+    if (!['skill', 'mmm', 'source'].includes(receipt.refType)) {
+      addViolation(violations, `${path}.refType`, 'invalid_loaded_context_ref_type', `${path}.refType must be skill, mmm, or source.`);
+    }
+    if (validateString(receipt.ref, `${path}.ref`, violations, MAX_ID_BYTES)) {
+      loadedRefs.add(receipt.ref);
+    }
+    validateReceiptRef(receipt.receiptRef, `${path}.receiptRef`, violations);
+    validateHash(receipt.contentHash, `${path}.contentHash`, violations);
+    if (receipt.sourceRef !== undefined) {
+      validateString(receipt.sourceRef, `${path}.sourceRef`, violations, MAX_TEXT_BYTES);
+    }
+    if (receipt.loaderRef !== undefined) {
+      validateString(receipt.loaderRef, `${path}.loaderRef`, violations, MAX_ID_BYTES);
+    }
+    if (
+      receipt.claimCeiling !== undefined
+      && receipt.claimCeiling !== 'loaded_context_receipt_not_source_authority'
+    ) {
+      addViolation(
+        violations,
+        `${path}.claimCeiling`,
+        'loaded_context_claim_ceiling_overclaim',
+        `${path}.claimCeiling must be loaded_context_receipt_not_source_authority when present.`,
+      );
+    }
+  });
+  return loadedRefs;
+}
+
+function validateContextLoadPlan(
+  plan: unknown,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): plan is ClaimGateContextLoadPlanEntry[] {
+  if (!Array.isArray(plan) || plan.length === 0) {
+    addViolation(violations, 'contextLoadPlan', 'missing_context_load_plan', 'Workflow specs must declare a context load plan.');
+    return false;
+  }
+
+  const refs = new Set<string>();
+  plan.forEach((entry, index) => {
+    const path = `contextLoadPlan[${index}]`;
+    if (!isRecord(entry)) {
+      addViolation(violations, path, 'expected_context_load_plan_entry_object', `${path} must be an object.`);
+      return;
+    }
+    if (typeof entry.refType !== 'string' || !['skill', 'mmm', 'source'].includes(entry.refType)) {
+      addViolation(violations, `${path}.refType`, 'invalid_loaded_context_ref_type', `${path}.refType must be skill, mmm, or source.`);
+    }
+    if (validateString(entry.ref, `${path}.ref`, violations, MAX_ID_BYTES)) {
+      const ref = entry.ref;
+      if (refs.has(ref)) {
+        addViolation(violations, `${path}.ref`, 'duplicate_context_load_ref', `${ref} appears more than once in the context load plan.`);
+      }
+      refs.add(ref);
+    }
+    validateString(entry.sourceRef, `${path}.sourceRef`, violations, MAX_TEXT_BYTES);
+    validateString(entry.content, `${path}.content`, violations, MAX_CONTEXT_CONTENT_BYTES);
+  });
+
+  return true;
+}
+
+function compileLoadedContextReceiptsFromPlan(plan: unknown): ClaimGateLoadedContextReceipt[] {
+  const violations: ClaimGateWavegraphSliceInputViolation[] = [];
+  if (!validateContextLoadPlan(plan, violations)) {
+    throw new ClaimGateWavegraphSliceInputError(violations);
+  }
+  if (violations.length > 0) {
+    throw new ClaimGateWavegraphSliceInputError(violations);
+  }
+  return plan.map((entry) => ({
+    refType: entry.refType,
+    ref: entry.ref,
+    receiptRef: `receipt:rcpt-load-${safePacketIdFragment(entry.ref)}`,
+    contentHash: sha256({
+      refType: entry.refType,
+      ref: entry.ref,
+      sourceRef: entry.sourceRef,
+      content: entry.content,
+    }),
+  }));
+}
+
+export async function resolveClaimGateContextLoadPlan(
+  options: ResolveClaimGateContextLoadPlanOptions,
+): Promise<ClaimGateResolvedContextLoadResult> {
+  const violations: ClaimGateWavegraphSliceInputViolation[] = [];
+  validateString(options.loaderRef, 'contextLoader.loaderRef', violations, MAX_ID_BYTES);
+  if (!validateContextLoadPlan(options.plan, violations)) {
+    throw new ClaimGateWavegraphSliceInputError(violations);
+  }
+  if (violations.length > 0) {
+    throw new ClaimGateWavegraphSliceInputError(violations);
+  }
+
+  const resolvedEntries: Array<{
+    entry: ClaimGateContextLoadPlanEntry;
+    resolution: ClaimGateContextLoaderResolution;
+    path: string;
+  }> = [];
+  for (const [index, entry] of options.plan.entries()) {
+    const path = `contextLoadPlan[${index}]`;
+    const resolution = await options.resolve({
+      refType: entry.refType,
+      ref: entry.ref,
+      sourceRef: entry.sourceRef,
+      plannedContent: entry.content,
+    });
+    if (!resolution) {
+      addViolation(
+        violations,
+        path,
+        'context_loader_ref_unresolved',
+        `${entry.ref} could not be resolved by ${options.loaderRef}.`,
+      );
+      continue;
+    }
+    validateString(resolution.content, `${path}.resolved.content`, violations, MAX_CONTEXT_CONTENT_BYTES);
+    if (resolution.sourceRef !== undefined) {
+      validateString(resolution.sourceRef, `${path}.resolved.sourceRef`, violations, MAX_TEXT_BYTES);
+    }
+    if (resolution.receiptRef !== undefined) {
+      validateReceiptRef(resolution.receiptRef, `${path}.resolved.receiptRef`, violations);
+    }
+    resolvedEntries.push({ entry, resolution, path });
+  }
+
+  if (violations.length > 0) {
+    throw new ClaimGateWavegraphSliceInputError(violations);
+  }
+
+  return {
+    kind: 'ClaimGateResolvedContextLoadResult',
+    loaderRef: options.loaderRef,
+    loadedContextReceipts: resolvedEntries.map(({ entry, resolution }) => {
+      const sourceRef = resolution.sourceRef ?? entry.sourceRef;
+      const content = resolution.content;
+      return {
+        refType: entry.refType,
+        ref: entry.ref,
+        receiptRef: resolution.receiptRef ?? `receipt:rcpt-load-${safePacketIdFragment(entry.ref)}`,
+        sourceRef,
+        loaderRef: options.loaderRef,
+        claimCeiling: 'loaded_context_receipt_not_source_authority',
+        contentHash: sha256({
+          refType: entry.refType,
+          ref: entry.ref,
+          sourceRef,
+          loaderRef: options.loaderRef,
+          content,
+        }),
+      };
+    }),
+    claimCeiling: 'resolved_context_load_receipts_not_source_authority',
+  };
+}
+
+function validateBindingLoaded(
+  binding: ClaimGateCouncilMemberCognitiveBinding,
+  path: string,
+  loadedRefs: Set<string>,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): void {
+  for (const [field, refs] of [
+    ['mmmRefs', binding.mmmRefs],
+    ['skillRefs', binding.skillRefs],
+    ['sourceRefs', binding.sourceRefs],
+  ] as const) {
+    refs.forEach((ref, index) => {
+      if (!loadedRefs.has(ref)) {
+        addViolation(
+          violations,
+          `${path}.cognitiveBinding.${field}[${index}]`,
+          'missing_loaded_context_receipt',
+          `${ref} was declared by ${path} but has no loaded context receipt.`,
+        );
+      }
+    });
+  }
+}
+
+function validateMember(
+  member: unknown,
+  path: string,
+  loadedRefs: Set<string>,
+  violations: ClaimGateWavegraphSliceInputViolation[],
+): member is ClaimGateWavegraphMemberManifest {
+  if (!isRecord(member)) {
+    addViolation(violations, path, 'expected_member_manifest_object', `${path} must be an object.`);
+    return false;
+  }
+  validateString(member.memberId, `${path}.memberId`, violations, MAX_ID_BYTES);
+  validateString(member.role, `${path}.role`, violations, MAX_TEXT_BYTES);
+  if (!isRecord(member.cognitiveBinding)) {
+    addViolation(violations, `${path}.cognitiveBinding`, 'missing_cognitive_binding', `${path}.cognitiveBinding is required.`);
+    return false;
+  }
+  const binding = member.cognitiveBinding as unknown as ClaimGateCouncilMemberCognitiveBinding;
+  for (const field of ['mmmRefs', 'skillRefs', 'sourceRefs', 'inputContractRefs', 'outputContractRefs', 'gateContractRefs'] as const) {
+    if (!Array.isArray(binding[field]) || binding[field].length === 0) {
+      addViolation(violations, `${path}.cognitiveBinding.${field}`, `missing_${field}`, `${path}.cognitiveBinding.${field} must be non-empty.`);
+    }
+  }
+  validateString(binding.requeuePolicyRef, `${path}.cognitiveBinding.requeuePolicyRef`, violations, MAX_TEXT_BYTES);
+  validateBindingLoaded(binding, path, loadedRefs, violations);
+  return true;
