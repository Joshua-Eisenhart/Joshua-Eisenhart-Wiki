+
+function parseFrontmatter(text: string): Frontmatter {
+  const result: Frontmatter = { tags: [] };
+  if (!text.startsWith('---')) return result;
+  const end = text.indexOf('\n---', 3);
+  if (end === -1) return result;
+
+  const block = text.slice(3, end).split('\n');
+  for (const line of block) {
+    if (/^\s/.test(line)) continue;
+    const idx = line.indexOf(':');
+    if (idx === -1) continue;
+    const key = line.slice(0, idx).trim();
+    const rawValue = line.slice(idx + 1).trim().replace(/^['"]|['"]$/g, '');
+    if (key === 'name') result.name = rawValue;
+    if (key === 'description') result.description = rawValue;
+    if (key === 'tags' || key.endsWith('.tags')) {
+      result.tags.push(...rawValue
+        .replace(/^\[/, '')
+        .replace(/\]$/, '')
+        .split(',')
+        .map((tag) => tag.trim().replace(/^['"]|['"]$/g, ''))
+        .filter(Boolean));
+    }
+  }
+  return result;
+}
