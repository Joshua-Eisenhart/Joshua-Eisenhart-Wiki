@@ -0,0 +1,102 @@
+import type { MechanicalProbeRunReceipt } from './mechanical-probe-runner.js';
+import { validateMechanicalProbeRunReceipt } from './mechanical-probe-runner.js';
+
+export const CODEX_RATCHET_R0_QUOTIENT_SOURCE_SHA256 =
+  'sha256:7104a9b052ed56eccb8912f1974d0949815b10203aaf864a48e01f94fe935af8';
+export const CODEX_RATCHET_R0_QUOTIENT_SOURCE_REF_SUFFIX =
+  '/system_v5/julia_carrier/foundation_r0_probe_quotient_refinement_julia.jl';
+
+const REQUIRED_NEGATIVE_CONTROLS = [
+  'empty_probe_collapses_identity',
+  'duplicate_Z_does_not_refine',
+  'relabel_Z_does_not_refine',
+  'invalid_density_candidates_rejected',
+  'cross_engine_agreement_is_plumbing_not_proof',
+];
+
+export type CodexRatchetR0ProbeValidation = {
+  ok: boolean;
+  findings: string[];
+};
+
+function hasLoadBearingPackage(data: Record<string, unknown>, packageName: string): boolean {
+  const packages = data.packages;
+  if (!packages || typeof packages !== 'object') return false;
+  const loadBearing = (packages as Record<string, unknown>).load_bearing;
+  return Array.isArray(loadBearing) && loadBearing.includes(packageName);
+}
+
+function missingNegativeControls(data: Record<string, unknown>): string[] {
+  const controls = data.negative_controls;
+  if (!controls || typeof controls !== 'object') return REQUIRED_NEGATIVE_CONTROLS;
+  return REQUIRED_NEGATIVE_CONTROLS.filter((control) => {
+    const entry = (controls as Record<string, unknown>)[control];
+    return !(entry && typeof entry === 'object' && (entry as Record<string, unknown>).pass === true);
+  });
+}
+
+function resultArtifact(receipt: MechanicalProbeRunReceipt): string | undefined {
+  return receipt.outputArtifacts.find((artifact) => artifact.id === 'result')?.text;
+}
+
+export function validateCodexRatchetR0QuotientProbeReceipt(
+  receipt: MechanicalProbeRunReceipt,
+): CodexRatchetR0ProbeValidation {
+  const findings = [...validateMechanicalProbeRunReceipt(receipt, { requireExecutedNegativeControl: true }).findings];
+
+  if (receipt.engine !== 'julia') findings.push('engine must be julia');
+  if (!receipt.sourceRef.endsWith(CODEX_RATCHET_R0_QUOTIENT_SOURCE_REF_SUFFIX)) {
+    findings.push('sourceRef must target Codex Ratchet R0 quotient probe path');
+  }
+  if (receipt.sourceHash !== CODEX_RATCHET_R0_QUOTIENT_SOURCE_SHA256) {
+    findings.push('sourceHash must match Codex Ratchet R0 quotient probe');
+  }
+
+  const text = resultArtifact(receipt);
+  if (!text) {
+    findings.push('result artifact is required');
+    return { ok: false, findings };
+  }
+
+  let data: Record<string, unknown>;
+  try {
+    data = JSON.parse(text) as Record<string, unknown>;
+  } catch {
+    findings.push('result artifact must parse as JSON');
+    return { ok: false, findings };
+  }
+
+  if (data.schema !== 'codex_ratchet.formal_scout.scratch_diagnostic.v1') {
+    findings.push('schema must be codex_ratchet.formal_scout.scratch_diagnostic.v1');
+  }
+  if (data.object_id !== 'foundation_r0_probe_quotient_refinement_v1') {
+    findings.push('object_id must be foundation_r0_probe_quotient_refinement_v1');
+  }
+  if (data.classification !== 'scratch_diagnostic') findings.push('classification must be scratch_diagnostic');
+  if (data.engine !== 'julia') findings.push('result engine must be julia');
+  if (typeof data.claim_ceiling !== 'string' || !data.claim_ceiling.includes('Not M(C)')) {
+    findings.push('claim_ceiling must keep the R0 scratch diagnostic ceiling');
+  }
+  if (data.all_pass !== true) findings.push('all_pass must be true');
+  if (data.promotion_allowed !== false) findings.push('promotion_allowed must be false');
+  if (data.formal_admission_allowed !== false) findings.push('formal_admission_allowed must be false');
+  if (data.reads_peer_result !== false) findings.push('reads_peer_result must be false');
+  if (!hasLoadBearingPackage(data, 'QuantumOptics')) findings.push('QuantumOptics must be load-bearing');
+  for (const control of missingNegativeControls(data)) {
+    findings.push(`negative_controls.${control} must pass`);
+  }
+
+  const coreChecks = data.core_checks;
+  if (!coreChecks || typeof coreChecks !== 'object') {
+    findings.push('core_checks is required');
+  } else {
+    const checks = coreChecks as Record<string, unknown>;
+    if (checks.strict_quotient_refinement !== true) findings.push('strict_quotient_refinement must be true');
+    if (checks.all_pass !== true) findings.push('core_checks.all_pass must be true');
+  }
+
+  return {
+    ok: findings.length === 0,
+    findings,
+  };
+}
