@@ -0,0 +1,566 @@
+import { createHash } from 'node:crypto';
+
+import type {
+  ClaimGateModelLaneManifest,
+  ClaimGateModelLaneRunner,
+  ClaimGateModelLaneRunnerMap,
+  ClaimGateModelLaneRunnerOutput,
+} from './claim-gate-wavegraph-slice.js';
+
+export interface ClaimGateProcessRunnerRequest {
+  lane: ClaimGateModelLaneManifest;
+  model: string;
+  prompt: string;
+  timeoutMs: number;
+  signal: AbortSignal;
+}
+
+export interface ClaimGateProcessRunnerResult {
+  stdout?: string;
+  stderr?: string;
+  exitCode?: number;
+  elapsedMs?: number;
+  costUsd?: number;
+}
+
+export interface ClaimGateHttpModelMessage {
+  role: 'user';
+  content: string;
+}
+
+export interface ClaimGateHttpModelRequestBody {
+  model: string;
+  messages: ClaimGateHttpModelMessage[];
+  temperature: number;
+  max_tokens: number;
+  response_format?: { type: 'json_object' };
+}
+
+export interface ClaimGateHttpJsonRequest {
+  lane: ClaimGateModelLaneManifest;
+  model: string;
+  prompt: string;
+  timeoutMs: number;
+  signal: AbortSignal;
+  body: ClaimGateHttpModelRequestBody;
+}
+
+export interface ClaimGateHttpJsonResult {
+  json: unknown;
+  elapsedMs?: number;
+}
+
+export interface ClaimGateClaudeBridgeRunnerOptions {
+  run: (request: ClaimGateProcessRunnerRequest) => Promise<ClaimGateProcessRunnerResult>;
+}
+
+export interface ClaimGateGoogleGeminiTuiRunnerOptions {
+  run: (request: ClaimGateProcessRunnerRequest) => Promise<ClaimGateProcessRunnerResult>;
+}
+
+export interface ClaimGateHttpModelRunnerOptions {
+  postJson: (request: ClaimGateHttpJsonRequest) => Promise<ClaimGateHttpJsonResult>;
+  maxTokens?: number;
+  temperature?: number;
+}
+
+export interface ClaimGateCodexLocalRunnerOptions {
+  run: (request: ClaimGateProcessRunnerRequest) => Promise<ClaimGateModelLaneRunnerOutput>;
+}
+
+export interface ClaimGateModelLaneRunnerMapOptions {
+  claudeBridge?: ClaimGateClaudeBridgeRunnerOptions;
+  openRouter?: ClaimGateHttpModelRunnerOptions;
+  xai?: ClaimGateHttpModelRunnerOptions;
+  googleGeminiTui?: ClaimGateGoogleGeminiTuiRunnerOptions;
+  codexLocal?: ClaimGateCodexLocalRunnerOptions;
+}
+
+export interface ClaimGateExecFileOptions {
+  cwd?: string;
+  env?: Record<string, string | undefined>;
+  signal?: AbortSignal;
+  timeoutMs?: number;
+}
+
+export type ClaimGateLiveExecFile = (
+  file: string,
+  args: string[],
+  options: ClaimGateExecFileOptions,
+) => Promise<ClaimGateProcessRunnerResult>;
+
+export interface ClaimGateLiveHttpPostJsonInit {
+  method: 'POST';
+  headers: Record<string, string>;
+  body: string;
+  signal: AbortSignal;
+  timeoutMs: number;
+}
+
+export interface ClaimGateLiveHttpPostJsonResult {
+  ok: boolean;
+  status: number;
+  json: () => Promise<unknown>;
+  text?: () => Promise<string>;
+}
+
+export type ClaimGateLiveHttpPostJson = (
+  url: string,
+  init: ClaimGateLiveHttpPostJsonInit,
+) => Promise<ClaimGateLiveHttpPostJsonResult>;
+
+export interface ClaimGateLiveClaudeBridgeRunnerOptions {
+  command: string;
+  scriptPath: string;
+  execFile: ClaimGateLiveExecFile;
+  cwd?: string;
+  budget?: number;
+  env?: Record<string, string | undefined>;
+}
+
+export interface ClaimGateGoogleGeminiTuiBuildArgsInput {
+  lane: ClaimGateModelLaneManifest;
+  model: string;
+  prompt: string;
+  timeoutMs: number;
+}
+
+export interface ClaimGateLiveGoogleGeminiTuiRunnerOptions {
+  command: string;
+  execFile: ClaimGateLiveExecFile;
+  cwd?: string;
+  env?: Record<string, string | undefined>;
+  buildArgs?: (input: ClaimGateGoogleGeminiTuiBuildArgsInput) => string[];
+}
+
+export interface ClaimGateLiveHttpRunnerOptions {
+  postJson: ClaimGateLiveHttpPostJson;
+  apiKey?: string;
+  endpoint?: string;
+  referer?: string;
+  title?: string;
+  maxTokens?: number;
+  temperature?: number;
+}
+
+export interface ClaimGateLiveModelLaneRunnerMapOptions {
+  claudeBridge?: ClaimGateLiveClaudeBridgeRunnerOptions;
+  openRouter?: ClaimGateLiveHttpRunnerOptions;
+  xai?: ClaimGateLiveHttpRunnerOptions;
+  googleGeminiTui?: ClaimGateLiveGoogleGeminiTuiRunnerOptions;
+  codexLocal?: ClaimGateCodexLocalRunnerOptions;
+  bindUnavailableDefaults?: boolean;
+}
+
+function sha256(value: unknown): string {
+  return `sha256:${createHash('sha256').update(JSON.stringify(value)).digest('hex')}`;
+}
+
+function safeReceiptFragment(value: string): string {
+  return value.toLowerCase().replace(/[^a-z0-9._:-]+/g, '-').replace(/^-+|-+$/g, '');
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+function stringField(record: Record<string, unknown> | undefined, key: string): string | undefined {
+  const value = record?.[key];
+  return typeof value === 'string' && value.trim().length > 0 ? value : undefined;
+}
+
+function numberField(record: Record<string, unknown> | undefined, key: string): number | undefined {
+  const value = record?.[key];
+  return typeof value === 'number' && Number.isFinite(value) ? value : undefined;
+}
+
+function parseJsonObject(text: string | undefined): Record<string, unknown> | undefined {
+  if (!text?.trim()) return undefined;
+  try {
+    const parsed = JSON.parse(text);
+    return isRecord(parsed) ? parsed : undefined;
+  } catch {
+    return undefined;
+  }
+}
+
+function normalizeProcessResult(result: ClaimGateProcessRunnerResult): ClaimGateModelLaneRunnerOutput {
+  const parsed = parseJsonObject(result.stdout);
+  const outputText = stringField(parsed, 'outputText')
+    ?? stringField(parsed, 'content')
+    ?? result.stdout?.trim()
+    ?? '';
+  const receiptRef = stringField(parsed, 'receiptRef');
+  const costUsd = numberField(parsed, 'costUsd') ?? result.costUsd;
+  const failed = result.exitCode !== undefined && result.exitCode !== 0;
+
+  return {
+    ...(outputText ? { outputText } : {}),
+    ...(receiptRef ? { receiptRef } : {}),
+    ...(result.elapsedMs !== undefined ? { elapsedMs: result.elapsedMs } : {}),
+    ...(costUsd !== undefined ? { costUsd } : {}),
+    ...(failed ? { schemaValid: false } : {}),
+    ...(failed ? { reason: result.stderr?.trim() || `Process exited with code ${result.exitCode}.` } : {}),
+  };
+}
+
+function buildHttpBody(
+  lane: ClaimGateModelLaneManifest,
+  prompt: string,
+  options: ClaimGateHttpModelRunnerOptions,
+): ClaimGateHttpModelRequestBody {
+  const wantsJson = lane.outputSchema.toLowerCase().includes('json');
+  return {
+    model: lane.model,
+    messages: [{ role: 'user', content: prompt }],
+    temperature: options.temperature ?? 0.1,
+    max_tokens: options.maxTokens ?? 1200,
+    ...(wantsJson ? { response_format: { type: 'json_object' as const } } : {}),
+  };
+}
+
+function extractChatCompletionContent(json: unknown): string {
+  if (!isRecord(json)) return '';
+  const choices = json.choices;
+  if (!Array.isArray(choices)) return '';
+  const first = choices[0];
+  if (!isRecord(first)) return '';
+  const message = first.message;
+  if (!isRecord(message)) return '';
+  const content = message.content;
+  return typeof content === 'string' ? content : '';
+}
+
+function extractCostUsd(json: unknown): number | undefined {
+  if (!isRecord(json)) return undefined;
+  const usage = json.usage;
+  if (!isRecord(usage)) return undefined;
+  const cost = usage.cost;
+  return typeof cost === 'number' && Number.isFinite(cost) ? cost : undefined;
+}
+
+function extractHttpErrorText(json: unknown): string | undefined {
+  if (!isRecord(json)) return undefined;
+  const error = json.error;
+  if (typeof error === 'string' && error.trim()) return error;
+  if (isRecord(error)) {
+    const message = stringField(error, 'message');
+    if (message) return message;
+  }
+  return undefined;
+}
+
+function strictJsonSchemaValid(lane: ClaimGateModelLaneManifest, outputText: string): boolean | undefined {
+  if (!lane.outputSchema.toLowerCase().includes('strict_json')) return undefined;
+  try {
+    JSON.parse(outputText);
+    return true;
+  } catch {
+    return false;
+  }
+}
+
+function receiptHashFragment(lane: ClaimGateModelLaneManifest, outputText: string): string {
+  return sha256({
+    laneId: lane.laneId,
+    provider: lane.provider,
+    model: lane.model,
+    outputText,
+  }).slice('sha256:'.length, 'sha256:'.length + 16);
+}
+
+function claudeBridgeModelAlias(model: string): string {
+  const lower = model.toLowerCase();
+  if (lower.includes('opus')) return 'opus';
+  if (lower.includes('haiku')) return 'haiku';
+  if (lower.includes('sonnet')) return 'sonnet';
+  return model;
+}
+
+function buildClaudeBridgeArgs(
+  lane: ClaimGateModelLaneManifest,
+  prompt: string,
+  options: ClaimGateLiveClaudeBridgeRunnerOptions,
+): string[] {
+  const args = [
+    options.scriptPath,
+    '--model',
+    claudeBridgeModelAlias(lane.model),
+    '--prompt',
+    prompt,
+    '--budget',
+    String(options.budget ?? 1),
+  ];
+  if (options.cwd) {
+    args.push('--cwd', options.cwd);
+  }
+  args.push('--name', lane.laneId);
+  return args;
+}
+
+function buildGeminiTuiArgs(input: ClaimGateGoogleGeminiTuiBuildArgsInput): string[] {
+  return [
+    '--model',
+    input.model,
+    '--prompt',
+    input.prompt,
+  ];
+}
+
+function normalizeHttpResponseJson(json: unknown, lane: ClaimGateModelLaneManifest, elapsedMs?: number): ClaimGateModelLaneRunnerOutput {
+  const outputText = extractChatCompletionContent(json);
+  const schemaValid = strictJsonSchemaValid(lane, outputText);
+  return {
+    outputText,
+    outputHash: sha256({ laneId: lane.laneId, provider: lane.provider, model: lane.model, outputText }),
+    receiptRef: `receipt:rcpt-runtime-${lane.laneId}-${receiptHashFragment(lane, outputText)}`,
+    ...(schemaValid === false ? { schemaValid, reason: `Provider output did not satisfy ${lane.outputSchema} schema.` } : {}),
+    ...(elapsedMs !== undefined ? { elapsedMs } : {}),
+    ...(extractCostUsd(json) !== undefined ? { costUsd: extractCostUsd(json) } : {}),
+  };
+}
+
+function createLiveHttpRunner(options: {
+  providerName: 'OpenRouter' | 'xAI';
+  missingKeyEnvName: string;
+  missingKeyReceiptSuffix: string;
+  defaultEndpoint: string;
+  authHeaderPrefix: string;
+  requestTitle: string;
+  runnerOptions: ClaimGateLiveHttpRunnerOptions;
+}): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => {
+    const apiKey = options.runnerOptions.apiKey?.trim();
+    if (!apiKey) {
+      return {
+        runtimeStatus: 'unavailable',
+        receiptRef: `receipt:rcpt-runtime-${safeReceiptFragment(lane.laneId)}-${options.missingKeyReceiptSuffix}`,
+        reason: `${options.missingKeyEnvName} is not configured.`,
+      };
+    }
+
+    const body = buildHttpBody(lane, prompt, {
+      postJson: async () => ({ json: {} }),
+      maxTokens: options.runnerOptions.maxTokens,
+      temperature: options.runnerOptions.temperature,
+    });
+    const startedAt = Date.now();
+    const response = await options.runnerOptions.postJson(
+      options.runnerOptions.endpoint ?? options.defaultEndpoint,
+      {
+        method: 'POST',
+        headers: {
+          Authorization: `${options.authHeaderPrefix} ${apiKey}`,
+          'Content-Type': 'application/json',
+          'HTTP-Referer': options.runnerOptions.referer ?? 'https://local.lev.invalid/claimgate-model-lane',
+          'X-Title': options.runnerOptions.title ?? options.requestTitle,
+        },
+        body: JSON.stringify(body),
+        signal,
+        timeoutMs,
+      },
+    );
+    const json = await response.json();
+    const elapsedMs = Date.now() - startedAt;
+    if (!response.ok) {
+      return {
+        runtimeStatus: 'provider_error',
+        receiptRef: `receipt:rcpt-runtime-${safeReceiptFragment(lane.laneId)}-${safeReceiptFragment(options.providerName)}-http-${response.status}`,
+        reason: extractHttpErrorText(json) ?? `${options.providerName} returned HTTP ${response.status}.`,
+        elapsedMs,
+      };
+    }
+    return normalizeHttpResponseJson(json, lane, elapsedMs);
+  };
+}
+
+export function createClaimGateClaudeBridgeRunner(options: ClaimGateClaudeBridgeRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => normalizeProcessResult(await options.run({
+    lane,
+    model: lane.model,
+    prompt,
+    timeoutMs,
+    signal,
+  }));
+}
+
+export function createClaimGateGoogleGeminiTuiRunner(options: ClaimGateGoogleGeminiTuiRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => normalizeProcessResult(await options.run({
+    lane,
+    model: lane.model,
+    prompt,
+    timeoutMs,
+    signal,
+  }));
+}
+
+export function createClaimGateOpenRouterRunner(options: ClaimGateHttpModelRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => {
+    const result = await options.postJson({
+      lane,
+      model: lane.model,
+      prompt,
+      timeoutMs,
+      signal,
+      body: buildHttpBody(lane, prompt, options),
+    });
+    const outputText = extractChatCompletionContent(result.json);
+    const schemaValid = strictJsonSchemaValid(lane, outputText);
+    return {
+      outputText,
+      outputHash: sha256({ laneId: lane.laneId, provider: lane.provider, model: lane.model, outputText }),
+      receiptRef: `receipt:rcpt-runtime-${lane.laneId}-${receiptHashFragment(lane, outputText)}`,
+      ...(schemaValid === false ? { schemaValid, reason: `Provider output did not satisfy ${lane.outputSchema} schema.` } : {}),
+      ...(result.elapsedMs !== undefined ? { elapsedMs: result.elapsedMs } : {}),
+      ...(extractCostUsd(result.json) !== undefined ? { costUsd: extractCostUsd(result.json) } : {}),
+    };
+  };
+}
+
+export function createClaimGateXaiRunner(options: ClaimGateHttpModelRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => {
+    const result = await options.postJson({
+      lane,
+      model: lane.model,
+      prompt,
+      timeoutMs,
+      signal,
+      body: buildHttpBody(lane, prompt, options),
+    });
+    const outputText = extractChatCompletionContent(result.json);
+    return {
+      outputText,
+      outputHash: sha256({ laneId: lane.laneId, provider: lane.provider, model: lane.model, outputText }),
+      receiptRef: `receipt:rcpt-runtime-${lane.laneId}-${receiptHashFragment(lane, outputText)}`,
+      ...(result.elapsedMs !== undefined ? { elapsedMs: result.elapsedMs } : {}),
+      ...(extractCostUsd(result.json) !== undefined ? { costUsd: extractCostUsd(result.json) } : {}),
+    };
+  };
+}
+
+export function createClaimGateCodexLocalRunner(options: ClaimGateCodexLocalRunnerOptions): ClaimGateModelLaneRunner {
+  return async ({ lane, prompt, timeoutMs, signal }) => options.run({
+    lane,
+    model: lane.model,
+    prompt,
+    timeoutMs,
+    signal,
+  });
+}
+
+export function createClaimGateModelLaneRunnerMap(options: ClaimGateModelLaneRunnerMapOptions): ClaimGateModelLaneRunnerMap {
+  return {
+    ...(options.claudeBridge ? { claude: createClaimGateClaudeBridgeRunner(options.claudeBridge) } : {}),
+    ...(options.openRouter ? { openrouter: createClaimGateOpenRouterRunner(options.openRouter) } : {}),
+    ...(options.xai ? { xai: createClaimGateXaiRunner(options.xai) } : {}),
+    ...(options.googleGeminiTui ? { google: createClaimGateGoogleGeminiTuiRunner(options.googleGeminiTui) } : {}),
+    ...(options.codexLocal ? {
+      codex: createClaimGateCodexLocalRunner(options.codexLocal),
+      local: createClaimGateCodexLocalRunner(options.codexLocal),
+    } : {}),
+  };
+}
+
+function createUnavailableLiveBindingRunner(options: {
+  receiptSuffix: string;
+  reason: string;
+}): ClaimGateModelLaneRunner {
+  return async ({ lane }) => ({
+    runtimeStatus: 'unavailable',
+    receiptRef: `receipt:rcpt-runtime-${safeReceiptFragment(lane.laneId)}-${options.receiptSuffix}`,
+    reason: options.reason,
+  });
+}
+
+export function createClaimGateLiveModelLaneRunnerMap(options: ClaimGateLiveModelLaneRunnerMapOptions = {}): ClaimGateModelLaneRunnerMap {
+  const bindUnavailableDefaults = options.bindUnavailableDefaults ?? true;
+  return {
+    claude: options.claudeBridge ? createClaimGateClaudeBridgeRunner({
+        run: async ({ lane, prompt, timeoutMs, signal }) => options.claudeBridge!.execFile(
+          options.claudeBridge!.command,
+          buildClaudeBridgeArgs(lane, prompt, options.claudeBridge!),
+          {
+            cwd: options.claudeBridge!.cwd,
+            env: options.claudeBridge!.env,
+            signal,
+            timeoutMs,
+          },
+        ),
+      })
+      : bindUnavailableDefaults
+        ? createUnavailableLiveBindingRunner({
+          receiptSuffix: 'claude-bridge-missing-config',
+          reason: 'Claude Bridge command/scriptPath/execFile configuration is not configured.',
+        })
+        : undefined,
+    openrouter: options.openRouter ? createLiveHttpRunner({
+        providerName: 'OpenRouter',
+        missingKeyEnvName: 'OPENROUTER_API_KEY',
+        missingKeyReceiptSuffix: 'openrouter-missing-api-key',
+        defaultEndpoint: 'https://openrouter.ai/api/v1/chat/completions',
+        authHeaderPrefix: 'Bearer',
+        requestTitle: 'ClaimGate OpenRouter Model Lane',
+        runnerOptions: options.openRouter,
+      })
+      : bindUnavailableDefaults
+        ? createUnavailableLiveBindingRunner({
+          receiptSuffix: 'openrouter-missing-config',
+          reason: 'OpenRouter postJson/apiKey configuration is not configured.',
+        })
+        : undefined,
+    xai: options.xai ? createLiveHttpRunner({
+        providerName: 'xAI',
+        missingKeyEnvName: 'XAI_API_KEY',
+        missingKeyReceiptSuffix: 'xai-missing-api-key',
+        defaultEndpoint: 'https://api.x.ai/v1/chat/completions',
+        authHeaderPrefix: 'Bearer',
+        requestTitle: 'ClaimGate xAI Model Lane',
+        runnerOptions: options.xai,
+      })
+      : bindUnavailableDefaults
+        ? createUnavailableLiveBindingRunner({
+          receiptSuffix: 'xai-missing-config',
+          reason: 'xAI postJson/apiKey configuration is not configured.',
+        })
+        : undefined,
+    google: options.googleGeminiTui ? createClaimGateGoogleGeminiTuiRunner({
+        run: async ({ lane, prompt, timeoutMs, signal }) => options.googleGeminiTui!.execFile(
+          options.googleGeminiTui!.command,
+          (options.googleGeminiTui!.buildArgs ?? buildGeminiTuiArgs)({
+            lane,
+            model: lane.model,
+            prompt,
+            timeoutMs,
+          }),
+          {
+            cwd: options.googleGeminiTui!.cwd,
+            env: options.googleGeminiTui!.env,
+            signal,
+            timeoutMs,
+          },
+        ),
+      })
+      : bindUnavailableDefaults
+        ? createUnavailableLiveBindingRunner({
+          receiptSuffix: 'google-gemini-tui-missing-config',
+          reason: 'Google Gemini TUI command/execFile configuration or trust approval is not configured.',
+        })
+        : undefined,
+    codex: options.codexLocal
+      ? createClaimGateCodexLocalRunner(options.codexLocal)
+      : bindUnavailableDefaults
+        ? createUnavailableLiveBindingRunner({
+          receiptSuffix: 'codex-local-missing-config',
+          reason: 'Codex local model-lane runner configuration is not configured.',
+        })
+        : undefined,
+    local: options.codexLocal
+      ? createClaimGateCodexLocalRunner(options.codexLocal)
+      : bindUnavailableDefaults
+        ? createUnavailableLiveBindingRunner({
+          receiptSuffix: 'codex-local-missing-config',
+          reason: 'Codex local model-lane runner configuration is not configured.',
+        })
+        : undefined,
+  };
+}
