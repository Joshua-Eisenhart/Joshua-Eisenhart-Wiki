+}
+
+export interface ClaimGateWaveRunResult {
+  kind: 'ClaimGateWaveRunResult';
+  sessionId: string;
+  workstreamId?: string;
+  status: 'passed' | 'passed_after_repair' | 'blocked';
+  waveResults: ClaimGateLoopResult[];
+  repairPlans: ClaimGateRepairWavePlan[];
+  dispatchPlans: ClaimGateRepairDispatchPlan[];
+  engineObligationResults: ClaimGateWaveRunEngineObligationResult[];
+  failurePackets: ClaimGateFailurePacket[];
+  requeueEvents: ClaimGateLoopResult['requeueEvents'];
+  repairFindings: ClaimGateWaveRunRepairFinding[];
+  acceptedClaimIds: string[];
+  withheldClaimIds: string[];
+  engineGraphOperationProposal: ClaimGateWaveRunEngineGraphOperationProposal | null;
+  nextRunSeed: ClaimGateWaveRunNextRunSeed | null;
