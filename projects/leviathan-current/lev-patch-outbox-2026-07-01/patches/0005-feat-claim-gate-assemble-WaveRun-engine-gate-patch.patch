+import { mkdirSync, mkdtempSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+import { describe, expect, it } from 'vitest';
+import {
+  buildSkillSourcePackFromDirectory,
+  createExecutionProfileFormalSkillSet,
+  runExecutionProfileFormalSkillSetIntake,
+  runSkillSourcePackIntake,
+} from '../probes/skill-source-pack-runner.js';
+import { validateFormalSkillSet } from '../contracts/formal-skill-set.js';
+import { validateSkillSourcePack } from '../contracts/source-pack-intake.js';
+
+function writeSkill(root: string, relDir: string, body: string): void {
+  const dir = join(root, relDir);
+  mkdirSync(dir, { recursive: true });
+  writeFileSync(join(dir, 'SKILL.md'), body);
+}
+
+function makeHermesFixture(): string {
+  const root = mkdtempSync(join(tmpdir(), 'lev-hermes-runner-'));
+  writeSkill(root, 'autonomous-ai-agents/tribunal', [
+    '---',
+    'name: tribunal',
+    'description: Run independent comparison across models.',
+    'tags: [tribunal, audit]',
+    '---',
+    '# Tribunal',
+    'Same prompt to independent lanes; preserve disagreement.',
+  ].join('\n'));
+  writeSkill(root, 'software-development/subagent-driven-development', [
+    '---',
+    'name: subagent-driven-development',
+    'description: delegate_task implementer then spec review and quality review.',
+    '---',
+    '# Subagent development',
+  ].join('\n'));
+  writeSkill(root, 'autonomous-ai-agents/cli-coding-agents', [
+    '---',
+    'name: cli-coding-agents',
+    'description: External terminal-native worker orchestration.',
+    '---',
+    '# CLI coding agents',
+  ].join('\n'));
+  writeSkill(root, 'autonomous-ai-agents/hermes-agent', [
+    '---',
+    'name: hermes-agent',
+    'description: Hermes agent with MoA and Mixture of Agents support.',
+    '---',
+    '# Hermes Agent',
+  ].join('\n'));
+  writeSkill(root, 'writing/govuk-style', [
+    '---',
+    'name: govuk-style',
+    'description: Write and edit in GOV.UK / GDS house style.',
+    'user-invokable: true',
+    'args:',
+    '  - name: target',
+    '    description: The document or text to write or rewrite in GOV.UK style.',
+    '    required: false',
+    '---',
+    '# GOV.UK style',
+    'Open the content up so anyone can understand it.',
+  ].join('\n'));
+  writeSkill(root, '.archive/old/tribunal', [
+    '---',
+    'name: tribunal',
+    'description: old archived tribunal.',
+    '---',
+    '# Archived Tribunal',
+  ].join('\n'));
+  return root;
+}
+
+describe('skill source pack runner', () => {
+  it('walks a skill tree, excludes archived skills by default, and validates the generated source pack', () => {
+    const root = makeHermesFixture();
+
+    const run = runSkillSourcePackIntake({
+      rootDir: root,
+      packId: 'hermes-fixture',
+    });
+
+    expect(run.totalSkillFilesFound).toBe(6);
+    expect(run.recordsBuilt).toBe(5);
+    expect(run.includedArchived).toBe(false);
+    expect(run.sourcePackReceipt.ok).toBe(true);
+    expect(run.sourcePackReceipt.admittedRecordIds).toEqual([
+      'autonomous-ai-agents/cli-coding-agents',
+      'autonomous-ai-agents/hermes-agent',
+      'autonomous-ai-agents/tribunal',
+      'software-development/subagent-driven-development',
+      'writing/govuk-style',
+    ]);
+  });
+
+  it('keeps archived skill files red when explicitly included', () => {
+    const root = makeHermesFixture();
+    const pack = buildSkillSourcePackFromDirectory({
+      rootDir: root,
+      packId: 'hermes-fixture-with-archive',
+      includeArchived: true,
+    });
+
+    const receipt = validateSkillSourcePack(pack);
+
+    expect(pack.records).toHaveLength(6);
+    expect(receipt.ok).toBe(false);
+    expect(receipt.findings.map((finding) => finding.code)).toContain('archived_record_reference_only');
+  });
+
+  it('turns admitted execution-profile skills into formal skill bundles', () => {
+    const root = makeHermesFixture();
+    const pack = buildSkillSourcePackFromDirectory({
+      rootDir: root,
+      packId: 'hermes-fixture',
+    });
+    const sourceReceipt = validateSkillSourcePack(pack);
+    const formalSkillSet = createExecutionProfileFormalSkillSet(pack, sourceReceipt);
+    const formalReceipt = validateFormalSkillSet(formalSkillSet, pack, sourceReceipt);
+
+    expect(formalReceipt.ok).toBe(true);
+    expect(formalSkillSet.skills.map((skill) => skill.sourceRecordId)).not.toContain('writing/govuk-style');
+    expect(formalSkillSet.skills.map((skill) => skill.executionProfile).sort()).toEqual([
+      'external.cli_coding_agent_worker',
+      'hermes.moa.reference_synthesis',
+      'hermes.subagent_development.plan_execute_review',
+      'hermes.tribunal.independent_comparison',
+    ]);
+    expect(formalSkillSet.bundles.map((bundle) => bundle.executionProfile).sort()).toEqual([
+      'external.cli_coding_agent_worker',
+      'hermes.moa.reference_synthesis',
+      'hermes.subagent_development.plan_execute_review',
+      'hermes.tribunal.independent_comparison',
+    ]);
+  });
+
+  it('runs the full source-pack and formal-skill-set intake as one bounded receipt', () => {
+    const root = makeHermesFixture();
+
+    const run = runExecutionProfileFormalSkillSetIntake({
+      rootDir: root,
+      packId: 'hermes-fixture',
+    });
+
+    expect(run.sourcePackReceipt.ok).toBe(true);
+    expect(run.formalSkillSetReceipt?.ok).toBe(true);
+    expect(run.formalSkillSet?.claimCeiling).toBe('formal_skill_set_candidate_not_runtime_loaded');
+    expect(run.formalSkillSetReceipt?.admittedSkillIds).toHaveLength(4);
+  });
+
+  it('keeps top-level skill description separate from nested argument descriptions', () => {
+    const root = makeHermesFixture();
+
+    const pack = buildSkillSourcePackFromDirectory({
+      rootDir: root,
+      packId: 'hermes-fixture',
+    });
+
+    const govuk = pack.records.find((record) => record.id === 'writing/govuk-style');
+
+    expect(govuk?.procedure?.trigger).toBe('Write and edit in GOV.UK / GDS house style.');
+    expect(govuk?.procedure?.trigger).not.toContain('document or text');
+  });
+});
