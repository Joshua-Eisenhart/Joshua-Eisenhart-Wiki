+
+function writeSourceBoundGateEvidence(
+  root: string,
+  sessionId: string,
+  gateId: 'object_binding' | 'evidence_manifest' | 'falsifier',
+  overrides: Record<string, unknown> = {},
+): string[] {
+  const file = join(root, `${gateId}-${Math.random().toString(36).slice(2)}.json`);
+  const body = `${JSON.stringify({
+    kind: 'ClaimGateSourceBoundGateEvidence',
+    claimCeiling: 'local_hash_bound_source_evidence_not_host_admission',
+    gateId,
+    sessionId,
+    taskHash: sha256Text('claim-gate-wave-runner-task'),
+    objectRef: 'claim-gate-wave-runner-object',
+    contextReceiptRefs: ['receipt:rcpt-wave-runner-context'],
+    contextContentHashes: [sha256Text('wave-runner-context')],
+    threeEngineEnvelopeHash: null,
+    engineSubstrateDigestHash: null,
+    falsifierStatus: 'closed',
+    openFalsifierCount: 0,
+    ...overrides,
+  }, null, 2)}\n`;
+  writeFileSync(file, body);
+  return [`file:${file}`, sha256Text(body)];
+}
+
+function passingGateChecks(
+  root: string,
+  sessionId: string,
+  overrides: Partial<Record<'object_binding' | 'evidence_manifest' | 'falsifier', Record<string, unknown>>> = {},
+) {
+  return [
+    { gateId: 'object_binding', status: 'pass' as const, evidenceRefs: writeSourceBoundGateEvidence(root, sessionId, 'object_binding', overrides.object_binding) },
+    { gateId: 'evidence_manifest', status: 'pass' as const, evidenceRefs: writeSourceBoundGateEvidence(root, sessionId, 'evidence_manifest', overrides.evidence_manifest) },
+    { gateId: 'falsifier', status: 'pass' as const, evidenceRefs: writeSourceBoundGateEvidence(root, sessionId, 'falsifier', overrides.falsifier) },
+  ];
+}
