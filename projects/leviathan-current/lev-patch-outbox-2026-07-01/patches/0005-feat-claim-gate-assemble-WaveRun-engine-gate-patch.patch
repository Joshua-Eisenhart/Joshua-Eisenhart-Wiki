+function graphPatchExecutionErrors(result: ClaimGateGraphPatchExecutionInput): unknown[] {
+  const data = graphPatchExecutionData(result);
+  return [
+    ...(Array.isArray(result.errors) ? result.errors : []),
+    ...(Array.isArray(data.errors) ? data.errors : []),
+  ];
