+      expect(result.status).toBe('host_blocked');
+      expect(result.ok).toBe(false);
+      expect(result.findings.map((finding) => finding.code)).not.toContain('host_witness.ledger_invalid_json');
+      expect(result.findings.map((finding) => finding.code)).toContain('host_witness.host_proof_execution_not_passed');
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+
+  it('A6: a host witness issued by another process is not replayable into this process', () => {
+    const root = makeTempRoot('a6-cross-process-replay');
+    try {
+      const runDir = writeSteeringRun(root, 'a6-cross-process-replay-run');
+      const hostWitnessLedgerPath = join(root, 'host-witnesses.jsonl');
