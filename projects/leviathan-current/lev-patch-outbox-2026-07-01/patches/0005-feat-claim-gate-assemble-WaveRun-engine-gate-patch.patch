+import { createHash } from 'node:crypto';
+import { mkdtempSync, mkdirSync, readFileSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+import { describe, expect, it } from 'vitest';
+
+import {
+  createClaimGateCanonicalContextLoadRegistry,
+  createClaimGateUnavailableContextLoadReceipts,
+  inspectClaimGateContextLoadRegistry,
+} from './claim-gate-context-loader.js';
+
+function makeTempRoot(name: string): string {
+  return mkdtempSync(join(tmpdir(), `${name}-`));
+}
+
+function sha256Text(content: string): string {
+  return `sha256:${createHash('sha256').update(content).digest('hex')}`;
+}
+
+async function readTextOrMissing(path: string): Promise<string | undefined> {
+  try {
+    return readFileSync(path, 'utf8');
+  } catch {
+    return undefined;
+  }
+}
+
+describe('ClaimGate context load registry inspection', () => {
+  it('emits a pre-dispatch receipt for available and missing canonical context refs', async () => {
+    const root = makeTempRoot('claim-gate-context-registry-inspection');
+    const repoRoot = join(root, 'repo');
+    const skillRoot = join(root, 'skills');
+    const sourceRoot = join(root, 'sources');
+    mkdirSync(join(repoRoot, 'dna'), { recursive: true });
+    mkdirSync(join(repoRoot, 'docs/design'), { recursive: true });
+    mkdirSync(join(skillRoot, 'premortem'), { recursive: true });
+    mkdirSync(sourceRoot, { recursive: true });
+
+    writeFileSync(join(repoRoot, 'dna/graph.yaml'), 'inspection dna graph\n');
+    writeFileSync(join(repoRoot, 'docs/design/design-codex-ratchet-claim-gate-bridge.md'), 'inspection Lev bridge\n');
+    writeFileSync(join(skillRoot, 'premortem/SKILL.md'), 'inspection premortem skill\n');
+    writeFileSync(join(sourceRoot, 'claim-gate-v58.md'), 'inspection ClaimGate v58 source\n');
+
+    const registry = createClaimGateCanonicalContextLoadRegistry({
+      registryVersion: 'inspection-v1',
+      repoRoot: {
+        rootPath: repoRoot,
+        sourceRefPrefix: 'source:lev-repo',
+      },
+      skillRoots: [{
+        rootPath: skillRoot,
+        sourceRefPrefix: 'source:skills',
+      }],
+      sourceRoots: [{
+        rootPath: sourceRoot,
+        sourceRefPrefix: 'source:claimgate-provenance',
+      }],
+    });
+
+    const receipt = await inspectClaimGateContextLoadRegistry({
+      registryVersion: 'inspection-v1',
+      loaderRef: 'loader:claim-gate-canonical-context-registry',
+      registry,
+      readTextFile: readTextOrMissing,
+    });
+
+    expect(receipt).toMatchObject({
+      kind: 'ClaimGateContextLoadRegistryInspectionReceipt',
+      registryVersion: 'inspection-v1',
+      loaderRef: 'loader:claim-gate-canonical-context-registry',
+      inspectedEntryCount: 5,
+      availableRefCount: 4,
+      missingRequiredRefs: ['skill:autoresearch'],
+      claimCeiling: 'context_registry_inspection_receipt_not_loaded_context',
+    });
+    expect(receipt.entries.find((entry) => entry.ref === 'skill:premortem')).toMatchObject({
+      refType: 'skill',
+      ref: 'skill:premortem',
+      status: 'available',
+      availableSourceRef: 'source:skills@inspection-v1:premortem/SKILL.md',
+      availableContentHash: sha256Text('inspection premortem skill\n'),
+    });
+    expect(receipt.entries.find((entry) => entry.ref === 'skill:autoresearch')).toMatchObject({
+      refType: 'skill',
+      ref: 'skill:autoresearch',
+      status: 'missing',
+      candidateCount: 4,
+    });
+    expect(receipt.entries.find((entry) => entry.ref === 'skill:autoresearch')?.candidates).toEqual(
+      expect.arrayContaining([
+        expect.objectContaining({
+          sourceRef: 'source:skills@inspection-v1:codex-autoresearch/SKILL.md',
+          status: 'missing',
+        }),
+      ]),
+    );
+
+    const unavailableReceipts = createClaimGateUnavailableContextLoadReceipts(receipt);
+    expect(unavailableReceipts).toEqual([
+      {
+        kind: 'ClaimGateUnavailableContextLoadReceipt',
+        refType: 'skill',
+        ref: 'skill:autoresearch',
+        receiptRef: 'receipt:rcpt-context-unavailable-skill-autoresearch',
+        loaderRef: 'loader:claim-gate-canonical-context-registry',
+        registryVersion: 'inspection-v1',
+        reason: 'configured_source_missing',
+        candidateSourceRefs: [
+          'source:skills@inspection-v1:codex-autoresearch/SKILL.md',
+          'source:skills@inspection-v1:autoresearch/SKILL.md',
+          'source:skills@inspection-v1:skills/codex-autoresearch/SKILL.md',
+          'source:skills@inspection-v1:skills/autoresearch/SKILL.md',
+        ],
+        missingCandidateCount: 4,
+        claimCeiling: 'unavailable_context_receipt_not_loaded_context',
+        retryPolicy: 'requires_explicit_registry_root_or_source_file',
+      },
+    ]);
+  });
+
+  it('records empty candidate lists as missing refs instead of falling back to ambient discovery', async () => {
+    const root = makeTempRoot('claim-gate-empty-registry-inspection');
+    const repoRoot = join(root, 'repo');
+    mkdirSync(join(repoRoot, 'dna'), { recursive: true });
+    writeFileSync(join(repoRoot, 'dna/graph.yaml'), 'inspection dna graph\n');
+
+    const registry = createClaimGateCanonicalContextLoadRegistry({
+      registryVersion: 'inspection-v2',
+      repoRoot: {
+        rootPath: repoRoot,
+        sourceRefPrefix: 'source:lev-repo',
+      },
+    });
+
+    const receipt = await inspectClaimGateContextLoadRegistry({
+      registryVersion: 'inspection-v2',
+      loaderRef: 'loader:claim-gate-canonical-context-registry',
+      registry,
+      readTextFile: readTextOrMissing,
+    });
+
+    expect(receipt.missingRequiredRefs).toEqual([
+      'skill:premortem',
+      'skill:autoresearch',
+      'source:claim-gate-v58',
+    ]);
+    expect(receipt.entries.find((entry) => entry.ref === 'skill:premortem')).toMatchObject({
+      status: 'missing',
+      candidateCount: 0,
+      candidates: [],
+    });
+    expect(createClaimGateUnavailableContextLoadReceipts(receipt)).toEqual(
+      expect.arrayContaining([
+        expect.objectContaining({
+          ref: 'skill:premortem',
+          candidateSourceRefs: [],
+          missingCandidateCount: 0,
+          claimCeiling: 'unavailable_context_receipt_not_loaded_context',
+        }),
+      ]),
+    );
+  });
+});
