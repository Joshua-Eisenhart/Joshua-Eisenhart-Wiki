+function validateThreeEngineEvidence(
+  envelope: ThreeEngineProbeEnvelope | undefined,
+): EnvelopeValidationResult {
+  if (!envelope) {
+    return { ok: false, findings: ['threeEngineEnvelope is required for sim_engine_probe'] };
+  }
+  const validation = validateThreeEngineProbeEnvelope(envelope);
+  const findings = [...validation.findings];
+  if (envelope.mode !== 'all_three_full_sims') {
+    findings.push('mode must be all_three_full_sims for this Wizard Ratchet slice');
+  }
+  if (!envelope.engines.pytorch) {
+    findings.push('pytorch lane is required for all_three_full_sims');
+  }
+  findings.push(...validateLevNativeR0EnvelopeSemantics(envelope));
+  return { ok: findings.length === 0, findings };
+}
+
+function validateEngineSubstrateDigestEvidence(
+  digest: LevEngineSubstrateDigest | undefined,
+  options: {
+    required?: boolean;
+    hostExecutionWitness?: LevEngineSubstrateExecutionWitness;
+  } = {},
+): EnvelopeValidationResult {
+  if (!digest) {
+    return options.required
+      ? {
+          ok: false,
+          findings: ['engine substrate digest is required when the three-engine envelope is valid'],
+        }
+      : { ok: true, findings: [] };
+  }
+  const validation = validateLevEngineSubstrateDigest(digest, {
+    hostExecutionWitness: options.hostExecutionWitness,
+  });
+  return {
+    ok: validation.ok,
+    findings: validation.findings.map((finding) => `engine substrate digest: ${finding}`),
+  };
+}
+
+function parseJsonObjectLine(stdout: string): Record<string, unknown> | undefined {
+  for (const line of stdout.split(/\r?\n/)) {
+    const trimmed = line.trim();
+    if (!trimmed.startsWith('{')) continue;
+    try {
+      const parsed = JSON.parse(trimmed) as unknown;
+      if (parsed && typeof parsed === 'object' && !Array.isArray(parsed)) return parsed as Record<string, unknown>;
+    } catch {
+      continue;
+    }
+  }
+  return undefined;
+}
+
+function recordField(value: Record<string, unknown>, key: string): Record<string, unknown> | undefined {
+  const entry = value[key];
+  return entry && typeof entry === 'object' && !Array.isArray(entry) ? entry as Record<string, unknown> : undefined;
+}
+
+function validateMirrorR0Primary(
+  engine: 'jax' | 'pytorch',
+  receipt: MechanicalProbeRunReceipt | undefined,
+): string[] {
+  const findings: string[] = [];
+  if (!receipt) return [`${engine} R0 receipt is required`];
+  const data = parseJsonObjectLine(receipt.stdout);
+  if (!data) return [`${engine} R0 receipt stdout must include a JSON result line`];
+
+  const expectedObjectId = `lev_r0_probe_quotient_refinement_${engine}_v1`;
+  if (data.schema !== 'lev.sim_engine.scratch_diagnostic.v1') {
+    findings.push(`${engine} R0 schema must be lev.sim_engine.scratch_diagnostic.v1`);
+  }
+  if (data.object_id !== expectedObjectId) findings.push(`${engine} R0 object_id must be ${expectedObjectId}`);
+  if (data.classification !== 'scratch_diagnostic') findings.push(`${engine} R0 classification must be scratch_diagnostic`);
+  if (data.engine !== engine) findings.push(`${engine} R0 result engine must be ${engine}`);
+  if (data.promotion_allowed !== false) findings.push(`${engine} R0 promotion_allowed must be false`);
+  if (data.formal_admission_allowed !== false) findings.push(`${engine} R0 formal_admission_allowed must be false`);
+  if (data.reads_peer_result !== false) findings.push(`${engine} R0 reads_peer_result must be false`);
+  if (data.all_pass !== true) findings.push(`${engine} R0 all_pass must be true`);
+
+  const quotient = recordField(data, 'quotient');
+  if (quotient?.M_Z_class_count !== 3) findings.push(`${engine} R0 M_Z_class_count must be 3`);
+  if (quotient?.M_ZX_class_count !== 4) findings.push(`${engine} R0 M_ZX_class_count must be 4`);
+
+  const witness = recordField(data, 'witness_pair');
+  if (witness?.same_under_Z !== true) findings.push(`${engine} R0 witness same_under_Z must be true`);
+  if (witness?.distinct_under_X !== true) findings.push(`${engine} R0 witness distinct_under_X must be true`);
+  if (witness?.same_Z_class !== true) findings.push(`${engine} R0 witness same_Z_class must be true`);
+  if (witness?.split_ZX_class !== true) findings.push(`${engine} R0 witness split_ZX_class must be true`);
+
+  const coreChecks = recordField(data, 'core_checks');
+  if (coreChecks?.strict_quotient_refinement !== true) {
+    findings.push(`${engine} R0 strict_quotient_refinement must be true`);
+  }
+  if (coreChecks?.all_pass !== true) findings.push(`${engine} R0 core_checks.all_pass must be true`);
+
+  return findings;
+}
+
+function validateMirrorR0ExecutedControl(
+  engine: 'jax' | 'pytorch',
+  receipt: MechanicalProbeRunReceipt | undefined,
+): string[] {
+  const findings: string[] = [];
+  const control = receipt?.executedNegativeControl;
+  if (!control) return [`${engine} executed negative control is required`];
+  const data = parseJsonObjectLine(control.stdout);
+  if (!data) return [`${engine} executed negative control stdout must include a JSON result line`];
+
+  const expectedObjectId = `lev_r0_probe_quotient_refinement_${engine}_negative_control_v1`;
+  if (data.object_id !== expectedObjectId) {
+    findings.push(`${engine} executed negative control object_id must be ${expectedObjectId}`);
+  }
+  if (data.negative_control !== 'duplicate_Z_does_not_refine') {
+    findings.push(`${engine} executed negative control must be duplicate_Z_does_not_refine`);
+  }
+  if (data.promotion_allowed !== false) findings.push(`${engine} executed negative control promotion_allowed must be false`);
+  if (data.formal_admission_allowed !== false) {
+    findings.push(`${engine} executed negative control formal_admission_allowed must be false`);
+  }
+  if (data.reads_peer_result !== false) findings.push(`${engine} executed negative control reads_peer_result must be false`);
+  if (data.all_pass !== true) findings.push(`${engine} executed negative control all_pass must be true`);
+
+  const quotient = recordField(data, 'quotient');
+  if (quotient?.M_Z_class_count !== 3) findings.push(`${engine} executed negative control M_Z_class_count must be 3`);
+  if (quotient?.M_ZZ_class_count !== 3) findings.push(`${engine} executed negative control M_ZZ_class_count must be 3`);
+
+  const coreChecks = recordField(data, 'core_checks');
+  if (coreChecks?.duplicate_Z_does_not_refine !== true) {
+    findings.push(`${engine} executed negative control duplicate_Z_does_not_refine must be true`);
+  }
+  if (coreChecks?.strict_quotient_refinement !== false) {
+    findings.push(`${engine} executed negative control strict_quotient_refinement must be false`);
+  }
+  if (coreChecks?.all_pass !== true) findings.push(`${engine} executed negative control core_checks.all_pass must be true`);
+
+  return findings;
+}
+
+function validateLevNativeR0EnvelopeSemantics(envelope: ThreeEngineProbeEnvelope): string[] {
+  const receipts = envelope.mechanicalProbeReceipts;
+  if (!receipts) return [];
+  const findings = receipts.julia
+    ? validateLevNativeR0QuotientProbeReceipt(receipts.julia as MechanicalProbeRunReceipt)
+      .findings.map((finding) => `julia R0 receipt: ${finding}`)
+    : ['julia R0 receipt is required'];
+  findings.push(...validateMirrorR0Primary('jax', receipts.jax as MechanicalProbeRunReceipt | undefined));
+  findings.push(...validateMirrorR0ExecutedControl('jax', receipts.jax as MechanicalProbeRunReceipt | undefined));
+  findings.push(...validateMirrorR0Primary('pytorch', receipts.pytorch as MechanicalProbeRunReceipt | undefined));
+  findings.push(...validateMirrorR0ExecutedControl('pytorch', receipts.pytorch as MechanicalProbeRunReceipt | undefined));
+  return findings;
+}
