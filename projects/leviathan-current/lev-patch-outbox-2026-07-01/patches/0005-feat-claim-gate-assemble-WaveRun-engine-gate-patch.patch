+
+function normalizeModelLaneFailureSignal(lane: ClaimGateModelLaneManifest): string | undefined {
+  if (lane.status !== 'blocked' && lane.status !== 'unavailable') return undefined;
+  const rawSignal = lane.runtimeOutcome?.reason
+    ?? lane.unavailableReason
+    ?? lane.runtimeOutcome?.runtimeStatus
+    ?? lane.status;
+  const normalized = rawSignal
+    .trim()
+    .toLowerCase()
+    .replace(/\s+/g, ' ')
+    .replace(/sha256:[a-f0-9]{64}/g, 'sha256:<hash>')
+    .replace(/receipt:rcpt-[a-z0-9._:-]+/g, 'receipt:<ref>');
+  return normalized.length > 0 ? normalized : undefined;
+}
+
+function createModelLaneSignalCollapsePackets(input: ClaimGateWavegraphSliceInput): ClaimGateModelLaneFailurePacket[] {
+  const lanesBySignal = new Map<string, ClaimGateModelLaneManifest[]>();
+  for (const lane of input.modelLanes) {
+    const signal = normalizeModelLaneFailureSignal(lane);
+    if (!signal) continue;
+    lanesBySignal.set(signal, [...(lanesBySignal.get(signal) ?? []), lane]);
+  }
+  const failureSignalLaneCount = Array.from(lanesBySignal.values()).reduce((sum, lanes) => sum + lanes.length, 0);
+  if (failureSignalLaneCount === 0) return [];
+
+  return Array.from(lanesBySignal.entries())
+    .filter(([, lanes]) => (
+      lanes.length >= MIN_MODEL_LANE_SIGNAL_COLLAPSE_COUNT
+      && lanes.length / failureSignalLaneCount >= MIN_MODEL_LANE_SIGNAL_COLLAPSE_RATIO
+    ))
+    .map(([failureSignal, lanes]) => {
+      const ratio = lanes.length / failureSignalLaneCount;
+      const signalFragment = sha256({
+        aggregateId: input.modelAggregation.aggregateId,
+        failureSignal,
+        laneIds: lanes.map((lane) => lane.laneId).sort(),
+      }).slice('sha256:'.length, 'sha256:'.length + 16);
+      return {
+        packetId: `mlfp-signal-collapse-${signalFragment}`,
+        laneId: `signal-collapse:${signalFragment}`,
+        provider: 'local',
+        model: 'advisory-signal-collapse-gate',
+        family: 'gate',
+        violatedGate: 'model_lane_signal_collapse',
+        reason: `Model lane advisory failures collapsed onto one repeated signal across ${lanes.length}/${failureSignalLaneCount} failed lanes: ${failureSignal}`,
+        receiptRef: `receipt:rcpt-model-lane-signal-collapse-${signalFragment}`,
+        claimCeiling: 'signal_collapse_failure_not_model_judgment',
+        retryPolicy: 'requires_independent_model_lane_or_distinct_failure_signal',
+        failureSignal,
+        collapsedLaneIds: lanes.map((lane) => lane.laneId).sort(),
+        repeatedSignalCount: lanes.length,
+        repeatedSignalRatio: Number(ratio.toFixed(6)),
+      };
+    });
+}
+
+function createModelLaneFailurePackets(input: ClaimGateWavegraphSliceInput): ClaimGateModelLaneFailurePacket[] {
+  const availabilityPackets: ClaimGateModelLaneFailurePacket[] = input.modelLanes
+    .filter((lane) => lane.status === 'blocked' || lane.status === 'unavailable')
+    .map((lane) => ({
+      packetId: `mlfp-${safePacketIdFragment(lane.laneId)}`,
+      laneId: lane.laneId,
+      provider: lane.provider,
+      model: lane.model,
+      family: lane.family,
