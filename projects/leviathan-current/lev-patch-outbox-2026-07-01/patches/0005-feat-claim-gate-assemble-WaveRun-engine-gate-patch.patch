+ * Lev-owned producer for ClaimGate `.lev/steering/runs/<run-id>` projections.
+ *
+ * Emits a self-consistent steering run from a (deterministic) eval/council
+ * execution so the host boundary (`consumeClaimGateSteeringRun`) can
+ * INDEPENDENTLY recompute the verdict and consume it. This is the producer
+ * half of the host/source split: the producer NEVER self-asserts host
+ * authority — every authority flag is emitted falsy and only the one allowed
+ * `compatibility_only` flag is true. Host Lev writes the authority receipt
+ * separately after it consumes the run.
+ *
+ * The output shape mirrors the core-eval adapter projection the host already
+ * consumes; the host is the spec, so a produced run is only "good" if the real
+ * consumer recomputes it to `host_consumed`.
+ */
+import { mkdirSync, writeFileSync } from 'node:fs';
+import { join } from 'node:path';
+
+const ADAPTER_VERSION = '0.7.0-core-eval-adapter';
+const VERIFIER_VERSION = `claimgate/${ADAPTER_VERSION}`;
+
+export type ProduceObligationStatus = 'passed' | 'failed' | 'timeout';
+
+export interface ProduceClaimGateObligation {
+  /** e.g. `claimgate.object_binding` */
+  constraintId: string;
+  status: ProduceObligationStatus;
+  elapsedMs?: number;
+  evidenceRefs?: string[];
+}
+
+export interface ProduceClaimGateSteeringRunInput {
+  /** e.g. `claimgate.pr-trust` */
+  targetRef: string;
+  /** Defaults to `targetRef`. */
+  suiteId?: string;
+  /** The eval input receipt id; the produced verdict receipt must reference it. */
+  inputReceiptId: string;
+  /** The constraint obligations the council/eval execution actually checked. */
+  obligations: ProduceClaimGateObligation[];
+  /** Defaults to `cg-<inputReceiptId>`. */
+  runId?: string;
+  /** ISO timestamp; supply for deterministic output (defaults to now). */
+  generatedAt?: string;
+}
+
+export interface ProduceClaimGateSteeringRunResult {
+  runId: string;
+  runDir: string;
+  verdict: 'pass' | 'fail' | 'conditional';
+  files: string[];
+}
+
+function constraintShortName(constraintId: string): string {
+  const idx = constraintId.lastIndexOf('.');
+  return idx >= 0 ? constraintId.slice(idx + 1) : constraintId;
+}
+
+/**
+ * Mirror of the host's `validateProofResults` recompute so the produced
+ * projected verdict already agrees with what the host will independently
+ * recompute: any failed/timeout obligation → `fail`; all passed → `pass`.
+ */
+function recomputeVerdict(
+  obligations: ProduceClaimGateObligation[],
+): 'pass' | 'fail' | 'conditional' {
+  if (obligations.some((o) => o.status === 'failed' || o.status === 'timeout')) return 'fail';
+  if (obligations.length > 0 && obligations.every((o) => o.status === 'passed')) return 'pass';
+  return 'conditional';
+}
+
+export function produceClaimGateSteeringRun(
+  input: ProduceClaimGateSteeringRunInput,
+  outRoot: string,
+): ProduceClaimGateSteeringRunResult {
+  if (!input.targetRef) throw new Error('produceClaimGateSteeringRun: targetRef is required');
+  if (!input.inputReceiptId) throw new Error('produceClaimGateSteeringRun: inputReceiptId is required');
+  if (!Array.isArray(input.obligations) || input.obligations.length === 0) {
+    // Fail-closed: a zero-obligation run carries no evidence, recomputes to
+    // `conditional`, and the host blocks it. Refuse to emit empty-evidence runs.
+    throw new Error('produceClaimGateSteeringRun: at least one obligation is required (no empty-evidence runs)');
+  }
+
+  const { targetRef } = input;
+  const suiteId = input.suiteId ?? targetRef;
+  const generatedAt = input.generatedAt ?? new Date().toISOString();
+  const runId = input.runId ?? `cg-${input.inputReceiptId}`;
+  const specId = `ps-claimgate-${runId}`;
+  const jobId = `ej-claimgate-${runId}`;
+  const verdict = recomputeVerdict(input.obligations);
+
+  const evidence = input.obligations.map((o) => ({
+    status: o.status,
+    elapsedMs: o.elapsedMs ?? 0,
+    verifierVersion: VERIFIER_VERSION,
+    evidenceRefs: o.evidenceRefs ?? [],
+  }));
+
+  const proofObligations = input.obligations.map((o) => {
+    const short = constraintShortName(o.constraintId);
+    return {
+      obligationId: `obl-claimgate-${short}`,
+      constraintId: o.constraintId,
+      shellCheck: `claimgate internal gate ${short}`,
+      expectedResult: 'exit_zero',
+      actualResult: {
+        status: o.status,
+        elapsedMs: o.elapsedMs ?? 0,
+        verifierVersion: VERIFIER_VERSION,
+        evidenceRefs: o.evidenceRefs ?? [],
+      },
+    };
+  });
+
+  // eval-job.output must byte-match eval-job-output.json exactly (host check).
+  const evalOutput = { verdict, evidence, receiptId: input.inputReceiptId };
+
+  const runJson = {
+    version: ADAPTER_VERSION,
+    run_id: runId,
+    suite_id: suiteId,
+    target_ref: targetRef,
+    layout: '.lev/steering/runs/<run-id>',
+    compatibility_only: true,
+    live_lev_consumed: false,
+    claim_ceiling: 'adapter_partial',
+    release_admission_allowed: false,
+    generated_at: generatedAt,
+  };
+  const proofSpec = {
+    specId,
+    targetRef,
+    constraintPackId: targetRef,
+    proofObligations,
+    proofStrategy: 'compiled_guard',
+    generatedAt,
+  };
+  const evalJob = {
+    jobId,
+    jobClass: 'eval',
+    targetRef,
+    proofSpecId: specId,
+    constraintPackId: targetRef,
+    inputReceiptIds: [input.inputReceiptId],
+    startedAt: generatedAt,
+    completedAt: generatedAt,
+    output: evalOutput,
+  };
+  const boundary = {
+    version: ADAPTER_VERSION,
+    status: 'adapter_projection_only',
+    live_lev_consumed: false,
+    claim_ceiling: 'adapter_partial',
+    release_admission_allowed: false,
+    authority:
+      'host Lev EvalFlow / ProofSpec / execution ledger must consume this before it is Lev-admitted',
+    required_host_receipt_fields: [
+      'execution_ledger_receipt_id',
+      'run_seal_ref',
+      'host_lev_runtime',
+      'proof_spec_consumed',
+      'eval_job_output_consumed',
+    ],
+    target_files: [
+      'core/orchestration/src/proof/eval-job-types.ts',
+      'core/orchestration/src/proof/flows/eval-flow.ts',
+      'core/orchestration/src/proof/proof-spec-generator.ts',
+      'core/flowmind/src/gate-evaluator.ts',
+      'core/flowmind/src/kernel/constraint-manifold.ts',
+    ],
+    generated_at: generatedAt,
+  };
+
+  const runDir = join(outRoot, runId);
+  mkdirSync(runDir, { recursive: true });
+  const write = (name: string, data: unknown): string => {
+    const filePath = join(runDir, name);
+    writeFileSync(filePath, `${JSON.stringify(data, null, 2)}\n`);
+    return filePath;
+  };
+  const files = [
+    write('run.json', runJson),
+    write('proof-spec.json', proofSpec),
+    write('eval-job.json', evalJob),
+    write('eval-job-output.json', evalOutput),
+    write('boundary.json', boundary),
+  ];
+
+  return { runId, runDir, verdict, files };
+}
