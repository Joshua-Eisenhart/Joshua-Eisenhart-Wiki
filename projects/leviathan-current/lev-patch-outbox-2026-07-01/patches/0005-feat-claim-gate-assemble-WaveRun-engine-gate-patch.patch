+function runSeededSelfAuditCycle(
+  sourceResult: LevWizardRatchetRunResult,
+  realEngines: boolean,
+): LevWizardRatchetRunResult | undefined {
+  if (!sourceResult.nextRunSeed) return undefined;
+  const baseInput = makeDemoInput(false, false, true, false);
+  baseInput.sessionId = sourceResult.sessionId;
+  const seededInput = createSeededLevWizardRatchetInput(sourceResult, baseInput);
+  if (realEngines) {
+    const engineArtifacts = buildRealThreeEngineEnvelopeAndDigest();
+    seededInput.threeEngineEnvelope = engineArtifacts.envelope;
+    seededInput.levEngineSubstrateDigest = engineArtifacts.digest;
+    seededInput.levEngineSubstrateExecutionWitness = engineArtifacts.digestExecutionWitness;
+  }
+  attachRealSourceEvidence(seededInput);
+  return runLevWizardRatchetCouncil(seededInput);
+}
+
+function runSelfAudit(realEngines: boolean): LevWizardRatchetSelfAuditResult {
+  const baseline = runLevWizardRatchetCouncil(makeDemoInput(false, realEngines, false, true));
+  const repaired = runLevWizardRatchetCouncil(makeDemoInput(false, realEngines, true, true));
+  const seededNextRun = runSeededSelfAuditCycle(repaired, realEngines);
+  const invalidSimCheck = runLevWizardRatchetCouncil(makeDemoInput(true, realEngines, true, true));
+  const invalidSimRepairPlan = buildClaimGateRepairWavePlan(
+    invalidSimCheck.councilWaveInput,
+    invalidSimCheck.gateLoopResult,
+    {
+      sessionId: `${invalidSimCheck.sessionId}-self-audit-repair-wave`,
+      workstreamId: invalidSimCheck.workstreamId,
+    },
+  );
+  const invalidSimRepairDispatchPlan = buildClaimGateRepairDispatchPlan(
+    invalidSimRepairPlan,
+    {
+      sessionId: `${invalidSimCheck.sessionId}-self-audit-repair-dispatch`,
+      workstreamId: invalidSimCheck.workstreamId,
+    },
+  );
+  const invalidSimRepairDispatchExecution = recordClaimGateRepairDispatchExecution(
+    invalidSimRepairDispatchPlan,
+    buildSelfAuditRepairDispatchArtifact(invalidSimRepairPlan, invalidSimRepairDispatchPlan),
+    {
+      sessionId: `${invalidSimCheck.sessionId}-self-audit-repair-dispatch-execution`,
+      workstreamId: invalidSimCheck.workstreamId,
+    },
+  );
+
+  return {
+    kind: 'LevWizardRatchetSelfAuditResult',
+    claimCeiling: 'self_audit_metric_not_runtime_autonomy',
+    baseline,
+    repaired,
+    seededNextRun,
+    invalidSimRepairPlan,
+    invalidSimRepairDispatchPlan,
+    invalidSimRepairDispatchExecution,
+    metrics: {
+      baselineDeclaredOnlySkillDebt: baseline.skillIntake.declaredOnlyAfter,
+      repairedDeclaredOnlySkillDebt: repaired.skillIntake.declaredOnlyAfter,
+      declaredOnlySkillDebtDelta: baseline.skillIntake.declaredOnlyAfter - repaired.skillIntake.declaredOnlyAfter,
+      skillSourceRecordsBuilt: repaired.skillIntake.recordsBuilt,
+      admittedSourceSkillRecords: repaired.skillIntake.admittedRecordCount,
+      referenceOrBlockedSkillRecords: repaired.skillIntake.referenceOrBlockedRecordCount,
+      formalSkillCandidates: repaired.skillIntake.formalSkillCandidateCount,
+      admittedFormalSkills: repaired.skillIntake.admittedFormalSkillCount,
+      formalSkillBundles: repaired.skillIntake.formalSkillBundleCount,
+      formalSkillRuntimeDebt: repaired.skillIntake.formalSkillRuntimeDebt,
+      repairImprovementRatio: repaired.skillIntake.improvementRatio,
+      baselineDetectedDeclaredOnlySkillDebt: baseline.findings.some((finding) => finding.code === 'wizard_skill_intake_not_run'),
+      simGateStillBites: !invalidSimCheck.threeEngineValidation.ok && invalidSimCheck.gateLoopResult.failurePackets.length > 0,
+      invalidSimFailurePackets: invalidSimCheck.gateLoopResult.failurePackets.length,
+      invalidSimRepairClaims: invalidSimRepairPlan.repairClaims.length,
+      invalidSimRepairPlanMissingClaimIds: invalidSimRepairPlan.missingClaimIds.length,
+      invalidSimRepairDispatchRequests: invalidSimRepairDispatchPlan.dispatchRequests.length,
+      invalidSimRepairDispatchFindings: invalidSimRepairDispatchPlan.findings.length,
+      invalidSimRepairDispatchReady: invalidSimRepairDispatchPlan.ok && invalidSimRepairDispatchPlan.status === 'dispatch_ready',
+      invalidSimRepairDispatchExecutionEmittedClaims: invalidSimRepairDispatchExecution.emittedClaimIds.length,
+      invalidSimRepairDispatchExecutionMissingClaims: invalidSimRepairDispatchExecution.missingDispatchClaimIds.length,
+      invalidSimRepairDispatchExecutionFindings: invalidSimRepairDispatchExecution.findings.length,
+      repairDispatchExecuted: invalidSimRepairDispatchExecution.ok
+        && invalidSimRepairDispatchExecution.status === 'repair_dispatch_executed',
+      seededNextRunConsumedSeed: !!seededNextRun
+        && repaired.nextRunSeed?.seedSessionId === seededNextRun.sessionId
+        && repaired.nextRunSeed.sourceRunReceiptId === repaired.receipt.id,
+      seededNextRunPassed: !!seededNextRun
+        && seededNextRun.threeEngineValidation.ok
+        && seededNextRun.gateLoopResult.failurePackets.length === 0
+        && seededNextRun.graphAdmission.ok
+        && steeringAdmissionPassed(seededNextRun),
+      seededNextRunFailurePackets: seededNextRun?.gateLoopResult.failurePackets.length ?? 0,
+    },
+  };
+}
+
+function formatSelfAudit(result: LevWizardRatchetSelfAuditResult, out?: string): string {
+  const metricImproved = result.metrics.declaredOnlySkillDebtDelta > 0 && result.metrics.simGateStillBites;
+  const status = metricImproved
+    ? result.metrics.repairDispatchExecuted
+      ? 'runtime_repair_executed'
+      : 'metrics_improved_only'
+    : 'blocked';
+  return [
+    `Lev Wizard Ratchet self-audit: ${status}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Detected declared-only skill debt: ${result.metrics.baselineDetectedDeclaredOnlySkillDebt}`,
+    `Declared-only skill debt: ${result.metrics.baselineDeclaredOnlySkillDebt} -> ${result.metrics.repairedDeclaredOnlySkillDebt}`,
+    `Skill source records: ${result.metrics.skillSourceRecordsBuilt} built, ${result.metrics.admittedSourceSkillRecords} admitted, ${result.metrics.referenceOrBlockedSkillRecords} reference/blocked`,
+    `Formal skill candidates: ${result.metrics.formalSkillCandidates} candidates, ${result.metrics.admittedFormalSkills} admitted, ${result.metrics.formalSkillBundles} bundles`,
+    `Runtime dispatch debt: ${result.metrics.formalSkillRuntimeDebt} formal skills not dispatched`,
+    `Improvement ratio: ${result.metrics.repairImprovementRatio}`,
+    `Sim gate still bites: ${result.metrics.simGateStillBites}`,
+    `Invalid sim repair plan: ${result.metrics.invalidSimRepairClaims} repair claims, ${result.metrics.invalidSimRepairPlanMissingClaimIds} missing claim IDs`,
+    `Invalid sim dispatch plan: ${result.metrics.invalidSimRepairDispatchRequests} requests, ${result.metrics.invalidSimRepairDispatchFindings} findings, ready=${result.metrics.invalidSimRepairDispatchReady}`,
+    `Repair dispatch execution: ${result.metrics.repairDispatchExecuted ? 'ran' : 'not run'} (${result.metrics.invalidSimRepairDispatchExecutionEmittedClaims} emitted, ${result.metrics.invalidSimRepairDispatchExecutionMissingClaims} missing, ${result.metrics.invalidSimRepairDispatchExecutionFindings} findings)`,
+    `Seeded next run: ${result.metrics.seededNextRunPassed ? 'passed' : 'blocked'} (consumedSeed=${result.metrics.seededNextRunConsumedSeed}, failurePackets=${result.metrics.seededNextRunFailurePackets})`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function selfAuditResponse(result: LevWizardRatchetSelfAuditResult, parsed: ParsedArgs) {
+  const success = result.metrics.declaredOnlySkillDebtDelta > 0
+    && result.metrics.repairedDeclaredOnlySkillDebt === 0
+    && result.metrics.baselineDetectedDeclaredOnlySkillDebt
+    && result.metrics.simGateStillBites
+    && result.metrics.invalidSimRepairClaims > 0
+    && result.metrics.invalidSimRepairPlanMissingClaimIds === 0
+    && result.metrics.invalidSimRepairDispatchRequests === result.metrics.invalidSimRepairClaims
+    && result.metrics.invalidSimRepairDispatchReady
+    && result.metrics.repairDispatchExecuted
+    && result.metrics.invalidSimRepairDispatchExecutionMissingClaims === 0
+    && result.metrics.invalidSimRepairDispatchExecutionFindings === 0
+    && result.metrics.seededNextRunConsumedSeed
+    && result.metrics.seededNextRunPassed
+    && result.metrics.seededNextRunFailurePackets === 0;
+  if (parsed.out) writeJson(parsed.out, result);
+  return {
+    success,
+    formatted_response: parsed.json ? JSON.stringify(result, null, 2) : formatSelfAudit(result, parsed.out),
+    data: result,
+    error_code: success ? undefined : 'LEV_WIZARD_RATCHET_SELF_AUDIT_BLOCKED',
+  };
+}
+
+async function runCouncilForHandler(
+  input: LevWizardRatchetRunInput,
+  parsed: ParsedArgs,
+  deps: LevWizardRatchetHandlerDeps,
+): Promise<LevWizardRatchetRunResult> {
+  const hostFalsifierState = hostFalsifierStateForParsed(parsed);
+  const council = {
+    steeringOverclaimProbe: parsed.steeringOverclaim,
+    hostFalsifierState,
+  };
+  if (!parsed.runModelLanes) {
+    return runLevWizardRatchetCouncil(input, council);
+  }
+  return runLevWizardRatchetCouncilWithModelLaneRuntime(input, {
+    runners: deps.modelLaneRunners ?? createDefaultLiveModelLaneRunners(),
+    timeoutMs: deps.modelLaneTimeoutMs ?? 30_000,
+    defaultPrompt: [
+      'Redacted Lev Wizard model-lane audit.',
+      'Return an advisory finding only; do not claim authority or admission.',
+      input.task,
+    ].join('\n'),
+    council,
+  });
+}
+
+export async function handler(args: string[], deps: LevWizardRatchetHandlerDeps = {}) {
+  const parsed = parseArgs(args);
+
+  if (parsed.subcommand === 'help' || parsed.subcommand === '--help' || parsed.subcommand === '-h') {
+    return {
+      success: true,
+      formatted_response: usage(),
+    };
+  }
+
+  try {
+    if (parsed.subcommand === 'demo') {
+      return await resultResponse(
+        await runCouncilForHandler(
+          makeDemoInput(
+            parsed.invalidSim,
+            parsed.realEngines,
+            parsed.realSkills,
+            parsed.realSourceEvidence,
+            hostFalsifierStateForParsed(parsed),
+          ),
+          parsed,
+          deps,
+        ),
+        parsed,
+      );
+    }
+
+    if (parsed.subcommand === 'self-audit') {
+      return selfAuditResponse(runSelfAudit(parsed.realEngines), parsed);
+    }
+
+    if (parsed.subcommand === 'seed') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'LEV_WIZARD_RATCHET_MISSING_INPUT',
+        };
+      }
+      const previousArtifact = readJson<unknown>(parsed.input);
+      const graphApplyBridge = isLevWizardRatchetGraphApplyBridgeResult(previousArtifact) ? previousArtifact : undefined;
+      const previousResult = graphApplyBridge?.wizardResult ?? previousArtifact;
+      if (!isLevWizardRatchetRunResult(previousResult)) {
+        return {
+          success: false,
+          formatted_response: `Lev Wizard Ratchet blocked: seed requires a graph-applied LevWizardRatchetGraphApplyBridgeResult, got ${artifactKind(previousArtifact) ?? 'unknown artifact'}.`,
+          error_code: 'LEV_WIZARD_RATCHET_SEED_SOURCE_KIND_INVALID',
+          data: {
+            kind: artifactKind(previousArtifact),
+            expectedKind: 'LevWizardRatchetGraphApplyBridgeResult',
+          },
+        };
+      }
+      if (!graphApplyBridge) {
+        return {
+          success: false,
+          formatted_response: 'Lev Wizard Ratchet blocked: raw run-result seed artifacts are not host seed authority; run demo with --apply-graph-patch and seed from the graph-apply bridge artifact.',
+          error_code: 'LEV_WIZARD_RATCHET_GRAPH_APPLIED_SEED_REQUIRED',
+          data: {
+            kind: artifactKind(previousArtifact),
+            expectedKind: 'LevWizardRatchetGraphApplyBridgeResult',
+          },
+        };
+      }
+      {
+        const bridgeGraphExecutionFindings = graphAppliedBridgeExecutionFindings(graphApplyBridge);
+        const graphAppliedNextRunSeed = buildGraphAppliedNextRunSeed(graphApplyBridge.wizardResult, graphApplyBridge.graphExecution);
+        const graphEventStoreFindings = bridgeGraphExecutionFindings.length === 0
+          ? await graphAppliedEventStoreFindings(graphApplyBridge, graphApplyBridge.graphExecution)
+          : [];
+        const graphStateFindings = bridgeGraphExecutionFindings.length === 0
+          ? await graphAppliedStateFindings(graphApplyBridge, graphApplyBridge.graphExecution)
+          : [];
+        if (bridgeGraphExecutionFindings.length > 0 || !graphAppliedNextRunSeed) {
+          return {
+            success: false,
+            formatted_response: 'Lev Wizard Ratchet blocked: graph-applied seed source must carry a clean graph_patch_executed bridge receipt and graph-applied next seed.',
+            error_code: 'LEV_WIZARD_RATCHET_GRAPH_APPLIED_SEED_NOT_EARNED',
+            data: {
+              kind: 'LevWizardRatchetGraphAppliedSeedFindings',
+              graphExecutionStatus: graphApplyBridge.graphExecution.status,
+              graphMutationApplied: graphApplyBridge.graphExecution.graphMutationApplied,
+              hasGraphAppliedNextRunSeed: !!graphAppliedNextRunSeed,
+              findings: bridgeGraphExecutionFindings,
+            },
+          };
+        }
+        if (graphEventStoreFindings.length > 0) {
+          return {
+            success: false,
+            formatted_response: 'Lev Wizard Ratchet blocked: graph-applied seed source must be backed by the host graph event store.',
+            error_code: 'LEV_WIZARD_RATCHET_GRAPH_APPLIED_SEED_EVENT_MISSING',
+            data: {
+              kind: 'LevWizardRatchetGraphAppliedSeedFindings',
+              graphExecutionStatus: graphApplyBridge.graphExecution.status,
+              graphMutationApplied: graphApplyBridge.graphExecution.graphMutationApplied,
+              graphEventId: graphApplyBridge.graphExecution.graphEventId,
+              hasGraphAppliedNextRunSeed: !!graphAppliedNextRunSeed,
+              findings: graphEventStoreFindings,
+            },
+          };
+        }
+        if (graphStateFindings.length > 0) {
+          return {
+            success: false,
+            formatted_response: 'Lev Wizard Ratchet blocked: graph-applied seed source must be present in the host graph state with the execution graph event id.',
+            error_code: 'LEV_WIZARD_RATCHET_GRAPH_APPLIED_SEED_GRAPH_STATE_MISSING',
+            data: {
+              kind: 'LevWizardRatchetGraphAppliedSeedFindings',
+              graphExecutionStatus: graphApplyBridge.graphExecution.status,
+              graphMutationApplied: graphApplyBridge.graphExecution.graphMutationApplied,
+              graphEventId: graphApplyBridge.graphExecution.graphEventId,
+              hasGraphAppliedNextRunSeed: !!graphAppliedNextRunSeed,
+              findings: graphStateFindings,
+            },
+          };
+        }
+        previousResult.nextRunSeed = {
+          ...previousResult.nextRunSeed!,
+          inputPatch: {
+            sessionId: graphAppliedNextRunSeed.inputPatch.sessionId,
+            contextReceipts: graphAppliedNextRunSeed.inputPatch.contextReceipts.map((receipt) => ({ ...receipt })),
+          },
+        };
+      }
+      const consumptionRef = seedConsumptionRef(previousResult);
+      if (consumptionRef && consumedSeedRefs().has(consumptionRef)) {
+        return {
+          success: false,
+          formatted_response: 'Lev Wizard Ratchet blocked: next-run seed was already consumed by this host.',
+          error_code: 'LEV_WIZARD_RATCHET_SEED_REPLAY_BLOCKED',
+          data: {
+            kind: 'LevWizardRatchetSeedReplayFindings',
+            seedConsumptionRef: consumptionRef,
+            seedSessionId: previousResult.nextRunSeed?.seedSessionId,
+            ledgerPath: levWizardSeedConsumptionLedgerPath(),
+          },
+        };
+      }
+      const baseInput = makeDemoInput(
+        false,
+        false,
+        parsed.realSkills,
+        false,
+      );
+      baseInput.sessionId = previousResult.sessionId;
+      const seededInput = createSeededLevWizardRatchetInput(previousResult, baseInput);
+      if (consumptionRef) recordSeedConsumption(previousResult, consumptionRef);
+      if (parsed.realEngines) {
+        const engineArtifacts = buildRealThreeEngineEnvelopeAndDigest();
+        seededInput.threeEngineEnvelope = engineArtifacts.envelope;
+        seededInput.levEngineSubstrateDigest = engineArtifacts.digest;
+        seededInput.levEngineSubstrateExecutionWitness = engineArtifacts.digestExecutionWitness;
+      }
+      if (parsed.invalidSim && seededInput.threeEngineEnvelope) {
+        seededInput.threeEngineEnvelope = {
+          ...seededInput.threeEngineEnvelope,
+          engines: {
+            ...seededInput.threeEngineEnvelope.engines,
+            jax: {
+              ...seededInput.threeEngineEnvelope.engines.jax,
+              negativeControl: '',
+            },
+          },
+        };
+      }
+      if (parsed.realSourceEvidence) {
+        attachRealSourceEvidence(seededInput, hostFalsifierStateForParsed(parsed));
+      }
+      return await resultResponse(
+        await runCouncilForHandler(
+          seededInput,
+          parsed,
+          deps,
+        ),
+        parsed,
+      );
+    }
+
+    if (parsed.subcommand === 'consume') {
+      if (!parsed.input) {
+        return {
+          success: false,
+          formatted_response: usage(),
+          error_code: 'LEV_WIZARD_RATCHET_MISSING_INPUT',
+        };
+      }
+      const inputArtifact = readJson<unknown>(parsed.input);
+      if (!isLevWizardRatchetRunInput(inputArtifact)) {
+        return {
+          success: false,
+          formatted_response: `Lev Wizard Ratchet blocked: consume requires LevWizardRatchetRunInput, got ${artifactKind(inputArtifact) ?? 'unknown artifact'}.`,
+          error_code: 'LEV_WIZARD_RATCHET_INPUT_KIND_INVALID',
+          data: {
+            kind: artifactKind(inputArtifact),
+            expectedKind: 'LevWizardRatchetRunInput',
+          },
+        };
+      }
+      const input = inputArtifact;
+      const fileEvidenceFindings = validateExternalFileEvidenceRoots(input, parsed.fileEvidenceRoots);
+      if (fileEvidenceFindings.length > 0) {
+        return {
+          success: false,
+          formatted_response: `Lev Wizard Ratchet blocked: ${fileEvidenceFindings.join('; ')}`,
+          error_code: 'LEV_WIZARD_RATCHET_FILE_EVIDENCE_ROOT_REQUIRED',
+          data: {
+            kind: 'LevWizardRatchetFileEvidenceRootFindings',
+            findings: fileEvidenceFindings,
+          },
+        };
+      }
+      if (input.levEngineSubstrateDigest && !parsed.realEngines) {
+        return {
+          success: false,
+          formatted_response: 'Lev Wizard Ratchet blocked: external consume inputs cannot supply their own Lev engine substrate digest; rerun consume with --real-engines so the host rebuilds engine evidence.',
+          error_code: 'LEV_WIZARD_RATCHET_EXTERNAL_ENGINE_SUBSTRATE_DIGEST_REJECTED',
+          data: {
+            kind: 'LevWizardRatchetExternalEngineSubstrateDigestRejected',
+            requiredFlag: '--real-engines',
+          },
+        };
+      }
+      if (parsed.realEngines) {
+        const engineArtifacts = buildRealThreeEngineEnvelopeAndDigest();
+        input.threeEngineEnvelope = engineArtifacts.envelope;
+        input.levEngineSubstrateDigest = engineArtifacts.digest;
+        input.levEngineSubstrateExecutionWitness = engineArtifacts.digestExecutionWitness;
+      }
+      return await resultResponse(
+        await runCouncilForHandler(
+          input,
+          parsed,
+          deps,
+        ),
+        parsed,
+      );
+    }
+  } catch (error) {
+    return {
+      success: false,
+      formatted_response: `Lev Wizard Ratchet failed: ${error instanceof Error ? error.message : String(error)}`,
+      error_code: 'LEV_WIZARD_RATCHET_FAILED',
+    };
+  }
+
+  return {
+    success: false,
+    formatted_response: usage(),
+    error_code: 'LEV_WIZARD_RATCHET_UNKNOWN_SUBCOMMAND',
+  };
+}
