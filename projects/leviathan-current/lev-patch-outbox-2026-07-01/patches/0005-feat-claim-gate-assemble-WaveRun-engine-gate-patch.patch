+function createThreeEngineReceiptManifest(
+  envelope: ThreeEngineProbeEnvelope | undefined,
+  validation: EnvelopeValidationResult,
+  engineSubstrateDigest?: LevEngineSubstrateDigest,
+  engineSubstrateExecutionWitness?: LevEngineSubstrateExecutionWitness,
+  engineSubstrateValidation?: EnvelopeValidationResult,
+): LevWizardThreeEngineReceiptManifest {
+  return {
+    kind: 'LevWizardThreeEngineReceiptManifest',
+    claimCeiling: 'mechanical_probe_receipt_manifest_not_proof_authority',
+    envelopeHash: envelope ? sha256(envelope) : 'missing',
+    validationOk: validation.ok,
+    findings: validation.findings,
+    runtimeCarrier: envelope?.runtimeCarrier,
+    receiptHashes: envelope?.mechanicalProbeRunReceiptHashes,
+    receipts: envelope?.mechanicalProbeReceipts,
+    engineSubstrateDigestHash: engineSubstrateDigest ? sha256(engineSubstrateDigest) : undefined,
+    engineSubstrateDigest,
+    engineSubstrateExecutionWitness,
+    engineSubstrateValidation,
+    semanticChecks: {
+      juliaPinnedR0Receipt: validation.ok && !!envelope?.mechanicalProbeReceipts?.julia,
+      jaxPrimaryR0QuotientRefinement: validation.ok && hasJsonResult(envelope?.mechanicalProbeReceipts?.jax),
+      jaxExecutedDuplicateZControl: validation.ok && hasJsonExecutedControl(envelope?.mechanicalProbeReceipts?.jax),
+      pytorchPrimaryR0QuotientRefinement: validation.ok && hasJsonResult(envelope?.mechanicalProbeReceipts?.pytorch),
+      pytorchExecutedDuplicateZControl: validation.ok && hasJsonExecutedControl(envelope?.mechanicalProbeReceipts?.pytorch),
+    },
+  };
+}
