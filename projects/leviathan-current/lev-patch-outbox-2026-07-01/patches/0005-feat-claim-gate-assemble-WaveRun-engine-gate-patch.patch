+function makeTempRoot(name: string): string {
+  const root = join(tmpdir(), `lev-redteam-${name}-${Date.now()}-${Math.random().toString(16).slice(2)}`);
+  mkdirSync(root, { recursive: true });
+  return root;
+}
+
+function stableStringify(value: unknown): string {
+  if (value === null || typeof value !== 'object') return JSON.stringify(value);
+  if (Array.isArray(value)) return `[${value.map(stableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${stableStringify(record[key])}`).join(',')}}`;
+}
+
+function sha256(value: unknown): string {
+  return createHash('sha256').update(stableStringify(value)).digest('hex');
+}
+
+function sha256Ref(value: unknown): string {
+  return `sha256:${sha256(value)}`;
+}
+
+function writeSourceBoundGateEvidence(
+  root: string,
+  gateId: 'object_binding' | 'evidence_manifest' | 'falsifier',
+  sessionId: string,
+  overrides: Record<string, unknown> = {},
+): string[] {
+  const file = join(root, `${gateId}-${Math.random().toString(36).slice(2)}.json`);
+  const body = `${JSON.stringify({
+    kind: 'ClaimGateSourceBoundGateEvidence',
+    claimCeiling: 'local_hash_bound_source_evidence_not_host_admission',
+    gateId,
+    sessionId,
+    taskHash: sha256Ref('redteam-source-bound-task'),
+    objectRef: 'claim-gate-redteam-object',
+    contextReceiptRefs: ['receipt:rcpt-redteam-context'],
+    contextContentHashes: [sha256Ref('redteam-context')],
+    threeEngineEnvelopeHash: sha256Ref('redteam-three-engine-envelope'),
+    falsifierStatus: 'closed',
+    openFalsifierCount: 0,
+    ...overrides,
+  }, null, 2)}\n`;
+  writeFileSync(file, body);
+  return [`file:${file}`, sha256Ref(body)];
+}
+
+function writeSteeringRun(root: string, runId: string, verdict: 'pass' | 'fail' = 'pass'): string {
+  const runDir = join(root, runId);
+  mkdirSync(runDir, { recursive: true });
+  const status = verdict === 'pass' ? 'passed' : 'failed';
+  const proofSpec = {
+    specId: `ps-${runId}`,
+    targetRef: `target-${runId}`,
+    proofStrategy: 'compiled_guard',
+    generatedAt: new Date().toISOString(),
+    proofObligations: [
+      {
+        obligationId: 'obl-0',
+        constraintId: 'constraint-0',
+        shellCheck: 'echo redteam',
+        expectedResult: 'exit_zero',
+        actualResult: {
+          status,
+          elapsedMs: 1,
+          verifierVersion: 'redteam/1.0',
+        },
+      },
+    ],
+  };
+  const output = {
+    verdict,
+    evidence: proofSpec.proofObligations.map((obligation) => obligation.actualResult),
+    receiptId: `claim-receipt-${runId}`,
+  };
+  const evalJob = {
+    jobId: `ej-${runId}`,
+    jobClass: 'eval',
+    targetRef: proofSpec.targetRef,
+    proofSpecId: proofSpec.specId,
+    output,
+  };
+
+  writeFileSync(join(runDir, 'run.json'), `${JSON.stringify({ run_id: runId }, null, 2)}\n`);
+  writeFileSync(join(runDir, 'proof-spec.json'), `${JSON.stringify(proofSpec, null, 2)}\n`);
+  writeFileSync(join(runDir, 'eval-job.json'), `${JSON.stringify(evalJob, null, 2)}\n`);
+  writeFileSync(join(runDir, 'eval-job-output.json'), `${JSON.stringify(output, null, 2)}\n`);
+  writeFileSync(join(runDir, 'boundary.json'), `${JSON.stringify({ live_lev_consumed: false }, null, 2)}\n`);
+  return runDir;
+}
+
+function testWaveContract() {
