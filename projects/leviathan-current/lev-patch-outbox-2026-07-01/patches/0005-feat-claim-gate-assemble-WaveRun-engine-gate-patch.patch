+import { describe, it, expect } from 'vitest';
+import { mkdtempSync, readFileSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+import { produceClaimGateSteeringRun } from './claim-gate-steering-produce.js';
+import {
+  consumeClaimGateSteeringRun,
+  consumeClaimGateSteeringRunWithHostWitness,
+} from './claim-gate-steering-run.js';
+
+const PASSED_OBLIGATIONS = [
+  'claimgate.claim_card_validity',
+  'claimgate.effect_envelope_validity',
+  'claimgate.object_binding',
+].map((constraintId) => ({ constraintId, status: 'passed' as const }));
+
+function baseInput() {
+  return {
+    targetRef: 'claimgate.pr-trust',
+    inputReceiptId: 'cg_receipt_produce_test',
+    obligations: PASSED_OBLIGATIONS,
+    runId: 'cg-produce-test',
+    generatedAt: '2026-06-25T00:00:00.000Z',
+  };
+}
+
+function freshOutDir(): string {
+  return mkdtempSync(join(tmpdir(), 'lev-produce-'));
+}
+
+describe('produceClaimGateSteeringRun', () => {
+  it('produces a structurally consistent run that the host blocks until the full internal gate set is present', () => {
+    const produced = produceClaimGateSteeringRun(baseInput(), freshOutDir());
+    expect(produced.verdict).toBe('pass');
+    expect(produced.files).toHaveLength(5);
+    const hostWitnessLedgerPath = join(freshOutDir(), 'host-witnesses.jsonl');
+
+    const result = consumeClaimGateSteeringRunWithHostWitness({
+      runDir: produced.runDir,
+      writeReceipt: false,
+      hostWitnessLedgerPath,
+    });
+    expect(result.status).toBe('host_blocked');
+    expect(result.projectedVerdict).toBe('pass');
+    expect(result.recomputedVerdict).toBe('pass');
+    expect(result.findings.map((f) => f.code)).toContain('host_witness.required_internal_gate_missing');
+  });
+
+  it('recomputes fail when an obligation fails (verdict stays honest and self-consistent)', () => {
+    const input = baseInput();
+    input.obligations = [
+      ...PASSED_OBLIGATIONS.slice(0, 2),
+      { constraintId: 'claimgate.object_binding', status: 'failed' as const },
+    ];
+    const produced = produceClaimGateSteeringRun(input, freshOutDir());
+    expect(produced.verdict).toBe('fail');
+
+    const result = consumeClaimGateSteeringRun({ runDir: produced.runDir, writeReceipt: false });
+    expect(result.recomputedVerdict).toBe('fail');
+    expect(result.projectedVerdict).toBe('fail');
+    // projected matches recomputed -> no verdict-mismatch error.
+    expect(result.findings.some((f) => f.code === 'eval_output.verdict_mismatch')).toBe(false);
+  });
+
+  it('refuses to produce an empty-evidence run (fail-closed)', () => {
+    expect(() => produceClaimGateSteeringRun({ ...baseInput(), obligations: [] }, freshOutDir())).toThrow();
+  });
+
+  it('the host BLOCKS a produced run tampered to self-assert host authority', () => {
+    const produced = produceClaimGateSteeringRun(baseInput(), freshOutDir());
+    const runJsonPath = join(produced.runDir, 'run.json');
+    const runJson = JSON.parse(readFileSync(runJsonPath, 'utf8'));
+    runJson.release_admission_allowed = true;
+    writeFileSync(runJsonPath, `${JSON.stringify(runJson, null, 2)}\n`);
+
+    const result = consumeClaimGateSteeringRun({ runDir: produced.runDir, writeReceipt: false });
+    expect(result.status).toBe('host_blocked');
+    expect(result.findings.some((f) => f.code.includes('release_admission_allowed'))).toBe(true);
+  });
+
+  it('the host BLOCKS a produced run whose projected verdict was faked over failing evidence', () => {
+    const produced = produceClaimGateSteeringRun(baseInput(), freshOutDir());
+    for (const name of ['eval-job-output.json', 'eval-job.json']) {
+      const p = join(produced.runDir, name);
+      const json = JSON.parse(readFileSync(p, 'utf8'));
+      const evidence = name === 'eval-job.json' ? json.output.evidence : json.evidence;
+      evidence[0].status = 'failed';
+      writeFileSync(p, `${JSON.stringify(json, null, 2)}\n`);
+    }
+    const result = consumeClaimGateSteeringRun({ runDir: produced.runDir, writeReceipt: false });
+    expect(result.status).toBe('host_blocked');
+    expect(result.recomputedVerdict).toBe('fail');
+    expect(result.projectedVerdict).toBe('pass');
+  });
+});
