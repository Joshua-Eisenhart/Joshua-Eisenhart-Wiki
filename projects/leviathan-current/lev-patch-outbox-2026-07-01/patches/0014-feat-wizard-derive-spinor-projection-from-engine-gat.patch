+function finiteNumberArray(value: unknown): value is number[] {
+  return Array.isArray(value) && value.every((entry) => typeof entry === 'number' && Number.isFinite(entry));
+}
+
+function graphInvariantsFromDigest(digest: ReturnType<typeof buildRealLevEngineSubstrateDigest>) {
+  return {
+    nodeCount: digest.graphInvariants.nodeCount,
+    edgeCount: digest.graphInvariants.edgeCount,
+    juliaAlgebraicConnectivity: digest.graphInvariants.juliaAlgebraicConnectivity,
+    jaxMessagePassing: [...digest.graphInvariants.jaxMessagePassing],
+    pytorchAutogradGradient: [...digest.graphInvariants.pytorchAutogradGradient],
+  };
+}
