+    obligationKind: input.obligationKind,
+    obligationHash: input.obligationHash,
+    sourceDigestHash: input.sourceDigestHash,
+    graphInvariants: graphInvariantsFromDigest(input.digest),
+    ...(input.obligationKind === 'spinor_memory_projection_probe'
+      ? {
+          spinorFrame: {
+            chirality: 'mixed' as const,
+            phase: 'cycle4:spectral>message>autograd',
+            orientation: 'engine_derived_graph_tensor_read_model',
+          },
+        }
+      : {}),
+  };
+
+  return {
+    ...base,
+    projectionHash: sha256(projectionHashPayload(base)),
+  };
+}
