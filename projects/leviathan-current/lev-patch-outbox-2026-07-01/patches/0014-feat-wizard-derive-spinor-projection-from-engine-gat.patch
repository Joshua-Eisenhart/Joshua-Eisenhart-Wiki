+function validateDerivedProjection(
+  projection: ClaimGateWaveRunEngineDerivedProjection | undefined,
+  obligation: ClaimGateWaveRunEngineObligation,
+  obligationHash: string,
+): string[] {
+  const findings: string[] = [];
+  if (projection === undefined) return findings;
+
+  if (projection.kind !== 'ClaimGateWaveRunEngineDerivedProjection') {
+    findings.push('Host three-engine derived projection kind must be ClaimGateWaveRunEngineDerivedProjection.');
+  }
+  if (projection.schemaVersion !== 'claim-gate-wave-run-engine-derived-projection-v0') {
+    findings.push('Host three-engine derived projection schemaVersion must be claim-gate-wave-run-engine-derived-projection-v0.');
+  }
+  if (projection.claimCeiling !== 'engine_derived_projection_not_graph_or_memory_authority') {
+    findings.push('Host three-engine derived projection claimCeiling must be engine_derived_projection_not_graph_or_memory_authority.');
+  }
+  if (projection.runtimeOwner !== 'lev') {
+    findings.push('Host three-engine derived projection runtimeOwner must be lev.');
+  }
+  if (projection.promotionAllowed !== false) {
+    findings.push('Host three-engine derived projection promotionAllowed must be false.');
+  }
+  if (projection.graphMutationApplied !== false) {
+    findings.push('Host three-engine derived projection graphMutationApplied must be false.');
+  }
+  if (projection.memoryPromotionApplied !== false) {
+    findings.push('Host three-engine derived projection memoryPromotionApplied must be false.');
+  }
+  if (projection.obligationKind !== obligation.kind) {
+    findings.push('Host three-engine derived projection obligationKind must match the obligation kind.');
+  }
+  if (projection.obligationHash !== obligationHash) {
+    findings.push('Host three-engine derived projection obligationHash must match the computed obligationHash.');
+  }
+  if (!isSha256Ref(projection.sourceDigestHash)) {
+    findings.push('Host three-engine derived projection sourceDigestHash must be a sha256 ref.');
+  }
+  if (!isSha256Ref(projection.projectionHash)) {
+    findings.push('Host three-engine derived projection projectionHash must be a sha256 ref.');
+  } else {
+    const { projectionHash: _projectionHash, ...base } = projection;
+    if (projection.projectionHash !== sha256(projectionHashPayload(base))) {
+      findings.push('Host three-engine derived projection projectionHash must bind the projection payload.');
+    }
+  }
+  if (projection.graphInvariants.nodeCount !== 4) {
+    findings.push('Host three-engine derived projection graphInvariants.nodeCount must be 4.');
+  }
+  if (projection.graphInvariants.edgeCount !== 4) {
+    findings.push('Host three-engine derived projection graphInvariants.edgeCount must be 4.');
+  }
+  if (projection.graphInvariants.juliaAlgebraicConnectivity !== 2) {
+    findings.push('Host three-engine derived projection graphInvariants.juliaAlgebraicConnectivity must be 2.');
+  }
+  if (!finiteNumberArray(projection.graphInvariants.jaxMessagePassing) || projection.graphInvariants.jaxMessagePassing.join(',') !== '6,4,6,4') {
+    findings.push('Host three-engine derived projection graphInvariants.jaxMessagePassing must be [6,4,6,4].');
+  }
+  if (!finiteNumberArray(projection.graphInvariants.pytorchAutogradGradient) || projection.graphInvariants.pytorchAutogradGradient.join(',') !== '2,2,2,2') {
+    findings.push('Host three-engine derived projection graphInvariants.pytorchAutogradGradient must be [2,2,2,2].');
+  }
+  if (obligation.kind === 'spinor_memory_projection_probe') {
+    if (!projection.spinorFrame) {
+      findings.push('Host spinor memory projection requires a spinorFrame.');
+    } else {
+      if (projection.spinorFrame.chirality !== 'mixed') {
+        findings.push('Host spinor memory projection chirality must be mixed in V0.');
+      }
+      if (!projection.spinorFrame.phase) {
+        findings.push('Host spinor memory projection phase is required.');
+      }
+      if (!projection.spinorFrame.orientation) {
+        findings.push('Host spinor memory projection orientation is required.');
+      }
+    }
+  }
+
+  return findings;
+}
