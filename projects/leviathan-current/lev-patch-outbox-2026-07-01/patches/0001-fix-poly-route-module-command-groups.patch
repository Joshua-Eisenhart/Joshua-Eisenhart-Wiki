--- /dev/null
+++ b/core/poly/src/surfaces/cli/module-dispatch.ts
@@ -0,0 +1,88 @@
+import type { CommandEntry, CommandRegistry } from './types.js';
+
+export type ModuleInvocation =
+  | {
+      kind: 'command';
+      module: string;
+      entry: CommandEntry;
+      args: string[];
+    }
+  | {
+      kind: 'help';
+      module: string;
+      commands: CommandEntry[];
+    }
+  | {
+      kind: 'unknown-subcommand';
+      module: string;
+      command: string;
+      commands: CommandEntry[];
+    };
+
+function isHelpToken(token: string | undefined): boolean {
+  return token === undefined || token === '--help' || token === '-h' || token === 'help';
+}
+
+export function getModuleCommands(registry: CommandRegistry, moduleName: string): CommandEntry[] {
+  return Object.values(registry.commands)
+    .filter((entry) => entry.module === moduleName)
+    .sort((a, b) => a.name.localeCompare(b.name));
+}
+
+export function resolveModuleInvocation(
+  cliArgs: string[],
+  registry: CommandRegistry,
+): ModuleInvocation | null {
+  const [moduleName, subcommand, ...rest] = cliArgs;
+  if (!moduleName) return null;
+
+  const commands = getModuleCommands(registry, moduleName);
+  if (commands.length === 0) return null;
+
+  if (isHelpToken(subcommand)) {
+    return {
+      kind: 'help',
+      module: moduleName,
+      commands,
+    };
+  }
+
+  const entry = commands.find((command) => command.name === subcommand);
+  if (!entry) {
+    return {
+      kind: 'unknown-subcommand',
+      module: moduleName,
+      command: subcommand,
+      commands,
+    };
+  }
+
+  return {
+    kind: 'command',
+    module: moduleName,
+    entry,
+    args: rest,
+  };
+}
+
+export function formatModuleHelp(moduleName: string, commands: CommandEntry[]): string {
+  const commandRows = commands.map((command) => `  ${command.name}`).join('\n');
+  return [
+    `lev ${moduleName} - module command group`,
+    '',
+    'Usage:',
+    `  lev ${moduleName} <command> [args]`,
+    '',
+    'Commands:',
+    commandRows,
+  ].join('\n');
+}
+
+export function formatUnknownModuleSubcommand(
+  moduleName: string,
+  command: string,
+  commands: CommandEntry[],
+): string {
+  const available = commands.map((entry) => entry.name).join(', ');
+  return `Unknown ${moduleName} subcommand: ${command}\nAvailable: ${available}`;
+}
