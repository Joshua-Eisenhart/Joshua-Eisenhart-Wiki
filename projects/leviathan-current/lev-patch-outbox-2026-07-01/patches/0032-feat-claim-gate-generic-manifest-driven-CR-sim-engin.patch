+function validateRelativeScriptPath(value: string, label: string, simId: string): string {
+  if (value.startsWith('/') || value.includes('\\')) {
+    failManifest(simId, `${label} must be a relative carrier path.`);
+  }
+  const parts = value.split('/');
+  if (parts.length > 2 || parts.some((part) => !part || part === '.' || part === '..')) {
+    failManifest(simId, `${label} must be a filename or one-subdir relative path.`);
+  }
+  return parts.join('/');
+}
+
+function validateRelativeCarrierSegments(value: string, label: string, simId: string): string[] {
+  if (value.startsWith('/') || value.includes('\\')) {
+    failManifest(simId, `${label} must be relative carrier segments.`);
+  }
+  const parts = value.split('/');
+  if (parts.some((part) => !part || part === '.' || part === '..')) {
+    failManifest(simId, `${label} must not contain empty, dot, or parent segments.`);
+  }
+  return parts;
+}
