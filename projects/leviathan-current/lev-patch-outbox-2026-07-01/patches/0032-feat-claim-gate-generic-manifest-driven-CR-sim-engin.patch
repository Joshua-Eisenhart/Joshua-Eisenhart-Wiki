+function validateResultArtifactPath(value: string, carrierDir: string, label: string, simId: string): string {
+  if (value.startsWith('/') || value.includes('\\')) {
+    failManifest(simId, `${label} must be a relative path under results/.`);
+  }
+  const parts = value.split('/');
+  if (parts.length < 2 || parts[0] !== 'results' || parts.some((part) => !part || part === '.' || part === '..')) {
