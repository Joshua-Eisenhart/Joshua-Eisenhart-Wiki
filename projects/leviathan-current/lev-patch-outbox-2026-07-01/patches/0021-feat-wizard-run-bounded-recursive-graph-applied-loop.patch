+function validateLoopArgs(parsed: ParsedArgs): HandlerResponse | number {
+  const waveCount = parsed.waves ?? 3;
+  if (!Number.isInteger(waveCount) || waveCount < 1 || waveCount > 10) {
+    return {
+      success: false,
+      formatted_response: 'Lev Wizard Ratchet loop blocked: --waves must be an integer from 1 to 10.',
+      error_code: 'LEV_WIZARD_RATCHET_LOOP_WAVES_INVALID',
+      data: {
+        kind: 'LevWizardRatchetLoopArgumentFindings',
+        waves: parsed.waves,
+        maxWaves: 10,
+      },
+    };
+  }
+  const missingFlags = [
+    parsed.realEngines ? undefined : '--real-engines',
+    parsed.realSkills ? undefined : '--real-skills',
+    parsed.realSourceEvidence ? undefined : '--real-source-evidence',
+  ].filter((flag): flag is string => typeof flag === 'string');
+  if (missingFlags.length > 0) {
+    return {
+      success: false,
+      formatted_response: `Lev Wizard Ratchet loop blocked: recursive loop requires host-owned runtime evidence flags ${missingFlags.join(', ')}.`,
+      error_code: 'LEV_WIZARD_RATCHET_LOOP_REAL_EVIDENCE_REQUIRED',
+      data: {
+        kind: 'LevWizardRatchetLoopArgumentFindings',
+        missingFlags,
+      },
+    };
+  }
+  return waveCount;
+}
+
+function summarizeLoopWave(
+  wave: number,
+  bridge: LevWizardRatchetGraphApplyBridgeResult,
+): LevWizardRatchetLoopWaveReceipt {
+  const passed = bridge.graphExecution.ok
+    && bridge.graphExecution.status === 'graph_patch_executed'
+    && bridge.graphExecution.graphMutationApplied
+    && bridge.wizardResult.gateLoopResult.failurePackets.length === 0
+    && steeringAdmissionPassed(bridge.wizardResult);
+  return {
+    wave,
+    sessionId: bridge.wizardResult.sessionId,
+    status: passed ? 'passed' : 'blocked',
+    graphExecutionStatus: bridge.graphExecution.status,
+    graphMutationApplied: bridge.graphExecution.graphMutationApplied,
+    graphEventId: bridge.graphExecution.graphEventId ?? undefined,
+    steeringStatus: bridge.wizardResult.steeringAdmission.status,
+    graphAdmissionStatus: bridge.wizardResult.graphAdmission.status,
+    failurePacketCount: bridge.wizardResult.gateLoopResult.failurePackets.length,
+    graphAppliedSeedSessionId: bridge.graphAppliedNextRunSeed?.inputPatch.sessionId,
+    nextRunSeedSessionId: bridge.wizardResult.nextRunSeed?.seedSessionId,
+  };
+}
+
+function loopBridgePassed(bridge: LevWizardRatchetGraphApplyBridgeResult): boolean {
+  const receipt = summarizeLoopWave(0, bridge);
+  return receipt.status === 'passed';
+}
+
+async function runGraphAppliedInitialWave(
+  parsed: ParsedArgs,
+  deps: LevWizardRatchetHandlerDeps,
+): Promise<LevWizardRatchetGraphApplyBridgeResult> {
+  const result = await runCouncilForHandler(
+    makeDemoInput(
+      parsed.invalidSim,
+      parsed.realEngines,
+      parsed.realSkills,
+      parsed.realSourceEvidence,
+      hostFalsifierStateForParsed(parsed),
+    ),
+    parsed,
+    deps,
+  );
+  return applyWizardGraphPatchThroughHost(result);
+}
+
+async function runGraphAppliedSeedWave(
+  previousBridge: LevWizardRatchetGraphApplyBridgeResult,
+  parsed: ParsedArgs,
+  deps: LevWizardRatchetHandlerDeps,
+): Promise<LevWizardRatchetGraphApplyBridgeResult | HandlerResponse> {
+  const prepared = await prepareGraphAppliedSeedInput(previousBridge, parsed);
+  if ('success' in prepared) return prepared;
+  const result = await runCouncilForHandler(prepared.seededInput, parsed, deps);
+  return applyWizardGraphPatchThroughHost(result);
+}
+
+async function runLoopForHandler(
+  parsed: ParsedArgs,
+  deps: LevWizardRatchetHandlerDeps,
+): Promise<LevWizardRatchetLoopResult | HandlerResponse> {
+  const requestedWaves = validateLoopArgs(parsed);
+  if (typeof requestedWaves !== 'number') return requestedWaves;
+
+  const findings: string[] = [];
+  const bridges: LevWizardRatchetGraphApplyBridgeResult[] = [];
+  let bridge = await runGraphAppliedInitialWave(parsed, deps);
+  bridges.push(bridge);
+
+  while (bridges.length < requestedWaves && loopBridgePassed(bridge)) {
+    const nextBridge = await runGraphAppliedSeedWave(bridge, parsed, deps);
+    if ('success' in nextBridge) {
+      findings.push(`${nextBridge.error_code ?? 'LEV_WIZARD_RATCHET_LOOP_SEED_BLOCKED'}: ${nextBridge.formatted_response}`);
+      break;
+    }
+    bridge = nextBridge;
+    bridges.push(bridge);
+  }
+
+  const waveReceipts = bridges.map((candidate, index) => summarizeLoopWave(index + 1, candidate));
+  const status = bridges.length === requestedWaves
+    && waveReceipts.every((receipt) => receipt.status === 'passed')
+    ? 'completed'
+    : 'blocked';
+  if (status === 'blocked' && findings.length === 0) {
+    const blocked = waveReceipts.find((receipt) => receipt.status === 'blocked');
+    findings.push(blocked
+      ? `wave ${blocked.wave} blocked before emitting a graph-applied survivor seed`
+      : 'loop blocked before requested wave count completed');
+  }
+
+  return {
+    kind: 'LevWizardRatchetLoopResult',
+    claimCeiling: 'bounded_recursive_wave_loop_receipt_not_autonomous_code_mutation',
+    requestedWaves,
+    completedWaves: waveReceipts.filter((receipt) => receipt.status === 'passed').length,
+    status,
+    findings,
+    waveReceipts,
+    bridges,
+  };
+}
+
+function formatLoopResult(result: LevWizardRatchetLoopResult, out?: string): string {
+  return [
+    `Lev Wizard Ratchet loop: ${result.status}`,
+    `Claim ceiling: ${result.claimCeiling}`,
+    `Waves: ${result.completedWaves}/${result.requestedWaves}`,
+    ...result.waveReceipts.map((receipt) => [
+      `Wave ${receipt.wave}: ${receipt.status}`,
+      `session=${receipt.sessionId}`,
+      `steering=${receipt.steeringStatus}`,
+      `graph=${receipt.graphExecutionStatus}`,
+      `event=${receipt.graphEventId ?? '(none)'}`,
+      `next=${receipt.graphAppliedSeedSessionId ?? '(none)'}`,
+      `failures=${receipt.failurePacketCount}`,
+    ].join(' ')),
+    `Findings: ${result.findings.length === 0 ? 'none' : result.findings.join('; ')}`,
+    `Output: ${out ? resolve(out) : '(not written)'}`,
+  ].join('\n');
+}
+
+function loopResponse(result: LevWizardRatchetLoopResult, parsed: ParsedArgs): HandlerResponse {
+  if (parsed.out) writeJson(parsed.out, result);
+  const success = result.status === 'completed';
+  return {
+    success,
+    formatted_response: parsed.json ? JSON.stringify(result, null, 2) : formatLoopResult(result, parsed.out),
+    data: result,
+    error_code: success ? undefined : 'LEV_WIZARD_RATCHET_LOOP_BLOCKED',
+  };
+}
