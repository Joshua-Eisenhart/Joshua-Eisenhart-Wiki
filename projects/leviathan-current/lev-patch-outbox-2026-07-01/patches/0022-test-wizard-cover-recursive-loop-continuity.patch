+  it('runs a two-wave real-evidence loop and blocks replay without graph side effects', async () => {
+    await withIsolatedLevRuntime('lev-wizard-loop-positive-', async (projectRoot) => {
+      const response = await handler([
+        'loop',
+        '--waves',
+        '2',
+        '--real-engines',
+        '--real-skills',
+        '--real-source-evidence',
+      ]);
+
+      expect(response.success).toBe(true);
+      const result = response.data as {
+        kind: string;
+        status: string;
+        completedWaves: number;
+        waveReceipts: Array<{
+          status: string;
+          graphExecutionStatus: string;
+          graphMutationApplied: boolean;
+          graphEventId?: string;
+        }>;
+        bridges: Array<Record<string, unknown>>;
+      };
+      expect(result.kind).toBe('LevWizardRatchetLoopResult');
+      expect(result.status).toBe('completed');
+      expect(result.completedWaves).toBe(2);
+      expect(result.waveReceipts).toHaveLength(2);
+      expect(result.waveReceipts.every((receipt) => receipt.status === 'passed')).toBe(true);
+      expect(result.waveReceipts.every((receipt) => receipt.graphExecutionStatus === 'graph_patch_executed')).toBe(true);
+      expect(result.waveReceipts.every((receipt) => receipt.graphMutationApplied === true)).toBe(true);
+      expect(result.waveReceipts.every((receipt) => typeof receipt.graphEventId === 'string')).toBe(true);
+
+      const eventCountBeforeReplay = graphOperationsAppliedEvents(projectRoot).length;
+      const seedRecordCountBeforeReplay = seedConsumptionEntries(projectRoot).length;
+      expect(eventCountBeforeReplay).toBe(2);
+      expect(seedRecordCountBeforeReplay).toBe(1);
+
+      const replaySeedFile = join(projectRoot, 'wave-1-bridge-replay.json');
+      writeFileSync(replaySeedFile, `${JSON.stringify(result.bridges[0], null, 2)}\n`);
+      const replay = await handler([
+        'seed',
+        replaySeedFile,
+        '--real-engines',
+        '--real-skills',
+        '--real-source-evidence',
+        '--apply-graph-patch',
