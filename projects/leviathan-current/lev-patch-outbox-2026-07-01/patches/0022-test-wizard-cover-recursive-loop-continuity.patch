-import { mkdirSync, mkdtempSync, readFileSync, rmSync, writeFileSync } from 'node:fs';
+import { existsSync, mkdirSync, mkdtempSync, readFileSync, rmSync, writeFileSync } from 'node:fs';
 import { tmpdir } from 'node:os';
 import { join } from 'node:path';
 
@@ -40,6 +40,58 @@ function writeLevProjectMarkers(root: string): void {
   writeFileSync(join(root, '.lev', 'validation-gates.yaml'), 'test validation gates\n');
 }
 
+function readJsonLines<T>(file: string): T[] {
+  if (!existsSync(file)) return [];
+  return readFileSync(file, 'utf8')
+    .split('\n')
+    .map((line) => line.trim())
+    .filter((line) => line.length > 0)
+    .map((line) => JSON.parse(line) as T);
+}
+
+function seedConsumptionLedgerPath(root: string): string {
+  return join(root, '.lev', 'context', 'lev-wizard-seed-consumptions.jsonl');
+}
+
+function seedConsumptionEntries(root: string): Array<Record<string, unknown>> {
+  return readJsonLines<Record<string, unknown>>(seedConsumptionLedgerPath(root));
+}
+
+function graphOperationsAppliedEvents(root: string): Array<{ id?: string; type?: string }> {
+  return readJsonLines<{ id?: string; type?: string }>(join(root, '.lev', 'context', 'events.jsonl'))
+    .filter((event) => event.type === 'graph.operations_applied');
+}
+
+async function withIsolatedLevRuntime<T>(
+  prefix: string,
+  run: (projectRoot: string) => Promise<T>,
+): Promise<T> {
+  const projectRoot = mkdtempSync(join(tmpdir(), prefix));
+  const oldProjectRoot = process.env.LEV_PROJECT_ROOT;
+  const oldHostTrustSecretPath = process.env.LEV_HOST_TRUST_SECRET_PATH;
+  writeLevProjectMarkers(projectRoot);
+  process.env.LEV_PROJECT_ROOT = projectRoot;
+  process.env.LEV_HOST_TRUST_SECRET_PATH = join(projectRoot, 'host-trust-root-secret');
+  const graphRuntime = await import('@lev-os/graph');
+  graphRuntime.resetGraphInstance();
+  try {
+    return await run(projectRoot);
+  } finally {
+    graphRuntime.resetGraphInstance();
+    if (oldProjectRoot === undefined) {
+      delete process.env.LEV_PROJECT_ROOT;
+    } else {
+      process.env.LEV_PROJECT_ROOT = oldProjectRoot;
+    }
+    if (oldHostTrustSecretPath === undefined) {
+      delete process.env.LEV_HOST_TRUST_SECRET_PATH;
+    } else {
+      process.env.LEV_HOST_TRUST_SECRET_PATH = oldHostTrustSecretPath;
+    }
+    rmSync(projectRoot, { recursive: true, force: true });
+  }
+}
