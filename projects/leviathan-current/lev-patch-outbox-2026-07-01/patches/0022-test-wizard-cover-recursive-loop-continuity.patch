+
+      expect(replay.success).toBe(false);
+      expect(replay.error_code).toBe('LEV_WIZARD_RATCHET_SEED_REPLAY_BLOCKED');
+      expect(graphOperationsAppliedEvents(projectRoot)).toHaveLength(eventCountBeforeReplay);
+      expect(seedConsumptionEntries(projectRoot)).toHaveLength(seedRecordCountBeforeReplay);
+    });
+  }, 240_000);
