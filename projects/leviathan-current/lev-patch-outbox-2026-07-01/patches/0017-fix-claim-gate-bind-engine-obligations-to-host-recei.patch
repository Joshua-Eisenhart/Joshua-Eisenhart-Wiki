+const THREE_ENGINE_OBLIGATION_LANES: ThreeEngineObligationLane[] = ['julia', 'jax', 'pytorch'];
+
+type HostEngineObligationReceipt = {
+  sourceRef: string;
+  sourceHash: string;
+  inputHash: string;
+};
+
+function uniqueSorted(values: string[]): string[] {
+  return Array.from(new Set(values)).sort();
+}
+
+function hostEngineReceiptsFromSubstrateDigest(
+  digest: ReturnType<typeof buildRealLevEngineSubstrateDigest>,
+): HostEngineObligationReceipt[] {
+  return THREE_ENGINE_OBLIGATION_LANES.map((lane) => digest.receipts[lane]);
+}
+
+function hostEngineReceiptsFromEnvelope(
+  envelope: ReturnType<typeof buildRealThreeEngineEnvelopeAndDigest>['envelope'],
+): HostEngineObligationReceipt[] {
+  return THREE_ENGINE_OBLIGATION_LANES.flatMap((lane) => {
+    const receipt = envelope.mechanicalProbeReceipts?.[lane];
+    return receipt ? [receipt] : [];
+  });
+}
+
+function compareDeclaredHostSet(input: {
+  label: string;
+  declared?: string[];
+  host: string[];
+}): string[] {
+  const declared = uniqueSorted(input.declared ?? []);
+  const host = uniqueSorted(input.host);
+  if (declared.length === 0) {
+    return [`Host three-engine obligation must declare ${input.label} for all executed lanes.`];
+  }
+  if (declared.length !== host.length || declared.some((value, index) => value !== host[index])) {
+    return [`Host three-engine obligation ${input.label} did not match host-executed lane ${input.label}.`];
+  }
+  return [];
+}
+
+function validateRealRunnerGraphStateBinding(obligation: ClaimGateWaveRunEngineObligation): string[] {
+  const scope = obligation.graphStateScope ?? 'not_scoped';
+  if (scope === 'not_scoped') {
+    return obligation.graphStateHash
+      ? ['Host three-engine obligation graphStateHash must be absent when graphStateScope is not_scoped.']
+      : [];
+  }
+  return [`Host three-engine obligation graphStateScope ${scope} is not supported by the V0 real runner.`];
+}
+
+function validateRealRunnerObligationBindings(input: {
+  obligation: ClaimGateWaveRunEngineObligation;
+  receipts: HostEngineObligationReceipt[];
+}): string[] {
+  const findings: string[] = [];
+  const receipts = input.receipts;
+  if (receipts.length !== THREE_ENGINE_OBLIGATION_LANES.length) {
+    findings.push('Host three-engine obligation requires host receipts for julia, jax, and pytorch lanes.');
+    return findings;
+  }
+
+  findings.push(...compareDeclaredHostSet({
+    label: 'sourceRefs',
+    declared: input.obligation.sourceRefs,
+    host: receipts.map((receipt) => receipt.sourceRef),
+  }));
+  findings.push(...compareDeclaredHostSet({
+    label: 'sourceHashes',
+    declared: input.obligation.sourceHashes,
+    host: receipts.map((receipt) => receipt.sourceHash),
+  }));
+
+  const hostInputHashes = uniqueSorted(receipts.map((receipt) => receipt.inputHash));
+  if (hostInputHashes.length !== 1) {
+    findings.push('Host three-engine obligation receipts must share one host-executed inputHash in V0.');
+  } else if (!input.obligation.inputHash) {
+    findings.push('Host three-engine obligation must declare the host-executed inputHash.');
+  } else if (input.obligation.inputHash !== hostInputHashes[0]) {
+    findings.push('Host three-engine obligation inputHash did not match the host-executed lane inputHash.');
+  }
+
+  findings.push(...validateRealRunnerGraphStateBinding(input.obligation));
+  return findings;
+}
