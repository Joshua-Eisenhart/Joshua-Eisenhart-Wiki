+function wizardWaveRunEngineGraphOperations(
+  result: LevWizardRatchetRunResult,
+): ClaimGateGraphPatchApplyPlan['graphOperations'] {
+  const waveRun = result.waveRunResult;
+  const proposal = waveRun.engineGraphOperationProposal;
+  if (!proposal) return [];
+  if (!claimGateWaveRunReceiptMatches(waveRun)) {
+    throw new Error('Wizard WaveRun engine graph operations require a matching outer WaveRun receipt contentHash.');
+  }
+  if (proposal.claimCeiling !== 'engine_graph_operation_proposal_not_graph_apply') {
+    throw new Error('Wizard WaveRun engine graph operation proposal has an unexpected claim ceiling.');
+  }
+  if (proposal.graphMutationApplied !== false) {
+    throw new Error('Wizard WaveRun engine graph operation proposal must preserve graphMutationApplied:false until apply.');
+  }
+  if (proposal.sourceReceiptId !== result.gateLoopResult.receipt.id) {
+    throw new Error('Wizard WaveRun engine graph operation proposal sourceReceiptId must match the gate loop receipt.');
+  }
+  if (proposal.operationHash !== sha256Value(proposal.operations)) {
+    throw new Error('Wizard WaveRun engine graph operation proposal operationHash must match its operations.');
+  }
+  return proposal.operations;
+}
