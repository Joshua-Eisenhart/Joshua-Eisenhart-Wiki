+function firstSimEngineClaimId(councilWaveInput: ClaimGateCouncilWaveInput): string | null {
+  for (const wave of councilWaveInput.waves) {
+    for (const claim of wave.claims) {
+      if (claim.gateChecks.some((check) => check.gateId === 'sim_engine_probe')) {
+        return claim.claimId;
+      }
+    }
+  }
+  return councilWaveInput.waves[0]?.claims[0]?.claimId ?? null;
+}
+
+function wizardEngineObligationsForInput(
+  input: LevWizardRatchetRunInput,
+  councilWaveInput: ClaimGateCouncilWaveInput,
+): ClaimGateWaveRunEngineObligation[] {
+  const claimId = firstSimEngineClaimId(councilWaveInput);
+  if (!claimId) return [];
+  const threeEngineEnvelopeHash = input.threeEngineEnvelope ? sha256(input.threeEngineEnvelope) : sha256(null);
+  const engineSubstrateDigestHash = input.levEngineSubstrateDigest ? sha256(input.levEngineSubstrateDigest) : sha256(null);
+  return [
+    {
+      registryVersion: 'claim-gate-wave-run-engine-obligation-v0',
+      obligationId: 'lev-wizard-three-engine-probe',
+      claimId,
+      sessionId: input.sessionId,
+      ...(input.workstreamId ? { workstreamId: input.workstreamId } : {}),
+      kind: 'lev_engine_substrate_digest',
+      engineMode: 'all_three_required',
+      requiredLanes: ['julia', 'jax', 'pytorch'],
+      sourceRefs: ['source:lev-wizard-ratchet:three-engine-envelope', 'source:lev-engine-substrate-digest'],
+      sourceHashes: uniqueStrings([threeEngineEnvelopeHash, engineSubstrateDigestHash]),
+      inputHash: sha256({
+        sessionId: input.sessionId,
+        task: input.task,
+        claimId,
+        threeEngineEnvelopeHash,
+        engineSubstrateDigestHash,
+      }),
+      graphStateScope: 'not_scoped',
+      expectedOutputSchema: 'lev-wizard-three-engine-receipt-manifest-v0',
+      negativeControlSpec: {
+        kind: 'executed_negative_control',
+        required: true,
+        mustDifferFromPrimary: true,
+      },
+      claimCeiling: 'engine_obligation_not_host_admission',
+      compilerId: 'lev-wizard-ratchet-wave-run-v0',
+      canonicalizerId: 'stable-json-v0',
+    },
+  ];
+}
+
+function wizardThreeEngineObligationRunner(
+  input: LevWizardRatchetRunInput,
+  threeEngineValidation: EnvelopeValidationResult,
+  engineSubstrateValidation: EnvelopeValidationResult,
+): ClaimGateWaveRunThreeEngineRunner {
+  return ({ obligationHash }) => {
+    const findings = [
+      ...threeEngineValidation.findings,
+      ...engineSubstrateValidation.findings,
+    ];
+    if (!threeEngineValidation.ok || !engineSubstrateValidation.ok) {
+      return {
+        ok: false,
+        obligationHash,
+        evidenceRefs: [obligationHash, ...threeEngineSteeringEvidenceRefs(input.threeEngineEnvelope)],
+        threeEngineEnvelopeHash: input.threeEngineEnvelope ? sha256(input.threeEngineEnvelope) : null,
+        engineSubstrateDigestHash: input.levEngineSubstrateDigest ? sha256(input.levEngineSubstrateDigest) : null,
+        findings,
+      };
+    }
+    const threeEngineEnvelopeHash = sha256(input.threeEngineEnvelope);
+    const engineSubstrateDigestHash = sha256(input.levEngineSubstrateDigest);
+    return {
+      ok: true,
+      obligationHash,
+      evidenceRefs: [
+        obligationHash,
+        ...threeEngineSteeringEvidenceRefs(input.threeEngineEnvelope),
+        `hash:${threeEngineEnvelopeHash}`,
+        `hash:${engineSubstrateDigestHash}`,
+      ],
+      threeEngineEnvelopeHash,
+      engineSubstrateDigestHash,
+    };
+  };
+}
