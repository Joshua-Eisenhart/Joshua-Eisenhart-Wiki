From b5b62df55ef8c247543ba6dfa58751bab3d2b31e Mon Sep 17 00:00:00 2001
From: Joshua-Eisenhart <40147598+Joshua-Eisenhart@users.noreply.github.com>
Date: Wed, 1 Jul 2026 14:32:28 -0700
Subject: [PATCH 30/35] ci: mandatory cheap ClaimGate proof-suite backstop on
 every relevant push
MIME-Version: 1.0
Content-Type: text/plain; charset=UTF-8
Content-Transfer-Encoding: 8bit

Runs the proof spine each push/PR touching core/orchestration or
core/graph, so a stub-level regression is caught immediately rather
than only between opt-in real-engines cron runs. Each package uses its
OWN runner: orchestration=vitest (820 tests), graph=bun test (393
tests across 44 files). Running graph under vitest would discover only
~83 and report a misleading green, so setup-bun is added and the graph
step is 'bun test'. No Julia/Python/API keys — stubbed engines pass on
a bare runner.

Co-Authored-By: Claude Fable 5 <noreply@anthropic.com>
---
 .github/workflows/claimgate-proof-suite.yml | 60 +++++++++++++++++++++
 1 file changed, 60 insertions(+)
 create mode 100644 .github/workflows/claimgate-proof-suite.yml

diff --git a/.github/workflows/claimgate-proof-suite.yml b/.github/workflows/claimgate-proof-suite.yml
new file mode 100644
index 000000000..dfb8dcc4e
--- /dev/null
+++ b/.github/workflows/claimgate-proof-suite.yml
@@ -0,0 +1,60 @@
+name: ClaimGate Proof Suite
+
+# Mandatory cheap backstop: runs the ClaimGate/WaveRun proof spine on every
+# relevant push and PR so a stub-level regression is caught immediately,
+# NOT only between the opt-in real-engines cron runs. These suites use
+# stubbed engines and need no Julia/Python/API keys — a bare runner passes.
+#
+# Each package is run with its OWN declared test runner: core/orchestration
+# is vitest; core/graph is `bun test` (all its files import from 'vitest'
+# but the package script is `bun test`, and `vitest run` discovers only a
+# partial subset — running graph under vitest would report a misleading green).
+on:
+  push:
+    paths:
+      - "core/orchestration/**"
+      - "core/graph/**"
+      - ".github/workflows/claimgate-proof-suite.yml"
+      - "pnpm-lock.yaml"
+      - "package.json"
+  pull_request:
+    paths:
+      - "core/orchestration/**"
+      - "core/graph/**"
+      - ".github/workflows/claimgate-proof-suite.yml"
+      - "pnpm-lock.yaml"
+      - "package.json"
+
+concurrency:
+  group: claimgate-proof-suite-${{ github.ref }}
+  cancel-in-progress: true
+
+jobs:
+  proof-suite:
+    name: Run stubbed ClaimGate proof suites
+    runs-on: ubuntu-latest
+    timeout-minutes: 20
+    steps:
+      - uses: actions/checkout@v6
+
+      - uses: pnpm/action-setup@v5
+
+      - uses: actions/setup-node@v6
+        with:
+          node-version: 22
+          cache: pnpm
+
+      - uses: oven-sh/setup-bun@v2
+        with:
+          bun-version: latest
+
+      - name: Install dependencies
+        run: pnpm install --frozen-lockfile
+
+      - name: Run orchestration proof suite (vitest)
+        working-directory: core/orchestration
+        run: pnpm vitest run
+
+      - name: Run graph proof suite (bun test)
+        working-directory: core/graph
+        run: bun test
-- 
