+async function applySyntheticBridgeToGraph(
+  bridge: ReturnType<typeof syntheticGraphApplyBridgeWithoutEventStoreProof>,
+) {
+  const graphHandlers = await import('@lev-os/graph/handlers');
+  const applyPlanAuthority = graphHandlers.issueClaimGateGraphApplyPlanAuthority({
+    applyPlanReceiptId: bridge.applyPlan.receipt.id,
+    operations: bridge.applyPlan.graphOperations,
+  });
+  const graphResult = await graphHandlers.patch([
+    '--operations',
+    JSON.stringify(bridge.applyPlan.graphOperations),
+    '--apply-plan-receipt-id',
+    bridge.applyPlan.receipt.id,
+    '--apply-plan-authority',
+    JSON.stringify(applyPlanAuthority),
+  ]);
+  const persistedGraphResult = JSON.parse(JSON.stringify(graphResult));
+  const graphExecution = recordHostClaimGateGraphPatchExecution(bridge.applyPlan, persistedGraphResult, {
+    sessionId: 'lev-wizard-synthetic-bridge-graph-execution',
+    workstreamId: 'lev-wizard-synthetic-workstream',
+  });
+  return {
+    ...bridge,
+    graphResult: persistedGraphResult,
+    graphExecution,
+  };
+}
