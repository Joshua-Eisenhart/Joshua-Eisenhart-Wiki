diff --git a/core/orchestration/src/proof/claim-gate-steering-run.ts b/core/orchestration/src/proof/claim-gate-steering-run.ts
index 6709048aa..d795ffa83 100644
--- a/core/orchestration/src/proof/claim-gate-steering-run.ts
+++ b/core/orchestration/src/proof/claim-gate-steering-run.ts
@@ -721,6 +721,58 @@ function proofObligations(validated: ValidatedClaimGateProjection): ProofSpec['p
   return Array.isArray(validated.proofSpec?.proofObligations) ? validated.proofSpec.proofObligations : [];
 }
 
+interface EvidenceRefCarrier {
+  evidenceRefs?: unknown;
+  evidenceRef?: unknown;
+  actualResult?: {
+    evidenceRefs?: unknown;
+    evidenceRef?: unknown;
+  };
+}
+
+function evidenceRefsForObligation(obligation: EvidenceRefCarrier): string[] {
+  return [
+    ...evidenceRefList(obligation.evidenceRefs),
+    ...evidenceRefList(obligation.evidenceRef),
+    ...evidenceRefList(obligation.actualResult?.evidenceRefs),
+    ...evidenceRefList(obligation.actualResult?.evidenceRef),
+  ];
+}
+
+function evidenceRefList(value: unknown): string[] {
+  if (typeof value === 'string') return [value];
+  if (!Array.isArray(value)) return [];
+  return value.filter((entry): entry is string => typeof entry === 'string');
+}
+
+function isAllZeroSha256Ref(ref: string): boolean {
+  return /^sha256:0{64}$/i.test(ref);
+}
+
+function isMissingFileRef(ref: string): boolean {
+  if (!ref.startsWith('file:')) return false;
+  const filePath = ref.slice('file:'.length);
+  return filePath.length === 0 || !existsSync(filePath);
+}
+
+function addSuspectEvidenceRefWarningsOnFailedProjection(
+  findings: ClaimGateConsumptionFinding[],
+  validated: ValidatedClaimGateProjection,
+): void {
+  if (validated.recomputedVerdict !== 'fail') return;
+  for (const obligation of proofObligations(validated)) {
+    for (const ref of evidenceRefsForObligation(obligation)) {
+      if (!isAllZeroSha256Ref(ref) && !isMissingFileRef(ref)) continue;
+      addFinding(
+        findings,
+        'warning',
+        'evidence.suspect_ref_on_failed_projection',
+        `Failed ClaimGate projection carried structurally suspect evidence ref: ${ref}`,
+      );
+    }
+  }
+}
+
 function boundaryRecord(validated: ValidatedClaimGateProjection): Record<string, unknown> | undefined {
   try {
     return readJson<Record<string, unknown>>(validated.files.boundary);
@@ -1421,6 +1473,9 @@ export function consumeClaimGateSteeringRun(
   );
   const hostExecutionWitness = hostExecutionWitnessResult.witness;
   validated.findings.push(...hostExecutionWitnessResult.findings);
+  if (!validated.findings.some((finding) => finding.severity === 'error')) {
+    addSuspectEvidenceRefWarningsOnFailedProjection(validated.findings, validated);
+  }
   const ok = !validated.findings.some((finding) => finding.severity === 'error');
   const status = consumptionStatus(ok, validated.projectedVerdict, validated.recomputedVerdict);
   const liveLevConsumed = status === 'host_consumed';
