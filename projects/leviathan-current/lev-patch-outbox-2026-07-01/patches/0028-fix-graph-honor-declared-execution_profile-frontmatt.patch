+const EXECUTION_PROFILE_FAMILIES: ExecutionProfileFamily[] = [
+  'hermes.moa.reference_synthesis',
+  'hermes.tribunal.independent_comparison',
+  'hermes.subagent_development.plan_execute_review',
+  'external.cli_coding_agent_worker',
+];
+
+// A skill may DECLARE its execution-profile family in frontmatter (the reliable path).
+// Validate it against the closed family union; an unrecognised value is not coerced.
+function asExecutionProfileFamily(value: string | undefined): ExecutionProfileFamily | undefined {
+  if (!value) return undefined;
+  return EXECUTION_PROFILE_FAMILIES.find((family) => family === value);
+}
+
 function executionProfileFor(id: string, haystack: string): ExecutionProfileFamily | undefined {
   if (id === 'tribunal' || haystack.includes('independent comparison')) {
     return 'hermes.tribunal.independent_comparison';
@@ -151,7 +169,13 @@ function recordFromSkillFile(rootDir: string, path: string): SkillSourceRecord {
   const title = frontmatter.name?.trim() || basename(join(path, '..'));
   const haystack = lowerHaystack(id, text, frontmatter);
   const targetDomain = targetDomainFor(haystack);
-  const executionProfile = executionProfileFor(id, haystack);
+  // An explicit, valid frontmatter declaration wins over the fuzzy full-text heuristic.
+  // An explicit but UNRECOGNISED declaration is left undefined rather than silently
+  // fuzzy-matched into a family the author did not declare (avoids mis-classification).
+  const declaredProfile = frontmatter.executionProfile;
+  const executionProfile = declaredProfile
+    ? asExecutionProfileFamily(declaredProfile)
+    : executionProfileFor(id, haystack);
   const stat = statSync(path);
 
