@@ -0,0 +1,68 @@
+import { mkdirSync, mkdtempSync, writeFileSync } from 'node:fs';
+import { tmpdir } from 'node:os';
+import { join } from 'node:path';
+
+import { describe, expect, it } from 'vitest';
+
+import { runExecutionProfileFormalSkillSetIntake } from './skill-source-pack-runner.js';
+
+function writeSkill(root: string, dir: string, frontmatter: string, body: string): void {
+  mkdirSync(join(root, dir), { recursive: true });
+  writeFileSync(join(root, dir, 'SKILL.md'), `---\n${frontmatter}\n---\n${body}\n`);
+}
+
+describe('skill-source-pack execution-profile derivation', () => {
+  it('admits a formal skill from an explicit frontmatter execution_profile, even with no trigger substring; excludes invalid declarations and generic skills; keeps the heuristic', () => {
+    const root = mkdtempSync(join(tmpdir(), 'skill-source-pack-'));
+
+    // A: declares a VALID family in frontmatter, with NO heuristic trigger words in the
+    // body -> must become formal purely from the declaration (the false-negative fix).
+    writeSkill(
+      root,
+      'convergence-panel',
+      'name: Convergence Panel\ndescription: Weigh options and keep the dissent visible.\nexecution_profile: hermes.tribunal.independent_comparison',
+      'Lay out the choices and score them side by side.',
+    );
+
+    // B: declares an UNRECOGNISED family -> must NOT be coerced into any profile.
+    writeSkill(
+      root,
+      'typo-profile',
+      'name: Typo Profile\ndescription: A skill whose author mistyped the family.\nexecution_profile: hermes.bogus.not_a_real_family',
+      'Some neutral content with no trigger words.',
+    );
+
+    // C: no declaration, but the body carries a heuristic trigger -> heuristic preserved.
+    writeSkill(
+      root,
+      'task-delegator',
+      'name: Task Delegator\ndescription: Breaks work into bounded units.',
+      'This worker uses delegate_task to plan, execute, and review.',
+    );
+
+    // D: generic skill, no declaration, no trigger -> must stay OUT (no laundering).
+    writeSkill(
+      root,
+      'pdf-tools',
+      'name: PDF Tools\ndescription: Extract text and tables from documents.',
+      'Read a document and return its extracted text.',
+    );
+
+    const result = runExecutionProfileFormalSkillSetIntake({ rootDir: root, packId: 'test-pack' });
+
+    expect(result.formalSkillSet).toBeDefined();
+    const profiles = (result.formalSkillSet?.skills ?? [])
+      .map((skill) => skill.executionProfile)
+      .filter((p): p is NonNullable<typeof p> => Boolean(p))
+      .sort();
+
+    // Exactly A (declared tribunal) and C (heuristic subagent) — not B, not D.
+    expect(profiles).toEqual([
+      'hermes.subagent_development.plan_execute_review',
+      'hermes.tribunal.independent_comparison',
+    ]);
+
+    const names = (result.formalSkillSet?.skills ?? []).map((s) => s.sourceRecordId).sort();
+    expect(names).toEqual(['convergence-panel', 'task-delegator']);
+  });
+});
