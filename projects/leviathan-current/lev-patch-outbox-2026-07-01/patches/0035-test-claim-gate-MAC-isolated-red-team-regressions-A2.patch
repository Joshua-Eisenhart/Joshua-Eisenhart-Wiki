+function steeringStableStringify(value: unknown): string {
+  if (value === undefined) return '"__undefined__"';
+  if (value === null || typeof value !== 'object') return JSON.stringify(value) ?? '"__undefined__"';
+  if (Array.isArray(value)) return `[${value.map(steeringStableStringify).join(',')}]`;
+  const record = value as Record<string, unknown>;
+  return `{${Object.keys(record).sort().map((key) => `${JSON.stringify(key)}:${steeringStableStringify(record[key])}`).join(',')}}`;
+}
+
+function steeringSha256(value: unknown): string {
+  return createHash('sha256').update(steeringStableStringify(value)).digest('hex');
+}
+
+function wrongHmacSha256(): string {
+  return `hmac-sha256:${'0'.repeat(64)}`;
+}
+
+function flipHmacSha256(mac: string): string {
+  expect(mac).toMatch(/^hmac-sha256:[0-9a-f]{64}$/i);
+  const hex = mac.slice('hmac-sha256:'.length).toLowerCase();
+  return `hmac-sha256:${hex[0] === '0' ? '1' : '0'}${hex.slice(1)}`;
+}
+
+function hostTrustedEvidenceRefPayload(entry: Record<string, unknown>) {
+  return {
+    kind: entry.kind,
+    claimCeiling: entry.claimCeiling,
+    authority: entry.authority,
+    ref: entry.ref,
+    nonce: entry.nonce,
+    issuedAt: entry.issuedAt,
+  };
+}
+
+function graphPatchExecutionData(result: Record<string, unknown>): Record<string, unknown> {
+  return result.data && typeof result.data === 'object' && !Array.isArray(result.data)
+    ? result.data as Record<string, unknown>
+    : result;
+}
+
+function graphPatchExecutionTrustPayload(result: Record<string, unknown>) {
+  const data = graphPatchExecutionData(result);
+  const errors = [
+    ...(Array.isArray(result.errors) ? result.errors : []),
+    ...(Array.isArray(data.errors) ? data.errors : []),
+  ];
+  return {
+    success: data.success ?? result.success,
+    status: data.status ?? result.status,
+    applied: data.applied ?? result.applied,
+    applyPlanReceiptId: data.apply_plan_receipt_id
+      ?? data.applyPlanReceiptId
+      ?? result.apply_plan_receipt_id
+      ?? result.applyPlanReceiptId,
+    graphEventId: data.graph_event_id ?? data.graphEventId ?? result.graph_event_id ?? result.graphEventId,
+    ...(errors.length > 0 ? { errors } : {}),
+  };
+}
+
+function graphPatchExecutionTrustHash(result: Record<string, unknown>): string {
+  return sha256Ref(graphPatchExecutionTrustPayload(result));
+}
+
+function hostGraphEventTrustPayload(entry: Record<string, unknown>) {
+  return {
+    kind: entry.kind,
+    claimCeiling: entry.claimCeiling,
+    authority: entry.authority,
+    graphEventId: entry.graphEventId,
+    applyPlanReceiptId: entry.applyPlanReceiptId,
+    graphResultHash: entry.graphResultHash,
+    operationCount: entry.operationCount,
+    sessionId: entry.sessionId,
+    ...(entry.workstreamId ? { workstreamId: entry.workstreamId } : {}),
+    nonce: entry.nonce,
+    issuedAt: entry.issuedAt,
+  };
+}
+
+function hostWitnessSignedPayload(witness: Record<string, unknown>) {
+  return {
+    kind: witness.kind,
+    claimCeiling: witness.claimCeiling,
+    authority: witness.authority,
+    runId: witness.runId,
