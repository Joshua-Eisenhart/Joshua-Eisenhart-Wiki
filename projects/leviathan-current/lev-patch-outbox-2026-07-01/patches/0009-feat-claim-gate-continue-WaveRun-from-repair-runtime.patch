+
+function validateRepairRuntimeReplay(
+  value: unknown,
+  dispatchPlan: ClaimGateRepairDispatchPlan,
+): { ok: true; runtime: ClaimGateRepairDispatchRuntimeReplay } | { ok: false; message: string } {
+  if (!isRecord(value)) {
+    return { ok: false, message: 'Repair runtime run must be a JSON object.' };
+  }
+  if (value.kind !== 'ClaimGateRepairDispatchRuntimeRun') {
+    return { ok: false, message: 'Repair runtime run kind must be ClaimGateRepairDispatchRuntimeRun.' };
+  }
+  if (value.status !== 'dispatch_executed' || value.ok !== true) {
+    return { ok: false, message: 'Repair runtime run must be ok:true with status dispatch_executed.' };
+  }
+  if (value.sourceRepairDispatchPlanReceiptId !== dispatchPlan.receipt.id) {
+    return {
+      ok: false,
+      message: `Repair runtime source dispatch receipt ${String(value.sourceRepairDispatchPlanReceiptId)} does not match current dispatch plan ${dispatchPlan.receipt.id}.`,
+    };
+  }
+  if (!isRecord(value.repairWaveInput)) {
+    return { ok: false, message: 'Repair runtime run must carry repairWaveInput.' };
+  }
+  const execution = isRecord(value.repairDispatchExecution)
+    ? value.repairDispatchExecution
+    : undefined;
+  if (!execution || execution.status !== 'repair_dispatch_executed' || execution.ok !== true) {
+    return { ok: false, message: 'Repair runtime run must carry a successful repairDispatchExecution receipt.' };
+  }
+  if (execution.repairDispatchPlanReceiptId !== dispatchPlan.receipt.id) {
+    return {
+      ok: false,
+      message: `Repair dispatch execution receipt ${String(execution.repairDispatchPlanReceiptId)} does not match current dispatch plan ${dispatchPlan.receipt.id}.`,
+    };
+  }
+  return { ok: true, runtime: value as unknown as ClaimGateRepairDispatchRuntimeReplay };
+}
