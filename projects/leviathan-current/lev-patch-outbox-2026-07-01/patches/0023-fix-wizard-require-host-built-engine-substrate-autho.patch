+const HOST_BUILT_ENGINE_SUBSTRATE_DIGEST_HASHES = new Set<string>();
+
+export function isHostBuiltLevEngineSubstrateDigest(digest: LevEngineSubstrateDigest | undefined): boolean {
+  return !!digest && HOST_BUILT_ENGINE_SUBSTRATE_DIGEST_HASHES.has(valueHash(digest));
+}
+
+function markHostBuiltLevEngineSubstrateDigest(digest: LevEngineSubstrateDigest): LevEngineSubstrateDigest {
+  HOST_BUILT_ENGINE_SUBSTRATE_DIGEST_HASHES.add(valueHash(digest));
+  return digest;
+}
