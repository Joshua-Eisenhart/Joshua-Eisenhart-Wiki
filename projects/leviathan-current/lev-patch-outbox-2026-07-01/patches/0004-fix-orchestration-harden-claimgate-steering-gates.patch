diff --git a/core/orchestration/src/proof/claim-gate-adapter-bridge.test.ts b/core/orchestration/src/proof/claim-gate-adapter-bridge.test.ts
new file mode 100644
index 000000000..b082320cd
--- /dev/null
+++ b/core/orchestration/src/proof/claim-gate-adapter-bridge.test.ts
@@ -0,0 +1,268 @@
+/**
+ * ClaimGate adapter → host consumer bridge contract.
+ *
+ * The existing claim-gate-steering-run.test.ts proves the consumer's internal
+ * logic with idealised fixtures. This file proves the harder thing: that a
+ * projection shaped exactly as the external ClaimGate `claimgate-lev-adapter`
+ * actually emits (`makeEvalJobProjection` / `writeSteeringRunProjection`) is
+ * accepted by the host consumer, with the verdict recomputed from evidence.
+ *
+ * `buildAdapterProjection` mirrors that adapter's field mapping. It is the
+ * host-side pin of the adapter output contract: if the adapter changes its
+ * projection shape, this contract test must move in lockstep.
+ */
+
+import { mkdirSync, readFileSync, rmSync, writeFileSync } from 'node:fs';
+import { join } from 'node:path';
+import { tmpdir } from 'node:os';
+
+import { describe, expect, it } from 'vitest';
+
+import { consumeClaimGateSteeringRun } from './claim-gate-steering-run.js';
+import type { EvalJob, EvalJobOutput, EvalVerdict, RepairCandidate } from './eval-job-types.js';
+import type { ProofObligation, ProofResult, ProofSpec } from './proof-spec-generator.js';
+
+// Mirrors claimgate-lev-adapter ADAPTER_VERSION; not load-bearing for consumption.
+const ADAPTER_VERSION = '0.7.0-core-eval-adapter';
+
+type GateSeverity = 'blocker' | 'fatal' | 'warning';
+interface GateDetail {
+  id: string;
+  pass: boolean;
+  reason?: string;
+  severity: GateSeverity;
+  details?: Record<string, unknown>;
+}
+type ClaimGateStatus = 'passed' | 'passed_with_caveats' | 'rework_required' | 'blocked';
+
+// claimgate-lev-adapter safeId
+function safeId(value: string): string {
+  return String(value || 'item')
+    .toLowerCase()
+    .replace(/[^a-z0-9._-]+/g, '-')
+    .replace(/^-|-$/g, '')
+    .slice(0, 96) || 'item';
+}
+
+// claimgate-lev-adapter proofResultForGate
+function proofResultForGate(gate: GateDetail): ProofResult {
+  if (gate.pass) {
+    return { status: 'passed', elapsedMs: 0, verifierVersion: `claimgate/${ADAPTER_VERSION}` };
+  }
+  if (gate.severity === 'warning') {
+    return {
+      status: 'skipped',
+      elapsedMs: 0,
+      verifierVersion: `claimgate/${ADAPTER_VERSION}`,
+      counterexample: gate.reason || 'Advisory gate remained open.',
+    };
+  }
+  return {
+    status: 'failed',
+    elapsedMs: 0,
+    verifierVersion: `claimgate/${ADAPTER_VERSION}`,
+    counterexample: gate.reason || 'ClaimGate deterministic gate failed.',
+  };
+}
+
+// claimgate-lev-adapter proofObligationForGate
+function proofObligationForGate(gate: GateDetail): ProofObligation {
+  return {
+    obligationId: `obl-claimgate-${safeId(gate.id)}`,
+    constraintId: `claimgate.${safeId(gate.id)}`,
+    shellCheck: `claimgate internal gate ${safeId(gate.id)}`,
+    expectedResult: 'exit_zero',
+    actualResult: proofResultForGate(gate),
+  };
+}
+
+// claimgate-lev-adapter repairCandidateForGate
+function repairCandidateForGate(gate: GateDetail): RepairCandidate {
+  return {
+    candidateId: `rc-claimgate-${safeId(gate.id)}`,
+    source: 'counterexample',
+    conflictingConstraints: [`claimgate.${safeId(gate.id)}`],
+    proposedPatch: { gate_id: gate.id, reason: gate.reason || '', next_check: null },
+    estimatedImpact: 'moderate',
+    verified: false,
+  };
+}
+
+// claimgate-lev-adapter evalVerdictFromGateResult
+function evalVerdictFromStatus(status: ClaimGateStatus): EvalVerdict {
+  if (status === 'passed') return 'pass';
+  if (status === 'passed_with_caveats') return 'conditional';
+  if (status === 'rework_required') return 'fail';
+  if (status === 'blocked') return 'deferred';
+  return 'conditional';
+}
+
+interface AdapterCaseSpec {
+  status: ClaimGateStatus;
+  gates: GateDetail[];
+  claimId?: string;
+  receiptId?: string;
+  suiteId?: string;
+  targetRef?: string;
+  runOverride?: Record<string, unknown>;
+  boundaryOverride?: Record<string, unknown>;
+}
+
+function makeTempRoot(name: string): string {
+  const root = join(tmpdir(), `lev-cg-bridge-${name}-${Date.now()}-${Math.random().toString(16).slice(2)}`);
+  mkdirSync(root, { recursive: true });
+  return root;
+}
+
+/** Write a `.lev/steering/runs/<id>` projection shaped like the ClaimGate adapter. */
+function buildAdapterProjection(root: string, spec: AdapterCaseSpec): string {
+  const claimId = spec.claimId ?? 'demo-claim';
+  const receiptId = spec.receiptId ?? 'cg_receipt_demo_001';
+  const suiteId = spec.suiteId ?? 'claimgate.pr-trust';
+  const targetRef = spec.targetRef ?? 'claimgate.pr-trust';
+  const runId = safeId(`${claimId}-${receiptId}`);
+  const generatedAt = new Date().toISOString();
+
+  const obligations = spec.gates.map(proofObligationForGate);
+  const evidence = obligations.map((obligation) => obligation.actualResult!);
+  const failedHardGates = spec.gates.filter((gate) => !gate.pass && gate.severity !== 'warning');
+  const output: EvalJobOutput = {
+    verdict: evalVerdictFromStatus(spec.status),
+    evidence,
+    ...(failedHardGates.length ? { repairCandidates: failedHardGates.map(repairCandidateForGate) } : {}),
+    receiptId,
+  };
+  const proofSpec: ProofSpec = {
+    specId: `ps-claimgate-${runId}`,
+    targetRef,
+    constraintPackId: suiteId,
+    proofObligations: obligations,
+    proofStrategy: 'compiled_guard',
+    generatedAt,
+  };
+  const evalJob: EvalJob = {
+    jobId: `ej-claimgate-${runId}`,
+    jobClass: 'eval',
+    targetRef,
+    proofSpecId: proofSpec.specId,
+    constraintPackId: suiteId,
+    inputReceiptIds: [receiptId],
+    startedAt: generatedAt,
+    completedAt: generatedAt,
+    output,
+  };
+
+  const runDir = join(root, runId);
+  mkdirSync(runDir, { recursive: true });
+  const write = (name: string, value: unknown) =>
+    writeFileSync(join(runDir, name), `${JSON.stringify(value, null, 2)}\n`);
+
+  write('run.json', {
+    version: ADAPTER_VERSION,
+    run_id: runId,
+    suite_id: suiteId,
+    target_ref: targetRef,
+    layout: '.lev/steering/runs/<run-id>',
+    compatibility_only: true,
+    live_lev_consumed: false,
+    claim_ceiling: 'adapter_partial',
+    release_admission_allowed: false,
+    generated_at: generatedAt,
+    ...spec.runOverride,
+  });
+  write('proof-spec.json', proofSpec);
+  write('eval-job.json', evalJob);
+  write('eval-job-output.json', output);
+  write('boundary.json', {
+    version: ADAPTER_VERSION,
+    status: 'adapter_projection_only',
+    live_lev_consumed: false,
+    claim_ceiling: 'adapter_partial',
+    release_admission_allowed: false,
+    generated_at: generatedAt,
+    ...spec.boundaryOverride,
+  });
+  return runDir;
+}
+
+const CASES: Array<{ name: string; spec: AdapterCaseSpec; verdict: EvalVerdict }> = [
+  {
+    name: 'pass',
+    verdict: 'pass',
+    spec: {
+      status: 'passed',
+      gates: [
+        { id: 'object_binding', pass: true, reason: 'bound to authoritative diff', severity: 'blocker' },
+        { id: 'evidence_manifest', pass: true, reason: 'out-of-band evidence', severity: 'blocker' },
+        { id: 'falsifier', pass: true, reason: 'closed with refs', severity: 'blocker' },
+      ],
+    },
+  },
+  {
+    name: 'caveat',
+    verdict: 'conditional',
+    spec: {
+      status: 'passed_with_caveats',
+      gates: [
+        { id: 'object_binding', pass: true, reason: 'bound', severity: 'blocker' },
+        { id: 'overclaim', pass: false, reason: 'possible overclaim term', severity: 'warning' },
+      ],
+    },
+  },
+  {
+    name: 'fail',
+    verdict: 'fail',
+    spec: {
+      status: 'rework_required',
+      gates: [
+        { id: 'object_binding', pass: false, reason: 'self-attested diff', severity: 'blocker' },
+        { id: 'evidence_manifest', pass: true, reason: 'ok', severity: 'blocker' },
+      ],
+    },
+  },
+];
+
+describe('ClaimGate adapter → host consumer bridge', () => {
+  for (const { name, spec, verdict } of CASES) {
+    it(`host-consumes a real adapter ${name} projection and recomputes its verdict`, () => {
+      const root = makeTempRoot(name);
+      try {
+        const runDir = buildAdapterProjection(root, { ...spec, claimId: `demo-claim-${name}`, receiptId: `cg_receipt_${name}_001` });
+        const result = consumeClaimGateSteeringRun({ runDir, writeReceipt: false });
+
+        expect(result.ok, JSON.stringify(result.findings)).toBe(true);
+        expect(result.status).toBe('host_consumed');
+        expect(result.projectedVerdict).toBe(verdict);
+        expect(result.recomputedVerdict).toBe(verdict);
+        expect(result.findings.filter((finding) => finding.severity === 'error')).toEqual([]);
+      } finally {
+        rmSync(root, { recursive: true, force: true });
+      }
+    });
+  }
+
+  it('blocks an adapter projection that self-claims host authority', () => {
+    const root = makeTempRoot('authority');
+    try {
+      const runDir = buildAdapterProjection(root, {
+        ...CASES[0].spec,
+        claimId: 'demo-claim-authority',
+        receiptId: 'cg_receipt_authority_001',
+        runOverride: { live_lev_consumed: true, release_admission_allowed: true },
+        boundaryOverride: { live_lev_consumed: true, properly_integrated: true },
+      });
+      const result = consumeClaimGateSteeringRun({ runDir, writeReceipt: false });
+
+      expect(result.ok).toBe(false);
+      expect(result.status).toBe('host_blocked');
+      expect(result.liveLevConsumed).toBe(false);
+      const codes = result.findings.map((finding) => finding.code);
+      expect(codes).toContain('run_metadata.live_lev_consumed_forbidden');
+      expect(codes).toContain('run_metadata.release_admission_allowed_forbidden');
+      expect(codes).toContain('boundary.live_lev_consumed_forbidden');
+      expect(codes).toContain('boundary.properly_integrated_forbidden');
+    } finally {
+      rmSync(root, { recursive: true, force: true });
+    }
+  });
+});
