+function rejectTruthyAuthorityFlag(
+  findings: ClaimGateConsumptionFinding[],
+  sourceLabel: string,
+  source: Record<string, unknown> | undefined,
+  field: string,
+): void {
+  if (!source || source[field] !== true) return;
+  addFinding(
+    findings,
+    'error',
+    `${sourceLabel}.${field}_forbidden`,
+    `${sourceLabel}.${field} must not be true in a source projection. Host Lev writes authority receipts separately after consumption.`,
+  );
+}
+
+// Allowlist, not denylist: a source projection may carry only KNOWN-safe boolean
+// flags. Any OTHER field === true is treated as a self-asserted authority/state
+// overclaim and rejected — so no renamed or exotic flag (sealed_by_lev, green_lit,
+// host_consumed, admitted_by_host, ...) can slip a name-based filter. The adapter
+// emits exactly one legitimate true flag (compatibility_only); everything else
+// authority-related is emitted false.
+const ALLOWED_TRUE_PROJECTION_FIELDS = new Set(['compatibility_only']);
+const EXPLICIT_AUTHORITY_PROJECTION_FIELDS = new Set([
+  'live_lev_consumed',
+  'release_admission_allowed',
+  'properly_integrated',
+  'public_lev_merged',
+]);
+
+function rejectUnexpectedTruthyFlag(
+  findings: ClaimGateConsumptionFinding[],
+  sourceLabel: string,
+  source: Record<string, unknown> | undefined,
+): void {
+  if (!source) return;
+  for (const [key, value] of Object.entries(source)) {
+    if (
+      value === true
+      && !ALLOWED_TRUE_PROJECTION_FIELDS.has(key)
+      && !EXPLICIT_AUTHORITY_PROJECTION_FIELDS.has(key)
+    ) {
+      addFinding(
+        findings,
+        'error',
+        `${sourceLabel}.${key}_forbidden`,
+        `${sourceLabel}.${key} is an unexpected self-asserted flag; a source projection may not set arbitrary true flags. Host authority (admission/consumption/release) is decided by host Lev separately after consumption.`,
+      );
+    }
+  }
+}
+
+function validateSourceAuthorityBoundary(
+  findings: ClaimGateConsumptionFinding[],
+  runMetadata: ClaimGateSteeringRunMetadata,
+  boundary: Record<string, unknown>,
+): void {
+  rejectTruthyAuthorityFlag(findings, 'run_metadata', runMetadata, 'live_lev_consumed');
+  rejectTruthyAuthorityFlag(findings, 'run_metadata', runMetadata, 'release_admission_allowed');
+  rejectTruthyAuthorityFlag(findings, 'run_metadata', runMetadata, 'properly_integrated');
+  rejectTruthyAuthorityFlag(findings, 'run_metadata', runMetadata, 'public_lev_merged');
+  rejectTruthyAuthorityFlag(findings, 'boundary', boundary, 'live_lev_consumed');
+  rejectTruthyAuthorityFlag(findings, 'boundary', boundary, 'release_admission_allowed');
+  rejectTruthyAuthorityFlag(findings, 'boundary', boundary, 'properly_integrated');
+  rejectTruthyAuthorityFlag(findings, 'boundary', boundary, 'public_lev_merged');
+  rejectUnexpectedTruthyFlag(
+    findings,
+    'run_metadata',
+    runMetadata as unknown as Record<string, unknown>,
+  );
+  rejectUnexpectedTruthyFlag(findings, 'boundary', boundary);
+}
