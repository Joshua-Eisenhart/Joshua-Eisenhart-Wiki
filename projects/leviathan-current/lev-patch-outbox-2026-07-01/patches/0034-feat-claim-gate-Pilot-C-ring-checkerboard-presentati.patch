+    rows = []
+    for sheet in (0, 1):
+        for shell in range(K_ETA):
+            for phi in range(N_PHI):
+                for chi in range(N_CHI):
+                    rows.append((sheet, shell, phi, chi))
+    return jnp.array(rows, dtype=jnp.int64)
