+#!/usr/bin/env python3
+"""Controller gate for cr-ring-checkerboard-v0.
+
+The controller first runs the exact Python oracle fresh using this same Python
+interpreter, then gates exact/JAX/Julia parity on finite integer observables and
+tables only.
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import os
+import subprocess
+import sys
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+
+SIM_ID = "cr-ring-checkerboard-v0"
+RESULT_STEM = "cr_ring_checkerboard_v0"
+HERE = Path(__file__).resolve().parent
+RESULTS = HERE / "results"
+EXACT_SCRIPT = HERE / "cr_ring_checkerboard_v0_exact.py"
+EXACT_RESULT = RESULTS / f"{RESULT_STEM}_exact_results.json"
+JAX_RESULT = RESULTS / f"{RESULT_STEM}_jax_results.json"
+JULIA_RESULT = RESULTS / f"{RESULT_STEM}_julia_results.json"
+OUT = RESULTS / f"{RESULT_STEM}_three_engine_results.json"
+CONTROL_ENV = "LEV_CR_RING_CHECKERBOARD_NEGATIVE_CONTROL"
+CONTROL_ID = "shell_nesting_erasure"
+
+INTEGER_OBSERVABLE_KEYS = [
+    "support_count",
+    "flat_support_count",
+    "spherical_support_count",
+    "ring_support_count",
+    "shell_eta_mismatch_count",
+    "ring_fiber_mismatch_count",
+    "density_class_count",
+    "phase_sensitive_class_count",
+    "flat_edge_count",
+    "ring_edge_count",
+    "full_component_count",
+    "shell_erased_class_count",
+    "fiber_erased_class_count",
+    "relation_ablated_component_count",
+]
+
+FINITE_TABLE_KEYS = [
+    "support_coordinate_table",
+    "presentation_agreement_table",
+    "ring_fiber_coordinate_table",
+    "density_probe_signature_table",
+    "phase_sensitive_signature_table",
+    "flat_adjacency_edges",
+    "ring_adjacency_edges",
+]
+
+EXPECTED_INTEGERS = {
+    "support_count": 96,
+    "flat_support_count": 96,
+    "spherical_support_count": 96,
+    "ring_support_count": 96,
+    "shell_eta_mismatch_count": 0,
+    "ring_fiber_mismatch_count": 0,
+    "density_class_count": 24,
+    "phase_sensitive_class_count": 96,
+    "flat_edge_count": 256,
+    "ring_edge_count": 256,
+    "full_component_count": 2,
+    "shell_erased_class_count": 32,
+    "fiber_erased_class_count": 24,
+    "relation_ablated_component_count": 96,
+}
+
+
+def sha256_of(path: Path) -> str:
+    return hashlib.sha256(path.read_bytes()).hexdigest()
+
+
+def load_json(path: Path) -> dict[str, Any]:
+    if not path.exists():
+        raise FileNotFoundError(path)
+    return json.loads(path.read_text(encoding="utf-8"))
+
+
+def run_exact_fresh() -> subprocess.CompletedProcess[str]:
+    RESULTS.mkdir(parents=True, exist_ok=True)
+    if EXACT_RESULT.exists():
+        EXACT_RESULT.unlink()
+    print(f"controller_exact_python={sys.executable}")
+    proc = subprocess.run(
+        [sys.executable, str(EXACT_SCRIPT)],
+        cwd=str(HERE),
+        env={**os.environ, "JAX_ENABLE_X64": "true"},
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.STDOUT,
+        check=False,
+    )
+    print(proc.stdout, end="")
+    return proc
+
+
+def run_negative_control() -> int:
+    proc = subprocess.run(
+        [sys.executable, str(EXACT_SCRIPT)],
+        cwd=str(HERE),
+        env={**os.environ, CONTROL_ENV: CONTROL_ID},
+        text=True,
+        stdout=subprocess.PIPE,
+        stderr=subprocess.STDOUT,
+        check=False,
+    )
+    print(proc.stdout, end="")
+    ok = proc.returncode == 0 and f"NEGATIVE_CONTROL_DONE engine=exact {CONTROL_ID}=true" in proc.stdout
+    if not ok:
+        return 1
+    print(json.dumps({"ok": True, "control": CONTROL_ID, "engine": "controller", "oracle_control_verified": True}, sort_keys=True))
+    print(f"NEGATIVE_CONTROL_DONE engine=controller {CONTROL_ID}=true")
+    return 0
+
+
+def check_leg_header(label: str, result: dict[str, Any], failures: list[str]) -> None:
+    if result.get("sim_id") != SIM_ID:
+        failures.append(f"{label}: sim_id mismatch")
+    if result.get("classification") != "scratch_diagnostic":
+        failures.append(f"{label}: classification is not scratch_diagnostic")
+    if result.get("promotion_allowed") is not False:
+        failures.append(f"{label}: promotion_allowed is not false")
+    if result.get("formal_admission_allowed") is not False:
+        failures.append(f"{label}: formal_admission_allowed is not false")
+    if result.get("reads_peer_result") is not False:
+        failures.append(f"{label}: reads_peer_result is not false")
+    if result.get("all_pass") is not True:
+        failures.append(f"{label}: all_pass is not true")
+
+
+def check_exact_integer_parity(
+    label: str,
+    exact: dict[str, Any],
+    other: dict[str, Any],
+    failures: list[str],
+) -> None:
+    exact_ints = exact["integer_observables"]
+    other_ints = other["integer_observables"]
+    for key in INTEGER_OBSERVABLE_KEYS:
+        if int(exact_ints[key]) != int(other_ints[key]):
+            failures.append(f"{label}: integer_observable {key} exact={exact_ints[key]} got={other_ints[key]}")
+    for key, expected in EXPECTED_INTEGERS.items():
+        if int(exact_ints[key]) != expected:
+            failures.append(f"exact: expected integer_observable {key}={expected}, got={exact_ints[key]}")
+
+    exact_tables = exact["finite_integer_tables"]
+    other_tables = other["finite_integer_tables"]
+    for key in FINITE_TABLE_KEYS:
+        if exact_tables[key] != other_tables[key]:
+            failures.append(f"{label}: finite_integer_table {key} mismatch")
+
+
+def main() -> int:
+    if os.environ.get(CONTROL_ENV) == CONTROL_ID:
+        return run_negative_control()
+
+    proc = run_exact_fresh()
+    failures: list[str] = []
+    if proc.returncode != 0:
+        failures.append(f"exact oracle exited {proc.returncode}")
+
+    try:
+        exact = load_json(EXACT_RESULT)
+        julia = load_json(JULIA_RESULT)
+        jax = load_json(JAX_RESULT)
+    except Exception as exc:
+        failures.append(f"result load failed: {exc}")
+        exact = julia = jax = {}
+
+    for label, result in (("exact", exact), ("julia", julia), ("jax", jax)):
+        if result:
+            check_leg_header(label, result, failures)
+
+    if exact and julia and jax:
+        check_exact_integer_parity("julia", exact, julia, failures)
+        check_exact_integer_parity("jax", exact, jax, failures)
+
+    agreement_ok = not failures
+    envelope = {
+        "schema_version": "three_engine_sim_result_v1",
+        "sim_id": SIM_ID,
+        "object_id": SIM_ID,
+        "engine": "envelope_controller",
+        "written_at": datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ"),
+        "classification": "scratch_diagnostic",
+        "promotion_allowed": False,
+        "formal_admission_allowed": False,
+        "all_pass": agreement_ok,
+        "build_status": "PASS" if agreement_ok else "BUILD FAILED",
+        "claim_ceiling": "scratch_diagnostic; promotion_allowed false; not M(C) admission",
+        "claim": "three finite presentations of the ring-checkerboard support are candidate-equivalent at support/chart level under finite integer table readouts",
+        "engine_contract": {
+            "mode": "julia_canon_jax_workhorse",
+            "lanes": ["exact_python_oracle", "julia", "jax"],
+            "manifest_receipted_lanes": ["julia", "jax"],
+            "controller_runs_exact_oracle_fresh": True,
+            "audit_order": ["exact_python_oracle", "julia_local", "jax_local", "controller_comparison"],
+        },
+        "exact_python": {
+            "ran": bool(exact),
+            "source_path": str(EXACT_SCRIPT),
+            "source_sha256": exact.get("source_sha256") if exact else None,
+            "result_path": str(EXACT_RESULT),
+        },
+        "engines": {
+            "julia": {
+                "ran": bool(julia),
+                "source_path": julia.get("source_path") if julia else None,
+                "source_sha256": julia.get("source_sha256") if julia else None,
+                "result_path": str(JULIA_RESULT),
+                "packages_used": julia.get("packages_used") if julia else [],
+                "aligned_packages_load_bearing": julia.get("aligned_packages_load_bearing") if julia else [],
+            },
+            "jax": {
+                "ran": bool(jax),
+                "source_path": jax.get("source_path") if jax else None,
+                "source_sha256": jax.get("source_sha256") if jax else None,
+                "result_path": str(JAX_RESULT),
+                "packages_used": jax.get("packages_used") if jax else [],
+                "aligned_packages_load_bearing": jax.get("aligned_packages_load_bearing") if jax else [],
+            },
+        },
+        "integer_observables": exact.get("integer_observables") if exact else {},
+        "gated_integer_observable_keys": INTEGER_OBSERVABLE_KEYS,
+        "gated_finite_integer_table_keys": FINITE_TABLE_KEYS,
+        "expected_integers": EXPECTED_INTEGERS,
+        "negative_control": {
+            "id": CONTROL_ID,
+            "must_drop_shell_classes": [96, 32],
+            "normal_lane_controls_passed": {
+                "julia": bool(julia.get("controls", {}).get("shell_nesting_erasure_merges_classes")) if julia else False,
+                "jax": bool(jax.get("controls", {}).get("shell_nesting_erasure_merges_classes")) if jax else False,
+                "exact": bool(exact.get("controls", {}).get("shell_nesting_erasure_merges_classes")) if exact else False,
+            },
+        },
+        "blocked_language_policy": {
+            "no_rho": True,
+            "no_cptp": True,
+            "no_entropy_as_master_variable": True,
+            "floats_gated": False,
+        },
+        "failures": failures,
+        "source_sha256": sha256_of(Path(__file__).resolve()),
+        "TOOL_MANIFEST": {
+            "python_stdlib": {
+                "tried": True,
+                "used": True,
+                "reason": "subprocess exact-oracle run and JSON integer-table parity gate",
+            },
+            "json": {"tried": True, "used": True, "reason": "receipt parsing and envelope output"},
+        },
+        "TOOL_INTEGRATION_DEPTH": {"python_stdlib": "load_bearing", "json": "supportive"},
+    }
+    RESULTS.mkdir(parents=True, exist_ok=True)
+    OUT.write_text(json.dumps(envelope, indent=2, sort_keys=True) + "\n", encoding="utf-8")
+    print(f"wrote {OUT}")
+    print(f"agreement_ok={agreement_ok} failures={len(failures)}")
+    if failures:
+        print(json.dumps({"failures": failures}, indent=2, sort_keys=True))
+    return 0 if agreement_ok else 1
+
+
+if __name__ == "__main__":
+    raise SystemExit(main())
