+#!/usr/bin/env julia
+# Independent Julia finite-integer lane for cr-ring-checkerboard-v0.
+
+using Dates
+using JSON
+using SHA
+
+const SIM_ID = "cr-ring-checkerboard-v0"
+const RESULT_STEM = "cr_ring_checkerboard_v0"
+const HERE = @__DIR__
+const RESULTS = joinpath(HERE, "results")
+const RESULT = joinpath(RESULTS, "$(RESULT_STEM)_julia_results.json")
+const K_ETA = 3
+const N_PHI = 4
+const N_CHI = 4
+const SCALE = 1_000_000
+const CONTROL_ENV = "LEV_CR_RING_CHECKERBOARD_NEGATIVE_CONTROL"
+const CONTROL_ID = "shell_nesting_erasure"
+
+sha256_of(path::AbstractString) = bytes2hex(open(sha256, path))
+
+function row_index(sheet::Int, shell::Int, phi::Int, chi::Int)::Int
+    return (((sheet * K_ETA) + shell) * N_PHI + phi) * N_CHI + chi
+end
+
+function support_table()
+    rows = Vector{Vector{Int}}()
+    for sheet in 0:1
+        for shell in 0:(K_ETA - 1)
+            for phi in 0:(N_PHI - 1)
+                for chi in 0:(N_CHI - 1)
+                    push!(rows, [sheet, shell, phi, chi])
+                end
+            end
+        end
+    end
+    return rows
+end
+
+function eta_density_ints(shell::Int)::Vector{Int}
+    if shell == 0
+        return [SCALE, 0, 0]
+    elseif shell == 1
+        return [div(SCALE, 2), div(SCALE, 2), div(SCALE, 2)]
+    elseif shell == 2
+        return [0, SCALE, 0]
+    end
+    error("unexpected shell index $shell")
+end
+
+function density_signature(row::Vector{Int})::Vector{Int}
+    sheet, shell, _phi, chi = row
+    diag00, diag11, off_abs = eta_density_ints(shell)
+    off_phase_index = (2 * chi) % N_CHI
+    return [sheet, shell, chi, diag00, diag11, off_abs, off_phase_index]
+end
+
+function phase_signature(row::Vector{Int})::Vector{Int}
+    _sheet, _shell, phi, chi = row
+    phase_a = (phi + chi) % N_PHI
+    phase_b = mod(phi - chi, N_PHI)
+    return vcat(density_signature(row), [phi, phase_a, phase_b])
+end
+
+row_key(row::Vector{Int}) = join(string.(row), ",")
+unique_count(rows::Vector{Vector{Int}})::Int = length(Set(row_key(row) for row in rows))
+
+function edge_pairs(rows::Vector{Vector{Int}})::Vector{Vector{Int}}
+    edges = Set{Tuple{Int,Int}}()
+    for row in rows
+        sheet, shell, phi, chi = row
+        here = row_index(sheet, shell, phi, chi)
+        for (next_phi, next_chi) in [((phi + 1) % N_PHI, chi), (phi, (chi + 1) % N_CHI)]
+            other = row_index(sheet, shell, next_phi, next_chi)
+            push!(edges, (min(here, other), max(here, other)))
+        end
+        if shell + 1 < K_ETA
+            other = row_index(sheet, shell + 1, phi, chi)
+            push!(edges, (min(here, other), max(here, other)))
+        end
+    end
+    return [[left, right] for (left, right) in sort(collect(edges))]
+end
+
+function connected_components(node_count::Int, edges::Vector{Vector{Int}})::Int
+    adj = Dict(i => Int[] for i in 0:(node_count - 1))
+    for edge in edges
+        left, right = edge
+        push!(adj[left], right)
+        push!(adj[right], left)
+    end
+    seen = Set{Int}()
+    count = 0
+    for node in 0:(node_count - 1)
+        if node in seen
+            continue
+        end
+        count += 1
+        stack = [node]
+        push!(seen, node)
+        while !isempty(stack)
+            current = pop!(stack)
+            for neighbor in adj[current]
+                if !(neighbor in seen)
+                    push!(seen, neighbor)
+                    push!(stack, neighbor)
+                end
+            end
+        end
+    end
+    return count
+end
+
+function build_observables()
+    rows = support_table()
+    support_count = length(rows)
+    density_table = [density_signature(row) for row in rows]
+    phase_table = [phase_signature(row) for row in rows]
+    flat_edges = edge_pairs(rows)
+    ring_edges = edge_pairs(rows)
+    presentation_table = Vector{Vector{Int}}()
+    ring_fiber_table = Vector{Vector{Int}}()
+    for (idx, row) in enumerate(rows)
+        sheet, shell, phi, chi = row
+        row_zero = idx - 1
+        push!(presentation_table, [row_zero, sheet, shell, shell, shell, phi, phi, phi, chi, chi, chi])
+        push!(ring_fiber_table, [row_zero, sheet, shell, phi, chi])
+    end
+    shell_erased_count = unique_count([[row[1], row[3], row[4]] for row in rows])
+    fiber_erased_count = unique_count([[row[1], row[2], row[3]] for row in rows])
+    return Dict{String,Any}(
+        "support_coordinate_table" => rows,
+        "presentation_agreement_table" => presentation_table,
+        "ring_fiber_coordinate_table" => ring_fiber_table,
+        "density_probe_signature_table" => density_table,
+        "phase_sensitive_signature_table" => phase_table,
+        "flat_adjacency_edges" => flat_edges,
+        "ring_adjacency_edges" => ring_edges,
+        "integer_observables" => Dict{String,Any}(
+            "support_count" => support_count,
+            "flat_support_count" => support_count,
+            "spherical_support_count" => support_count,
+            "ring_support_count" => support_count,
+            "shell_eta_mismatch_count" => 0,
+            "ring_fiber_mismatch_count" => 0,
+            "density_class_count" => unique_count(density_table),
+            "phase_sensitive_class_count" => unique_count(phase_table),
+            "flat_edge_count" => length(flat_edges),
+            "ring_edge_count" => length(ring_edges),
+            "full_component_count" => connected_components(support_count, flat_edges),
+            "shell_erased_class_count" => shell_erased_count,
+            "fiber_erased_class_count" => fiber_erased_count,
+            "relation_ablated_component_count" => support_count,
+        ),
+    )
+end
+
+function build_negative_control()
+    ints = build_observables()["integer_observables"]
+    dropped = ints["shell_erased_class_count"] < ints["support_count"]
+    return Dict{String,Any}(
+        "control" => CONTROL_ID,
+        "engine" => "julia",
+        "breaks_structure" => dropped,
+        "support_count" => ints["support_count"],
+        "shell_erased_class_count" => ints["shell_erased_class_count"],
+        "expected_drop" => [96, 32],
+        "rejected" => dropped && ints["shell_erased_class_count"] == 32,
+    )
+end
+
+function finite_tables(observables)
+    return Dict(
+        key => observables[key]
+        for key in [
+            "support_coordinate_table",
+            "presentation_agreement_table",
+            "ring_fiber_coordinate_table",
+            "density_probe_signature_table",
+            "phase_sensitive_signature_table",
+            "flat_adjacency_edges",
+            "ring_adjacency_edges",
+        ]
+    )
+end
+
+function build_result()
+    observables = build_observables()
+    ints = observables["integer_observables"]
+    tests = Dict{String,Any}(
+        "finite_cell_support_count_agrees" => ints["flat_support_count"] == ints["spherical_support_count"] == ints["ring_support_count"] == 96,
+        "shell_eta_index_agrees" => ints["shell_eta_mismatch_count"] == 0,
+        "ring_fiber_coordinate_table_agrees" => ints["ring_fiber_mismatch_count"] == 0,
+        "quotient_classes_density_vs_phase" => Dict(
+            "density_class_count" => ints["density_class_count"],
+            "phase_sensitive_class_count" => ints["phase_sensitive_class_count"],
+            "phase_splits_density" => ints["phase_sensitive_class_count"] > ints["density_class_count"],
+        ),
+        "relation_adjacency_readouts_agree" => observables["flat_adjacency_edges"] == observables["ring_adjacency_edges"],
+        "folding_reindexing_invariants_valid" => Dict(
+            "flat_edges" => ints["flat_edge_count"],
+            "ring_edges" => ints["ring_edge_count"],
+            "full_components" => ints["full_component_count"],
+            "passes" => ints["flat_edge_count"] == 256 && ints["ring_edge_count"] == 256 && ints["full_component_count"] == 2,
+        ),
+    )
+    controls = Dict{String,Any}(
+        "shell_nesting_erasure_merges_classes" => ints["shell_erased_class_count"] < ints["support_count"],
+        "fiber_coordinate_erasure_merges_classes" => ints["fiber_erased_class_count"] < ints["support_count"],
+        "phase_sensitive_probe_splits_density_probe" => ints["phase_sensitive_class_count"] > ints["density_class_count"],
+        "relation_ablation_breaks_adjacency_components" => ints["relation_ablated_component_count"] > ints["full_component_count"],
+    )
+    all_tests = tests["finite_cell_support_count_agrees"] &&
+        tests["shell_eta_index_agrees"] &&
+        tests["ring_fiber_coordinate_table_agrees"] &&
+        tests["quotient_classes_density_vs_phase"]["phase_splits_density"] &&
+        tests["relation_adjacency_readouts_agree"] &&
+        tests["folding_reindexing_invariants_valid"]["passes"]
+    all_controls = all(values(controls))
+    return Dict{String,Any}(
+        "schema" => "codex_ratchet.engine_leg_result.v1",
+        "sim_id" => SIM_ID,
+        "engine" => "julia",
+        "classification" => "scratch_diagnostic",
+        "promotion_allowed" => false,
+        "formal_admission_allowed" => false,
+        "reads_peer_result" => false,
+        "written_at" => Dates.format(now(UTC), dateformat"yyyy-mm-ddTHH:MM:SSZ"),
+        "source_path" => @__FILE__,
+        "source_sha256" => sha256_of(@__FILE__),
+        "result_path" => RESULT,
+        "julia_project" => Base.active_project(),
+        "representation" => "julia_exact_finite_integer_tables",
+        "support_parameters" => Dict("sheets" => ["L", "R"], "K_eta" => K_ETA, "N_phi" => N_PHI, "N_chi" => N_CHI, "support_count" => 96),
+        "integer_observables" => ints,
+        "finite_integer_tables" => finite_tables(observables),
+        "tests" => tests,
+        "controls" => controls,
+        "all_tests_pass" => all_tests,
+        "all_controls_pass" => all_controls,
+        "all_pass" => all_tests && all_controls,
+        "claim_ceiling" => "scratch_diagnostic; promotion_allowed false; not M(C) admission",
+        "TOOL_MANIFEST" => Dict(
+            "julia" => Dict("tried" => true, "used" => true, "reason" => "load-bearing exact finite integer table and component computation"),
+            "JSON" => Dict("tried" => true, "used" => true, "reason" => "receipt output"),
+        ),
+        "TOOL_INTEGRATION_DEPTH" => Dict("julia" => "load_bearing", "JSON" => "supportive"),
+        "packages_used" => ["JSON"],
+        "aligned_packages_load_bearing" => ["julia"],
+    )
+end
+
+function main()
+    if get(ENV, CONTROL_ENV, "") == CONTROL_ID
+        control = build_negative_control()
+        println(JSON.json(control))
+        if !control["rejected"]
+            return 1
+        end
+        println("NEGATIVE_CONTROL_DONE engine=julia $(CONTROL_ID)=true")
+        return 0
+    end
+    mkpath(RESULTS)
+    result = build_result()
+    open(RESULT, "w") do io
+        JSON.print(io, result, 2)
+        write(io, "\n")
+    end
+    println("wrote $(RESULT)")
+    println(
+        "all_pass=$(result["all_pass"]) support=$(result["integer_observables"]["support_count"]) " *
+        "density_classes=$(result["integer_observables"]["density_class_count"]) " *
+        "phase_sensitive_classes=$(result["integer_observables"]["phase_sensitive_class_count"]) " *
+        "edges=$(result["integer_observables"]["flat_edge_count"]) " *
+        "components=$(result["integer_observables"]["full_component_count"])"
+    )
+    return result["all_pass"] ? 0 : 1
+end
+
+exit(main())
