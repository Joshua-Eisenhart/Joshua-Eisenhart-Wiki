+def edge_pairs(rows: jnp.ndarray) -> list[list[int]]:
+    rows_py = [tuple(map(int, row)) for row in jax.device_get(rows).tolist()]
+    edges: set[tuple[int, int]] = set()
+    for sheet, shell, phi, chi in rows_py:
+        here = row_index(sheet, shell, phi, chi)
+        for next_phi, next_chi in [((phi + 1) % N_PHI, chi), (phi, (chi + 1) % N_CHI)]:
+            other = row_index(sheet, shell, next_phi, next_chi)
+            edges.add(tuple(sorted((here, other))))
+        if shell + 1 < K_ETA:
+            other = row_index(sheet, shell + 1, phi, chi)
+            edges.add(tuple(sorted((here, other))))
+    return [list(edge) for edge in sorted(edges)]
+
+
+def connected_components(node_count: int, edges: list[list[int]]) -> int:
+    adj: dict[int, list[int]] = {index: [] for index in range(node_count)}
+    for left, right in edges:
+        adj[left].append(right)
+        adj[right].append(left)
+    seen: set[int] = set()
+    count = 0
+    for node in range(node_count):
+        if node in seen:
+            continue
+        count += 1
+        queue: deque[int] = deque([node])
+        seen.add(node)
+        while queue:
+            current = queue.popleft()
+            for neighbor in adj[current]:
+                if neighbor not in seen:
+                    seen.add(neighbor)
+                    queue.append(neighbor)
+    return count
+
+
+def unique_count(table: list[list[int]]) -> int:
+    return len({tuple(row) for row in table})
+
+
+def as_py_table(array: jnp.ndarray) -> list[list[int]]:
