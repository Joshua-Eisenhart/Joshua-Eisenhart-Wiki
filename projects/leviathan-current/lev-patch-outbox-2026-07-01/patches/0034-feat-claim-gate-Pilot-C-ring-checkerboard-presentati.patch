+#!/usr/bin/env python3
+"""Exact finite-table oracle for cr-ring-checkerboard-v0.
+
+Adapted from the Codex-Ratchet source sim:
+finite_ring_checkerboard_support_three_presentation_consistency_v0_exact.py.
+
+This carrier writes only inside this Lev-owned carrier directory. Gated
+observables are finite integer tables; phase/density language is restricted to
+integer readout names and does not claim a density representation, CPTP map, or
+promotion into M(C).
+"""
+
+from __future__ import annotations
+
+import hashlib
+import json
+import os
+from collections import defaultdict, deque
+from datetime import datetime, timezone
+from pathlib import Path
+from typing import Any
+
+SIM_ID = "cr-ring-checkerboard-v0"
+RESULT_STEM = "cr_ring_checkerboard_v0"
+HERE = Path(__file__).resolve().parent
+RESULTS = HERE / "results"
+RESULT = RESULTS / f"{RESULT_STEM}_exact_results.json"
+
+SHEETS = ("L", "R")
+SHEET_TO_INT = {"L": 0, "R": 1}
+K_ETA = 3
+N_PHI = 4
+N_CHI = 4
+SCALE = 1_000_000
+CONTROL_ENV = "LEV_CR_RING_CHECKERBOARD_NEGATIVE_CONTROL"
+CONTROL_ID = "shell_nesting_erasure"
+
+
+def sha256_of(path: Path) -> str:
+    return hashlib.sha256(path.read_bytes()).hexdigest()
+
+
+def row_index(sheet: int, shell: int, phi: int, chi: int) -> int:
+    return (((sheet * K_ETA) + shell) * N_PHI + phi) * N_CHI + chi
+
+
+def row_id(sheet: int, shell: int, phi: int, chi: int) -> str:
+    label = SHEETS[sheet]
+    return f"{label}:eta{shell}:phi{phi}:chi{chi}"
+
+
+def support_rows() -> list[dict[str, Any]]:
+    rows: list[dict[str, Any]] = []
+    for sheet_label in SHEETS:
+        sheet = SHEET_TO_INT[sheet_label]
+        for shell in range(K_ETA):
+            for phi in range(N_PHI):
+                for chi in range(N_CHI):
+                    rid = row_index(sheet, shell, phi, chi)
+                    rows.append(
+                        {
+                            "row_index": rid,
+                            "row_id": row_id(sheet, shell, phi, chi),
+                            "coord": [sheet, shell, phi, chi],
+                            "flat": {
+                                "sheet": sheet,
+                                "shell_index": shell,
+                                "x_phi": phi,
+                                "y_chi": chi,
+                                "cell_index": rid,
+                            },
+                            "spherical": {
+                                "sheet": sheet,
+                                "eta_index": shell,
+                                "phi_index": phi,
+                                "chi_index": chi,
+                            },
+                            "ring": {
+                                "sheet": sheet,
+                                "shell_index": shell,
+                                "base_ring_phi": phi,
+                                "fiber_ring_chi": chi,
+                            },
+                        }
+                    )
+    return rows
+
+
+def eta_density_ints(shell: int) -> tuple[int, int, int]:
+    if shell == 0:
+        return (SCALE, 0, 0)
+    if shell == 1:
+        return (SCALE // 2, SCALE // 2, SCALE // 2)
+    if shell == 2:
+        return (0, SCALE, 0)
+    raise ValueError(f"unexpected shell index {shell}")
+
+
+def density_probe_key(row: dict[str, Any]) -> tuple[int, ...]:
+    sheet, shell, _phi, chi = row["coord"]
+    diag00, diag11, off_abs = eta_density_ints(shell)
+    off_phase_index = (2 * chi) % N_CHI
+    return (sheet, shell, chi, diag00, diag11, off_abs, off_phase_index)
+
+
+def phase_sensitive_key(row: dict[str, Any]) -> tuple[int, ...]:
+    sheet, shell, phi, chi = row["coord"]
+    phase_a_index = (phi + chi) % N_PHI
+    phase_b_index = (phi - chi) % N_PHI
+    return density_probe_key(row) + (phi, phase_a_index, phase_b_index)
+
+
+def quotient_classes(rows: list[dict[str, Any]], key_fn) -> dict[str, list[str]]:
+    groups: dict[tuple[int, ...], list[str]] = defaultdict(list)
+    for row in rows:
+        groups[key_fn(row)].append(row["row_id"])
+    out: dict[str, list[str]] = {}
+    for key, ids in sorted(groups.items(), key=lambda entry: entry[0]):
+        digest = hashlib.sha256(json.dumps(key).encode("utf-8")).hexdigest()[:12]
+        out[f"q_{digest}"] = sorted(ids)
+    return out
+
+
+def quotient_signature_table(rows: list[dict[str, Any]], key_fn) -> list[list[int]]:
+    return [list(key_fn(row)) for row in sorted(rows, key=lambda row: row["row_index"])]
+
+
+def edge_pairs(rows: list[dict[str, Any]], presentation: str) -> list[list[int]]:
+    edges: set[tuple[int, int]] = set()
+    by_coord = {tuple(row[presentation][key] for key in (
+        ("sheet", "shell_index", "x_phi", "y_chi")
+        if presentation == "flat"
+        else ("sheet", "shell_index", "base_ring_phi", "fiber_ring_chi")
+    )): row["row_index"] for row in rows}
+
+    for row in rows:
+        if presentation == "flat":
+            sheet = row["flat"]["sheet"]
+            shell = row["flat"]["shell_index"]
+            phi = row["flat"]["x_phi"]
+            chi = row["flat"]["y_chi"]
+        else:
+            sheet = row["ring"]["sheet"]
+            shell = row["ring"]["shell_index"]
+            phi = row["ring"]["base_ring_phi"]
+            chi = row["ring"]["fiber_ring_chi"]
+        here = row["row_index"]
+        for next_phi, next_chi in [((phi + 1) % N_PHI, chi), (phi, (chi + 1) % N_CHI)]:
+            other = by_coord[(sheet, shell, next_phi, next_chi)]
+            edges.add(tuple(sorted((here, other))))
+        if shell + 1 < K_ETA:
+            other = by_coord[(sheet, shell + 1, phi, chi)]
+            edges.add(tuple(sorted((here, other))))
+    return [list(edge) for edge in sorted(edges)]
+
+
+def connected_components(node_count: int, edges: list[list[int]]) -> int:
+    adj: dict[int, list[int]] = {index: [] for index in range(node_count)}
+    for left, right in edges:
+        adj[left].append(right)
+        adj[right].append(left)
+    seen: set[int] = set()
+    count = 0
+    for node in range(node_count):
+        if node in seen:
+            continue
+        count += 1
+        queue: deque[int] = deque([node])
+        seen.add(node)
+        while queue:
+            current = queue.popleft()
+            for neighbor in adj[current]:
+                if neighbor not in seen:
+                    seen.add(neighbor)
+                    queue.append(neighbor)
+    return count
+
+
+def unique_count(rows: list[list[int]]) -> int:
+    return len({tuple(row) for row in rows})
+
+
+def build_observables() -> dict[str, Any]:
+    rows = support_rows()
+    support_table = [row["coord"] for row in rows]
+    presentation_table = [
+        [
+            row["row_index"],
+            row["flat"]["sheet"],
+            row["flat"]["shell_index"],
+            row["spherical"]["eta_index"],
+            row["ring"]["shell_index"],
+            row["flat"]["x_phi"],
+            row["spherical"]["phi_index"],
+            row["ring"]["base_ring_phi"],
+            row["flat"]["y_chi"],
+            row["spherical"]["chi_index"],
+            row["ring"]["fiber_ring_chi"],
+        ]
+        for row in rows
+    ]
+    ring_fiber_table = [
+        [
+            row["row_index"],
+            row["ring"]["sheet"],
+            row["ring"]["shell_index"],
+            row["ring"]["base_ring_phi"],
+            row["ring"]["fiber_ring_chi"],
+        ]
+        for row in rows
+    ]
+    density_table = quotient_signature_table(rows, density_probe_key)
+    phase_table = quotient_signature_table(rows, phase_sensitive_key)
+    flat_edges = edge_pairs(rows, "flat")
+    ring_edges = edge_pairs(rows, "ring")
+    support_count = len(rows)
+    shell_erased_count = unique_count([[row["coord"][0], row["coord"][2], row["coord"][3]] for row in rows])
+    fiber_erased_count = unique_count([[row["coord"][0], row["coord"][1], row["coord"][2]] for row in rows])
+    relation_ablated_components = support_count
+
+    return {
+        "support_coordinate_table": support_table,
+        "presentation_agreement_table": presentation_table,
+        "ring_fiber_coordinate_table": ring_fiber_table,
+        "density_probe_signature_table": density_table,
+        "phase_sensitive_signature_table": phase_table,
+        "flat_adjacency_edges": flat_edges,
+        "ring_adjacency_edges": ring_edges,
+        "integer_observables": {
+            "support_count": support_count,
