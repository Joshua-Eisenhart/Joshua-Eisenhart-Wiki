+def row_index(sheet: int, shell: int, phi: int, chi: int) -> int:
+    return (((sheet * K_ETA) + shell) * N_PHI + phi) * N_CHI + chi
+
+
+def density_signature(rows: jnp.ndarray) -> jnp.ndarray:
+    shell = rows[:, 1]
+    diag00 = jnp.where(shell == 0, SCALE, jnp.where(shell == 1, SCALE // 2, 0))
+    diag11 = jnp.where(shell == 0, 0, jnp.where(shell == 1, SCALE // 2, SCALE))
+    off_abs = jnp.where(shell == 1, SCALE // 2, 0)
+    off_phase_index = (2 * rows[:, 3]) % N_CHI
+    return jnp.stack([rows[:, 0], rows[:, 1], rows[:, 3], diag00, diag11, off_abs, off_phase_index], axis=1)
+
+
+def phase_signature(rows: jnp.ndarray) -> jnp.ndarray:
+    phase_a = (rows[:, 2] + rows[:, 3]) % N_PHI
+    phase_b = (rows[:, 2] - rows[:, 3]) % N_PHI
+    return jnp.concatenate([density_signature(rows), rows[:, 2:3], phase_a[:, None], phase_b[:, None]], axis=1)
+
