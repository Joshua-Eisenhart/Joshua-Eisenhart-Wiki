+function isGraphOperation(value: unknown): value is ClaimGateGraphPatchApplyPlan['graphOperations'][number] {
+  if (!isRecord(value)) return false;
+  return (
+    ['upsert_entity', 'delete_entity', 'add_claim', 'update_claim', 'add_link', 'remove_link', 'set_depth'].includes(String(value.type))
+    && typeof value.timestamp === 'string'
+    && typeof value.source === 'string'
+    && typeof value.entity_id === 'string'
+    && isRecord(value.payload)
+  );
+}
+
+function waveRunEngineGraphOperationsFromArtifact(
+  artifact: unknown,
+  result: ClaimGateLoopResult,
+): ClaimGateGraphPatchApplyPlan['graphOperations'] {
+  if (!isRecord(artifact) || artifact.kind !== 'ClaimGateWaveRunResult') return [];
+  const waveRun = artifact as unknown as ClaimGateWaveRunResult;
+  const proposal = waveRun.engineGraphOperationProposal;
+  if (!proposal) return [];
+
+  if (!claimGateWaveRunReceiptMatches(waveRun)) {
+    throw new Error('WaveRun engine graph operations require a matching outer WaveRun receipt contentHash.');
+  }
+  if (proposal.claimCeiling !== 'engine_graph_operation_proposal_not_graph_apply') {
+    throw new Error('WaveRun engine graph operation proposal has an unexpected claim ceiling.');
+  }
+  if (proposal.graphMutationApplied !== false) {
+    throw new Error('WaveRun engine graph operation proposal must preserve graphMutationApplied:false until apply.');
+  }
+  if (proposal.sourceReceiptId !== result.receipt.id) {
+    throw new Error('WaveRun engine graph operation proposal sourceReceiptId must match the nested ClaimGate result receipt.');
+  }
+  if (!Array.isArray(proposal.operations) || proposal.operations.some((operation) => !isGraphOperation(operation))) {
+    throw new Error('WaveRun engine graph operation proposal contains invalid graph operations.');
+  }
+  if (proposal.operationHash !== `sha256:${sha256(proposal.operations)}`) {
+    throw new Error('WaveRun engine graph operation proposal operationHash must match its operations.');
+  }
+  return proposal.operations;
+}
+
+function readClaimGateGraphPatchApplySourceArtifact(file: string): {
+  result: ClaimGateLoopResult;
+  additionalGraphOperations: ClaimGateGraphPatchApplyPlan['graphOperations'];
+} {
+  const artifact = readJson<unknown>(file);
+  const result = claimGateLoopResultFromArtifact(artifact);
+  if (!result) {
+    throw new Error('Expected a ClaimGate loop result, WaveRun result, or WaveRun continuation result with a nested waveResult.');
+  }
+  return {
+    result,
+    additionalGraphOperations: waveRunEngineGraphOperationsFromArtifact(artifact, result),
+  };
+}
