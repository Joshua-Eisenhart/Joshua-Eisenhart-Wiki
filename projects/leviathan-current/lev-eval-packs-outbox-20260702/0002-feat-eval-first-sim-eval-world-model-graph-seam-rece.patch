+      prediction_error: numberVariable(worldModelMeasurement, 'world_model_prediction_error'),
+      discharge: {
+        verdict_id: worldModelVerdict.verdict_id,
+        status: worldModelVerdict.status,
+        gate_result_status: worldModelDischarge.gate_result.status,
+      },
+    },
+    graph: {
+      node_id: nodeId,
+      storage_path: graphStorePath,
+      event_count: storedEvents.length,
+      readback: {
+        node_exists: readbackNode !== undefined && storedNode !== undefined,
+        measurement_id: storedMeasurementId ?? null,
+      },
+    },
+    hop_chain: {
+      sim_result_sha256: [juliaSha, jaxSha],
+      evidence_content_address: providerEvidence.map((record) => record.content_address),
+      eval_decision: scoreResult.decision,
+      eval_verdict_id: evalVerdict.verdict_id,
+      measurement_id: worldModelMeasurement.measurement_id,
+      node_id: nodeId,
+    },
+    hops_completed: ['sim', 'evidence', 'eval', 'measurement', 'graph'],
+    blocked_at: 'none',
+  };
+}
+
+function providerEvidenceFromResult(
+  laneId: 'sim.julia' | 'sim.jax',
+  result: Record<string, unknown>,
+  resultPath: string,
+): StructuralSimEvalProviderEvidenceRecord {
+  const record = {
+    schema: 'lev.sim_eval.provider_evidence.v1',
+    lane_id: laneId,
+    status: 'non_authoritative_input',
+    subject_ref: subjectRef,
+    generation,
+    requested_at: new Date(stringField(result, 'written_at')).toISOString(),
+    content_address: '',
+    refs: [{ kind: 'codex_ratchet_result_json', ref: resultPath }],
+    facts: [
+      { name: 'sim_id', value: stringField(result, 'sim_id') },
+      { name: 'quotient_class_count_full', value: numberField(result, 'quotient_class_count_full') },
+      { name: 'quotient_class_count_erased', value: numberField(result, 'quotient_class_count_erased') },
+      { name: 'real_vs_erased_flip_confirmed', value: nestedBooleanField(result, ['smt_flip', 'real_vs_erased_flip_confirmed']) },
+      { name: 'tautology_guard_tripped', value: nestedBooleanField(result, ['flip_control', 'tautology_guard_tripped']) },
+      { name: 'negative_control_present', value: negativeControlPresent(result) },
+    ],
+    provenance: {
+      source_package: '@lev-os/sim-eval',
+      provider_id: laneId,
+      command: null,
+      bounded: true,
+    },
+  } satisfies Omit<StructuralSimEvalProviderEvidenceRecord, 'content_address'> & { content_address: string };
+
+  return {
+    ...record,
+    content_address: contentAddressForEvidence(record),
+  };
+}
+
+function contentAddressForEvidence(evidence: Omit<StructuralSimEvalProviderEvidenceRecord, 'content_address'>): string {
+  const serialized = [
+    evidence.schema,
+    evidence.lane_id,
+    evidence.status,
+    evidence.subject_ref,
+    String(evidence.generation),
+    evidence.requested_at,
+    evidence.refs.map((ref) => `${ref.kind}:${ref.ref}`).join('\n'),
+    evidence.facts.map((fact) => `${fact.name}:${String(fact.value)}`).join('\n'),
+    evidence.provenance.source_package,
+    evidence.provenance.provider_id,
+    'command:null',
+    'bounded:true',
+    'error:null',
+  ].join('\u001f');
+
+  return `sim-eval:fnv1a32:${fnv1a32(serialized)}`;
+}
+
+function fnv1a32(value: string): string {
+  let hash = 0x811c9dc5;
+  for (let index = 0; index < value.length; index += 1) {
+    hash ^= value.charCodeAt(index);
+    hash = Math.imul(hash, 0x01000193);
+  }
+  return (hash >>> 0).toString(16).padStart(8, '0');
+}
+
+async function scoreParity(input: unknown): Promise<ScoreResult> {
+  const module = await import(pathToFileURL(join(packDir, 'companions/sensor.mjs')).href) as {
+    score(input: unknown): unknown;
+  };
+  return module.score(input) as ScoreResult;
+}
+
+function measurementFromScore(
+  scoreResult: ScoreResult,
+  providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[],
+): Measurement {
+  return {
+    schema: 'lev.measurement.v1',
+    measurement_id: `measurement:cr_cross_engine_parity:${providerEvidence.map((record) => record.content_address.split(':').at(-1)).join(':')}`,
+    evaluator_id: 'cr_cross_engine_parity',
+    evaluator_version: '1',
+    subject_ref: subjectRef,
+    generation,
+    variables: scoreResult.measurements.variables,
+    provenance: 'runtime_fact',
+    evidence_refs: scoreResult.evidence_refs,
+    status: 'measured',
+    measured_at: evaluatedAt,
+  };
+}
+
+function evalObligation(): Obligation {
+  return {
+    obligation_id: 'obligation:cr_cross_engine_parity:world_engine_seam',
+    declared_by: 'consumer_requirement',
+    declared_at: observedAt,
+    predicate_ref: 'policy:cr_cross_engine_parity:world_engine_seam',
+    discharge_condition: { kind: 'all_pass' },
+    required_evidence: [{ kind: 'measurement', min_count: 1, freshness: 'current' }],
+  };
+}
+
+function evalGatePolicy(): GatePolicy {
+  return {
+    gate_id: 'cr_cross_engine_parity.world_engine_seam',
+    policy_ref: 'policy:cr_cross_engine_parity:world_engine_seam',
+    evaluator_id: 'cr_cross_engine_parity',
+    authored_at: observedAt,
+    requires: [
+      { variable_ref: 'cr_cross_engine_parity/max_abs_diff', op: 'eq', value: 0 },
+      { variable_ref: 'cr_cross_engine_parity/engines_agree', op: 'eq', value: true },
+      { variable_ref: 'cr_cross_engine_parity/engines_present', op: 'eq', value: true },
+      { variable_ref: 'cr_cross_engine_parity/negative_control_present', op: 'eq', value: true },
+    ],
+    freshness: { generation: 'current', max_age_ms: 120_000 },
+    on_missing: 'evaluation_error',
+  };
+}
+
+function worldModelEvidenceFromEval(input: {
+  fullClassCount: number;
+  providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[];
+  evalMeasurement: Measurement;
+  evalDischarge: ReturnType<typeof discharge>;
+}): StructuralWorldModelEvidenceRecord {
+  if (input.evalDischarge.verdict.kind !== 'evaluated') {
+    throw new Error('world-model evidence requires an evaluated verdict');
+  }
+  const predictor = createWorldModelPredictor();
+  const predictionError = predictor.predictionError('prior:probe_quotient_fingerprint_floor_v1', {
+    workUnitId: 'world-engine-seam',
+    raw: {
+      sim_id: 'probe_quotient_fingerprint_floor_v1',
+      quotient_class_count_full: input.fullClassCount,
+      eval_measurement_id: input.evalMeasurement.measurement_id,
+      eval_verdict_id: input.evalDischarge.verdict.verdict_id,
+    },
+  });
+  expect(Number.isFinite(predictionError)).toBe(true);
+  expect(predictionError).toBeGreaterThanOrEqual(0);
+
+  const evidenceId = `wm-evidence:world-engine-seam:${sha256Text([
+    input.evalDischarge.verdict.verdict_id,
+    input.evalMeasurement.measurement_id,
+    String(input.fullClassCount),
+    ...input.providerEvidence.map((record) => record.content_address),
+  ].join('\n')).slice(0, 16)}`;
+
+  return {
+    schema: 'lev.world_model.evidence.v1',
+    evidence_id: evidenceId,
+    kind: 'readout-fact',
+    subject_ref: subjectRef,
+    generation,
+    observed_at: observedAt,
+    status: 'non_authoritative_input',
+    produced_by: 'core/world-model',
+    refs: [
+      { kind: 'eval_verdict', ref: input.evalDischarge.verdict.verdict_id },
+      { kind: 'eval_measurement', ref: input.evalMeasurement.measurement_id },
+      ...input.providerEvidence.map((record) => ({
+        kind: 'sim_eval_provider_evidence',
+        ref: record.content_address,
+        exists: true,
+      })),
+    ],
+    reasons: [],
+    facts: [
+      { name: 'quotient_class_count_full', value: input.fullClassCount },
+      { name: 'eval_decision', value: input.evalDischarge.verdict.status },
+      { name: 'engines_agree', value: true },
+      { name: 'world_model_prediction_error', value: round(predictionError) },
+    ],
+    provenance: {
+      source_package: '@lev-os/world-model',
+      source_module: 'readout',
+      load_bearing: false,
+    },
+  };
+}
+
+function worldModelObligation(): Obligation {
+  return {
+    obligation_id: 'obligation:world_model:world_engine_seam',
+    declared_by: 'consumer_requirement',
+    declared_at: observedAt,
+    predicate_ref: 'policy:world_model:world_engine_seam',
+    discharge_condition: { kind: 'all_pass' },
+    required_evidence: [{ kind: 'world_model_evidence', min_count: 1, freshness: 'current' }],
+  };
+}
+
+function worldModelGatePolicy(): GatePolicy {
+  return {
+    gate_id: 'world_model.world_engine_seam',
+    policy_ref: 'policy:world_model:world_engine_seam',
+    evaluator_id: 'world_model_evidence',
+    authored_at: observedAt,
+    requires: [
+      { variable_ref: 'world_model_evidence/quotient_class_count_full', op: 'eq', value: 5 },
+      { variable_ref: 'world_model_evidence/eval_decision', op: 'eq', value: 'pass' },
+      { variable_ref: 'world_model_evidence/engines_agree', op: 'eq', value: true },
+      { variable_ref: 'world_model_evidence/world_model_prediction_error', op: 'gte', value: 0 },
+    ],
+    freshness: { generation: 'current', max_age_ms: 120_000 },
+    on_missing: 'evaluation_error',
+  };
+}
+
+function graphEventForMeasurement(
+  nodeId: string,
+  measurement: Measurement,
+  verdictId: string | undefined,
+) {
+  const entity: Entity = {
+    id: nodeId,
+    type: 'world_model_measurement',
+    source: 'core/eval/world-engine-seam',
+    via: 'world-engine-seam-replay',
+    depth: 'L1',
+    last_classified: evaluatedAt,
+    decay_rate: 0,
+    claims: [
+      claim(`${nodeId}:claim:measurement_id`, nodeId, 'has_measurement_id', measurement.measurement_id),
+      claim(`${nodeId}:claim:quotient_class_count_full`, nodeId, 'quotient_class_count_full', String(numberVariable(measurement, 'quotient_class_count_full'))),
+      claim(`${nodeId}:claim:eval_decision`, nodeId, 'eval_decision', stringVariable(measurement, 'eval_decision')),
+      claim(`${nodeId}:claim:verdict_id`, nodeId, 'discharged_by_verdict', verdictId ?? 'none'),
+    ],
+    links: [],
+  };
+  const operations: GraphOperation[] = [{
+    type: 'upsert_entity',
+    timestamp: evaluatedAt,
+    source: 'core/eval/world-engine-seam',
+    entity_id: nodeId,
+    payload: entity as unknown as Record<string, unknown>,
+  }];
+
+  return {
+    version: 1,
