+async function buildSeamReceipt(graphStorePath: string): Promise<SeamReceipt> {
+  const [juliaResult, jaxResult, threeEngineResult] = await Promise.all([
+    readJsonRecord(juliaResultPath),
+    readJsonRecord(jaxResultPath),
+    readJsonRecord(threeEngineResultPath),
