+  const [juliaSha, jaxSha, threeEngineSha] = await Promise.all([
+    sha256File(juliaResultPath),
+    sha256File(jaxResultPath),
+    sha256File(threeEngineResultPath),
+  ]);
+
+  expect(juliaResult.all_pass).toBe(true);
+  expect(jaxResult.all_pass).toBe(true);
+  expect(threeEngineResult.all_pass).toBe(true);
+  expect(numberField(juliaResult, 'quotient_class_count_full')).toBe(5);
+  expect(numberField(jaxResult, 'quotient_class_count_full')).toBe(5);
+
+  const providerEvidence = [
+    providerEvidenceFromResult('sim.julia', juliaResult, juliaResultPath),
+    providerEvidenceFromResult('sim.jax', jaxResult, jaxResultPath),
+  ];
+
+  const providerMeasurements = providerEvidence.map((record) => {
+    const result = simEvalProviderEvidenceToMeasurement(record, {
+      evaluatorId: 'sim_eval_provider_evidence',
+      evaluatorVersion: '1',
+      expectedSubjectRef: subjectRef,
+      currentGeneration: generation,
+      now: evaluatedAt,
+    });
+    expect(result.ok).toBe(true);
+    if (!result.ok) throw new Error(`provider evidence projection failed: ${record.lane_id}`);
+    return result.measurement;
+  });
+
+  const parityInput = {
+    schema: 'lev.cr_cross_engine_parity.trace.v1',
+    subject_ref: subjectRef,
+    observable_name: 'quotient_class_count_full',
+    tolerance: 0,
+    provider_evidence: providerEvidence,
+  };
+  const scoreResult = await scoreParity(parityInput);
+  expect(scoreResult.passed).toBe(true);
+  expect(scoreResult.decision).toBe('pass');
+  expect(scoreResult.measurements.variables.max_abs_diff.value).toBe(0);
+
+  const evalMeasurement = measurementFromScore(scoreResult, providerEvidence);
+  const evalDischarge = discharge(evalObligation(), [evalMeasurement], evalGatePolicy(), {
+    subject_ref: subjectRef,
+    generation,
+    now: evaluatedAt,
+  });
+  expect(evalDischarge.verdict.kind).toBe('evaluated');
+  if (evalDischarge.verdict.kind !== 'evaluated') {
+    throw new Error('expected evaluated parity discharge');
+  }
+  const evalVerdict = evalDischarge.verdict;
+  expect(evalVerdict.status).toBe('pass');
+
+  const fullClassCount = numberField(juliaResult, 'quotient_class_count_full');
+  const worldModelEvidence = worldModelEvidenceFromEval({
+    fullClassCount,
+    providerEvidence,
+    evalMeasurement,
+    evalDischarge,
+  });
+  const worldModelMeasurementResult = worldModelEvidenceToMeasurement(worldModelEvidence, {
+    evaluatorId: 'world_model_evidence',
