+    })),
+    eval: {
+      evaluator_id: 'cr_cross_engine_parity',
+      command: 'pnpm --dir core/eval exec vitest run src/world-engine-seam-receipt.test.ts',
+      decision: scoreResult.decision,
+      passed: scoreResult.passed,
+      reason: scoreResult.reason,
