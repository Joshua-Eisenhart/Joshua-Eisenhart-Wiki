diff --git a/plugins/sim-eval/evals/cr_ordered_channel_parity/flows/measure.flow.yaml b/plugins/sim-eval/evals/cr_ordered_channel_parity/flows/measure.flow.yaml
new file mode 100644
index 000000000..11191a3ed
--- /dev/null
+++ b/plugins/sim-eval/evals/cr_ordered_channel_parity/flows/measure.flow.yaml
@@ -0,0 +1,33 @@
+schema: lev.flowmind.flow.v1
+id: cr_ordered_channel_parity.measure
+description: Measure four-route ordered-channel parity over non-authoritative Codex-Ratchet sim provider evidence.
+inputs:
+  provider_evidence:
+    type: array
+    required: true
+  observable_names:
+    type: array
+    required: true
+  tolerance:
+    type: number
+    required: true
+outputs:
+  observations:
+    type: object
+  measurements:
+    type: object
+nodes:
+  - id: score_measurements
+    kind: companion.score
+    inputs:
+      companion: ../companions/sensor.mjs
+      provider_evidence: ${inputs.provider_evidence}
+      observable_names: ${inputs.observable_names}
+      tolerance: ${inputs.tolerance}
+    outputs:
+      variables:
+        - max_abs_diff
+        - engines_agree
+        - engines_present
