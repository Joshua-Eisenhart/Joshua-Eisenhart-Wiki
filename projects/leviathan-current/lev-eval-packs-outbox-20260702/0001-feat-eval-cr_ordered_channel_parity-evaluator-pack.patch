+schema: lev.evaluator_pack.v1
+evaluator_id: cr_ordered_channel_parity
+owner: plugins/sim-eval
+kind: shipped_evaluator_pack
+entrypoints:
+  flow: flows/measure.flow.yaml
+  sensor: companions/sensor.mjs
+policies:
+  gate: policies/gate-policy.yaml
+  routing: policies/routing-policy.yaml
+inputs:
+  provider_evidence:
+    required: true
+    description: Array of lev.sim_eval.provider_evidence.v1 records for sim.julia and sim.jax; each record refs its Codex-Ratchet result artifact.
+  observable_names:
+    required: true
+    description: Four ordered-channel route-delta numeric provider facts to compare across engine lanes.
+  tolerance:
+    required: true
+    description: Maximum allowed absolute float difference between engine facts.
+outputs:
+  result_schema: lev.evaluator.result.v1
+  measurement_schema: lev.measurement.v1
+variables:
+  - max_abs_diff
+  - engines_agree
+  - engines_present
+  - negative_control_present
+  - fenced_gamma_absent
+collision_policy:
+  evaluator_pack: select
+  proof_gate: reject
