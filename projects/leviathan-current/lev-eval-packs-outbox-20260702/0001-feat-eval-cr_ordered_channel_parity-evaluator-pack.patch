diff --git a/plugins/sim-eval/tests/cr-ordered-channel-parity.test.ts b/plugins/sim-eval/tests/cr-ordered-channel-parity.test.ts
new file mode 100644
index 000000000..043af4085
--- /dev/null
+++ b/plugins/sim-eval/tests/cr-ordered-channel-parity.test.ts
@@ -0,0 +1,162 @@
+import { readFile } from 'node:fs/promises';
+import { dirname, join, resolve } from 'node:path';
+import { pathToFileURL, fileURLToPath } from 'node:url';
+import { describe, expect, it } from 'vitest';
+import { loadProjectEvaluatorPacks } from '../../../core/eval/src/index.ts';
+import { createAvailableProviderEvidence } from '../src/index.ts';
+
+const repoRoot = resolve(dirname(fileURLToPath(import.meta.url)), '../../..');
+const packDir = join(repoRoot, 'plugins/sim-eval/evals/cr_ordered_channel_parity');
+const fixturesDir = join(packDir, 'fixtures');
+
+interface ScoreResult {
+  schema: string;
+  evaluator_id: string;
+  passed: boolean;
+  decision: string;
+  reason: string;
+  measurements: {
+    schema: string;
+    variables: Record<string, { value: unknown; confidence: number; evidence_count: number }>;
+  };
+}
+
+describe('cr_ordered_channel_parity evaluator pack', () => {
+  it('is discovered as a shipped evaluator pack', async () => {
+    const packs = await loadProjectEvaluatorPacks({
+      projectRoot: repoRoot,
+      evaluatorId: 'cr_ordered_channel_parity',
+    });
+
+    expect(packs).toHaveLength(1);
+    expect(packs[0]?.manifest).toMatchObject({
+      schema: 'lev.evaluator_pack.v1',
+      evaluator_id: 'cr_ordered_channel_parity',
+      owner: 'plugins/sim-eval',
+      kind: 'shipped_evaluator_pack',
+    });
+    expect(packs[0]?.diagnostics).toEqual([]);
+    expect(packs[0]?.evidence_refs).toEqual(expect.arrayContaining([
+      expect.objectContaining({
+        kind: 'manifest',
+        path: 'plugins/sim-eval/evals/cr_ordered_channel_parity/cr_ordered_channel_parity.eval.yaml',
+        exists: true,
+      }),
+      expect.objectContaining({
+        kind: 'entrypoint',
+        label: 'sensor',
+        path: 'plugins/sim-eval/evals/cr_ordered_channel_parity/companions/sensor.mjs',
+        exists: true,
+      }),
+      expect.objectContaining({
+        kind: 'policy',
+        label: 'gate',
+        path: 'plugins/sim-eval/evals/cr_ordered_channel_parity/policies/gate-policy.yaml',
+        exists: true,
+      }),
+    ]));
+  });
+
+  it('passes real Codex-Ratchet Julia and JAX ordered-channel route evidence', async () => {
+    const result = await scoreFixture('ordered-channel-parity-pass.trace.json');
+
+    expect(result.schema).toBe('lev.evaluator.result.v1');
+    expect(result.evaluator_id).toBe('cr_ordered_channel_parity');
+    expect(result.passed).toBe(true);
+    expect(result.decision).toBe('pass');
+    expect(result.measurements.variables.max_abs_diff.value).toBeLessThanOrEqual(1e-10);
+    expect(result.measurements.variables.engines_agree.value).toBe(true);
+    expect(result.measurements.variables.engines_present.value).toBe(true);
+    expect(result.measurements.variables.negative_control_present.value).toBe(true);
+    expect(result.measurements.variables.fenced_gamma_absent.value).toBe(true);
+  });
+
+  it('blocks when one ordered-channel route drifts beyond tolerance', async () => {
+    const result = await scoreFixture('ordered-channel-parity-adversarial.trace.json');
+
+    expect(result.passed).toBe(false);
+    expect(result.decision).toBe('block');
+    expect(result.measurements.variables.max_abs_diff.value).toBeGreaterThan(1e-10);
+    expect(result.measurements.variables.engines_agree.value).toBe(false);
+  });
+
+  it('blocks when a required engine lane is missing', async () => {
+    const result = await scoreFixture('ordered-channel-parity-missing-lane.trace.json');
+
+    expect(result.passed).toBe(false);
+    expect(result.decision).toBe('block');
+    expect(result.measurements.variables.engines_present.value).toBe(false);
+    expect(result.reason).toContain('required provider lanes');
+  });
+
+  it('blocks provider evidence whose content address does not match its fields', async () => {
+    const result = await scoreFixture('ordered-channel-parity-bad-address.trace.json');
+
+    expect(result.passed).toBe(false);
+    expect(result.decision).toBe('block');
+    expect(result.reason).toContain('content_address_mismatch');
+  });
+
+  it('blocks by-construction gamma fields even with valid content addresses', async () => {
+    const result = await scoreFixture('ordered-channel-parity-gamma-field-injection.trace.json');
+
+    expect(result.passed).toBe(false);
+    expect(result.decision).toBe('block');
+    expect(result.reason).toContain('by-construction gamma field');
+    expect(result.measurements.variables.fenced_gamma_absent.value).toBe(false);
+  });
+
+  it('blocks sub-rounding drift against zero tolerance while rounding display only', async () => {
+    const requestedAt = '2026-07-02T00:00:00.000Z';
+    const julia = createAvailableProviderEvidence('sim.julia', {
+      subject_ref: 'codex-ratchet:ordered-channel-sub-rounding-drift',
+      generation: 1,
+      requested_at: requestedAt,
+      refs: [{ kind: 'codex_ratchet_result_json', ref: 'julia.json' }],
+    }, [
+      { name: 'route_delta.rho0_plus', value: 1 },
+      { name: 'negative_control_present', value: true },
+    ]);
+    const jax = createAvailableProviderEvidence('sim.jax', {
+      subject_ref: 'codex-ratchet:ordered-channel-sub-rounding-drift',
+      generation: 1,
+      requested_at: requestedAt,
+      refs: [{ kind: 'codex_ratchet_result_json', ref: 'jax.json' }],
+    }, [
+      { name: 'route_delta.rho0_plus', value: 1 + 4e-13 },
+      { name: 'negative_control_present', value: true },
+    ]);
+
+    const result = await scoreInput({
+      provider_evidence: [julia, jax],
+      observable_name: 'route_delta.rho0_plus',
+      tolerance: 0,
+    });
+
+    expect(result.passed).toBe(false);
+    expect(result.decision).toBe('block');
+    expect(result.measurements.variables.max_abs_diff.value).toBe(0);
+    expect(result.measurements.variables.engines_agree.value).toBe(false);
+  });
+});
+
+async function scoreFixture(name: string): Promise<ScoreResult> {
+  const [{ score }, fixture] = await Promise.all([
+    loadSensor(),
+    readFixture(name),
+  ]);
+  return score(fixture) as ScoreResult;
+}
+
+async function scoreInput(input: unknown): Promise<ScoreResult> {
+  const { score } = await loadSensor();
+  return score(input) as ScoreResult;
+}
+
+async function loadSensor(): Promise<{ score(input: unknown): unknown }> {
+  return import(pathToFileURL(join(packDir, 'companions/sensor.mjs')).href) as Promise<{ score(input: unknown): unknown }>;
+}
+
+async function readFixture(name: string): Promise<unknown> {
+  return JSON.parse(await readFile(join(fixturesDir, name), 'utf8')) as unknown;
+}
