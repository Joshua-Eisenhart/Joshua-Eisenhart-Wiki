+const PROVIDER_SCHEMA = 'lev.sim_eval.provider_evidence.v1';
+const EVALUATOR_ID = 'cr_qit_bridge_stream_v0';
+const CONTENT_ADDRESS_PREFIX = 'sim-eval:fnv1a32:';
+const FNV_OFFSET = 0x811c9dc5;
+const FNV_PRIME = 0x01000193;
+const QIT_LANE_ID = 'sim.qit';
+const DEFAULT_SHAPE_CONTRACT = Object.freeze({
+  baseline_ticks: Object.freeze([3, 4, 5]),
+  spike_ticks: Object.freeze([6]),
+  tail_ticks: Object.freeze([10, 11, 12, 13]),
+  baseline_mean_lt: 0.05,
+  spike_max_gt: 1.0,
+  tail_mean_lt: 0.05,
+  tail_max_lt: 0.05,
+});
+const FORBIDDEN_PROVIDER_STATUSES = Object.freeze([
+  'evaluated',
+  'pass',
+  'fail',
+  'not_evaluated',
+]);
+const FORBIDDEN_PROVIDER_FIELDS = Object.freeze([
+  'verdict',
+  'EvalVerdict',
+  'gate_proof',
+  'GateProof',
+  'proof_bundle',
+  'ProofBundle',
+  'effect_receipt',
+  'EffectReceipt',
+  'run_seal',
+  'RunSeal',
+]);
+
+export function score(input) {
+  const providerEvidence = providerEvidenceFrom(input);
+  const shapeContractResult = shapeContractFrom(input);
+  const evidenceRefs = providerEvidence.flatMap(evidenceRefsFromRecord);
+  const blocked = (reason, partial = {}) => result('block', reason, {
+    baselineSurpriseMean: partial.baselineSurpriseMean ?? null,
+    spikeSurpriseMax: partial.spikeSurpriseMax ?? null,
+    relearnTailMean: partial.relearnTailMean ?? null,
+    relearnTailMax: partial.relearnTailMax ?? null,
+    providerTicksPresent: partial.providerTicksPresent ?? false,
+    contentAddressesValid: partial.contentAddressesValid ?? false,
+    regimeShiftResponsive: partial.regimeShiftResponsive ?? false,
+    tickCount: partial.tickCount ?? providerEvidence.length,
+    evidenceRefs,
+  });
+
+  if (!shapeContractResult.ok) {
+    return blocked(`declared shape contract is missing or malformed: ${shapeContractResult.reason}`);
+  }
+  if (providerEvidence.length === 0) {
+    return blocked('qit provider evidence ticks are missing');
+  }
+
+  const ticks = [];
+  for (const record of providerEvidence) {
+    if (hasTruthMintingShape(record)) {
+      return blocked('provider evidence contains forbidden verdict or proof-shaped fields');
+    }
+    if (!isProviderRecord(record)) {
+      return blocked('qit provider evidence is malformed');
+    }
+    if (record.lane_id !== QIT_LANE_ID) {
+      return blocked(`unexpected provider lane ${record.lane_id}`);
+    }
+    if (record.status !== 'non_authoritative_input') {
+      return blocked('qit provider evidence must be non_authoritative_input');
+    }
+    if (!contentAddressMatches(record)) {
+      return blocked('provider evidence content_address_mismatch: content_address does not match recomputed FNV-1a-32');
+    }
+
+    const tick = tickFromProviderEvidence(record);
+    if (!tick.ok) return blocked(tick.reason, { contentAddressesValid: true });
+    ticks.push(tick.value);
+  }
+
+  const orderedResult = orderTicks(ticks);
+  if (!orderedResult.ok) {
+    return blocked(orderedResult.reason, { contentAddressesValid: true });
+  }
+
+  const profileResult = surpriseProfile(orderedResult.ticks, shapeContractResult.contract);
+  if (!profileResult.ok) {
+    return blocked(profileResult.reason, {
+      contentAddressesValid: true,
+      providerTicksPresent: true,
+      tickCount: orderedResult.ticks.length,
+    });
+  }
+
+  const profile = profileResult.profile;
+  const contract = shapeContractResult.contract;
+  const baselineOk = profile.baselineSurpriseMean < contract.baseline_mean_lt;
+  const spikeOk = profile.spikeSurpriseMax > contract.spike_max_gt;
+  const tailMeanOk = profile.relearnTailMean < contract.tail_mean_lt;
+  const tailMaxOk = profile.relearnTailMax < contract.tail_max_lt;
+  const regimeShiftResponsive = baselineOk && spikeOk && tailMeanOk && tailMaxOk;
+
+  if (!baselineOk) {
+    return blocked('baseline surprise mean does not satisfy declared contract', {
+      ...profile,
+      contentAddressesValid: true,
+      providerTicksPresent: true,
+      regimeShiftResponsive,
+      tickCount: orderedResult.ticks.length,
+    });
+  }
+  if (!spikeOk) {
+    return blocked('spike surprise max does not satisfy declared contract', {
+      ...profile,
+      contentAddressesValid: true,
+      providerTicksPresent: true,
+      regimeShiftResponsive,
+      tickCount: orderedResult.ticks.length,
+    });
+  }
+  if (!tailMeanOk || !tailMaxOk) {
+    return blocked('relearn tail surprise does not satisfy declared contract', {
+      ...profile,
+      contentAddressesValid: true,
+      providerTicksPresent: true,
+      regimeShiftResponsive,
+      tickCount: orderedResult.ticks.length,
+    });
+  }
+
+  return result('pass', 'QIT provider stream surprise profile is regime-shift responsive', {
+    ...profile,
+    contentAddressesValid: true,
+    providerTicksPresent: true,
+    regimeShiftResponsive,
+    tickCount: orderedResult.ticks.length,
+    evidenceRefs,
+  });
+}
+
+function result(decision, reason, measurements) {
+  const passed = decision === 'pass';
+  return {
+    schema: 'lev.evaluator.result.v1',
+    evaluator_id: EVALUATOR_ID,
+    passed,
+    decision,
+    action: routeAction(decision),
+    reason,
+    measurements: {
+      schema: 'lev.measurement.v1',
+      variables: {
+        baseline_surprise_mean: triple(displayNumber(measurements.baselineSurpriseMean), measurements.baselineSurpriseMean === null ? 0 : 1, measurements.tickCount),
+        spike_surprise_max: triple(displayNumber(measurements.spikeSurpriseMax), measurements.spikeSurpriseMax === null ? 0 : 1, measurements.tickCount),
+        relearn_tail_mean: triple(displayNumber(measurements.relearnTailMean), measurements.relearnTailMean === null ? 0 : 1, measurements.tickCount),
+        relearn_tail_max: triple(displayNumber(measurements.relearnTailMax), measurements.relearnTailMax === null ? 0 : 1, measurements.tickCount),
+        provider_ticks_present: triple(measurements.providerTicksPresent, 1, measurements.tickCount),
+        content_addresses_valid: triple(measurements.contentAddressesValid, 1, measurements.tickCount),
+        regime_shift_responsive: triple(measurements.regimeShiftResponsive, 1, measurements.tickCount),
+        provider_tick_count: triple(measurements.tickCount, 1, measurements.tickCount),
+      },
+    },
+    evidence_refs: measurements.evidenceRefs,
+    required_repairs: passed ? [] : ['repair qit stream provider evidence before world-model admission'],
+  };
+}
+
+function providerEvidenceFrom(input) {
+  if (Array.isArray(input)) return input;
+  if (!isRecord(input)) return [];
+  if (Array.isArray(input.provider_evidence)) return input.provider_evidence;
+  return [];
+}
+
+function shapeContractFrom(input) {
+  if (!isRecord(input) || !isRecord(input.shape_contract)) {
+    return { ok: false, reason: 'shape_contract_missing' };
+  }
+  const contract = input.shape_contract;
+  const parsed = {
+    baseline_ticks: intArray(contract.baseline_ticks),
+    spike_ticks: intArray(contract.spike_ticks),
+    tail_ticks: intArray(contract.tail_ticks),
+    baseline_mean_lt: contract.baseline_mean_lt,
+    spike_max_gt: contract.spike_max_gt,
+    tail_mean_lt: contract.tail_mean_lt,
+    tail_max_lt: contract.tail_max_lt,
+  };
+  if (
+    parsed.baseline_ticks.length === 0
+    || parsed.spike_ticks.length === 0
+    || parsed.tail_ticks.length === 0
+    || !finiteNumber(parsed.baseline_mean_lt)
+    || !finiteNumber(parsed.spike_max_gt)
+    || !finiteNumber(parsed.tail_mean_lt)
+    || !finiteNumber(parsed.tail_max_lt)
+  ) {
+    return { ok: false, reason: 'shape_contract_malformed' };
+  }
+  return { ok: true, contract: parsed };
+}
+
+function tickFromProviderEvidence(record) {
+  const tick = numericFact(record, 'tick');
+  const beliefX = numericFact(record, 'belief_bloch_x');
+  const beliefY = numericFact(record, 'belief_bloch_y');
+  const beliefZ = numericFact(record, 'belief_bloch_z');
+  const surpriseBits = numericFact(record, 'surprise_bits');
+  const feGradient = numericFact(record, 'fe_gradient');
+  if (![tick, beliefX, beliefY, beliefZ, surpriseBits, feGradient].every((field) => field.ok)) {
+    return { ok: false, reason: 'qit provider tick facts are missing or malformed' };
+  }
+  if (!Number.isInteger(tick.value) || tick.value < 0) {
+    return { ok: false, reason: 'qit provider tick id is malformed' };
+  }
+  return {
+    ok: true,
+    value: {
+      tick: tick.value,
+      beliefBloch: [beliefX.value, beliefY.value, beliefZ.value],
+      surpriseBits: surpriseBits.value,
+      feGradient: feGradient.value,
+    },
+  };
+}
+
+function orderTicks(ticks) {
+  const seen = new Set();
+  const sorted = [...ticks].sort((left, right) => left.tick - right.tick);
+  for (let index = 0; index < sorted.length; index += 1) {
+    const tick = sorted[index];
+    if (seen.has(tick.tick)) return { ok: false, reason: `qit provider duplicate tick ${tick.tick}` };
+    seen.add(tick.tick);
+    if (tick.tick !== index) return { ok: false, reason: `qit provider tick sequence is not contiguous at ${index}` };
+  }
+  return { ok: true, ticks: sorted };
+}
+
+function surpriseProfile(ticks, contract = DEFAULT_SHAPE_CONTRACT) {
+  const byTick = new Map(ticks.map((tick) => [tick.tick, tick]));
+  const baseline = valuesForTicks(byTick, contract.baseline_ticks);
+  const spike = valuesForTicks(byTick, contract.spike_ticks);
+  const tail = valuesForTicks(byTick, contract.tail_ticks);
+  if (!baseline.ok) return baseline;
+  if (!spike.ok) return spike;
+  if (!tail.ok) return tail;
+
+  return {
+    ok: true,
+    profile: {
+      baselineSurpriseMean: mean(baseline.values),
+      spikeSurpriseMax: Math.max(...spike.values),
+      relearnTailMean: mean(tail.values),
+      relearnTailMax: Math.max(...tail.values),
+    },
+  };
+}
+
+function valuesForTicks(byTick, ticks) {
+  const values = [];
+  for (const tickId of ticks) {
+    const tick = byTick.get(tickId);
+    if (!tick) return { ok: false, reason: `qit provider evidence missing required tick ${tickId}` };
+    values.push(tick.surpriseBits);
+  }
+  return { ok: true, values };
+}
+
+function isProviderRecord(value) {
+  return isRecord(value)
+    && value.schema === PROVIDER_SCHEMA
+    && value.lane_id === QIT_LANE_ID
+    && (value.status === 'evaluation_error' || value.status === 'non_authoritative_input')
+    && hasText(value.subject_ref)
+    && Number.isInteger(value.generation)
+    && hasText(value.requested_at)
+    && Number.isFinite(Date.parse(value.requested_at))
+    && hasText(value.content_address)
+    && value.content_address.startsWith(CONTENT_ADDRESS_PREFIX)
+    && Array.isArray(value.refs)
+    && value.refs.every(isEvidenceRef)
+    && Array.isArray(value.facts)
+    && value.facts.every(isFact)
+    && isRecord(value.provenance)
+    && value.provenance.source_package === '@lev-os/sim-eval'
+    && value.provenance.provider_id === value.lane_id
+    && value.provenance.command === null
+    && value.provenance.bounded === true
+    && providerStatusShapeIsValid(value);
+}
+
+function contentAddressMatches(record) {
+  return record.content_address === contentAddressForEvidence(record);
+}
+
+function contentAddressForEvidence(evidence) {
+  const serialized = [
+    evidence.schema,
+    evidence.lane_id,
+    evidence.status,
+    evidence.subject_ref,
+    String(evidence.generation),
+    evidence.requested_at,
+    evidence.refs.map(formatEvidenceRef).join('\n'),
+    evidence.facts.map(formatFact).join('\n'),
+    evidence.provenance.source_package,
+    evidence.provenance.provider_id,
+    'command:null',
+    'bounded:true',
+    'error:null',
+  ].join('\u001f');
+
+  return `${CONTENT_ADDRESS_PREFIX}${fnv1a32(serialized)}`;
+}
+
+function fnv1a32(value) {
+  let hash = FNV_OFFSET;
+  for (let index = 0; index < value.length; index += 1) {
+    hash ^= value.charCodeAt(index);
+    hash = Math.imul(hash, FNV_PRIME);
+  }
+  return (hash >>> 0).toString(16).padStart(8, '0');
+}
+
+function providerStatusShapeIsValid(value) {
+  if (value.status === 'non_authoritative_input') return !Object.hasOwn(value, 'error');
+  return isRecord(value.error)
+    && value.error.reason_code === 'provider_unavailable'
+    && hasText(value.error.detail)
+    && value.error.retryable === false;
+}
+
+function evidenceRefsFromRecord(record) {
+  if (!isRecord(record) || typeof record.content_address !== 'string') return [];
+  return [{
+    kind: 'sim_eval_provider_evidence',
+    ref: record.content_address,
+    exists: true,
+  }];
+}
+
+function numericFact(record, name) {
+  const value = factValue(record, name);
+  return typeof value === 'number' && Number.isFinite(value)
+    ? { ok: true, value }
+    : { ok: false };
+}
+
+function factValue(record, name) {
+  if (!isRecord(record) || !Array.isArray(record.facts)) return undefined;
+  return record.facts.find((fact) => isRecord(fact) && fact.name === name)?.value;
+}
+
+function isEvidenceRef(value) {
+  return isRecord(value) && hasText(value.kind) && hasText(value.ref);
+}
+
+function isFact(value) {
+  return isRecord(value)
+    && hasText(value.name)
+    && (
+      value.value === null
+      || typeof value.value === 'string'
+      || typeof value.value === 'boolean'
+      || (typeof value.value === 'number' && Number.isFinite(value.value))
+    );
+}
+
+function hasTruthMintingShape(value) {
+  if (Array.isArray(value)) return value.some(hasTruthMintingShape);
+  if (!isRecord(value)) return false;
+  if (FORBIDDEN_PROVIDER_STATUSES.includes(value.status)) return true;
+  for (const field of FORBIDDEN_PROVIDER_FIELDS) {
+    if (Object.hasOwn(value, field)) return true;
+  }
+  return Object.values(value).some(hasTruthMintingShape);
+}
+
+function formatEvidenceRef(ref) {
+  return `${ref.kind}:${ref.ref}`;
+}
+
+function formatFact(fact) {
+  return `${fact.name}:${String(fact.value)}`;
+}
+
+function triple(value, confidence, evidenceCount) {
+  return {
+    value,
+    confidence,
+    evidence_count: evidenceCount,
+  };
+}
+
+function routeAction(decision) {
+  return {
+    pass: 'keep',
+    warn: 'hold',
+    repair: 'repair',
+    block: 'block',
+  }[decision] ?? 'hold';
+}
+
+function intArray(value) {
+  return Array.isArray(value)
+    ? value.filter((item) => Number.isInteger(item) && item >= 0)
+    : [];
+}
+
+function mean(values) {
+  return values.reduce((sum, value) => sum + value, 0) / values.length;
+}
+
+function round(value) {
+  return Math.round(value * 1000000000000) / 1000000000000;
+}
+
+function displayNumber(value) {
+  return value === null ? null : round(value);
+}
+
+function finiteNumber(value) {
+  return typeof value === 'number' && Number.isFinite(value);
+}
+
+function hasText(value) {
+  return typeof value === 'string' && value.trim().length > 0;
+}
+
+function isRecord(value) {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
