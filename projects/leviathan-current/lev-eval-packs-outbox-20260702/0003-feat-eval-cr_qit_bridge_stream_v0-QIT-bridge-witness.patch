new file mode 100644
index 000000000..3d862f283
--- /dev/null
+++ b/core/eval/src/qit-bridge-stream.ts
@@ -0,0 +1,259 @@
+import { readFile } from 'node:fs/promises';
+import type { VariableTriple } from '@lev-os/domain';
+import type { StructuralSimEvalProviderEvidenceRecord } from './sim-eval-provider-evidence-adapter.ts';
+
+export const QIT_BRIDGE_STREAM_SCHEMA = 'constraint_core.lev_bridge_stream.v1';
+export const QIT_BRIDGE_SUBJECT_REF = 'codex-ratchet:cc_laptop_v3/qit_lev_bridge_stream';
+export const QIT_BRIDGE_EVALUATOR_ID = 'cr_qit_bridge_stream_v0';
+export const QIT_BRIDGE_LANE_ID = 'sim.qit';
+
+const CONTENT_ADDRESS_PREFIX = 'sim-eval:fnv1a32:';
+const FNV_OFFSET = 0x811c9dc5;
+const FNV_PRIME = 0x01000193;
+
+export interface QitBridgeTick {
+  readonly tick: number;
+  readonly belief_bloch: readonly [number, number, number];
+  readonly surprise_bits: number;
+  readonly fe_gradient: number;
+}
+
+export interface QitBridgeStreamDocument {
+  readonly schema_version: typeof QIT_BRIDGE_STREAM_SCHEMA;
+  readonly classification: string;
+  readonly promotion_allowed: boolean;
+  readonly claim_ceiling: string;
+  readonly stream: readonly QitBridgeTick[];
+}
+
+export interface QitBridgeIngestOptions {
+  readonly subjectRef: string;
+  readonly generation: number;
+  readonly requestedAt: string;
+  readonly sourcePath: string;
+}
+
+export type QitBridgeIngestResult =
+  | { readonly ok: true; readonly document: QitBridgeStreamDocument; readonly providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[] }
+  | { readonly ok: false; readonly reason: string };
+
+export async function ingestQitBridgeStreamFile(
+  streamPath: string,
+  options: Omit<QitBridgeIngestOptions, 'sourcePath'>,
+): Promise<QitBridgeIngestResult> {
+  let parsed: unknown;
+  try {
+    parsed = JSON.parse(await readFile(streamPath, 'utf8')) as unknown;
+  } catch (error) {
+    return { ok: false, reason: `stream_json_unreadable:${error instanceof Error ? error.message : String(error)}` };
+  }
+
+  return ingestQitBridgeStreamDocument(parsed, {
+    ...options,
+    sourcePath: streamPath,
+  });
+}
+
+export function ingestQitBridgeStreamDocument(
+  input: unknown,
+  options: QitBridgeIngestOptions,
+): QitBridgeIngestResult {
+  const documentResult = parseQitBridgeStreamDocument(input);
+  if (!documentResult.ok) return documentResult;
+
+  if (!Number.isInteger(options.generation) || options.generation < 0) {
+    return { ok: false, reason: 'generation_malformed' };
+  }
+  if (!hasText(options.subjectRef)) {
+    return { ok: false, reason: 'subject_ref_malformed' };
+  }
+  if (!hasText(options.sourcePath)) {
+    return { ok: false, reason: 'source_path_malformed' };
+  }
+  if (!hasText(options.requestedAt) || !Number.isFinite(Date.parse(options.requestedAt))) {
+    return { ok: false, reason: 'requested_at_malformed' };
+  }
+
+  return {
+    ok: true,
+    document: documentResult.document,
+    providerEvidence: documentResult.document.stream.map((tick) => qitTickToProviderEvidence(tick, {
+      document: documentResult.document,
+      ...options,
+    })),
+  };
+}
+
+export function qitProviderEvidenceContentAddress(
+  evidence: Omit<StructuralSimEvalProviderEvidenceRecord, 'content_address'> | StructuralSimEvalProviderEvidenceRecord,
+): string {
+  const serialized = [
+    evidence.schema,
+    evidence.lane_id,
+    evidence.status,
+    evidence.subject_ref,
+    String(evidence.generation),
+    evidence.requested_at,
+    evidence.refs.map((ref) => `${ref.kind}:${ref.ref}`).join('\n'),
+    evidence.facts.map((fact) => `${fact.name}:${String(fact.value)}`).join('\n'),
+    evidence.provenance.source_package,
+    evidence.provenance.provider_id,
+    'command:null',
+    'bounded:true',
+    'error:null',
+  ].join('\u001f');
+
+  return `${CONTENT_ADDRESS_PREFIX}${fnv1a32(serialized)}`;
+}
+
+function qitTickToProviderEvidence(input: QitBridgeTick, options: QitBridgeIngestOptions & {
+  readonly document: QitBridgeStreamDocument;
+}): StructuralSimEvalProviderEvidenceRecord {
+  const [beliefX, beliefY, beliefZ] = input.belief_bloch;
+  const record = {
+    schema: 'lev.sim_eval.provider_evidence.v1',
+    lane_id: QIT_BRIDGE_LANE_ID,
+    status: 'non_authoritative_input',
+    subject_ref: options.subjectRef,
+    generation: options.generation,
+    requested_at: options.requestedAt,
+    content_address: '',
+    refs: [{
+      kind: 'constraint_core_lev_bridge_stream_json',
+      ref: `${options.sourcePath}#tick=${input.tick}`,
+    }],
+    facts: [
+      { name: 'stream_schema', value: options.document.schema_version },
+      { name: 'source_classification', value: options.document.classification },
+      { name: 'source_promotion_allowed', value: options.document.promotion_allowed },
+      { name: 'source_claim_ceiling', value: options.document.claim_ceiling },
+      { name: 'tick', value: input.tick },
+      { name: 'belief_bloch_x', value: beliefX },
+      { name: 'belief_bloch_y', value: beliefY },
+      { name: 'belief_bloch_z', value: beliefZ },
+      { name: 'surprise_bits', value: input.surprise_bits },
+      { name: 'fe_gradient', value: input.fe_gradient },
+    ],
+    provenance: {
+      source_package: '@lev-os/sim-eval',
+      provider_id: QIT_BRIDGE_LANE_ID,
+      command: null,
+      bounded: true,
+    },
+  } satisfies Omit<StructuralSimEvalProviderEvidenceRecord, 'content_address'> & { content_address: string };
+
+  return {
+    ...record,
+    content_address: qitProviderEvidenceContentAddress(record),
+  };
+}
+
+function parseQitBridgeStreamDocument(input: unknown): { readonly ok: true; readonly document: QitBridgeStreamDocument } | { readonly ok: false; readonly reason: string } {
+  if (!isRecord(input)) return { ok: false, reason: 'stream_document_malformed' };
+  if (input.schema_version !== QIT_BRIDGE_STREAM_SCHEMA) {
+    return { ok: false, reason: 'stream_schema_mismatch' };
+  }
+  if (!hasText(input.classification)) {
+    return { ok: false, reason: 'stream_classification_malformed' };
+  }
+  if (typeof input.promotion_allowed !== 'boolean') {
+    return { ok: false, reason: 'stream_promotion_allowed_malformed' };
+  }
+  if (!hasText(input.claim_ceiling)) {
+    return { ok: false, reason: 'stream_claim_ceiling_malformed' };
+  }
+  if (!Array.isArray(input.stream) || input.stream.length === 0) {
+    return { ok: false, reason: 'stream_ticks_missing' };
+  }
+
+  const ticks: QitBridgeTick[] = [];
+  const seen = new Set<number>();
+  for (let index = 0; index < input.stream.length; index += 1) {
+    const tickResult = parseTick(input.stream[index], index);
+    if (!tickResult.ok) return tickResult;
+    if (seen.has(tickResult.tick.tick)) {
+      return { ok: false, reason: `tick_duplicate:${tickResult.tick.tick}` };
+    }
+    seen.add(tickResult.tick.tick);
+    ticks.push(tickResult.tick);
+  }
+
+  const sorted = [...ticks].sort((left, right) => left.tick - right.tick);
+  for (let index = 0; index < sorted.length; index += 1) {
+    if (sorted[index]?.tick !== index) {
+      return { ok: false, reason: `tick_sequence_malformed:index=${index}` };
+    }
+  }
+
+  return {
+    ok: true,
+    document: {
+      schema_version: input.schema_version,
+      classification: input.classification,
+      promotion_allowed: input.promotion_allowed,
+      claim_ceiling: input.claim_ceiling,
+      stream: sorted,
+    },
+  };
+}
+
+function parseTick(input: unknown, index: number): { readonly ok: true; readonly tick: QitBridgeTick } | { readonly ok: false; readonly reason: string } {
+  if (!isRecord(input)) return { ok: false, reason: `tick_malformed:index=${index}` };
+  const tickId = input.tick;
+  if (!finiteNumber(tickId) || !Number.isInteger(tickId) || tickId < 0) {
+    return { ok: false, reason: `tick_id_malformed:index=${index}` };
+  }
+  if (!Array.isArray(input.belief_bloch) || input.belief_bloch.length !== 3) {
+    return { ok: false, reason: `tick_belief_bloch_malformed:tick=${tickId}` };
+  }
+  const beliefBloch = input.belief_bloch;
+  const [beliefX, beliefY, beliefZ] = beliefBloch;
+  if (!finiteNumber(beliefX) || !finiteNumber(beliefY) || !finiteNumber(beliefZ)) {
+    return { ok: false, reason: `tick_belief_bloch_nonfinite:tick=${tickId}` };
+  }
+  if (!finiteNumber(input.surprise_bits)) {
+    return { ok: false, reason: `tick_surprise_bits_nonfinite:tick=${tickId}` };
+  }
+  if (!finiteNumber(input.fe_gradient)) {
+    return { ok: false, reason: `tick_fe_gradient_nonfinite:tick=${tickId}` };
+  }
+
+  return {
+    ok: true,
+    tick: {
+      tick: tickId,
+      belief_bloch: [beliefX, beliefY, beliefZ],
+      surprise_bits: input.surprise_bits,
+      fe_gradient: input.fe_gradient,
+    },
+  };
+}
+
+function fnv1a32(value: string): string {
+  let hash = FNV_OFFSET;
+  for (let index = 0; index < value.length; index += 1) {
+    hash ^= value.charCodeAt(index);
+    hash = Math.imul(hash, FNV_PRIME);
+  }
+  return (hash >>> 0).toString(16).padStart(8, '0');
+}
+
+function finiteNumber(value: unknown): value is number {
+  return typeof value === 'number' && Number.isFinite(value);
+}
+
+function hasText(value: unknown): value is string {
+  return typeof value === 'string' && value.trim().length > 0;
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === 'object' && value !== null && !Array.isArray(value);
+}
+
+export function variable(value: VariableTriple['value'], evidenceCount = 1): VariableTriple {
+  return {
+    value,
+    confidence: 1,
+    evidence_count: evidenceCount,
+  };
+}
