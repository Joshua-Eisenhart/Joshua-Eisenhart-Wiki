@@ -0,0 +1,32 @@
+schema: lev.flowmind.flow.v1
+id: cr_qit_bridge_stream_v0.measure
+description: Measure a QIT engine bridge stream over non-authoritative provider evidence ticks.
+inputs:
+  provider_evidence:
+    type: array
+    required: true
+  shape_contract:
+    type: object
+    required: true
+outputs:
+  observations:
+    type: object
+  measurements:
+    type: object
+nodes:
+  - id: score_surprise_profile
+    kind: companion.score
+    inputs:
+      companion: ../companions/sensor.mjs
+      provider_evidence: ${inputs.provider_evidence}
+      shape_contract: ${inputs.shape_contract}
+    outputs:
+      variables:
+        - baseline_surprise_mean
+        - spike_surprise_max
+        - relearn_tail_mean
+        - relearn_tail_max
+        - provider_ticks_present
+        - content_addresses_valid
+        - regime_shift_responsive
+        - provider_tick_count
