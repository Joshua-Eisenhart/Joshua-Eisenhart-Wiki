+
+async function buildBridgeReceipt(graphStorePath: string): Promise<BridgeReceipt> {
+  const sourceFixture = await readJson(passFixturePath);
+  const fixtureSha = await sha256File(passFixturePath);
+  const scoreResult = await scoreStreamDocument(sourceFixture, passFixturePath);
+  if (!scoreResult.ingestResult.ok) {
+    throw new Error(`expected pass fixture ingestion to succeed: ${scoreResult.ingestResult.reason}`);
+  }
+  const providerEvidence = scoreResult.ingestResult.providerEvidence;
+  const providerMeasurements = providerEvidence.map((record) => {
+    const result = simEvalProviderEvidenceToMeasurement(record, {
+      evaluatorId: 'sim_eval_provider_evidence',
+      evaluatorVersion: '1',
+      expectedSubjectRef: QIT_BRIDGE_SUBJECT_REF,
+      currentGeneration: generation,
+      now: evaluatedAt,
+    });
+    expect(result.ok).toBe(true);
+    if (!result.ok) throw new Error(`provider evidence projection failed: ${record.content_address}`);
+    return result.measurement;
+  });
+
+  expect(scoreResult.scoreResult.passed).toBe(true);
+  const evalMeasurement = measurementFromScore(scoreResult.scoreResult, providerEvidence);
+  const evalDischarge = discharge(evalObligation(), [evalMeasurement], evalGatePolicy(), {
+    subject_ref: QIT_BRIDGE_SUBJECT_REF,
+    generation,
+    now: evaluatedAt,
+  });
+  expect(evalDischarge.verdict.kind).toBe('evaluated');
+  if (evalDischarge.verdict.kind !== 'evaluated') {
+    throw new Error('expected evaluated qit bridge discharge');
+  }
+  const evalVerdict = evalDischarge.verdict;
+  expect(evalVerdict.status).toBe('pass');
+
+  const worldModelEvidence = worldModelEvidenceFromEval({
+    scoreResult: scoreResult.scoreResult,
+    providerEvidence,
+    evalMeasurement,
+    evalVerdictId: evalVerdict.verdict_id,
+  });
+  const worldModelMeasurementResult = worldModelEvidenceToMeasurement(worldModelEvidence, {
+    evaluatorId: 'world_model_evidence',
+    evaluatorVersion: '1',
+    expectedSubjectRef: QIT_BRIDGE_SUBJECT_REF,
+    currentGeneration: generation,
+    now: evaluatedAt,
+    maxAgeMs: 120_000,
+  });
+  expect(worldModelMeasurementResult.ok).toBe(true);
+  if (!worldModelMeasurementResult.ok) {
+    throw new Error(`world-model evidence projection failed: ${worldModelMeasurementResult.reason}`);
+  }
+  const worldModelMeasurement = worldModelMeasurementResult.measurement;
+  const worldModelDischarge = discharge(worldModelObligation(), [worldModelMeasurement], worldModelGatePolicy(), {
+    subject_ref: QIT_BRIDGE_SUBJECT_REF,
+    generation,
+    now: evaluatedAt,
+  });
+  expect(worldModelDischarge.verdict.kind).toBe('evaluated');
+  if (worldModelDischarge.verdict.kind !== 'evaluated') {
+    throw new Error('expected evaluated world-model qit bridge discharge');
+  }
+  const worldModelVerdict = worldModelDischarge.verdict;
+  expect(worldModelVerdict.status).toBe('pass');
+
+  await rm(graphStorePath, { force: true });
+  const eventStore = new JsonlEventStore(graphStorePath);
+  const graph = new EntityGraph(eventStore);
+  const nodeId = `world-model:measurement:${safeId(worldModelMeasurement.measurement_id)}`;
+  const graphResult = await graph.process(graphEventForMeasurement(nodeId, worldModelMeasurement, worldModelVerdict.verdict_id));
+  expect(graphResult.status).toBe('applied');
+
+  const readbackNode = graph.reader.getEntity(nodeId);
+  expect(readbackNode).toBeDefined();
+  const storedEvents = await eventStore.query({ type: 'graph.operations_applied', limit: 10 });
+  const storedNode = readStoredNodeFromEvents(storedEvents, nodeId);
+  const storedMeasurementId = storedNode?.claims.find((claim) => claim.predicate === 'has_measurement_id')?.object;
+  expect(storedNode?.id).toBe(nodeId);
+  expect(storedMeasurementId).toBe(worldModelMeasurement.measurement_id);
+
+  return {
+    schema: 'lev.qit_bridge_stream_seam_receipt.v1',
+    generated_at: evaluatedAt,
+    source_material: {
+      spec_path: sourceSpecPath,
+      source_stream_path: sourceStreamPath,
+      committed_fixture_path: toProjectPath(passFixturePath),
+      committed_fixture_sha256: fixtureSha,
+      schema_version: String((sourceFixture as Record<string, unknown>).schema_version),
+      classification: String((sourceFixture as Record<string, unknown>).classification),
+      promotion_allowed: (sourceFixture as Record<string, unknown>).promotion_allowed === true,
+    },
+    deterministic_code_changes: [
+      'Added qit bridge stream adapter in core/eval/src/qit-bridge-stream.ts',
+      'Added cr_qit_bridge_stream_v0 evaluator pack and deterministic companion sensor',
+      'Added executable QIT bridge seam replay in core/eval/src/cr-qit-bridge-stream-v0.test.ts',
+    ],
+    dna_flowmind_yaml_changes: [
+      'Added evaluator manifest plugins/sim-eval/evals/cr_qit_bridge_stream_v0/cr_qit_bridge_stream_v0.eval.yaml',
+      'Added FlowMind measure flow and gate/routing policies for declared surprise shape contract',
+    ],
+    code_vs_llm: {
+      deterministic_code_handles: [
+        'Fail-closed stream tick validation for missing fields, malformed ticks, and non-finite values',
+        'FNV-1a-32 provider evidence addressing and address replay checks',
+        'Surprise profile scoring from declared baseline/spike/tail windows',
+        'core/eval discharge() comparisons',
+        'worldModelEvidenceToMeasurement projection',
+        'EntityGraph JsonlEventStore apply and readback',
+      ],
+      llm_handles: [
+        'Choosing the narrow proof harness composition from existing contracts',
+        'Summarizing the bridge receipt chain for humans',
+      ],
+    },
+    surprise_profile: {
+      baseline_ticks: [...shapeContract.baseline_ticks],
+      baseline_mean: numberVariable(scoreResult.scoreResult, 'baseline_surprise_mean'),
+      spike_ticks: [...shapeContract.spike_ticks],
+      spike_max: numberVariable(scoreResult.scoreResult, 'spike_surprise_max'),
+      tail_ticks: [...shapeContract.tail_ticks],
+      tail_mean: numberVariable(scoreResult.scoreResult, 'relearn_tail_mean'),
+      tail_max: numberVariable(scoreResult.scoreResult, 'relearn_tail_max'),
+      contract: shapeContract,
+    },
+    evidence: {
+      lane_id: 'sim.qit',
+      count: providerEvidence.length,
+      content_addresses: providerEvidence.map((record) => record.content_address),
+      measurement_ids: providerMeasurements.map((measurement) => measurement.measurement_id),
+    },
+    eval: {
+      evaluator_id: QIT_BRIDGE_EVALUATOR_ID,
+      command: 'pnpm --dir core/eval exec vitest run src/cr-qit-bridge-stream-v0.test.ts',
+      decision: scoreResult.scoreResult.decision,
+      passed: scoreResult.scoreResult.passed,
+      reason: scoreResult.scoreResult.reason,
+      measurement_id: evalMeasurement.measurement_id,
+      discharge: {
+        verdict_id: evalVerdict.verdict_id,
+        status: evalVerdict.status,
+        gate_result_status: evalDischarge.gate_result.status,
+      },
+    },
+    world_model: {
+      evidence_id: worldModelEvidence.evidence_id,
+      measurement_id: worldModelMeasurement.measurement_id,
+      claim: 'engine surprise signal, regime-shift responsive',
+      discharge: {
+        verdict_id: worldModelVerdict.verdict_id,
+        status: worldModelVerdict.status,
+        gate_result_status: worldModelDischarge.gate_result.status,
+      },
+    },
+    graph: {
+      node_id: nodeId,
+      storage_path: graphStorePath,
+      event_count: storedEvents.length,
+      readback: {
+        node_exists: readbackNode !== undefined && storedNode !== undefined,
+        measurement_id: storedMeasurementId ?? null,
+      },
+    },
+    hop_chain: {
+      evidence_content_address: providerEvidence.map((record) => record.content_address),
+      eval_decision: scoreResult.scoreResult.decision,
+      eval_verdict_id: evalVerdict.verdict_id,
+      measurement_id: worldModelMeasurement.measurement_id,
+      node_id: nodeId,
+    },
+    hops_completed: ['evidence', 'eval', 'measurement', 'graph'],
+    blocked_at: 'none',
+  };
+}
+
+async function scoreStreamFixture(path: string): Promise<{
+  readonly scoreResult: ScoreResult;
+  readonly providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[];
+}> {
+  const result = await scoreStreamDocument(await readJson(path), path);
+  if (!result.ingestResult.ok) {
+    throw new Error(`expected stream ingestion to pass: ${result.ingestResult.reason}`);
+  }
+  return {
+    scoreResult: result.scoreResult,
+    providerEvidence: result.ingestResult.providerEvidence,
+  };
+}
+
+async function scoreStreamDocument(document: unknown, sourcePath: string): Promise<{
+  readonly ingestResult: QitBridgeIngestResult;
+  readonly scoreResult: ScoreResult;
+}> {
+  const ingestResult = ingestQitBridgeStreamDocument(document, ingestOptions(sourcePath));
+  if (!ingestResult.ok) {
+    return {
+      ingestResult,
+      scoreResult: blockedScoreResult(ingestResult.reason),
+    };
+  }
+
+  return {
+    ingestResult,
+    scoreResult: await scoreProviderEvidence(ingestResult.providerEvidence),
+  };
+}
+
+async function scoreProviderEvidence(providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[]): Promise<ScoreResult> {
+  const module = await import(pathToFileURL(join(packDir, 'companions/sensor.mjs')).href) as {
+    score(input: unknown): unknown;
+  };
+  return module.score({
+    schema: 'lev.cr_qit_bridge_stream_v0.trace.v1',
+    subject_ref: QIT_BRIDGE_SUBJECT_REF,
+    provider_evidence: providerEvidence,
+    shape_contract: shapeContract,
+  }) as ScoreResult;
+}
+
+function blockedScoreResult(reason: string): ScoreResult {
+  return {
+    schema: 'lev.evaluator.result.v1',
+    evaluator_id: QIT_BRIDGE_EVALUATOR_ID,
+    passed: false,
+    decision: 'block',
+    reason,
+    measurements: { schema: 'lev.measurement.v1', variables: {} },
+    evidence_refs: [],
+  };
+}
+
+function measurementFromScore(
+  scoreResult: ScoreResult,
+  providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[],
+): Measurement {
+  return {
+    schema: 'lev.measurement.v1',
+    measurement_id: `measurement:${QIT_BRIDGE_EVALUATOR_ID}:${providerEvidence.map((record) => record.content_address.split(':').at(-1)).join(':')}`,
+    evaluator_id: QIT_BRIDGE_EVALUATOR_ID,
+    evaluator_version: '0',
+    subject_ref: QIT_BRIDGE_SUBJECT_REF,
+    generation,
+    variables: scoreResult.measurements.variables,
+    provenance: 'runtime_fact',
+    evidence_refs: scoreResult.evidence_refs,
+    status: 'measured',
+    measured_at: evaluatedAt,
+  };
+}
+
+function evalObligation(): Obligation {
+  return {
+    obligation_id: 'obligation:cr_qit_bridge_stream_v0:world_model_bridge',
+    declared_by: 'consumer_requirement',
+    declared_at: observedAt,
+    predicate_ref: 'policy:cr_qit_bridge_stream_v0:world_model_bridge',
+    discharge_condition: { kind: 'all_pass' },
+    required_evidence: [{ kind: 'measurement', min_count: 1, freshness: 'current' }],
+  };
+}
+
+function evalGatePolicy(): GatePolicy {
+  return {
+    gate_id: 'cr_qit_bridge_stream_v0.world_model_bridge',
+    policy_ref: 'policy:cr_qit_bridge_stream_v0:world_model_bridge',
+    evaluator_id: QIT_BRIDGE_EVALUATOR_ID,
+    authored_at: observedAt,
+    requires: [
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/baseline_surprise_mean`, op: 'lt', value: shapeContract.baseline_mean_lt },
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/spike_surprise_max`, op: 'gt', value: shapeContract.spike_max_gt },
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/relearn_tail_mean`, op: 'lt', value: shapeContract.tail_mean_lt },
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/relearn_tail_max`, op: 'lt', value: shapeContract.tail_max_lt },
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/provider_ticks_present`, op: 'eq', value: true },
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/content_addresses_valid`, op: 'eq', value: true },
+      { variable_ref: `${QIT_BRIDGE_EVALUATOR_ID}/regime_shift_responsive`, op: 'eq', value: true },
+    ],
+    freshness: { generation: 'current', max_age_ms: 120_000 },
+    on_missing: 'evaluation_error',
+  };
+}
+
+function worldModelEvidenceFromEval(input: {
+  readonly scoreResult: ScoreResult;
+  readonly providerEvidence: readonly StructuralSimEvalProviderEvidenceRecord[];
+  readonly evalMeasurement: Measurement;
+  readonly evalVerdictId: string;
+}): StructuralWorldModelEvidenceRecord {
+  const baselineMean = numberVariable(input.scoreResult, 'baseline_surprise_mean');
+  const spikeMax = numberVariable(input.scoreResult, 'spike_surprise_max');
+  const tailMean = numberVariable(input.scoreResult, 'relearn_tail_mean');
+  const tailMax = numberVariable(input.scoreResult, 'relearn_tail_max');
+  const predictionError = round(spikeMax - Math.max(baselineMean, tailMean));
+  const evidenceId = `wm-evidence:qit-bridge-stream:${sha256Text([
+    input.evalVerdictId,
+    input.evalMeasurement.measurement_id,
+    String(baselineMean),
+    String(spikeMax),
+    String(tailMean),
+    ...input.providerEvidence.map((record) => record.content_address),
+  ].join('\n')).slice(0, 16)}`;
+
+  return {
+    schema: 'lev.world_model.evidence.v1',
+    evidence_id: evidenceId,
+    kind: 'readout-fact',
+    subject_ref: QIT_BRIDGE_SUBJECT_REF,
+    generation,
+    observed_at: observedAt,
+    status: 'non_authoritative_input',
+    produced_by: 'core/world-model',
+    refs: [
+      { kind: 'eval_verdict', ref: input.evalVerdictId },
+      { kind: 'eval_measurement', ref: input.evalMeasurement.measurement_id },
+      ...input.providerEvidence.map((record) => ({
+        kind: 'sim_eval_provider_evidence',
+        ref: record.content_address,
+        exists: true,
+      })),
+    ],
+    reasons: [],
+    facts: [
+      { name: 'world_model_claim', value: 'engine surprise signal, regime-shift responsive' },
+      { name: 'signal_kind', value: 'engine_surprise_signal' },
+      { name: 'eval_decision', value: input.scoreResult.decision },
+      { name: 'regime_shift_responsive', value: true },
+      { name: 'baseline_surprise_mean', value: baselineMean },
+      { name: 'spike_surprise_max', value: spikeMax },
+      { name: 'relearn_tail_mean', value: tailMean },
+      { name: 'relearn_tail_max', value: tailMax },
+      { name: 'world_model_prediction_error', value: predictionError },
+    ],
+    provenance: {
+      source_package: '@lev-os/world-model',
+      source_module: 'readout',
+      load_bearing: false,
+    },
+  };
+}
+
+function worldModelObligation(): Obligation {
+  return {
+    obligation_id: 'obligation:world_model:qit_bridge_stream',
+    declared_by: 'consumer_requirement',
+    declared_at: observedAt,
+    predicate_ref: 'policy:world_model:qit_bridge_stream',
+    discharge_condition: { kind: 'all_pass' },
+    required_evidence: [{ kind: 'world_model_evidence', min_count: 1, freshness: 'current' }],
+  };
+}
+
+function worldModelGatePolicy(): GatePolicy {
+  return {
+    gate_id: 'world_model.qit_bridge_stream',
+    policy_ref: 'policy:world_model:qit_bridge_stream',
+    evaluator_id: 'world_model_evidence',
+    authored_at: observedAt,
+    requires: [
+      { variable_ref: 'world_model_evidence/world_model_claim', op: 'eq', value: 'engine surprise signal, regime-shift responsive' },
+      { variable_ref: 'world_model_evidence/signal_kind', op: 'eq', value: 'engine_surprise_signal' },
+      { variable_ref: 'world_model_evidence/eval_decision', op: 'eq', value: 'pass' },
+      { variable_ref: 'world_model_evidence/regime_shift_responsive', op: 'eq', value: true },
+      { variable_ref: 'world_model_evidence/world_model_prediction_error', op: 'gt', value: 1 },
+    ],
+    freshness: { generation: 'current', max_age_ms: 120_000 },
+    on_missing: 'evaluation_error',
+  };
+}
+
+function graphEventForMeasurement(
+  nodeId: string,
+  measurement: Measurement,
+  verdictId: string | undefined,
+) {
+  const entity: Entity = {
+    id: nodeId,
+    type: 'world_model_measurement',
+    source: 'core/eval/qit-bridge-stream',
+    via: 'qit-bridge-stream-v0-replay',
+    depth: 'L1',
+    last_classified: evaluatedAt,
+    decay_rate: 0,
+    claims: [
+      claim(`${nodeId}:claim:measurement_id`, nodeId, 'has_measurement_id', measurement.measurement_id),
+      claim(`${nodeId}:claim:world_model_claim`, nodeId, 'world_model_claim', stringVariable(measurement, 'world_model_claim')),
+      claim(`${nodeId}:claim:signal_kind`, nodeId, 'signal_kind', stringVariable(measurement, 'signal_kind')),
+      claim(`${nodeId}:claim:regime_shift_responsive`, nodeId, 'regime_shift_responsive', String(booleanMeasurementVariable(measurement, 'regime_shift_responsive'))),
+      claim(`${nodeId}:claim:verdict_id`, nodeId, 'discharged_by_verdict', verdictId ?? 'none'),
+    ],
+    links: [],
+  };
+  const operations: GraphOperation[] = [{
+    type: 'upsert_entity',
+    timestamp: evaluatedAt,
+    source: 'core/eval/qit-bridge-stream',
+    entity_id: nodeId,
+    payload: entity as unknown as Record<string, unknown>,
+  }];
+
+  return {
+    version: 1,
+    id: 'evt-qit-bridge-stream-001',
+    type: 'qit_bridge_stream.measurement_applied',
+    time: evaluatedAt,
+    source: 'core/eval/qit-bridge-stream',
+    data: { operations },
+    metadata: { correlation_id: 'qit-bridge-stream:cc_laptop_v3' },
+  } as const;
+}
+
+function claim(id: string, subject: string, predicate: string, object: string): Entity['claims'][number] {
+  return {
+    id,
+    kind: 'assertion',
+    subject,
+    predicate,
+    object,
+    truth_state: 'accepted',
+    evidence_refs: [],
+    valid_at: observedAt,
+    created_at: evaluatedAt,
+  };
+}
+
+function readStoredNodeFromEvents(events: readonly GraphEvent[], nodeId: string): Entity | undefined {
+  for (const event of events) {
+    const operations = (event.payload.operations ?? []) as GraphOperation[];
+    for (const operation of operations) {
+      if (operation.type === 'upsert_entity' && operation.entity_id === nodeId) {
+        return operation.payload as unknown as Entity;
+      }
+    }
+  }
+  return undefined;
+}
+
+function ingestOptions(sourcePath: string) {
+  return {
+    subjectRef: QIT_BRIDGE_SUBJECT_REF,
+    generation,
+    requestedAt: observedAt,
+    sourcePath,
+  };
+}
+
+async function readJson(path: string): Promise<unknown> {
+  return JSON.parse(await readFile(path, 'utf8')) as unknown;
+}
+
+async function sha256File(path: string): Promise<string> {
+  return createHash('sha256').update(await readFile(path)).digest('hex');
+}
+
+function sha256Text(value: string): string {
+  return createHash('sha256').update(value).digest('hex');
+}
+
+function numberVariable(scoreResult: ScoreResult, variableName: string): number {
+  const value = scoreResult.measurements.variables[variableName]?.value;
+  if (typeof value !== 'number' || !Number.isFinite(value)) {
+    throw new Error(`expected numeric variable ${variableName}`);
+  }
+  return value;
+}
+
+function booleanVariable(scoreResult: ScoreResult, variableName: string): boolean {
+  const value = scoreResult.measurements.variables[variableName]?.value;
+  if (typeof value !== 'boolean') {
+    throw new Error(`expected boolean variable ${variableName}`);
+  }
+  return value;
+}
+
+function stringVariable(measurement: Measurement, variableName: string): string {
+  const value = measurement.variables[variableName]?.value;
+  if (typeof value !== 'string' || value.trim() === '') {
+    throw new Error(`expected string variable ${variableName}`);
+  }
+  return value;
+}
+
+function booleanMeasurementVariable(measurement: Measurement, variableName: string): boolean {
+  const value = measurement.variables[variableName]?.value;
+  if (typeof value !== 'boolean') {
+    throw new Error(`expected boolean variable ${variableName}`);
+  }
+  return value;
+}
+
+function safeId(value: string): string {
+  return value.replace(/[^A-Za-z0-9:_-]/g, '_');
+}
+
+function round(value: number): number {
+  return Math.round(value * 1000000000000) / 1000000000000;
+}
+
+function toProjectPath(path: string): string {
+  return path.startsWith(repoRoot) ? path.slice(repoRoot.length + 1) : path;
+}
+
+interface BridgeReceipt {
+  readonly schema: 'lev.qit_bridge_stream_seam_receipt.v1';
+  readonly generated_at: string;
+  readonly source_material: Record<string, unknown>;
+  readonly deterministic_code_changes: readonly string[];
+  readonly dna_flowmind_yaml_changes: readonly string[];
+  readonly code_vs_llm: {
+    readonly deterministic_code_handles: readonly string[];
+    readonly llm_handles: readonly string[];
+  };
+  readonly surprise_profile: Record<string, unknown>;
