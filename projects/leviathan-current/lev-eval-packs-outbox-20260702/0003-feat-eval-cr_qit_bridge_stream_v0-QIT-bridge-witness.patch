+const sourceStreamPath = '/private/tmp/claude-501/-Users-joshuaeisenhart-Desktop-Codex-Ratchet/be658e3e-11bb-4bcc-8728-d7ac9e255db1/scratchpad/cc_laptop_v3/engines/lev_bridge_stream.json';
