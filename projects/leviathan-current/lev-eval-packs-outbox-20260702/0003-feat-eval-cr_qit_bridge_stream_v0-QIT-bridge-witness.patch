+    readonly passed: boolean;
+    readonly reason: string;
+    readonly measurement_id: string;
+    readonly discharge: {
+      readonly verdict_id: string;
+      readonly status: string;
+      readonly gate_result_status: string;
+    };
+  };
+  readonly world_model: {
+    readonly evidence_id: string;
+    readonly measurement_id: string;
+    readonly claim: string;
+    readonly discharge: {
+      readonly verdict_id: string;
+      readonly status: string;
+      readonly gate_result_status: string;
+    };
+  };
+  readonly graph: {
+    readonly node_id: string;
+    readonly storage_path: string;
+    readonly event_count: number;
+    readonly readback: {
+      readonly node_exists: boolean;
+      readonly measurement_id: string | null;
+    };
+  };
+  readonly hop_chain: Record<string, unknown>;
+  readonly hops_completed: readonly string[];
+  readonly blocked_at: string;
+}
