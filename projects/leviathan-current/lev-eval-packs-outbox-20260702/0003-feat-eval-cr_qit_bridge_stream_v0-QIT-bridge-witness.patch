+    expect(scoreResult.schema).toBe('lev.evaluator.result.v1');
+    expect(scoreResult.evaluator_id).toBe(QIT_BRIDGE_EVALUATOR_ID);
+    expect(scoreResult.passed).toBe(true);
+    expect(scoreResult.decision).toBe('pass');
+    expect(numberVariable(scoreResult, 'baseline_surprise_mean')).toBe(0.009166666667);
+    expect(numberVariable(scoreResult, 'spike_surprise_max')).toBe(1.499);
+    expect(numberVariable(scoreResult, 'relearn_tail_mean')).toBe(0.0307);
+    expect(numberVariable(scoreResult, 'relearn_tail_max')).toBe(0.0322);
+    expect(booleanVariable(scoreResult, 'regime_shift_responsive')).toBe(true);
+    expect(booleanVariable(scoreResult, 'content_addresses_valid')).toBe(true);
+  });
+
+  it('blocks an adversarial flat stream because no spike is present', async () => {
+    const { scoreResult } = await scoreStreamFixture(flatFixturePath);
+
+    expect(scoreResult.passed).toBe(false);
+    expect(scoreResult.decision).toBe('block');
+    expect(numberVariable(scoreResult, 'spike_surprise_max')).toBe(0.0062);
+    expect(booleanVariable(scoreResult, 'regime_shift_responsive')).toBe(false);
+    expect(scoreResult.reason).toContain('spike surprise max');
+  });
+
+  it('compares the QIT surprise profile before rounding display values', async () => {
+    const fixture = await readJson(passFixturePath) as { stream: Array<Record<string, unknown>> };
+    for (const tick of fixture.stream) {
+      if (tick.tick === 3 || tick.tick === 4 || tick.tick === 5) tick.surprise_bits = 0.0499999999999;
+      if (tick.tick === 6) tick.surprise_bits = 1.0000000000001;
+      if (tick.tick === 10 || tick.tick === 11 || tick.tick === 12 || tick.tick === 13) tick.surprise_bits = 0.0499999999999;
+    }
+
+    const { scoreResult } = await scoreStreamDocument(fixture, passFixturePath);
+
+    expect(scoreResult.passed).toBe(true);
+    expect(numberVariable(scoreResult, 'baseline_surprise_mean')).toBe(0.05);
+    expect(numberVariable(scoreResult, 'spike_surprise_max')).toBe(1);
+    expect(numberVariable(scoreResult, 'relearn_tail_mean')).toBe(0.05);
+    expect(numberVariable(scoreResult, 'relearn_tail_max')).toBe(0.05);
