{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/ratchet/schemas/ratchet_order_open_run.schema.json",
  "title": "Order-open finite Ratchet run v0.5",
  "type": "object",
  "required": [
    "schema_version",
    "run_id",
    "source_packet",
    "root_primitive",
    "process_law",
    "claim_ceiling",
    "candidate_population",
    "frontier_cache",
    "gate_order_search",
    "entropy_geometry_coface",
    "dig_pool",
    "audit_dispositions",
    "summary",
    "status"
  ],
  "properties": {
    "schema_version": {"const": "ratchet-order-open-run/0.5"},
    "root_primitive": {"const": "constrained_distinguishability"},
    "process_law": {
      "const": "ORDER_AND_GATE_BOUNDARIES_ARE_PROPOSALS__EXPLORE_MASSIVELY__ADMIT_PACKET_RELATIVE_MSS"
    },
    "claim_ceiling": {"const": "formal_generated_surface_process_test"},
    "candidate_population": {
      "type": "object",
      "required": [
        "generated_parameter_proposals",
        "executed_parameter_proposals",
        "behavioural_partition_classes",
        "parameter_aliases",
        "batches",
        "global_candidate_space_exhausted"
      ],
      "properties": {
        "generated_parameter_proposals": {"type": "integer", "minimum": 2},
        "executed_parameter_proposals": {"type": "integer", "minimum": 2},
        "behavioural_partition_classes": {"type": "integer", "minimum": 2},
        "parameter_aliases": {"type": "integer", "minimum": 0},
        "batches": {"type": "array", "minItems": 1},
        "global_candidate_space_exhausted": {"const": false}
      },
      "additionalProperties": true
    },
    "gate_order_search": {
      "type": "object",
      "required": [
        "schedule_hypotheses_executed",
        "canonical_gate_order_admitted",
        "canonical_gate_decomposition_admitted",
        "scheduling_priority_is_epistemic",
        "decomposition_census",
        "schedule_receipts"
      ],
      "properties": {
        "schedule_hypotheses_executed": {"type": "integer", "minimum": 2},
        "canonical_gate_order_admitted": {"const": false},
        "canonical_gate_decomposition_admitted": {"const": false},
        "scheduling_priority_is_epistemic": {"const": false},
        "decomposition_census": {"type": "array", "minItems": 1},
        "schedule_receipts": {"type": "array", "minItems": 2}
      },
      "additionalProperties": true
    },
    "entropy_geometry_coface": {
      "type": "object",
      "required": ["definition", "separate_entropy_running_on_geometry", "gradient_required_for_tooth"],
      "properties": {
        "separate_entropy_running_on_geometry": {"const": false},
        "gradient_required_for_tooth": {"const": true}
      },
      "additionalProperties": true
    },
    "dig_pool": {
      "type": "object",
      "required": [
        "authored_seed_proposals",
        "derived_from_this_run",
        "serialization_order_has_epistemic_priority"
      ],
      "properties": {
        "authored_seed_proposals": {"type": "array"},
        "derived_from_this_run": {"type": "array", "minItems": 1},
        "serialization_order_has_epistemic_priority": {"const": false}
      },
      "additionalProperties": true
    },
    "summary": {
      "type": "object",
      "required": [
        "canonical_gate_order_admitted",
        "canonical_gate_decomposition_admitted",
        "scientific_manifold_layers_admitted",
        "physical_entropy_types_admitted",
        "global_search_exhausted",
        "terminal_hold_asserted"
      ],
      "properties": {
        "canonical_gate_order_admitted": {"const": false},
        "canonical_gate_decomposition_admitted": {"const": false},
        "scientific_manifold_layers_admitted": {"const": 0},
        "physical_entropy_types_admitted": {"const": 0},
        "global_search_exhausted": {"const": false},
        "terminal_hold_asserted": {"const": false}
      },
      "additionalProperties": true
    },
    "status": {"const": "RUN_COMPLETE_WITH_OPEN_UNORDERED_DIG_POOL"}
  },
  "additionalProperties": true
}
